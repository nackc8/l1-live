[1285.588065, "o", "\u001b[1m\u001b[4mzoxide 0.9.3\u001b[22m\u001b[24m\r\nAjeet D'Souza <98ajeet@gmail.com>\r\nhttps://github.com/ajeetdsouza/zoxide\r\n\r\nA smarter cd command for your terminal\r\n\r\n\u001b[1m\u001b[4mUsage:\u001b[0m\r\n  \u001b[1mzoxide\u001b[0m <COMMAND>\r\n\r\n\u001b[1m\u001b[4mCommands:\u001b[0m\r\n  \u001b[1madd\u001b[0m     Add a new directory or increment its rank\r\n  \u001b[1medit\u001b[0m    Edit the database\r\n  \u001b[1mimport\u001b[0m  Import entries from another application\r\n  \u001b[1minit\u001b[0m    Generate shell configuration\r\n  \u001b[1mquery\u001b[0m   Search for a directory in the database\r\n  \u001b[1mremove\u001b[0m  Remove a directory from the database\r\n\r\n\u001b[1m\u001b[4mOptions:\u001b[0m\r\n  \u001b[1m-h\u001b[0m, \u001b[1m--help\u001b[0m     Print help\r\n  \u001b[1m-V\u001b[0m, \u001b[1m--version\u001b[0m  Print version\r\n\r\n\u001b[1m\u001b[4mEnvironment variables:\u001b[22m\u001b[24m\r\n  \u001b[1m_ZO_DATA_DIR\u001b[22m          Path for zoxide data files\r\n  \u001b[1m_ZO_ECHO\u001b[22m              Print the matched directory before navigating to it when set to 1\r\n  \u001b[1m_ZO_EXCLUDE_DIRS\u001b[22m      List of directory globs to be excluded\r\n  \u001b[1m_ZO_FZF_OPTS\u001b[22m          Custom flags to pass to fzf\r\n  \u001b[1m_ZO_MAXAGE\u001b[22m    "]
[1285.588085, "o", "        Maximum total age after which entries start getting deleted\r\n  \u001b[1m_ZO_RESOLVE_SYMLINKS\u001b[22m  Resolve symlinks when storing paths\r\n\u001b[?2004h\u001b]0;kent@ubse: ~\u0007\u001b[01;32mkent@ubse\u001b[00m:\u001b[01;34m~\u001b[00m$ "]
