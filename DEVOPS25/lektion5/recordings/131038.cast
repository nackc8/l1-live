[1587.079856, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM# configuration file, and defaults at the end.\r\n\u001b[19;1H\r\u001b[K:\u001b[K"]
[1587.111521, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM# Thus, host-specific definitions should be at the beginning of the\r\n\u001b[19;1H\r\u001b[K:\u001b[K"]
[1587.142706, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM# Any configuration value is only changed the first time it is set.\r\n\u001b[19;1H\r\u001b[K:\u001b[K"]
[1587.173952, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM#  3. system-wide file\r\n\u001b[19;1H\r\u001b[K:\u001b[K"]
[1587.205771, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM#  2. user-specific file\r\n\u001b[19;1H\r\u001b[K:\u001b[K"]
[1587.237281, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM#  1. command line options\r\n\u001b[19;1H\r\u001b[K:\u001b[K"]
[1587.267654, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM# Configuration data is parsed as follows:\r\n\u001b[19;1H\r\u001b[K:\u001b[K"]
[1587.299043, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\r\n\u001b[19;1H\r\u001b[K:\u001b[K"]
[1587.330783, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM# or on the command line.\r\n\u001b[19;1H\r\u001b[K:\u001b[K"]
[1587.362041, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM# users, and the values can be changed in per-user configuration files\r\n\u001b[19;1H\r\u001b[K:\u001b[K"]
[1587.393455, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM# ssh_config(5) for more information.  This file provides defaults for\r\n\u001b[19;1H\r\u001b[K:\u001b[K"]
