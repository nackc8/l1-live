[761.038827, "o", "MAN(1)                           Manual pager utils                           MAN(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       man - an interface to the system reference manuals\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mman\u001b[0m [\u001b[4mman\u001b[24m \u001b[4moptions\u001b[24m] [[\u001b[4msection\u001b[24m] \u001b[4mpage\u001b[24m ...] ...\u001b[m\r\n       \u001b[1mman\u001b[0m \u001b[1m-k\u001b[0m [\u001b[4mapropos\u001b[24m \u001b[4moptions\u001b[24m] \u001b[4mregexp\u001b[24m ...\u001b[m\r\n       \u001b[1mman\u001b[0m \u001b[1m-K\u001b[0m [\u001b[4mman\u001b[24m \u001b[4moptions\u001b[24m] [\u001b[4msection\u001b[24m] \u001b[4mterm\u001b[24m ...\u001b[m\r\n       \u001b[1mman\u001b[0m \u001b[1m-f\u001b[0m [\u001b[4mwhatis\u001b[24m \u001b[4moptions\u001b[24m] \u001b[4mpage\u001b[24m ...\u001b[m\r\n       \u001b[1mman\u001b[0m \u001b[1m-l\u001b[0m [\u001b[4mman\u001b[24m \u001b[4moptions\u001b[24m] \u001b[4mfile\u001b[24m ...\u001b[m\r\n       \u001b[1mman\u001b[0m \u001b[1m-w\u001b[0m|\u001b[1m-W\u001b[0m [\u001b[4mman\u001b[24m \u001b[4moptions\u001b[24m] \u001b[4mpage\u001b[24m ...\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page man(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[762.757478, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[7m Manual page man(1) line 2 (press h for help or q to quit)\u001b[27m\u001b[K"]
[762.846718, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mman\u001b[0m  is  the  system's manual pager.  Each \u001b[4mpage\u001b[24m argument given to \u001b[1mman\u001b[0m is nor‐\u001b[m\r\n\u001b[7m Manual page man(1) line 3 (press h for help or q to quit)\u001b[27m\u001b[K"]
[762.93044, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       mally the name of a program, utility or function.  The \u001b[4mmanual\u001b[24m \u001b[4mpage\u001b[24m associated\u001b[m\r\n\u001b[7m Manual page man(1) line 4 (press h for help or q to quit)\u001b[27m\u001b[K"]
[763.034887, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[763.034909, "o", "       with each of these arguments is then found and displayed.  A \u001b[4msection\u001b[24m, if pro‐\u001b[m\r\n\u001b[7m Manual page man(1) line 5 (press h for help or q to quit)\u001b[27m\u001b[K"]
[763.252478, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[763.252501, "o", "       vided, will direct \u001b[1mman\u001b[0m to look only in that \u001b[4msection\u001b[24m of the manual.   The  de‐\u001b[m\r\n\u001b[7m Manual page man(1) line 6 (press h for help or q to quit)\u001b[27m\u001b[K"]
[763.294125, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[763.294143, "o", "       fault  action  is to search in all of the available \u001b[4msections\u001b[24m following a pre-\u001b[m\r\n\u001b[7m Manual page man(1) line 7 (press h for help or q to quit)\u001b[27m\u001b[K"]
[763.327556, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[763.327698, "o", "       defined order (see \u001b[1mDEFAULTS\u001b[0m), and to show only the first \u001b[4mpage\u001b[24m found, even  if\u001b[m\r\n\u001b[7m Manual page man(1) line 8 (press h for help or q to quit)\u001b[27m\u001b[K"]
[763.361172, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[4mpage\u001b[24m exists in several \u001b[4msections\u001b[24m.\u001b[m\r\n\u001b[7m Manual page man(1) line 9 (press h for help or q to quit)\u001b[27m\u001b[K"]
