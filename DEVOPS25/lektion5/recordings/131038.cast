[4953.709661, "o", "p"]
[4954.656423, "o", " "]
[4955.150511, "o", "-"]
[4955.615476, "o", "P"]
[4956.065357, "o", " "]
[4956.11, "o", "\r\n"]
[4956.110087, "o", "\u001b[?2004l\r"]
[4956.114194, "o", "scp: option requires an argument -- P\r\r\nusage: scp [-346ABCOpqRrsTv] [-c cipher] [-D sftp_server_path] [-F ssh_config]\r\n           [-i identity_file] [-J destination] [-l limit] [-o ssh_option]\r\n           [-P port] [-S program] [-X sftp_option] source ... target\r\n"]
[4956.120297, "o", "\u001b[?2004h\u001b[94mDEVOPS25/lektion5\r\r\n\u001b(B\u001b[m$ "]
[4957.318678, "o", "scp -P "]
