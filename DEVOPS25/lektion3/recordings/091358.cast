[1062.691187, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       'auto' or 'never'.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 219/260 91% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1062.722605, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       The  WHEN  argument  defaults  to  'always' and can also be\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 218/260 91% (press h for help or q to quit)\u001b[27m\u001b[K"]
