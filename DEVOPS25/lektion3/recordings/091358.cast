[5403.223068, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mtuvSUX\u001b[0m nor \u001b[1m--sort\u001b[0m is specified.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7m Manual page ls(1) line 12 (press h for help or q to quit)\u001b[27m\u001b[K"]
