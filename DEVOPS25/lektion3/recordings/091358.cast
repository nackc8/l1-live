[1001.325436, "o", "...skipping...\r\n       \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m     use a long listing format\u001b[m\r\n\u001b[m\r\n       \u001b[1m\u001b[7m-L\u001b[27m\u001b[0m, \u001b[1m--dereference\u001b[0m\u001b[m\r\n              when showing file information for a  symbolic  link,\u001b[m\r\n              show  information  for  the file the link references\u001b[m\r\n              rather than for the link itself\u001b[m\r\n\u001b[m\r\n       \u001b[1m-m\u001b[0m     fill width with a comma separated list of entries\u001b[m\r\n\u001b[m\r\n       \u001b[1m-n\u001b[0m, \u001b[1m--numeric-uid-gid\u001b[0m\u001b[m\r\n              like \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m, but list numeric user and group IDs\u001b[m\r\n\u001b[m\r\n       \u001b[1m-N\u001b[0m, \u001b[1m-\u001b[0m\u001b[1m\u001b[7m-l\u001b[27m\u001b[0m\u001b[1miteral\u001b[0m\u001b[m\r\n              print entry names without quoting\u001b[m\r\n\u001b[m\r\n       \u001b[1m-o\u001b[0m     like \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m, but do not list group information\u001b[m\r\n\u001b[m\r\n\u001b[7mnual page ls(1) line 111/260 48% (press h for help or q to quit)\u001b[27m\u001b[K"]
