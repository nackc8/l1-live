[1062.784991, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       sets the default style to use.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 216/260 90% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1062.816671, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       the POSIX locale.  Also the TIME_STYLE environment variable\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 215/260 90% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1062.848422, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       TIME_STYLE prefixed with 'posix-' takes effect only outside\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 214/260 90% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1062.880509, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       to  non-recent  files  and   FORMAT2   to   recent   files.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 213/260 89% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1062.912853, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       If  FORMAT is FORMAT1<newline>FORMAT2, then FORMAT1 applies\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 212/260 89% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1062.943759, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       cale, or +FORMAT.  FORMAT is interpreted like  in  \u001b[1mdate\u001b[0m(1).\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 211/260 89% (press h for help or q to quit)\u001b[27m\u001b[K"]
