[4117.551171, "o", "\u001b[17;1H           with the \u001b[1m-G\u001b[0m option.\u001b[m\r\n\u001b[18;1H\u001b[1;1HUSERMOD(8)         System Management Commands         USERMOD(8)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       usermod - modify a user account\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1musermod\u001b[0m [\u001b[4moptions\u001b[24m] \u001b[4mLOGIN\u001b[24m\u001b[m\r\n\u001b[8;1H\u001b[m\r\n\u001b[9;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[10;1H       The \u001b[1musermod\u001b[0m command modifies t"]
[4117.551785, "o", "he system account files.\u001b[m\r\n\u001b[11;1H\u001b[m\r\n\u001b[12;1H\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[13;1H       The options which apply to the \u001b[1musermod\u001b[0m command are:\u001b[m\r\n\u001b[14;1H\u001b[m\r\n\u001b[15;1H       \u001b[1m-a\u001b[0m, \u001b[1m--append\u001b[0m\u001b[m\r\n\u001b[16;1H           Add the user to the supplementary group(s). Use only\u001b[m\r\n\u001b[17;1H           with the \u001b[1m-G\u001b[0m option.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mPattern not found  (press RETURN)\u001b[27m"]
