[1094.096884, "o", "mat\u001b[27mion  about the FILEs (the current directory\u001b[m\r\n\u001b[11;1H       by default).  Sort entries alphabetically if none of \u001b[1m-cf‐\u001b[0m\u001b[m\r\n\u001b[12;1H       \u001b[1mtuvSUX\u001b[0m nor \u001b[1m--sort\u001b[0m is specified.\u001b[m\r\n\u001b[13;1H\u001b[m\r\n\u001b[14;1H       Mandatory  arguments  to  long  options are mandatory for\u001b[m\r\n\u001b[15;1H       short options too.\u001b[m\r\n\u001b[16;1H\u001b[m\r\n\u001b[17;1H       \u001b[1m-a\u001b[0m, \u001b[1m--all\u001b[0m\u001b[m\r\n\u001b[18;1H              do not ignore entries starting with .\u001b[m\r\n\u001b[m\r\n       \u001b[1m-A\u001b[0m, \u001b[1m--almost-all\u001b[0m\u001b[m\r\n              do not list implied . and ..\u001b[m\r\n\u001b[m\r\n       \u001b[1m--author\u001b[0m\u001b[m\r\n              with \u001b[1m-l\u001b[0m, print the author of each file\u001b[m\r\n\u001b[m\r\n       \u001b[1m-b\u001b[0m, \u001b[1m--escape\u001b[0m\u001b[m\r\n\u001b[7mManual page ls(1) line 10/263 8% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1095.258048, "o", "\r\u001b[K/\r\u001b[K"]
[1095.258178, "o", "...skipping...\r\n              e.g., '--block-size=M'; see SIZE \u001b[7mformat\u001b[27m below\u001b[m\r\n\u001b[m\r\n       \u001b[1m-B\u001b[0m, \u001b[1m--ignore-backups\u001b[0m\u001b[m\r\n              do not list implied entries ending with ~\u001b[m\r\n\u001b[m\r\n       \u001b[1m-c\u001b[0m     with  \u001b[1m-lt\u001b[0m:  sort by, and show, ctime (time of last\u001b[m\r\n              modification of file status in\u001b[7mformat\u001b[27mion); with \u001b[1m-l\u001b[0m:\u001b[m\r\n              show  ctime  and  sort by name; otherwise: sort by\u001b[m\r\n              ctime, newest first\u001b[m\r\n\u001b[m\r\n       \u001b[1m-C\u001b[0m     list entries by columns\u001b[m\r\n\u001b[m\r\n       \u001b[1m--color\u001b[0m[=\u001b[4mWHEN\u001b[24m]\u001b[m\r\n              color the output WHEN; more info below\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[0m, \u001b[1m--directory\u001b[0m\u001b[m\r\n              list directories themselves, not their contents\u001b[m\r\n\u001b[7manual page ls(1) line 31/263 16% (press h for help or q to quit)\u001b[27m\u001b[K"]
