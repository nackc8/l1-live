[5406.726135, "o", "\r\u001b[K"]
[5406.726263, "o", "              do not ignore entries starting with .\u001b[m\r\n\u001b[m\r\n       \u001b[1m-A\u001b[0m, \u001b[1m--almost-all\u001b[0m\u001b[m\r\n              do not list implied . and ..\u001b[m\r\n\u001b[m\r\n       \u001b[1m--author\u001b[0m\u001b[m\r\n              with \u001b[1m-l\u001b[0m, print the author of each file\u001b[m\r\n\u001b[m\r\n       \u001b[1m-b\u001b[0m, \u001b[1m--escape\u001b[0m\u001b[m\r\n              print C-style escapes for nongraphic characters\u001b[m\r\n\u001b[m\r\n       \u001b[1m--block-size\u001b[0m=\u001b[4mSIZE\u001b[24m\u001b[m\r\n              with \u001b[1m-l\u001b[0m, scale sizes by SIZE when  printing  them;\u001b[m\r\n              e.g., '--block-size=M'; see SIZE format below\u001b[m\r\n\u001b[m\r\n       \u001b[1m-B\u001b[0m, \u001b[1m--ignore-backups\u001b[0m\u001b[m\r\n              do not list implied entries ending with ~\u001b[m\r\n\u001b[7m Manual page ls(1) line 18 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5407.451648, "o", "\r\u001b[K"]
[5407.451737, "o", "\u001b[m\r\n       \u001b[1m-c\u001b[0m     with  \u001b[1m-lt\u001b[0m:  sort by, and show, ctime (time of last\u001b[m\r\n              modification of file status information); with \u001b[1m-l\u001b[0m:\u001b[m\r\n              show  ctime  and  sort by name; otherwise: sort by\u001b[m\r\n              ctime, newest first\u001b[m\r\n\u001b[m\r\n       \u001b[1m-C\u001b[0m     list entries by columns\u001b[m\r\n\u001b[m\r\n       \u001b[1m--color\u001b[0m[=\u001b[4mWHEN\u001b[24m]\u001b[m\r\n              color the output WHEN; more info below\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[0m, \u001b[1m--directory\u001b[0m\u001b[m\r\n"]
[5407.451761, "o", "              list directories themselves, not their contents\u001b[m\r\n\u001b[m\r\n       \u001b[1m-D\u001b[0m, \u001b[1m--dired\u001b[0m\u001b[m\r\n              generate output designed for Emacs' dired mode\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ls(1) line 35 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5408.383355, "o", "\r\u001b[K"]
[5408.383441, "o", "       \u001b[1m-f\u001b[0m     list all entries in directory order\u001b[m\r\n\u001b[m\r\n       \u001b[1m-F\u001b[0m, \u001b[1m--classify\u001b[0m[=\u001b[4mWHEN\u001b[24m]\u001b[m\r\n              append indicator (one of */=>@|) to entries WHEN\u001b[m\r\n\u001b[m\r\n       \u001b[1m--file-type\u001b[0m\u001b[m\r\n              likewise, except do not append '*'\u001b[m\r\n\u001b[m\r\n       \u001b[1m--format\u001b[0m=\u001b[4mWORD\u001b[24m\u001b[m\r\n              across \u001b[1m-x\u001b[0m, commas \u001b[1m-m\u001b[0m, horizontal \u001b[1m-x\u001b[0m, long \u001b[1m-l\u001b[0m, sin‐\u001b[m\r\n              gle-column \u001b[1m-1\u001b[0m, verbose \u001b[1m-l\u001b[0m, vertical \u001b[1m-C\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1m--full-time\u001b[0m\u001b[m\r\n              like \u001b[1m-l\u001b[0m \u001b[1m--time-style\u001b[0m=\u001b[4mfull-iso\u001b[24m\u001b[m\r\n\u001b[m\r\n       \u001b[1m-g\u001b[0m     like \u001b[1m-l\u001b[0m, but do not list owner\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ls(1) line 52 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5410.162001, "o", "\r\u001b[K"]
[5410.162125, "o", "       \u001b[1m--group-directories-first\u001b[0m\u001b[m\r\n              group  directories  before files; can be augmented\u001b[m\r\n              with a \u001b[1m--sort\u001b[0m option, but any use  of  \u001b[1m--sort\u001b[0m=\u001b[4mnone\u001b[24m\u001b[m\r\n              (\u001b[1m-U\u001b[0m) disables grouping\u001b[m\r\n\u001b[m\r\n       \u001b[1m-G\u001b[0m, \u001b[1m--no-group\u001b[0m\u001b[m\r\n              in a long listing, don't print group names\u001b[m\r\n\u001b[m\r\n       \u001b[1m-h\u001b[0m, \u001b[1m--human-readable\u001b[0m\u001b[m\r\n              with \u001b[1m-l\u001b[0m and \u001b[1m-s\u001b[0m, print sizes like 1K 234M 2G etc.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--si\u001b[0m   likewise, but use powers of 1000 not 1024\u001b[m\r\n\u001b[m\r\n       \u001b[1m-H\u001b[0m, \u001b[1m--dereference-command-line\u001b[0m\u001b[m\r\n              follow symbolic links listed on the command line\u001b[m\r\n\u001b[m\r\n       \u001b[1m--dereference-command-line-symlink-to-dir\u001b[0m\u001b[m\r\n\u001b[7m Manual page ls(1) line 69 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5410.797949, "o", "\r\u001b[K"]
[5410.797973, "o", "              follow each command line symbolic link that points\u001b[m\r\n              to a directory\u001b[m\r\n\u001b[m\r\n       \u001b[1m--hide\u001b[0m=\u001b[4mPATTERN\u001b[24m\u001b[m\r\n              do not list implied entries matching shell PATTERN\u001b[m\r\n              (overridden by \u001b[1m-a\u001b[0m or \u001b[1m-A\u001b[0m)\u001b[m\r\n\u001b[m\r\n       \u001b[1m--hyperlink\u001b[0m[=\u001b[4mWHEN\u001b[24m]\u001b[m\r\n              hyperlink file names WHEN\u001b[m\r\n\u001b[m\r\n       \u001b[1m--indicator-style\u001b[0m=\u001b[4mWORD\u001b[24m\u001b[m\r\n              append  indicator  with style WORD to entry names:\u001b[m\r\n              none    (default),    slash    (\u001b[1m-p\u001b[0m),     file-type\u001b[m\r\n              (\u001b[1m--file-type\u001b[0m), classify (\u001b[1m-F\u001b[0m)\u001b[m\r\n\u001b[m\r\n       \u001b[1m-i\u001b[0m, \u001b[1m--inode\u001b[0m\u001b[m\r\n              print the index number of each file\u001b[m\r\n\u001b[7m Manual page ls(1) line 86 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5411.466065, "o", "\r\u001b[K\u001b[m\r\n"]
[5411.466204, "o", "       \u001b[1m-I\u001b[0m, \u001b[1m--ignore\u001b[0m=\u001b[4mPATTERN\u001b[24m\u001b[m\r\n              do not list implied entries matching shell PATTERN\u001b[m\r\n\u001b[m\r\n       \u001b[1m-k\u001b[0m, \u001b[1m--kibibytes\u001b[0m\u001b[m\r\n              default to 1024-byte blocks for file system usage;\u001b[m\r\n              used only with \u001b[1m-s\u001b[0m and per directory totals\u001b[m\r\n\u001b[m\r\n       \u001b[1m-l\u001b[0m     use a long listing format\u001b[m\r\n\u001b[m\r\n       \u001b[1m-L\u001b[0m, \u001b[1m--dereference\u001b[0m\u001b[m\r\n              when showing file information for a symbolic link,\u001b[m\r\n              show  information for the file the link references\u001b[m\r\n              rather than for the link itself\u001b[m\r\n\u001b[m\r\n       \u001b[1m-m\u001b[0m     fill width with a comma separated list of entries\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ls(1) line 103 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5412.177851, "o", "\r\u001b[K       \u001b[1m-n\u001b[0m, \u001b[1m--numeric-uid-gid\u001b[0m\u001b[m\r\n              like \u001b[1m-l\u001b[0m, but list numeric user and group IDs\u001b[m\r\n\u001b[m\r\n       \u001b[1m-N\u001b[0m, \u001b[1m--literal\u001b[0m\u001b[m\r\n              print entry names without quoting\u001b[m\r\n\u001b[m\r\n       \u001b[1m-o\u001b[0m     like \u001b[1m-l\u001b[0m, but do not list group information\u001b[m\r\n\u001b[m\r\n       \u001b[1m-p\u001b[0m, \u001b[1m--indicator-style\u001b[0m=\u001b[4mslash\u001b[24m\u001b[m\r\n              append / indicator to directories\u001b[m\r\n\u001b[m\r\n       \u001b[1m-q\u001b[0m, \u001b[1m--hide-control-chars\u001b[0m\u001b[m\r\n              print ? instead of nongraphic characters\u001b[m\r\n\u001b[m\r\n       \u001b[1m--show-control-chars\u001b[0m\u001b[m\r\n              show nongraphic characters as-is (the default, un‐\u001b[m\r\n              less program is 'ls' and output is a terminal)\u001b[m\r\n\u001b[7m Manual page ls(1) line 120 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5413.235784, "o", "\r\u001b[K"]
[5413.235895, "o", "\u001b[m\r\n       \u001b[1m-Q\u001b[0m, \u001b[1m--quote-name\u001b[0m\u001b[m\r\n              enclose entry names in double quotes\u001b[m\r\n\u001b[m\r\n       \u001b[1m--quoting-style\u001b[0m=\u001b[4mWORD\u001b[24m\u001b[m\r\n              use  quoting  style WORD for entry names: literal,\u001b[m\r\n              locale,   shell,    shell-always,    shell-escape,\u001b[m\r\n              shell-escape-always,  c,  escape  (overrides QUOT‐\u001b[m\r\n              ING_STYLE environment variable)\u001b[m\r\n\u001b[m\r\n       \u001b[1m-r\u001b[0m, \u001b[1m--reverse\u001b[0m\u001b[m\r\n              reverse order while sorting\u001b[m\r\n\u001b[m\r\n       \u001b[1m-R\u001b[0m, \u001b[1m--recursive\u001b[0m\u001b[m\r\n              list subdirectories recursively\u001b[m\r\n\u001b[m\r\n       \u001b[1m-s\u001b[0m, \u001b[1m--size\u001b[0m\u001b[m\r\n\u001b[7m Manual page ls(1) line 137 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5414.114054, "o", "\r\u001b[K              print the allocated size of each file, in blocks\u001b[m\r\n\u001b[m\r\n       \u001b[1m-S\u001b[0m     sort by file size, largest first\u001b[m\r\n\u001b[m\r\n       \u001b[1m--sort\u001b[0m=\u001b[4mWORD\u001b[24m\u001b[m\r\n              sort by WORD instead  of  name:  none  (\u001b[1m-U\u001b[0m),  size\u001b[m"]
[5414.114082, "o", "\r\n              (\u001b[1m-S\u001b[0m),  time  (\u001b[1m-t\u001b[0m),  version  (\u001b[1m-v\u001b[0m), extension (\u001b[1m-X\u001b[0m),\u001b[m\r\n              width\u001b[m\r\n\u001b[m\r\n       \u001b[1m--time\u001b[0m=\u001b[4mWORD\u001b[24m\u001b[m\r\n              change the default of  using  modification  times;\u001b[m\r\n              access  time (\u001b[1m-u\u001b[0m): atime, access, use; change time\u001b[m\r\n              (\u001b[1m-c\u001b[0m): ctime, status; birth time: birth, creation;\u001b[m\r\n\u001b[m\r\n              with \u001b[1m-l\u001b[0m, WORD determines which time to show;  with\u001b[m\r\n              \u001b[1m--sort\u001b[0m=\u001b[4mtime\u001b[24m, sort by WORD (newest first)\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ls(1) line 154 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5414.774147, "o", "\r\u001b[K       \u001b[1m--time-style\u001b[0m=\u001b[4mTIME_STYLE\u001b[24m\u001b[m\r\n              time/date format with \u001b[1m-l\u001b[0m; see TIME_STYLE below\u001b[m\r\n\u001b[m\r\n       \u001b[1m-t\u001b[0m     sort by time, newest first; see \u001b[1m--time\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1m-T\u001b[0m, \u001b[1m--tabsize\u001b[0m=\u001b[4mCOLS\u001b[24m\u001b[m\r\n              assume tab stops at each COLS instead of 8\u001b[m\r\n\u001b[m\r\n       \u001b[1m-u\u001b[0m     with \u001b[1m-lt\u001b[0m: sort by, and show, access time; with \u001b[1m-l\u001b[0m:\u001b[m\r\n              show access time and sort by name; otherwise: sort\u001b[m\r\n              by access time, newest first\u001b[m\r\n\u001b[m\r\n       \u001b[1m-U\u001b[0m     do not sort; list entries in directory order\u001b[m\r\n\u001b[m\r\n       \u001b[1m-v\u001b[0m     natural sort of (version) numbers within text\u001b[m\r\n\u001b[m\r\n       \u001b[1m-w\u001b[0m, \u001b[1m--width\u001b[0m=\u001b[4mCOLS\u001b[24m\u001b[m\r\n\u001b[7m Manual page ls(1) line 171 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5415.839582, "o", "\r\u001b[K"]
[5415.839678, "o", "              set output width to COLS.  0 means no limit\u001b[m\r\n\u001b[m\r\n       \u001b[1m-x\u001b[0m     list entries by lines instead of by columns\u001b[m\r\n\u001b[m\r\n       \u001b[1m-X\u001b[0m     sort alphabetically by entry extension\u001b[m\r\n\u001b[m\r\n       \u001b[1m-Z\u001b[0m, \u001b[1m--context\u001b[0m\u001b[m\r\n              print any security context of each file\u001b[m\r\n\u001b[m\r\n       \u001b[1m--zero\u001b[0m end each output line with NUL, not newline\u001b[m\r\n\u001b[m\r\n       \u001b[1m-1\u001b[0m     list one file per line\u001b[m\r\n\u001b[m\r\n       \u001b[1m--help\u001b[0m display this help and exit\u001b[m\r\n\u001b[m\r\n       \u001b[1m--version\u001b[0m\u001b[m\r\n              output version information and exit\u001b[m\r\n\u001b[7m Manual page ls(1) line 188 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5416.544246, "o", "\r\u001b[K\u001b[m\r\n       The  SIZE argument is an integer and optional unit (exam‐\u001b[m\r\n       ple: 10K is 10*1024).  Units are K,M,G,T,P,E,Z,Y  (powers\u001b[m\r\n"]
[5416.544275, "o", "       of  1024) or KB,MB,... (powers of 1000).  Binary prefixes\u001b[m\r\n       can be used, too: KiB=K, MiB=M, and so on.\u001b[m\r\n\u001b[m\r\n       The TIME_STYLE argument can be full-iso,  long-iso,  iso,\u001b[m\r\n       locale,  or  +FORMAT.   FORMAT  is  interpreted  like  in\u001b[m\r\n       \u001b[1mdate\u001b[0m(1).  If FORMAT is FORMAT1<newline>FORMAT2, then FOR‐\u001b[m\r\n       MAT1  applies  to  non-recent files and FORMAT2 to recent\u001b[m\r\n       files.  TIME_STYLE prefixed with  'posix-'  takes  effect\u001b[m\r\n       only outside the POSIX locale.  Also the TIME_STYLE envi‐\u001b[m\r\n       ronment variable sets the default style to use.\u001b[m\r\n\u001b[m\r\n       The WHEN argument defaults to 'always' and  can  also  be\u001b[m\r\n       'auto' or 'never'.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ls(1) line 205 (press h for help or q to quit)\u001b[27m\u001b[K"]
[5418.080898, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              output version information and exit\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7m Manual page ls(1) line 204 (press h for help or q to quit)\u001b[27m\u001b[K"]
