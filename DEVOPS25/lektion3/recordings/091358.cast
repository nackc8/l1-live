[1061.7203, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       a  terminal.  The LS_COLORS environment variable can change\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 224/260 93% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1061.751355, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       emits color codes only when standard output is connected to\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 223/260 92% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1061.783285, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       default  and  with  \u001b[1m--color\u001b[0m=\u001b[4mnever\u001b[24m.   With  \u001b[1m--color\u001b[0m=\u001b[4mauto\u001b[24m, ls\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 222/260 92% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1061.815103, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       Using color to distinguish file types is disabled  both  by\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 221/260 92% (press h for help or q to quit)\u001b[27m\u001b[K"]
