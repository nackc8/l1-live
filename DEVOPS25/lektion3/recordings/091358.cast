[4012.402217, "o", "USERMOD(8)         System Management Commands         USERMOD(8)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       usermod - modify a user account\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1musermod\u001b[0m [\u001b[4moptions\u001b[24m] \u001b[4mLOGIN\u001b[24m\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       The \u001b[1musermod\u001b[0m command modifies the system account files.\u001b[m\r\n\u001b[m\r\n\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n       The options which apply to the \u001b[1musermod\u001b[0m command are:\u001b[m\r\n\u001b[m\r\n       \u001b[1m-a\u001b[0m, \u001b[1m--append\u001b[0m\u001b[m\r\n           Add the user to the supplementary group(s). Use only\u001b[m\r\n           with the \u001b[1m-G\u001b[0m option.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4014.804547, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 2 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4015.306519, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-b\u001b[0m, \u001b[1m--badname\u001b[0m\u001b[m\r\n\u001b[7m Manual page usermod(8) line 3 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4015.338298, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Allow names that do not conform to standards.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 4 (press h for help or q to quit)\u001b[27m\u001b[K"]
