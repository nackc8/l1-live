[1133.120582, "o", "\u001b[18;1H\u001b[K\r\u001b[K"]
[1133.120709, "o", "\u001b[H\u001b[2J\u001b[H\u001bM       \u001b[1m-a\u001b[0m, \u001b[1m--all\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       short options too.\u001b[m\r\n\u001b[H\u001bM       Mandatory  arguments  to  long  options are mandatory for\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       \u001b[1mtuvSUX\u001b[0m nor \u001b[1m--sort\u001b[0m is specified.\u001b[m\r\n\u001b[H\u001bM       by default).  Sort entries alphabetically if none of \u001b[1m-cf‐\u001b[0m\u001b[m\r\n\u001b[H\u001bM       List  in\u001b[7mformat\u001b[27mion  about the FILEs (the current directory\u001b[m\r\n\u001b[H\u001bM\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       \u001b[1mls\u001b[0m [\u001b[4mOPTION\u001b[24m]... [\u001b[4mFILE\u001b[24m]...\u001b[m\r\n\u001b[H\u001bM\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       ls - list directory contents\u001b[m\r\n\u001b[H\u001bM\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bMLS(1)                     User Commands                    LS(1)\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7m Manual page ls(1) line 1/263 5% (press h for help or q to quit)\u001b[27m\u001b[K"]
