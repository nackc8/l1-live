[983.340665, "o", "FILEs (the current directory by\u001b[m\r\n\u001b[11;1H       default).  Sort entries alphabetically if none of \u001b[1m-cftuvSUX\u001b[0m\u001b[m\r\n\u001b[12;1H       nor \u001b[1m--sort\u001b[0m is specified.\u001b[m\r\n\u001b[13;1H\u001b[m\r\n\u001b[14;1H       Mandatory arguments to long options are mandatory for short\u001b[m\r\n\u001b[15;1H       options too.\u001b[m\r\n\u001b[16;1H\u001b[m\r\n\u001b[17;1H       \u001b[1m-a\u001b[0m, \u001b[1m--all\u001b[0m\u001b[m\r\n\u001b[18;1H...skipping...\r\n              with \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m, print the author of each file\u001b[m\r\n\u001b[m\r\n       \u001b[1m-b\u001b[0m, \u001b[1m--escape\u001b[0m\u001b[m\r\n              print C-style escapes for nongraphic characters\u001b[m\r\n\u001b[m\r\n       \u001b[1m--block-size\u001b[0m=\u001b[4mSIZE\u001b[24m\u001b[m\r\n              with \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m, scale sizes by  SIZE  when  printing  them;\u001b[m\r\n              e.g., '--block-size=M'; see SIZE format below\u001b[m\r\n\u001b[m\r\n       \u001b[1m-B\u001b[0m, \u001b[1m--ignore-backups\u001b[0m\u001b[m\r\n              do not list implied entries ending with ~\u001b[m\r\n\u001b[m\r\n       \u001b[1m-c\u001b[0m     with  \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m\u001b[1mt\u001b[0m:  sort  by,  and show, ctime (time of last\u001b[m\r\n              modification of file status"]
[983.340758, "o", " information);  with  \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m:\u001b[m\r\n              show  ctime  and  sort  by  name; otherwise: sort by\u001b[m\r\n              ctime, newest first\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ls(1) line 24 (press h for help or q to quit)\u001b[27m\u001b[K"]
[991.725005, "o", "\r\u001b[K/\r\u001b[K       \u001b[1m-C\u001b[0m     list entries by columns\u001b[m\r\n\u001b[m\r\n       \u001b[1m--color\u001b[0m[=\u001b[4mWHEN\u001b[24m]\u001b[m\r\n              color the output WHEN; more info below\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[0m, \u001b[1m--directory\u001b[0m\u001b[m\r\n\u001b[7m Manual page ls(1) line 30 (press h for help or q to quit)\u001b[27m\u001b[K"]
[993.413196, "o", "\r\u001b[K/\r\u001b[K              list directories themselves, not their contents\u001b[m\r\n\u001b[m\r\n       \u001b[1m-D\u001b[0m, \u001b[1m--dired\u001b[0m\u001b[m\r\n              generate output designed for Emacs' dired mode\u001b[m\r\n\u001b[m\r\n       \u001b[1m-f\u001b[0m     list all entries in directory order\u001b[m\r\n\u001b[7m Manual page ls(1) line 36 (press h for help or q to quit)\u001b[27m\u001b[K"]
[994.380595, "o", "\r\u001b[K/\r\u001b[K\u001b[m\r\n\u001b[7m Manual page ls(1) line 37 (press h for help or q to quit)\u001b[27m\u001b[K"]
[995.333549, "o", "\r\u001b[K/\r\u001b[K"]
[995.333734, "o", "...skipping...\r\n              across \u001b[1m-x\u001b[0m, commas \u001b[1m-m\u001b[0m, horizontal \u001b[1m-x\u001b[0m, long  \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m,  sin‐\u001b[m\r\n              gle-column \u001b[1m-1\u001b[0m, verbose \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m, vertical \u001b[1m-C\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1m--full-time\u001b[0m\u001b[m\r\n              like \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m \u001b[1m--time-style\u001b[0m=\u001b[4mfull-iso\u001b[24m\u001b[m\r\n\u001b[m\r\n       \u001b[1m-g\u001b[0m     like \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m, but do not list owner\u001b[m\r\n\u001b[m\r\n       \u001b[1m--group-directories-first\u001b[0m\u001b[m\r\n              group  directories  before  files;  can be augmented\u001b[m\r\n              with a \u001b[1m--sort\u001b[0m option, but  any  use  of  \u001b[1m--sort\u001b[0m=\u001b[4mnone\u001b[24m\u001b[m\r\n              (\u001b[1m-U\u001b[0m) disables grouping\u001b[m\r\n\u001b[m\r\n       \u001b[1m-G\u001b[0m, \u001b[1m--no-group\u001b[0m\u001b[m\r\n              in a long listing, don't print group names\u001b[m\r\n\u001b[m\r\n       \u001b[1m-h\u001b[0m, \u001b[1m--human-readable\u001b[0m\u001b[m\r\n\u001b[7m Manual page ls(1) line 61 (press h for help or q to quit)\u001b[27m\u001b[K"]
[996.443227, "o", "\r\u001b[K/\r\u001b[K              with \u001b[1m\u001b[7m-l\u001b[27m\u001b[0m and \u001b[1m-s\u001b[0m, print sizes like 1K 234M 2G etc.\u001b[m\r\n\u001b[7m Manual page ls(1) line 62 (press h for help or q to quit)\u001b[27m\u001b[K"]
[997.004504, "o", "\r\u001b[K/\r\u001b[K\u001b[m\r\n       \u001b[1m--si\u001b[0m   likewise, but use powers of 1000 not 1024\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ls(1) line 65 (press h for help or q to quit)\u001b[27m\u001b[K"]
[997.590311, "o", "\r\u001b[K/\r\u001b[K       \u001b[1m-H\u001b[0m, \u001b[1m--dereference-command\u001b[0m\u001b[1m\u001b[7m-l\u001b[27m\u001b[0m\u001b[1mine\u001b[0m\u001b[m\r\n              follow symbolic links listed on the command line\u001b[m\r\n\u001b[7m Manual page ls(1) line 67 (press h for help or q to quit)\u001b[27m\u001b[K"]
[999.749894, "o", "\r\u001b[K/\r\u001b[K"]
[999.750013, "o", "\u001b[m\r\n       \u001b[1m--dereference-command\u001b[0m\u001b[1m\u001b[7m-l\u001b[27m\u001b[0m\u001b[1mine-symlink-to-dir\u001b[0m\u001b[m\r\n              follow  each  command line symbolic link that points\u001b[m\r\n              to a directory\u001b[m\r\n\u001b[m\r\n       \u001b[1m--hide\u001b[0m=\u001b[4mPATTERN\u001b[24m\u001b[m\r\n              do not list implied entries matching  shell  PATTERN\u001b[m\r\n              (overridden by \u001b[1m-a\u001b[0m or \u001b[1m-A\u001b[0m)\u001b[m\r\n\u001b[m\r\n       \u001b[1m--hyperlink\u001b[0m[=\u001b[4mWHEN\u001b[24m]\u001b[m\r\n              hyperlink file names WHEN\u001b[m\r\n\u001b[7m Manual page ls(1) line 78 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1000.43345, "o", "\r\u001b[K/\r\u001b[K\u001b[m\r\n       \u001b[1m--indicator-style\u001b[0m=\u001b[4mWORD\u001b[24m\u001b[m\r\n              append  indicator  with  style  WORD to entry names:\u001b[m\r\n              none (default), slash (\u001b[1m-p\u001b[0m), file-type (\u001b[1m--file-type\u001b[0m),\u001b[m\r\n\u001b[7m Manual page ls(1) line 82 (press h for help or q to quit)\u001b[27m\u001b[K"]
