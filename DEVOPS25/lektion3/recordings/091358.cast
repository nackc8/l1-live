[4142.655265, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           can't update group file\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mpage userdel(8) line 192/224 89% (press h for help or q to quit)\u001b[27m\u001b[K"]
