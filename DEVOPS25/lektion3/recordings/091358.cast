[1111.474967, "o", "...skipping...\r\n       \u001b[1m-l\u001b[0m     use a long listing \u001b[7mformat\u001b[27m\u001b[m\r\n\u001b[m\r\n       \u001b[1m-L\u001b[0m, \u001b[1m--dereference\u001b[0m\u001b[m\r\n              when showing file in\u001b[7mformat\u001b[27mion for a symbolic link,\u001b[m\r\n              show  in\u001b[7mformat\u001b[27mion for the file the link references\u001b[m\r\n              rather than for the link itself\u001b[m\r\n\u001b[m\r\n       \u001b[1m-m\u001b[0m     fill width with a comma separated list of entries\u001b[m\r\n\u001b[m\r\n       \u001b[1m-n\u001b[0m, \u001b[1m--numeric-uid-gid\u001b[0m\u001b[m\r\n              like \u001b[1m-l\u001b[0m, but list numeric user and group IDs\u001b[m\r\n\u001b[m\r\n       \u001b[1m-N\u001b[0m, \u001b[1m--literal\u001b[0m\u001b[m\r\n              print entry names without quoting\u001b[m\r\n\u001b[m\r\n       \u001b[1m-o\u001b[0m     like \u001b[1m-l\u001b[0m, but do not list group in\u001b[7mformat\u001b[27mion\u001b[m\r\n\u001b[m\r\n\u001b[7mnual page ls(1) line 111/263 48% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1112.554921, "o", "\r\u001b[K/\r\u001b[K       \u001b[1m-p\u001b[0m, \u001b[1m--indicator-style\u001b[0m=\u001b[4mslash\u001b[24m\u001b[m\r\n              append / indicator to directories\u001b[m\r\n\u001b[m\r\n\u001b[7mnual page ls(1) line 114/263 49% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1113.086893, "o", "\r\u001b[K/\r\u001b[K       \u001b[1m-q\u001b[0m, \u001b[1m--hide-control-chars\u001b[0m\u001b[m\r\n\u001b[7mnual page ls(1) line 115/263 50% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1113.514102, "o", "\r\u001b[K/\r\u001b[K"]
[1113.514124, "o", "              print ? instead of nongraphic characters\u001b[m\r\n\u001b[m\r\n       \u001b[1m--show-control-chars\u001b[0m\u001b[m\r\n              show nongraphic characters as-is (the default, un‐\u001b[m\r\n              less program is 'ls' and output is a terminal)\u001b[m\r\n\u001b[m\r\n       \u001b[1m-Q\u001b[0m, \u001b[1m--quote-name\u001b[0m\u001b[m\r\n              enclose entry names in double quotes\u001b[m\r\n\u001b[m\r\n       \u001b[1m--quoting-style\u001b[0m=\u001b[4mWORD\u001b[24m\u001b[m\r\n              use  quoting  style WORD for entry names: literal,\u001b[m\r\n\u001b[7mnual page ls(1) line 126/263 55% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1114.115243, "o", "\r\u001b[K/\r\u001b[K"]
[1114.115365, "o", "...skipping...\r\n              time/date \u001b[7mformat\u001b[27m with \u001b[1m-l\u001b[0m; see TIME_STYLE below\u001b[m\r\n\u001b[m\r\n       \u001b[1m-t\u001b[0m     sort by time, newest first; see \u001b[1m--time\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1m-T\u001b[0m, \u001b[1m--tabsize\u001b[0m=\u001b[4mCOLS\u001b[24m\u001b[m\r\n              assume tab stops at each COLS instead of 8\u001b[m\r\n\u001b[m\r\n       \u001b[1m-u\u001b[0m     with \u001b[1m-lt\u001b[0m: sort by, and show, access time; with \u001b[1m-l\u001b[0m:\u001b[m\r\n              show access time and sort by name; otherwise: sort\u001b[m\r\n              by access time, newest first\u001b[m\r\n\u001b[m\r\n       \u001b[1m-U\u001b[0m     do not sort; list entries in directory order\u001b[m\r\n\u001b[m\r\n       \u001b[1m-v\u001b[0m     natural sort of (version) numbers within text\u001b[m\r\n\u001b[m\r\n       \u001b[1m-w\u001b[0m, \u001b[1m--width\u001b[0m=\u001b[4mCOLS\u001b[24m\u001b[m\r\n              set output width to COLS.  0 means no limit\u001b[m\r\n\u001b[7mnual page ls(1) line 172/263 73% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1115.740326, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m--time-style\u001b[0m=\u001b[4mTIME_STYLE\u001b[24m\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 171/263 72% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1115.78927, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 170/263 72% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1115.846966, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              \u001b[1m--sort\u001b[0m=\u001b[4mtime\u001b[24m, sort by WORD (newest first)\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 169/263 71% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1115.987992, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              with \u001b[1m-l\u001b[0m, WORD determines which time to show;  with\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mnual page ls(1) line 168/263 71% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1117.144912, "o", "\r\u001b[K/\r\u001b[K       \u001b[1m-v\u001b[0m     natural sort of (version) numbers within text\u001b[m\r\n\u001b[m\r\n       \u001b[1m-w\u001b[0m, \u001b[1m--width\u001b[0m=\u001b[4mCOLS\u001b[24m\u001b[m\r\n              set output width to COLS.  0 means no limit\u001b[m\r\n\u001b[7mnual page ls(1) line 172/263 73% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1117.317023, "o", "\r\u001b[K/\r\u001b[K"]
[1117.317143, "o", "...skipping...\r\n              output version in\u001b[7mformat\u001b[27mion and exit\u001b[m\r\n\u001b[m\r\n       The  SIZE argument is an integer and optional unit (exam‐\u001b[m\r\n       ple: 10K is 10*1024).  Units are K,M,G,T,P,E,Z,Y  (powers\u001b[m\r\n       of  1024) or KB,MB,... (powers of 1000).  Binary prefixes\u001b[m\r\n       can be used, too: KiB=K, MiB=M, and so on.\u001b[m\r\n\u001b[m\r\n       The TIME_STYLE argument can be full-iso,  long-iso,  iso,\u001b[m\r\n       locale,  or  +\u001b[7mFORMAT\u001b[27m.   \u001b[7mFORMAT\u001b[27m  is  interpreted  like  in\u001b[m\r\n       \u001b[1mdate\u001b[0m(1).  If \u001b[7mFORMAT\u001b[27m is \u001b[7mFORMAT\u001b[27m1<newline>\u001b[7mFORMAT\u001b[27m2, then FOR‐\u001b[m\r\n       MAT1  applies  to  non-recent files and \u001b[7mFORMAT\u001b[27m2 to recent\u001b[m\r\n       files.  TIME_STYLE prefixed with  'posix-'  takes  effect\u001b[m\r\n       only outside the POSIX locale.  Also the TIME_STYLE envi‐\u001b[m\r\n       ronment variable sets the default style to use.\u001b[m\r\n\u001b[m\r\n       The WHEN argument defaults to 'always' and  can  also  be\u001b[m\r\n       'auto' or 'never'.\u001b[m\r\n\u001b[7mnual page ls(1) line 204/"]
[1117.317154, "o", "263 85% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1122.440793, "o", "\r\u001b[K/\r\u001b[K"]
[1122.440818, "o", "\u001b[m\r\n       Using color to distinguish file types is disabled both by\u001b[m\r\n       default and with \u001b[1m--color\u001b[0m=\u001b[4mnever\u001b[24m.   With  \u001b[1m--color\u001b[0m=\u001b[4mauto\u001b[24m,  ls\u001b[m\r\n       emits  color codes only when standard output is connected\u001b[m\r\n       to a terminal.  The LS_COLORS  environment  variable  can\u001b[m\r\n       change the settings.  Use the \u001b[1mdircolors\u001b[0m(1) command to set\u001b[m\r\n       it.\u001b[m\r\n\u001b[m\r\n\u001b[7mnual page ls(1) line 212/263 89% (press h for help or q to quit)\u001b[27m\u001b[K"]
