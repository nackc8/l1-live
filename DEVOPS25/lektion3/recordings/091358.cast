[4139.362129, "o", "\u001b[1;1H\u001b[m\r\n\u001b[2;1H       \u001b[1m-P\u001b[0m, \u001b[1m--prefix\u001b[0m \u001b[4mPREFIX_DIR\u001b[24m\u001b[m\r\n\u001b[3;1H           Apply changes in the \u001b[4mPREFIX_DIR\u001b[24m directory and use the\u001b[m\r\n\u001b[4;1H           configuration files from the \u001b[4mPREFIX_DIR\u001b[24m directory.\u001b[m\r\n\u001b[5;1H           This option does not chroot and is intended for\u001b[m\r\n\u001b[6;1H           preparing a cross-compilation target. Some\u001b[m\r\n\u001b[7;1H           limitations: NIS and LDAP users/groups are not\u001b[m\r\n\u001b[8;1H           verified. PAM authentication is using the host files.\u001b[m\r\n\u001b[9;1H           No SELINUX support.\u001b[m\r\n\u001b[10;1H\u001b[m\r\n\u001b[11;1H       \u001b[1m-Z\u001b[0m, \u001b[1m--selinux-user\u001b[0m\u001b[m\r\n\u001b[12;1H           Remove any SELinux user mapping for the user's login.\u001b[m\r\n\u001b[13;1H\u001b[m\r\n\u001b[14;1H\u001b[1mCONFIGURATION\u001b[0m\u001b[m\r\n\u001b[15;1H       The following configuration variables in /etc/login.defs\u001b[m\r\n\u001b[16;1H       change the behavior of this tool:\u001b[m\r\n\u001b[17;1H\u001b[m\r\n\u001b[18;1H\u001b[1;1H\u001b[m\r\n\u001b[2;1H       \u001b[1m-P\u001b[0m, \u001b[1m--prefix\u001b[0m \u001b[4mPREFIX_DIR\u001b[24m\u001b[m\r\n\u001b[3;1H           Apply changes in the \u001b[4mPREFIX_DIR\u001b[24"]
[4139.362246, "o", "m directory and us"]
[4139.362327, "o", "e the\u001b[m\r\n\u001b[4;1H           configuration files from the \u001b[4mPREFIX_DIR\u001b[24m directory.\u001b[m\r\n\u001b[5;1H           This option does not chroot and is intended for\u001b[m\r\n\u001b[6;1H           preparing a cross-compilation target. Some\u001b[m\r\n\u001b[7;1H           limitations: NIS and LDAP users/groups are not\u001b[m\r\n\u001b[8;1H           verified. PAM authentication is using the host files.\u001b[m\r\n\u001b[9;1H           No SELINUX support.\u001b[m\r\n\u001b[10;1H\u001b[m\r\n\u001b[11;1H       \u001b[1m-Z\u001b[0m, \u001b[1m--selinux-user\u001b[0m\u001b[m\r\n\u001b[12;1H           Remove any SELinux user mapping for the user's login.\u001b[m\r\n\u001b[13;1H\u001b[m\r\n\u001b[14;1H\u001b[1mCONFIGURATION\u001b[0m\u001b[m\r\n\u001b[15;1H       The following configuration variables in /etc/login.defs\u001b[m\r\n\u001b[16;1H       change the behavior of this tool:\u001b[m\r\n\u001b[17;1H\u001b[m\r\n\u001b[18;1H...skipping...\r\n           relatively to their \u001b[7mhome\u001b[27m directory.\u001b[m\r\n\u001b[m\r\n       The \u001b[1mMAIL_DIR\u001b[0m and \u001b[1mMAIL_FILE\u001b[0m variables are used by \u001b[1museradd\u001b[0m,\u001b[m\r\n       \u001b[1musermod\u001b[0m, and \u001b[1muserdel\u001b[0m to create, move, or delete the\u001b[m\r\n       user's mail spool.\u001b[m\r\n\u001b"]
[4139.362378, "o", "[m\r\n       \u001b[1mMAX_MEMBERS_PER_GROUP\u001b[0m (number)\u001b[m\r\n           Maximum members per group entry. When the maximum is\u001b[m\r\n           reached, a new group entry (line) is started in\u001b[m\r\n           /etc/group (with the same name, same password, and\u001b[m\r\n           same GID).\u001b[m\r\n\u001b[m\r\n           The default value is 0, meaning that there are no\u001b[m\r\n           limits in the number of members in a group.\u001b[m\r\n\u001b[m\r\n           This feature (split group) permits to limit the\u001b[m\r\n           length of lines in the group file. This is useful to\u001b[m\r\n\u001b[7m page userdel(8) line 79/224 49% (press h for help or q to quit)\u001b[27m\u001b[K"]
[4140.104239, "o", "\r\u001b[K/\r\u001b[K"]
[4140.104429, "o", "...skipping...\r\n           can't remove \u001b[7mhome\u001b[27m directory\u001b[m\r\n\u001b[m\r\n\u001b[1mCAVEATS\u001b[0m\u001b[m\r\n       \u001b[1muserdel\u001b[0m will not allow you to remove an account if there\u001b[m\r\n       are running processes which belong to this account. In\u001b[m\r\n       that case, you may have to kill those processes or lock\u001b[m\r\n       the user's password or account and remove the account\u001b[m\r\n       later. The \u001b[1m-f\u001b[0m option can force the deletion of this\u001b[m\r\n       account.\u001b[m\r\n\u001b[m\r\n       You should manually check all file systems to ensure that\u001b[m\r\n       no files remain owned by this user.\u001b[m\r\n\u001b[m\r\n       You may not remove any NIS attributes on a NIS client.\u001b[m\r\n       This must be performed on the NIS server.\u001b[m\r\n\u001b[m\r\n       If \u001b[1mUSERGROUPS_ENAB\u001b[0m is defined to \u001b[4myes\u001b[24m in /etc/login.defs,\u001b[m\r\n\u001b[7mpage userdel(8) line 195/224 91% (press h for help or q to quit)\u001b[27m\u001b[K"]
[4141.581086, "o", "\r\u001b[K/\r\u001b[K"]
[4141.581121, "o", "\r\u001b[K\u001b[7mPattern not found  (press RETURN)\u001b[27m"]
