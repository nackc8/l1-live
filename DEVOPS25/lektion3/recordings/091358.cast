[1080.768434, "o", "...skipping...\r\n              gle-\u001b[7mcolumn\u001b[27m \u001b[1m-1\u001b[0m, verbose \u001b[1m-l\u001b[0m, vertical \u001b[1m-C\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1m--full-time\u001b[0m\u001b[m\r\n              like \u001b[1m-l\u001b[0m \u001b[1m--time-style\u001b[0m=\u001b[4mfull-iso\u001b[24m\u001b[m\r\n\u001b[m\r\n       \u001b[1m-g\u001b[0m     like \u001b[1m-l\u001b[0m, but do not list owner\u001b[m\r\n\u001b[m\r\n       \u001b[1m--group-directories-first\u001b[0m\u001b[m\r\n              group  directories  before files; can be augmented\u001b[m\r\n              with a \u001b[1m--sort\u001b[0m option, but any use  of  \u001b[1m--sort\u001b[0m=\u001b[4mnone\u001b[24m\u001b[m\r\n              (\u001b[1m-U\u001b[0m) disables grouping\u001b[m\r\n\u001b[m\r\n       \u001b[1m-G\u001b[0m, \u001b[1m--no-group\u001b[0m\u001b[m\r\n              in a long listing, don't print group names\u001b[m\r\n\u001b[m\r\n       \u001b[1m-h\u001b[0m, \u001b[1m--human-readable\u001b[0m\u001b[m\r\n              with \u001b[1m-l\u001b[0m and \u001b[1m-s\u001b[0m, print sizes like 1K 234M 2G etc.\u001b[m\r\n\u001b[7m Manual page ls(1) line 62 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1081.661432, "o", "\r\u001b[K/\r\u001b[K"]
[1081.661853, "o", "...skipping...\r\n       \u001b[1m-x\u001b[0m     list entries by lines instead of by \u001b[7mcolumn\u001b[27ms\u001b[m\r\n\u001b[m\r\n       \u001b[1m-X\u001b[0m     sort alphabetically by entry extension\u001b[m\r\n\u001b[m\r\n       \u001b[1m-Z\u001b[0m, \u001b[1m--context\u001b[0m\u001b[m\r\n              print any security context of each file\u001b[m\r\n\u001b[m\r\n       \u001b[1m--zero\u001b[0m end each output line with NUL, not newline\u001b[m\r\n\u001b[m\r\n       \u001b[1m-1\u001b[0m     list one file per line\u001b[m\r\n\u001b[m\r\n       \u001b[1m--help\u001b[0m display this help and exit\u001b[m\r\n\u001b[m\r\n       \u001b[1m--version\u001b[0m\u001b[m\r\n              output version information and exit\u001b[m\r\n\u001b[m\r\n       The  SIZE argument is an integer and optional unit (exam‐\u001b[m\r\n\u001b[7mnual page ls(1) line 190/263 78% (press h for help or q to quit)\u001b[27m\u001b[K"]
