[4144.628265, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           Run-part files to execute during user deletion. The\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mpage userdel(8) line 160/224 80% (press h for help or q to quit)\u001b[27m\u001b[K"]
[4144.659698, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       /etc/shadow-maint/userdel-post.d/*\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mpage userdel(8) line 159/224 80% (press h for help or q to quit)\u001b[27m\u001b[K"]
[4145.985381, "o", "\r\u001b[K"]
[4145.985467, "o", "\u001b[H\u001b[2J\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       The named user must exist.\u001b[m\r\n\u001b[H\u001bM       deleting all entries that refer to the user name \u001b[4mLOGIN\u001b[24m.\u001b[m\r\n\u001b[H\u001bM       The \u001b[1muserdel\u001b[0m command modifies the system account files,\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       instead.\u001b[m\r\n\u001b[H\u001bM       Debian, administrators should usually use \u001b[1mdeluser\u001b[0m(8)\u001b[m\r\n\u001b[H\u001bM       \u001b[1muserdel\u001b[0m is a low level utility for removing users. On\u001b[m\r\n"]
[4145.985472, "o", "\u001b[H\u001bM\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       \u001b[1muserdel\u001b[0m [options] \u001b[4mLOGIN\u001b[24m\u001b[m\r\n\u001b[H\u001bM\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       userdel - delete a user account and related files\u001b[m\r\n\u001b[H\u001bM\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bMUSERDEL(8)         System Management Commands         USERDEL(8)\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page userdel(8) line 1/224 7% (press h for help or q to quit)\u001b[27m\u001b[K"]
[4146.52577, "o", "\r\u001b[K/"]
[4146.84719, "o", "\u001b[Kh\bh"]
[4147.035451, "o", "\u001b[Ko\bo"]
[4147.102292, "o", "\u001b[Km\bm"]
[4147.162289, "o", "\u001b[Ke\be"]
[4147.305208, "o", "\r\u001b[K"]
[4147.305423, "o", "\u001b[1;1HUSERDEL(8)         System Management Commands         USERDEL(8)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       userdel - delete a user account and related files\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1muserdel\u001b[0m [options] \u001b[4mLOGIN\u001b[24m\u001b[m\r\n\u001b[8;1H\u001b[m\r\n\u001b[9;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[10;1H       \u001b[1muserdel\u001b[0m is a low level utility for removing users. On\u001b[m\r\n\u001b[11;1H       Debian, administrators should usually use \u001b[1mdeluser\u001b[0m(8)\u001b[m\r\n\u001b[12;1H       instead.\u001b[m\r\n\u001b[13;1H\u001b[m\r\n\u001b[14;1H       The \u001b[1muserdel\u001b[0m command modifies the system account files,\u001b[m\r\n\u001b[15;1H       deleting all entries that refer to the user name \u001b[4mLOGIN\u001b[24m.\u001b[m\r\n\u001b[16;1H       The named user must exist.\u001b[m\r\n\u001b[17;1H\u001b[m\r\n\u001b[18;1H\u001b[1;1HUSERDEL(8)         System Management Commands         USERDEL(8)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       userdel - delete a user account and related files\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1muserdel\u001b[0m [options] \u001b[4mLOGIN\u001b[24m\u001b[m\r\n\u001b[8;1H\u001b[m\r\n\u001b["]
[4147.305435, "o", "9;1H\u001b[1mDESCRIPTION\u001b[0m\u001b"]
[4147.305578, "o", "[m\r\n\u001b[10;1H       \u001b[1muserdel\u001b[0m is a low level utility for removing users. On\u001b[m\r\n\u001b[11;1H       Debian, administrators should usually use \u001b[1mdeluser\u001b[0m(8)\u001b[m\r\n\u001b[12;1H       instead.\u001b[m\r\n\u001b[13;1H\u001b[m\r\n\u001b[14;1H       The \u001b[1muserdel\u001b[0m command modifies the system account files,\u001b[m\r\n\u001b[15;1H       deleting all entries that refer to the user name \u001b[4mLOGIN\u001b[24m.\u001b[m\r\n\u001b[16;1H       The named user must exist.\u001b[m\r\n\u001b[17;1H\u001b[m\r\n\u001b[18;1H...skipping...\r\n           \u001b[1muserdel\u001b[0m to remove the user's \u001b[7mhome\u001b[27m directory and mail\u001b[m\r\n           spool, even if another user uses the same \u001b[7mhome\u001b[27m\u001b[m\r\n           directory or if the mail spool is not owned by the\u001b[m\r\n           specified user. If \u001b[1mUSERGROUPS_ENAB\u001b[0m is defined to \u001b[4myes\u001b[24m\u001b[m\r\n           in /etc/login.defs and if a group exists with the\u001b[m\r\n           same name as the deleted user, then this group will\u001b[m\r\n           be removed, even if it is still the primary group of\u001b[m\r\n           another user.\u001b[m\r\n\u001b[m\r\n           \u001b[4mNote:\u001b[24m This option"]
[4147.305585, "o", " is dangerous and "]
[4147.305588, "o", "may leave your\u001b[m\r\n           system in an inconsistent state.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-h\u001b[0m, \u001b[1m--help\u001b[0m\u001b[m\r\n           Display help message and exit.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-r\u001b[0m, \u001b[1m--remove\u001b[0m\u001b[m\r\n           Files in the user's \u001b[7mhome\u001b[27m directory will be removed\u001b[m\r\n\u001b[7m page userdel(8) line 24/224 19% (press h for help or q to quit)\u001b[27m\u001b[K"]
[4148.445291, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           even if the user is still logged in. It also forces\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7m page userdel(8) line 23/224 18% (press h for help or q to quit)\u001b[27m\u001b[K"]
[4148.617415, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           This option forces the removal of the user account,\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7m page userdel(8) line 22/224 18% (press h for help or q to quit)\u001b[27m\u001b[K"]
[4148.759851, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m-f\u001b[0m, \u001b[1m--force\u001b[0m\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7m page userdel(8) line 21/224 18% (press h for help or q to quit)\u001b[27m\u001b[K"]
[4148.88017, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7m page userdel(8) line 20/224 17% (press h for help or q to quit)\u001b[27m\u001b[K"]
