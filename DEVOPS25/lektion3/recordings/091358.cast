[4144.565281, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1muserdel\u001b[0m and \u001b[1mSUBJECT\u001b[0m with the username.  userdel-pre.d\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mpage userdel(8) line 162/224 80% (press h for help or q to quit)\u001b[27m\u001b[K"]
