[727.610583, "o", "\u001b[?1049h\u001b[22;0;0t\u001b[?1h\u001b=\r"]
[727.622323, "o", "\u001b[4mUSERMOD\u001b[24m(8)         System Management Commands         \u001b[4mUSERMOD\u001b[24m(8)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       usermod - modify a user account\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1musermod \u001b[22m[\u001b[4moptions\u001b[24m] \u001b[4mLOGIN\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       The \u001b[1musermod \u001b[22mcommand modifies the system account files.\u001b[m\r\n\u001b[m\r\n\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n       The options which apply to the \u001b[1musermod \u001b[22mcommand are:\u001b[m\r\n\u001b[m\r\n       \u001b[1m-a\u001b[22m, \u001b[1m--append\u001b[0m\u001b[m\r\n           Add the user to the supplementary group(s). Use only\u001b[m\r\n\u001b[7m Manual page usermod(8) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[735.372259, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           with the \u001b[1m-G \u001b[22moption.\u001b[m"]
[735.372452, "o", "\r\n\u001b[7m Manual page usermod(8) line 2 (press h for help or q to quit)\u001b[27m\u001b[K"]
[735.517514, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 3 (press h for help or q to quit)\u001b[27m\u001b[K"]
[735.611309, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-b\u001b[22m, \u001b[1m--badname\u001b[0m\u001b[m\r\n\u001b[7m Manual page usermod(8) line 4 (press h for help or q to quit)\u001b[27m\u001b[K"]
[735.941602, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Allow names that do not conform to standards.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 5 (press h for help or q to quit)\u001b[27m\u001b[K"]
[735.985091, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 6 (press h for help or q to quit)\u001b[27m\u001b[K"]
[736.021134, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-c\u001b[22m, \u001b[1m--comment \u001b[4m\u001b[22mCOMMENT\u001b[0m\u001b[m\r\n\u001b[7m Manual page usermod(8) line 7 (press h for help or q to quit)\u001b[27m\u001b[K"]
[736.054515, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           update the comment field of the user in /etc/passwd,\u001b[m\r\n\u001b[7m Manual page usermod(8) line 8 (press h for help or q to quit)\u001b[27m\u001b[K"]
[736.087796, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           which is normally modified using the \u001b[1mchfn\u001b[22m(1) utility.\u001b[m"]
[736.087901, "o", "\r\n\u001b[7m Manual page usermod(8) line 9 (press h for help or q to quit)\u001b[27m\u001b[K"]
[736.120763, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 10 (press h for help or q to quit)\u001b[27m\u001b[K"]
[736.154062, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-d\u001b[22m, \u001b[1m--home \u001b[4m\u001b[22mHOME_DIR\u001b[0m\u001b[m"]
[736.154295, "o", "\r\n\u001b[7m Manual page usermod(8) line 11 (press h for help or q to quit)\u001b[27m\u001b[K"]
[736.188339, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The user's new login directory.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 12 (press h for help or q to quit)\u001b[27m\u001b[K"]
[736.220742, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 13 (press h for help or q to quit)\u001b[27m\u001b[K"]
[736.254269, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If the \u001b[1m-m \u001b[22moption is given, the contents of the\u001b[m\r\n\u001b[7m Manual page usermod(8) line 14 (press h for help or q to quit)\u001b[27m\u001b[K"]
[736.287822, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           current home directory will be moved to the new home\u001b[m\r\n\u001b[7m Manual page usermod(8) line 15 (press h for help or q to quit)\u001b[27m\u001b[K"]
[736.33106, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           directory, which is created if it does not already\u001b[m\r\n\u001b[7m Manual page usermod(8) line 16 (press h for help or q to quit)\u001b[27m\u001b[K"]
[736.388231, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           exist. If the current home directory does not exist\u001b[m\r\n\u001b[7m Manual page usermod(8) line 17 (press h for help or q to quit)\u001b[27m\u001b[K"]
[737.0093, "o", "\r\u001b[K           the new home directory will not be created.\u001b[m"]
[737.009372, "o", "\r\n\u001b[m\r\n       \u001b[1m-e\u001b[22m, \u001b[1m--expiredate \u001b[4m\u001b[22mEXPIRE_DATE\u001b[0m\u001b[m\r\n           The date on which the user account will be disabled.\u001b[m\r\n           The date is specified in the format \u001b[4mYYYY-MM-DD\u001b[24m.\u001b[m\r\n           Integers as input are interpreted as days after\u001b[m\r\n           1970-01-01.\u001b[m\r\n\u001b[m\r\n           An input of -1 or an empty string will blank the\u001b[m\r\n           account expiration field in the shadow password file.\u001b[m\r\n           The account will remain available with no date limit.\u001b[m\r\n\u001b[m\r\n           This option requires a /etc/shadow file. A\u001b[m\r\n           /etc/shadow entry will be created if there were none.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-f\u001b[22m, \u001b[1m--inactive \u001b[4m\u001b[22mINACTIVE\u001b[0m\u001b[m\r\n           defines the number of days after the password\u001b[m\r\n\u001b[7m Manual page usermod(8) line 34 (press h for help or q to quit)\u001b[27m\u001b[K"]
[737.90209, "o", "\r\u001b[K           exceeded its maximum age during which the user may\u001b[m\r\n           still login by immediately replacing the password.\u001b[m\r\n           This grace period before the account becomes inactive\u001b[m\r\n           is stored in the shadow password file. An input of 0\u001b[m\r\n           will disable an expired password with no delay. An\u001b[m\r\n           input of -1 will blank the respective field in the\u001b[m\r\n           shadow password file. See \u001b[1mshadow\u001b[22m(5) for more\u001b[m\r\n           information.\u001b[m\r\n\u001b[m\r\n           This option requires a /etc/shadow file. A\u001b[m\r\n           /etc/shadow entry will be created if there were none.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-g\u001b[22m, \u001b[1m--gid \u001b[4m\u001b[22mGROUP\u001b[0m\u001b[m\r\n           The name or numerical ID of the user's new primary\u001b[m\r\n           group. The group must exist.\u001b[m\r\n\u001b[m\r\n           Any file from the user's home directory owned by the\u001b[m\r\n\u001b[7m Manual page usermod(8) line 51 (press h for help or q to quit)\u001b[27m\u001b[K"]
[738.658529, "o", "\r\u001b[K           previous primary group of the user will be owned by\u001b[m\r\n           this new group.\u001b[m\r\n\u001b[m\r\n           The group ownership of files outside of the user's\u001b[m\r\n           home directory must be fixed manually.\u001b[m\r\n\u001b[m\r\n           The change of the group ownership of files inside of\u001b[m\r\n           the user's home directory is also not done if the\u001b[m\r\n           home dir owner uid is different from the current or\u001b[m\r\n           new user id. This is a safety measure for special\u001b[m\r\n           home directories such as /.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-G\u001b[22m, \u001b[1m--groups \u001b[4m\u001b[22mGROUP1\u001b[24m[\u001b[4m,GROUP2,...\u001b[24m[\u001b[4m,GROUPN\u001b[24m]]]\u001b[m\r\n           A list of supplementary groups which the user is also\u001b[m\r\n           a member of. Each group is separated from the next by\u001b[m\r\n           a comma, with no intervening whitespace. The groups\u001b[m\r\n           must exist.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 68 (press h for help or q to quit)\u001b[27m\u001b[K"]
[741.119202, "o", "\r\u001b[K\u001b[m"]
[741.11931, "o", "\r\n           If the user is currently a member of a group which is\u001b[m\r\n           not listed, the user will be removed from the group.\u001b[m\r\n           This behaviour can be changed via the \u001b[1m-a \u001b[22moption,\u001b[m\r\n           which appends the user to the current supplementary\u001b[m\r\n           group list.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-l\u001b[22m, \u001b[1m--login \u001b[4m\u001b[22mNEW_LOGIN\u001b[0m\u001b[m\r\n           The name of the user will be changed from \u001b[4mLOGIN\u001b[24m to\u001b[m\r\n           \u001b[4mNEW_LOGIN\u001b[24m. Nothing else is changed. In particular,\u001b[m\r\n           the user's home directory or mail spool should\u001b[m\r\n           probably be renamed manually to reflect the new login\u001b[m\r\n           name.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-L\u001b[22m, \u001b[1m--lock\u001b[0m\u001b[m\r\n           Lock a user's password. This puts a '!' in front of\u001b[m\r\n           the encrypted password, effectively disabling the\u001b[m\r\n\u001b[7m Manual page usermod(8) line 85 (press h for help or q to quit)\u001b[27m\u001b[K"]
[746.824344, "o", "\r\u001b[K           password. You can't use this option with \u001b[1m-p \u001b[22mor \u001b[1m-U\u001b[22m.\u001b[m\r\n\u001b[m\r\n           Note: if you wish to lock the account (not only\u001b[m\r\n           access with a password), you should also set the\u001b[m\r\n           \u001b[4mEXPIRE_DATE\u001b[24m to \u001b[4m1\u001b[24m.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-m\u001b[22m, \u001b[1m--move-home\u001b[0m\u001b[m\r\n           moves the content of the user's home directory to the\u001b[m\r\n           new location. If the current home directory does not\u001b[m\r\n           exist the new home directory will not be created.\u001b[m\r\n\u001b[m\r\n           This option is only valid in combination with the \u001b[1m-d\u001b[0m\u001b[m\r\n           (or \u001b[1m--home\u001b[22m) option.\u001b[m\r\n\u001b[m\r\n           \u001b[1musermod \u001b[22mwill try to adapt the ownership of the files\u001b[m\r\n           and to copy the modes, ACL and extended attributes,\u001b[m\r\n           but manual changes might be needed afterwards.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 102 (press h for help or q to quit)\u001b[27m\u001b[K"]
[747.4491, "o", "\r\u001b[K\u001b[m\r\n       \u001b[1m-o\u001b[22m, \u001b[1m--non-unique\u001b[0m\u001b[m\r\n           allows to change the user ID to a non-unique value.\u001b[m\r\n\u001b[m\r\n           This option is only valid in combination with the \u001b[1m-u\u001b[0m\u001b[m\r\n           option. As a user identity serves as key to map\u001b[m\r\n           between users on one hand and permissions, file\u001b[m\r\n           ownerships and other aspects that determine the\u001b[m\r\n           system's behavior on the other hand, more than one\u001b[m\r\n           login name will access the account of the given UID.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-p\u001b[22m, \u001b[1m--password \u001b[4m\u001b[22mPASSWORD\u001b[0m\u001b[m\r\n           defines a new password for the user. PASSWORD is\u001b[m\r\n           expected to be encrypted, as returned by \u001b[1mcrypt \u001b[22m(3).\u001b[m\r\n\u001b[m\r\n           \u001b[1mNote: \u001b[22mAvoid this option on the command line because\u001b[m\r\n           the password (or encrypted password) will be visible\u001b[m\r\n\u001b[7m Manual page usermod(8) line 119 (press h for help or q to quit)\u001b[27m\u001b[K"]
[748.229658, "o", "\r\u001b[K/"]
[748.687168, "o", "\u001b[KL\bL"]
[748.964081, "o", "\u001b[KO\bO"]
[749.083429, "o", "\u001b[KG\bG"]
[749.227076, "o", "\u001b[KI\bI"]
[749.301339, "o", "\u001b[KN\bN"]
[749.669883, "o", "\r\u001b[K\u001b[1;1H\u001b[m\r\n\u001b[2;1H       \u001b[1m-o\u001b[22m, \u001b[1m--non-unique\u001b[0m\u001b[m\r\n\u001b[3;1H           allows to change the user ID to a non-unique value.\u001b[m\r\n\u001b[4;1H\u001b[m\r\n\u001b[5;1H           This option is only valid in combination with the \u001b[1m-u\u001b[0m\u001b[m\r\n\u001b[6;1H           option. As a user identity serves as key to map\u001b[m\r\n\u001b[7;1H           between users on one hand and permissions, file\u001b[m\r\n\u001b[8;1H           ownerships and other aspects that determine the\u001b[m\r\n\u001b[9;1H           system's behavior on the other hand, more than one\u001b[m\r\n\u001b[10;1H           login name will access the account of the given UID.\u001b[m\r\n\u001b[11;1H\u001b[m\r\n\u001b[12;1H       \u001b[1m-p\u001b[22m, \u001b[1m--password \u001b[4m\u001b[22mPASSWORD\u001b[0m\u001b[m\r\n\u001b[13;1H           defines a new password for the user. PASSWORD is\u001b[m\r\n\u001b[14;1H           expected to be encrypted, as returned by \u001b[1mcrypt \u001b[22m(3).\u001b[m\r\n\u001b[15;1H\u001b[m\r\n\u001b[16;1H           \u001b[1mNote: \u001b[22mAvoid this option on the command line because\u001b[m\r\n\u001b[17;1H           the password (or encrypted password) will be visible\u001b[m\r\n\u001b[18;1H\u001b[1;1H\u001b[m\r\n\u001b[2;1H       \u001b[1"]
[749.669909, "o", "m-o\u001b[22m, \u001b[1m--non-unique\u001b[0m\u001b[m\r\n\u001b[3;1H           allows to change the user ID to a non-unique value.\u001b[m\r\n\u001b[4;1H\u001b[m\r\n\u001b[5;1H           This option is only valid in combination with the \u001b[1m-u\u001b[0m\u001b[m\r\n\u001b[6;1H           option. As a user identity serves as key to map\u001b[m\r\n\u001b[7;1H           between users on one hand and permissions, file\u001b[m\r\n\u001b[8;1H           ownerships and other aspects that determine the\u001b[m\r\n\u001b[9;1H           system's behavior on the other hand, more than one\u001b[m\r\n\u001b[10;1H           login name will access the account of the given UID.\u001b[m\r\n\u001b[11;1H\u001b[m\r\n\u001b[12;1H       \u001b[1m-p\u001b[22m, \u001b[1m--password \u001b[4m\u001b[22mPASSWORD\u001b[0m\u001b[m\r\n\u001b[13;1H           defines a new password for the user. PASSWORD is\u001b[m\r\n\u001b[14;1H           expected to be encrypted, as returned by \u001b[1mcrypt \u001b[22m(3).\u001b[m\r\n\u001b[15;1H\u001b[m\r\n\u001b[16;1H           \u001b[1mNote: \u001b[22mAvoid this option on the command line because\u001b[m\r\n\u001b[17;1H           the password (or encrypted password) will be visible\u001b[m\r\n\u001b[18;1H...skipping...\r\n           defines the SELinux user to be "]
[749.669919, "o", "mapped with \u001b[4m\u001b[7mLOGIN\u001b[27m\u001b[24m. An\u001b[m\r\n           empty string (\"\") will remove the respective entry\u001b[m\r\n           (if any). Note that the shadow system doesn't store\u001b[m\r\n           the selinux-user, it uses semanage(8) for that.\u001b[m\r\n\u001b[m\r\n\u001b[1mCAVEATS\u001b[0m\u001b[m\r\n       You must make certain that the named user is not\u001b[m\r\n       executing any processes when this command is being\u001b[m\r\n       executed if the user's numerical user ID, the user's\u001b[m\r\n       name, or the user's home directory is being changed.\u001b[m\r\n       \u001b[1musermod \u001b[22mchecks this on Linux. On other operating systems\u001b[m\r\n       it only uses utmp to check if the user is logged in.\u001b[m\r\n\u001b[m\r\n       You must change the owner of any \u001b[1mcrontab \u001b[22mfiles or \u001b[1mat \u001b[22mjobs\u001b[m\r\n       manually.\u001b[m\r\n\u001b[m\r\n       You must make any changes involving NIS on the NIS\u001b[m\r\n\u001b[7mpage usermod(8) line 253/374 74% (press h for help or q to quit)\u001b[27m\u001b[K"]
[751.813997, "o", "\r\u001b[K/\r\u001b[K\r\u001b[K\u001b[7mPattern not found  (press RETURN)\u001b[27m"]
[752.362176, "o", "\u001b[18;1H\u001b[K\r\u001b[K/\r\u001b[K"]
[752.362202, "o", "\r\u001b[K\u001b[7mPattern not found  (press RETURN)\u001b[27m"]
[752.908947, "o", "\u001b[18;1H\u001b[K\r\u001b[K"]
[752.909144, "o", "\u001b[H\u001b[2J\u001b[H\u001bM           Add the user to the supplementary group(s). Use only\u001b[m\r\n\u001b[H\u001bM       \u001b[1m-a\u001b[22m, \u001b[1m--append\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       The options which apply to the \u001b[1musermod \u001b[22mcommand are:\u001b[m\r\n\u001b[H\u001bM\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       The \u001b[1musermod \u001b[22mcommand modifies the system account files.\u001b[m\r\n\u001b[H\u001bM\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       \u001b[1musermod \u001b[22m[\u001b[4moptions\u001b[24m] \u001b[4m\u001b[7mLOGIN\u001b[27m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM       usermod - modify a user account\u001b[m\r\n\u001b[H\u001bM\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[H\u001bM\u001b[m\r\n\u001b[H\u001bM\u001b[4mUSERMOD\u001b[24m(8)         System Management Commands         \u001b[4mUSERMOD\u001b[24m(8)\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page usermod(8) line 1/374 3% (press h for help or q to quit)\u001b[27m\u001b[K"]
[753.494915, "o", "\r\u001b[K/"]
