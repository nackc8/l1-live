[913.046212, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --83%-----------\u001b[0m\u001b[1;1H‘--reference=REF_FILE’\u001b[2;1H     Change the mode of each FILE to be the same as that of REF_F\u001b[2;66H\\\u001b[3;1HILE.\u001b[K\u001b[4;1H     \u001b[4m*Note File permissions\u001b[24m::.  If REF_FILE is a symbolic link, d\u001b[K\u001b[4;66H\\\u001b[5;1H\u001b[K\u001b[5;1Ho not\u001b[6;1H     use the mode of the symbolic link, but rather that of the fi\u001b[6;66H\\\u001b[7;1Hle it\u001b[K\u001b[8;1H     refers to.\u001b[9;1H\u001b[K\u001b[10;1H‘-R’\u001b[11;3H-recursive’\u001b[12;1H     Recursively change permissions of directories and their cont\u001b[12;66H\\\u001b[13;1Hents.\u001b[K\u001b[14;1H\u001b[K\u001b[15;1H   An exit status of zero indicates success, and a nonzero value\u001b[16;1Hindicates failure.\u001b[K\u001b[16;1H\u001b[2;66H\\\u001b[4;66H\\\u001b[6;66H\\\u001b[12;66H\\\u001b[16;1H"]
[913.077937, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --84%-----------\u001b[0m\u001b[1;1H     Change the mode of each FILE to be the same as that of REF_F\u001b[1;66H\\\u001b[2;1HILE.\u001b[K\u001b[3;1H     \u001b[4m*Note File permissions\u001b[24m::.  If REF_FILE is a symbolic link, d\u001b[K\u001b[3;66H\\\u001b[4;1H\u001b[K\u001b[4;1Ho not\u001b[5;1H     use the mode of the symbolic link, but rather that of the fi\u001b[5;66H\\\u001b[6;1Hle it\u001b[K\u001b[7;1H     refers to.\u001b[8;1H\u001b[K\u001b[9;1H‘-R’\u001b[10;3H-recursive’\u001b[11;1H     Recursively change permissions of directories and their cont\u001b[11;66H\\\u001b[12;1Hents.\u001b[K\u001b[13;1H\u001b[K\u001b[14;1H   An exit status of zero indicates success, and a nonzero value\u001b[15;1Hindicates failure.\u001b[K\u001b[16;1H\u001b[K\u001b[16;1H\u001b[1;66H\\\u001b[3;66H\\\u001b[5;66H\\\u001b[11;66H\\\u001b[16;1H"]
[913.10867, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --85%-----------\u001b[0m\u001b[1;1HILE.\u001b[K\u001b[2;1H     \u001b[4m*Note File permissions\u001b[24m::.  If REF_FILE is a symbolic link, d\u001b[K\u001b[2;66H\\\u001b[3;1H\u001b[K\u001b[3;1Ho not\u001b[4;1H     use the mode of the symbolic link, but rather that of the fi\u001b[4;66H\\\u001b[5;1Hle it\u001b[K\u001b[6;1H     refers to.\u001b[7;1H\u001b[K\u001b[8;1H‘-R’"]
[913.108849, "o", "\u001b[9;3H-recursive’\u001b[10;1H     Recursively change permissions of directories and their cont\u001b[10;66H\\\u001b[11;1Hents.\u001b[K\u001b[12;1H\u001b[K\u001b[13;1H   An exit status of zero indicates success, and a nonzero value\u001b[14;1Hindicates failure.\u001b[K\u001b[15;1H\u001b[K\u001b[16;1H   Examples:\u001b[16;1H\u001b[2;66H\\\u001b[4;66H\\\u001b[10;66H\\\u001b[16;1H"]
[913.139869, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --86%-----------\u001b[0m\u001b[1;1H     \u001b[4m*Note File permissions\u001b[24m::.  If REF_FILE is a symbolic link, d\u001b[K\u001b[1;66H\\\u001b[2;1H\u001b[K\u001b[2;1Ho not\u001b[3;1H     use the mode of the symbolic link, but rather that of the fi\u001b[3;66H\\\u001b[4;1Hle it\u001b[K\u001b[5;1H     refers to.\u001b[6;1H\u001b[K\u001b[7;1H‘-R’\u001b[8;3H-recursive’\u001b[9;1H     Recursively change permissions of directories and their cont\u001b[9;66H\\\u001b[10;1Hents.\u001b[K\u001b[11;1H\u001b[K\u001b[12;1H   An exit status of zero indicates success, and a nonzero value\u001b[13;1Hindicates failure.\u001b[K\u001b[14;1H\u001b[K\u001b[15;1H   Examples:\u001b[16;1H\u001b[K\u001b[16;1H\u001b[1;66H\\\u001b[3;66H\\\u001b[9;66H\\\u001b[16;1H"]
[913.171595, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --87%-----------\u001b[0m\u001b[1;1H\u001b[K\u001b[1;1Ho not\u001b[2;1H     use the mode of the symbolic link, but rather that of the fi\u001b[2;66H\\\u001b[3;1Hle it\u001b[K\u001b[4;1H     refers to.\u001b[5;1H\u001b[K\u001b[6;1H‘-R’\u001b[7;3H-recursive’\u001b[8;1H     Recursively change permissions of directories and their cont\u001b[8;66H\\\u001b[9;1Hents.\u001b[K\u001b[10;1H\u001b[K\u001b[11;1H   An exit status of zero indicates success, and a nonzero value\u001b[12;1Hindicates failure.\u001b[K\u001b[13;1H\u001b[K\u001b[14;1H   Examples:\u001b[15;1H\u001b[K\u001b[16;1H     # Change file permissions of FOO to be world readable\u001b[16;1H\u001b[2;66H\\\u001b[8;66H\\\u001b[16;1H"]
[913.20291, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --88%-----------\u001b[0m\u001b[1;1H     use the mode of the symbolic link, but rather that of the fi\u001b[1;66H\\\u001b[2;1Hle it\u001b[K\u001b[3;1H     refers to.\u001b[4;1H\u001b[K\u001b[5;1H‘-R’\u001b[6;3H-recursive’\u001b[7;1H     Recursively change permissions of directories and their cont\u001b[7;66H\\\u001b[8;1Hents.\u001b[K"]
[913.203094, "o", "\u001b[9;1H\u001b[K\u001b[10;1H   An exit status of zero indicates success, and a nonzero value\u001b[11;1Hindicates failure.\u001b[K\u001b[12;1H\u001b[K\u001b[13;1H   Examples:\u001b[14;1H\u001b[K\u001b[15;1H     # Change file permissions of FOO to be world readable\u001b[16;8Hand user writable, with no other permissions.\u001b[K\u001b[16;1H\u001b[1;66H\\\u001b[7;66H\\\u001b[16;1H"]
[913.234497, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --89%-----------\u001b[0m\u001b[1;1Hle it\u001b[K\u001b[2;1H     refers to.\u001b[3;1H\u001b[K\u001b[4;1H‘-R’\u001b[5;3H-recursive’\u001b[6;1H     Recursively change permissions of directories and their cont\u001b[6;66H\\\u001b[7;1Hents.\u001b[K\u001b[8;1H\u001b[K\u001b[9;1H   An exit status of zero indicates success, and a nonzero value\u001b[10;1Hindicates failure.\u001b[K\u001b[11;1H\u001b[K\u001b[12;1H   Examples:\u001b[13;1H\u001b[K\u001b[14;1H     # Change file permissions of FOO to be world readable\u001b[15;8Hand user writable, with no other permissions.\u001b[K\u001b[16;6Hchmod 644 foo\u001b[K\u001b[16;1H\u001b[6;66H\\\u001b[16;1H"]
[913.265479, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --90%-----------\u001b[0m\u001b[1;1H     refers to.\u001b[2;1H\u001b[K\u001b[3;1H‘-R’\u001b[4;3H-recursive’\u001b[5;1H     Recursively change permissions of directories and their cont\u001b[5;66H\\\u001b[6;1Hents.\u001b[K\u001b[7;1H\u001b[K\u001b[8;1H   An exit status of zero indicates success, and a nonzero value\u001b[9;1Hindicates failure.\u001b[K\u001b[10;1H\u001b[K\u001b[11;1H   Examples:\u001b[12;1H\u001b[K\u001b[13;1H     # Change file permissions of FOO to be world readable\u001b[14;8Hand user writable, with no other permissions.\u001b[K\u001b[15;6Hchmod 644 foo\u001b[K\u001b[16;12Ha=r,u+w foo\u001b[16;1H\u001b[5;66H\\\u001b[16;1H"]
[913.296931, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --91%-----------\u001b[0m\u001b[1;1H\u001b[K\u001b[2;1H‘-R’\u001b[3;3H-recursive’\u001b[4;1H     Recursively change permissions of directories and their cont\u001b[4;66H\\\u001b[5;1Hents.\u001b[K\u001b[6;1H\u001b[K\u001b[7;1H   An exit status of zero indicates success, and a nonzero value\u001b[8;1Hindicates failure.\u001b[K\u001b[9;1H\u001b[K\u001b[10;1H   Examples:\u001b[11;1H\u001b[K\u001b[12;1H     # Change file permissions of FOO to be world readable\u001b[13;8Hand user writable, with no other permissions.\u001b[K\u001b[14;6Hchmod 644 foo\u001b[K\u001b[15;12Ha=r,u+w foo\u001b[16;1H\u001b[K\u001b[16;1H\u001b[4;66H\\\u001b[16;1H"]
[913.327916, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --92%-----------\u001b[0m\u001b[1;1H‘-R’\u001b[2;3H-recursive’"]
[913.328001, "o", "\u001b[3;1H     Recursively change permissions of directories and their cont\u001b[3;66H\\\u001b[4;1Hents.\u001b[K\u001b[5;1H\u001b[K\u001b[6;1H   An exit status of zero indicates success, and a nonzero value\u001b[7;1Hindicates failure.\u001b[K\u001b[8;1H\u001b[K\u001b[9;1H   Examples:\u001b[10;1H\u001b[K"]
[913.328063, "o", "\u001b[11;1H     # Change file permissions of FOO to be world readable\u001b[12;8Hand user writable, with no other permissions.\u001b[K\u001b[13;6Hchmod 644 foo\u001b[K\u001b[14;12Ha=r,u+w foo\u001b[15;1H\u001b[K\u001b[16;1H     # Add user and group execute permissions to FOO.\u001b[16;1H\u001b[3;66H\\\u001b[16;1H"]
[913.359724, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --93%-----------\u001b[0m\u001b[1;3H-recursive’\u001b[2;1H     Recursively change permissions of directories and their cont\u001b[2;66H\\\u001b[3;1Hents.\u001b[K\u001b[4;1H\u001b[K\u001b[5;1H   An exit status of zero indicates success, and a nonzero value\u001b[6;1Hindicates failure.\u001b[K\u001b[7;1H\u001b[K\u001b[8;1H   Examples:\u001b[9;1H\u001b[K\u001b[10;1H     # Change file permissions of FOO to be world readable\u001b[11;8Hand user writable, with no other permissions.\u001b[K\u001b[12;6Hchmod 644 foo\u001b[K\u001b[13;12Ha=r,u+w foo"]
[913.359812, "o", "\u001b[14;1H\u001b[K\u001b[15;1H     # Add user and group execute permissions to FOO.\u001b[16;6Hchmod +110 file\u001b[K\u001b[16;1H\u001b[2;66H\\\u001b[16;1H"]
[913.39158, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --94%-----------\u001b[0m\u001b[1;1H     Recursively change permissions of directories and their cont\u001b[1;66H\\\u001b[2;1Hents.\u001b[K\u001b[3;1H\u001b[K\u001b[4;1H   An exit status of zero indicates success, and a nonzero value\u001b[5;1Hindicates failure.\u001b[K\u001b[6;1H\u001b[K\u001b[7;1H   Examples:\u001b[8;1H\u001b[K\u001b[9;1H     # Change file permissions of FOO to be world readable\u001b[10;8Hand user writable, with no other permissions.\u001b[K\u001b[11;6Hchmod 644 foo\u001b[K\u001b[12;12Ha=r,u+w foo"]
[913.391744, "o", "\u001b[13;1H\u001b[K\u001b[14;1H     # Add user and group execute permissions to FOO.\u001b[15;6Hchmod +110 file\u001b[K\u001b[16;12Hug+x file\u001b[16;1H\u001b[1;66H\\\u001b[16;1H"]
[913.422585, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --95%-----------\u001b[0m\u001b[1;1Hents.\u001b[K\u001b[2;1H\u001b[K\u001b[3;1H   An exit status of zero indicates success, and a nonzero value\u001b[4;1Hindicates failure.\u001b[K\u001b[5;1H\u001b[K\u001b[6;1H   Examples:\u001b[7;1H\u001b[K\u001b[8;1H     # Change file permissions of FOO to be world readable\u001b[9;8Hand user writable, with no other permissions.\u001b[K\u001b[10;6Hchmod 644 foo\u001b[K\u001b[11;12Ha=r,u+w foo\u001b[12;1H\u001b[K\u001b[13;1H     # Add user and group execute permissions to FOO.\u001b[14;6Hchmod +110 file\u001b[K\u001b[15;12Hug+x file\u001b[16;1H\u001b[K\u001b[16;1H\u001b[16;1H"]
[913.454039, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --96%-----------\u001b[0m\u001b[1;1H\u001b[K\u001b[2;1H   An exit status of zero indicates success, and a nonzero value\u001b[3;1Hindicates failure.\u001b[K\u001b[4;1H\u001b[K\u001b[5;1H   Examples:\u001b[6;1H\u001b[K\u001b[7;1H     # Change file permissions of FOO to be world readable\u001b[8;8Hand user writable, with no other permissions.\u001b[K\u001b[9;6Hchmod 644 foo\u001b[K\u001b[10;12Ha=r,u+w foo\u001b[11;1H\u001b[K\u001b[12;1H     # Add user and group execute permissions to FOO.\u001b[13;6Hchmod +110 file\u001b[K\u001b[14;12Hug+x file\u001b[15;1H\u001b[K\u001b[16;1H     # Set file permissions of DIR and subsidiary files to\u001b[16;1H"]
