[913.484481, "o", "\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --97%-----------\u001b[0m\u001b[1;1H   An exit status of zero indicates success, and a nonzero value\u001b[2;1Hindicates failure.\u001b[K\u001b[3;1H\u001b[K\u001b[4;1H   Examples:\u001b[5;1H\u001b[K\u001b[6;1H     # Change file permissions of FOO to be world readable\u001b[7;8Hand user writable, with no other permissions.\u001b[K\u001b[8;6Hchmod 644 foo\u001b[K\u001b[9;12Ha=r,u+w foo\u001b[10;1H\u001b[K\u001b[11;1H     # Add user and group execute permissions to FOO.\u001b[12;6Hchmod +110 file\u001b[K\u001b[13;12Hug+x file\u001b[14;1H\u001b[K\u001b[15;1H     # Set file permissions of DIR and subsidiary files to\u001b[16;8Hbe the umask default, assuming execute permissions for\u001b[16;1H\u001b[16;1H"]
