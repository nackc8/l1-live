[904.683207, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines -- 0%-----------\u001b[0m\u001b[1;1Hle attributes\u001b[K\u001b[2;1H\u001b[K\u001b[3;1H13.3 ‘chmod’: Change access permissions\u001b[4;1H=======================================\u001b[5;1H\u001b[K\u001b[6;1H‘chmod’ changes the access permissions of the named files.  Synop\u001b[6;66H\\\u001b[7;1Hsis:\u001b[K\u001b[8;1H\u001b[K\u001b[9;1H     chmod [OPTION]... {MODE | --reference=REF_FILE} FILE...\u001b[10;1H\u001b[K\u001b[11;1H   ‘chmod’ never changes the permissions of symbolic links, since\u001b[11;66H\\\u001b[12;2Hthe\u001b[K\u001b[13;1H‘chmod’ system call cannot change their permissions.  This is not\u001b[13;66H\\\u001b[14;1H a\u001b[K\u001b[15;1Hproblem since the permissions of symbolic links are never used.\u001b[16;1HHowever, for each symbolic link listed on the command line, ‘chmo\u001b[16;66H\\\u001b[16;1H\u001b[6;66H\\\u001b[11;66H\\\u001b[13;66H\\\u001b[16;66H\\\u001b[16;1H"]
[904.714736, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines -- 1%-----------\u001b[0m\u001b[1;1H\u001b[K\u001b[2;1H13.3 ‘chmod’: Change access permissions\u001b[3;1H=======================================\u001b[4;1H\u001b[K\u001b[5;1H‘chmod’ changes the access permissions of the named files.  Synop\u001b[5;66H\\\u001b[6;1Hsis:\u001b[K\u001b[7;1H\u001b[K\u001b[8;1H     chmod [OPTION]... {MODE | --reference=REF_FILE} FILE...\u001b[9;1H\u001b[K\u001b[10;1H   ‘chmod’ never changes the permissions of symbolic links, since\u001b[10;66H\\\u001b[11;2Hthe\u001b[K\u001b[12;1H‘chmod’ system call cannot change their permissions.  This is not\u001b[12;66H\\\u001b[13;1H a\u001b[K\u001b[14;1Hproblem since the permissions of symbolic links are never used.\u001b[15;1HHowever, for each symbolic link listed on the command line, ‘chmo\u001b[15;66H\\\u001b[16;1Hd’\u001b[K\u001b[16;1H\u001b[5;66H\\\u001b[10;66H\\\u001b[12;66H\\\u001b[15;66H\\\u001b[16;1H"]
[904.746015, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines -- 2%-----------\u001b[0m\u001b[1;1H13.3 ‘chmod’: Change access permissions\u001b[2;1H=======================================\u001b[3;1H\u001b[K\u001b[4;1H‘chmod’ changes the access permissions of the named files.  Synop\u001b[4;66H\\\u001b[5;1Hsis:\u001b[K\u001b[6;1H\u001b[K\u001b[7;1H     chmod [OPTION]... {MODE | --reference=REF_FILE} FILE...\u001b[8;1H\u001b[K\u001b[9;1H   ‘chmod’ never changes the permissions of symbolic links, since\u001b[9;66H\\\u001b[10;2Hthe\u001b[K\u001b[11;1H‘chmod’ system call cannot change their permissions.  This is not\u001b[11;66H\\\u001b[12;1H a\u001b[K\u001b[13;1Hproblem since the permissions of symbolic links are never used.\u001b[14;1HHowever, for each symbolic link listed on the command line, ‘chmo\u001b[14;66H\\\u001b[15;1Hd’\u001b[K"]
[904.746315, "o", "\u001b[16;1Hchanges the permissions of the pointed-to file.  In contrast, ‘ch\u001b[16;66H\\\u001b[16;1H\u001b[4;66H\\\u001b[9;66H\\\u001b[11;66H\\\u001b[14;66H\\\u001b[16;66H\\\u001b[16;1H"]
[904.77719, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines -- 3%-----------\u001b[0m\u001b[1;1H=======================================\u001b[2;1H\u001b[K\u001b[3;1H‘chmod’ changes the access permissions of the named files.  Synop\u001b[3;66H\\\u001b[4;1Hsis:\u001b[K\u001b[5;1H\u001b[K\u001b[6;1H     chmod [OPTION]... {MODE | --reference=REF_FILE} FILE...\u001b[7;1H\u001b[K\u001b[8;1H   ‘chmod’ never changes the permissions of symbolic links, since\u001b[8;66H\\\u001b[9;2Hthe\u001b[K\u001b[10;1H‘chmod’ system call cannot change their permissions.  This is not\u001b[10;66H\\\u001b[11;1H a\u001b[K\u001b[12;1Hproblem since the permissions of symbolic links are never used.\u001b[13;1HHowever, for each symbolic link listed on the command line, ‘chmo\u001b[13;66H\\\u001b[14;1Hd’\u001b[K\u001b[15;1Hchanges the permissions of the pointed-to file.  In contrast, ‘ch\u001b[15;66H\\\u001b[16;1Hmod’\u001b[K\u001b[16;1H\u001b[3;66H\\\u001b[8;66H\\\u001b[10;66H\\\u001b[13;66H\\\u001b[15;66H\\\u001b[16;1H"]
