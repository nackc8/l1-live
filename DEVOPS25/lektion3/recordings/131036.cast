[888.592848, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mu+s \u001b[22mand \u001b[1mg-s\u001b[22m.  To clear these bits for directories with  a\u001b[m\r\n\u001b[7m Manual page chmod(1) line 69 (press h for help or q to quit)\u001b[27m\u001b[K"]
[888.62464, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       numeric  mode  requires  an  additional leading zero like\u001b[m\r\n\u001b[7m Manual page chmod(1) line 70 (press h for help or q to quit)\u001b[27m\u001b[K"]
[888.655387, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m00755\u001b[22m, leading minus like \u001b[1m-6000\u001b[22m, or leading  equals  like\u001b[m\r\n\u001b[7m Manual page chmod(1) line 71 (press h for help or q to quit)\u001b[27m\u001b[K"]
[888.687842, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m=755\u001b[22m.\u001b[m\r\n\u001b[7m Manual page chmod(1) line 72 (press h for help or q to quit)\u001b[27m\u001b[K"]
[889.402275, "o", "\r\u001b[K\u001b[m\r\n\u001b[1mRESTRICTED DELETION FLAG OR STICKY BIT\u001b[0m\u001b[m\r\n       The  restricted  deletion  flag or sticky bit is a single\u001b[m\r\n       bit, whose interpretation depends on the file type.   For\u001b[m\r\n       directories, it prevents unprivileged users from removing\u001b[m\r\n       or  renaming  a file in the directory unless they own the\u001b[m\r\n       file or the directory;  this  is  called  the  \u001b[4mrestricted\u001b[0m\u001b[m\r\n       \u001b[4mdeletion\u001b[24m \u001b[4mflag\u001b[24m for the directory, and is commonly found on\u001b[m\r\n       world-writable  directories like \u001b[1m/tmp\u001b[22m.  For regular files\u001b[m\r\n       on some older systems, the bit saves the  program's  text\u001b[m\r\n       image  on  the  swap  device so it will load more quickly\u001b[m\r\n       when run; this is called the \u001b[4msticky\u001b[24m \u001b[4mbit\u001b[24m.\u001b[m\r\n\u001b[m\r\n\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n       Change the mode of each FILE to MODE.  With  \u001b[1m--reference\u001b[22m,\u001b[m\r\n       change the mode of each FILE to that of RFILE.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page chmod(1) line 89 (press h for help or q to quit)\u001b[27m\u001b["]
[889.402303, "o", "K"]
[889.903696, "o", "\r\u001b[K       \u001b[1m-c\u001b[22m, \u001b[1m--changes\u001b[0m\u001b[m\r\n              like verbose but report only when a change is made\u001b[m\r\n\u001b[m\r\n       \u001b[1m-f\u001b[22m, \u001b[1m--silent\u001b[22m, \u001b[1m--quiet\u001b[0m\u001b[m\r\n              suppress most error messages\u001b[m\r\n\u001b[m\r\n       \u001b[1m-v\u001b[22m, \u001b[1m--verbose\u001b[0m\u001b[m\r\n              output a diagnostic for every file processed\u001b[m\r\n\u001b[m\r\n       \u001b[1m--no-preserve-root\u001b[0m\u001b[m\r\n              do not treat '/' specially (the default)\u001b[m\r\n\u001b[m\r\n       \u001b[1m--preserve-root\u001b[0m\u001b[m\r\n              fail to operate recursively on '/'\u001b[m\r\n\u001b[m\r\n       \u001b[1m--reference\u001b[22m=\u001b[4mRFILE\u001b[0m\u001b[m\r\n              use  RFILE's  mode instead of specifying MODE val‐\u001b[m\r\n\u001b[7m Manual page chmod(1) line 106 (press h for help or q to quit)\u001b[27m\u001b[K"]
[889.934146, "o", "\r\u001b[K              ues.  RFILE is always dereferenced if  a  symbolic\u001b[m\r\n              link.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-R\u001b[22m, \u001b[1m--recursive\u001b[0m\u001b[m\r\n              change files and directories recursively\u001b[m\r\n\u001b[m\r\n       \u001b[1m--help \u001b[22mdisplay this help and exit\u001b[m\r\n\u001b[m\r\n       \u001b[1m--version\u001b[0m\u001b[m\r\n              output version information and exit\u001b[m\r\n\u001b[m\r\n       Each        MODE        is        of       the       form\u001b[m\r\n       '[ugoa]*([-+=]([rwxXst]*|[ugo]))+|[-+=][0-7]+'.\u001b[m\r\n\u001b[m\r\n\u001b[1mAUTHOR\u001b[0m\u001b[m\r\n       Written by David MacKenzie and Jim Meyering.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page chmod(1) line 123 (press h for help or q to quit)\u001b[27m\u001b[K"]
[889.965931, "o", "\r\u001b[K\u001b[1mREPORTING BUGS\u001b[0m\u001b[m\r\n       GNU  coreutils  online  help:  <https://www.gnu.org/soft‐\u001b[m\r\n       ware/coreutils/>\u001b[m\r\n       Report  any  translation bugs to <https://translationpro‐\u001b[m\r\n       ject.org/team/>\u001b[m\r\n\u001b[m\r\n\u001b[1mCOPYRIGHT\u001b[0m\u001b[m\r\n       Copyright © 2023 Free Software Foundation, Inc.   License\u001b[m\r\n       GPLv3+:  GNU  GPL version 3 or later <https://gnu.org/li‐\u001b[m\r\n       censes/gpl.html>.\u001b[m\r\n       This is free software: you are free to change and  redis‐\u001b[m\r\n       tribute  it.  There is NO WARRANTY, to the extent permit‐\u001b[m\r\n       ted by law.\u001b[m\r\n\u001b[m\r\n\u001b[1mSEE ALSO\u001b[0m\u001b[m\r\n       \u001b[1mchmod\u001b[22m(2)\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page chmod(1) line 140 (press h for help or q to quit)\u001b[27m\u001b[K"]
