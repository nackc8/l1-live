[904.808553, "o", "\u001b[4;1H\u001b[K\u001b[5;1H     chmod [OPTION]... {MODE | --reference=REF_FILE} FILE...\u001b[6;1H\u001b[K\u001b[7;1H   ‘chmod’ never changes the permissions of symbolic links, since\u001b[7;66H\\\u001b[8;2Hthe\u001b[K\u001b[9;1H‘chmod’ system call cannot change their permissions.  This is not\u001b[9;66H\\\u001b[10;1H a\u001b[K\u001b[11;1Hproblem since the permissions of symbolic links are never used.\u001b[12;1HHowever, for each symbolic link listed on the command line, ‘chmo\u001b[12;66H\\\u001b[13;1Hd’\u001b[K\u001b[14;1Hchanges the permissions of the pointed-to file.  In contrast, ‘ch\u001b[14;66H\\\u001b[15;1Hmod’\u001b[K\u001b[16;1Hignores symbolic links encountered during recursive directory\u001b[16;1H\u001b[2;66H\\\u001b[7;66H\\\u001b[9;66H\\\u001b[12;66H\\\u001b[14;66H\\\u001b[16;1H"]
