[851.285484, "o", "\u001b[?1049h\u001b[22;0;0t\u001b[?1h\u001b=\r"]
[851.29559, "o", "\u001b[4mCHMOD\u001b[24m(1)                  User Commands                 \u001b[4mCHMOD\u001b[24m(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       chmod - change file mode bits\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mchmod \u001b[22m[\u001b[4mOPTION\u001b[24m]... \u001b[4mMODE\u001b[24m[\u001b[4m,MODE\u001b[24m]... \u001b[4mFILE\u001b[24m...\u001b[m\r\n       \u001b[1mchmod \u001b[22m[\u001b[4mOPTION\u001b[24m]... \u001b[4mOCTAL-MODE\u001b[24m \u001b[4mFILE\u001b[24m...\u001b[m\r\n       \u001b[1mchmod \u001b[22m[\u001b[4mOPTION\u001b[24m]... \u001b[4m--reference=RFILE\u001b[24m \u001b[4mFILE\u001b[24m...\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       This  manual  page  documents  the  GNU version of \u001b[1mchmod\u001b[22m.\u001b[m\r\n       \u001b[1mchmod \u001b[22mchanges the file mode bits of each given  file  ac‐\u001b[m\r\n       cording to \u001b[4mmode\u001b[24m, which can be either a symbolic represen‐\u001b[m\r\n       tation  of changes to make, or an octal number represent‐\u001b[m\r\n       ing the bit pattern for the new mode bits.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page chmod(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[882.319963, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       The     format     of     a     symbolic     mode      is\u001b[m\r\n\u001b[7m Manual page chmod(1) line 2 (press h for help or q to quit)\u001b[27m\u001b[K"]
[882.844035, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       [\u001b[1mugoa\u001b[22m...][[\u001b[1m-+=\u001b[22m][\u001b[4mperms\u001b[24m...]...], where \u001b[4mperms\u001b[24m is either zero\u001b[m\r\n\u001b[7m Manual page chmod(1) line 3 (press h for help or q to quit)\u001b[27m\u001b[K"]
[883.270477, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       or  more  letters from the set \u001b[1mrwxXst\u001b[22m, or a single letter\u001b[m\r\n\u001b[7m Manual page chmod(1) line 4 (press h for help or q to quit)\u001b[27m\u001b[K"]
[885.211404, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       from the set \u001b[1mugo\u001b[22m.  Multiple symbolic modes can be  given,\u001b[m\r\n\u001b[7m Manual page chmod(1) line 5 (press h for help or q to quit)\u001b[27m\u001b[K"]
[885.711688, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       separated by commas.\u001b[m\r\n\u001b[7m Manual page chmod(1) line 6 (press h for help or q to quit)\u001b[27m\u001b[K"]
[885.743093, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page chmod(1) line 7 (press h for help or q to quit)\u001b[27m\u001b[K"]
[885.775522, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       A  combination  of the letters \u001b[1mugoa \u001b[22mcontrols which users'\u001b[m\r\n\u001b[7m Manual page chmod(1) line 8 (press h for help or q to quit)\u001b[27m\u001b[K"]
[885.806538, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       access to the file will be changed: the user who owns  it\u001b[m\r\n\u001b[7m Manual page chmod(1) line 9 (press h for help or q to quit)\u001b[27m\u001b[K"]
[885.837737, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       (\u001b[1mu\u001b[22m), other users in the file's group (\u001b[1mg\u001b[22m), other users not\u001b[m\r\n\u001b[7m Manual page chmod(1) line 10 (press h for help or q to quit)\u001b[27m\u001b[K"]
