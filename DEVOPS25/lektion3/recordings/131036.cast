[1181.222505, "o", "\u001b[?1049h\u001b[22;0;0t\u001b[?1h\u001b=\r"]
[1181.235722, "o", "\u001b[4mLS\u001b[24m(1)                     User Commands                    \u001b[4mLS\u001b[24m(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       ls - list directory contents\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mls \u001b[22m[\u001b[4mOPTION\u001b[24m]... [\u001b[4mFILE\u001b[24m]...\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       List  information  about the FILEs (the current directory\u001b[m\r\n       by default).  Sort entries alphabetically if none of \u001b[1m-cf‐\u001b[0m\u001b[m\r\n       \u001b[1mtuvSUX \u001b[22mnor \u001b[1m--sort \u001b[22mis specified.\u001b[m\r\n\u001b[m\r\n       Mandatory arguments to long  options  are  mandatory  for\u001b[m\r\n       short options too.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-a\u001b[22m, \u001b[1m--all\u001b[0m\u001b[m\r\n\u001b[7m Manual page ls(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1182.364177, "o", "\r\u001b[K              do not ignore entries starting with .\u001b[m\r\n\u001b[m\r\n       \u001b[1m-A\u001b[22m, \u001b[1m--almost-all\u001b[0m\u001b[m\r\n              do not list implied . and ..\u001b[m\r\n\u001b[m\r\n       \u001b[1m--author\u001b[0m\u001b[m\r\n              with \u001b[1m-l\u001b[22m, print the author of each file\u001b[m\r\n\u001b[m\r\n       \u001b[1m-b\u001b[22m, \u001b[1m--escape\u001b[0m\u001b[m\r\n              print C-style escapes for nongraphic characters\u001b[m\r\n\u001b[m\r\n       \u001b[1m--block-size\u001b[22m=\u001b[4mSIZE\u001b[0m\u001b[m\r\n              with  \u001b[1m-l\u001b[22m,  scale sizes by SIZE when printing them;\u001b[m\r\n              e.g., '--block-size=M'; see SIZE format below\u001b[m\r\n\u001b[m\r\n       \u001b[1m-B\u001b[22m, \u001b[1m--ignore-backups\u001b[0m\u001b[m\r\n              do not list implied entries ending with ~\u001b[m\r\n\u001b[7m Manual page ls(1) line 18 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1183.833988, "o", "\r\u001b[K\u001b[m\r\n       \u001b[1m-c     \u001b[22mwith \u001b[1m-lt\u001b[22m: sort by, and show, ctime (time  of  last\u001b[m\r\n              change  of file status information); with \u001b[1m-l\u001b[22m: show\u001b[m\r\n              ctime and sort by name; otherwise: sort by  ctime,\u001b[m\r\n              newest first\u001b[m\r\n\u001b[m\r\n       \u001b[1m-C     \u001b[22mlist entries by columns\u001b[m\r\n\u001b[m\r\n       \u001b[1m--color\u001b[22m[=\u001b[4mWHEN\u001b[24m]\u001b[m\r\n              color the output WHEN; more info below\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[22m, \u001b[1m--directory\u001b[0m\u001b[m\r\n              list directories themselves, not their contents\u001b[m\r\n\u001b[m\r\n       \u001b[1m-D\u001b[22m, \u001b[1m--dired\u001b[0m\u001b[m\r\n              generate output designed for Emacs' dired mode\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ls(1) line 35 (press h for help or q to quit)\u001b[27m\u001b[K"]
