[754.416185, "o", "\u001b[KN\bN"]
[754.679325, "o", "\r\u001b[K\u001b[1;1H\u001b[4mUSERMOD\u001b[24m(8)         System Management Commands         \u001b[4mUSERMOD\u001b[24m(8)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       usermod - modify a user account\u001b[m\r\n\u001b[5;1H\u001b[m"]
[754.679473, "o", "\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[m\r\n\u001b[8;1H       \u001b[1musermod \u001b[22m[\u001b[4moptions\u001b[24m] \u001b[4mLOGIN\u001b[0m\u001b[m\r\n\u001b[9;1H\u001b[m\r\n\u001b[10;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[11;1H       The \u001b[1musermod \u001b[22mcommand modifies the system account files.\u001b[m\r\n\u001b[12;1H\u001b[m\r\n\u001b[13;1H\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[14;1H       The options which apply to the \u001b[1musermod \u001b[22mcommand are:\u001b[m\r\n\u001b[15;1H\u001b[m\r\n"]
[754.679895, "o", "\u001b[16;1H       \u001b[1m-a\u001b[22m, \u001b[1m--append\u001b[0m\u001b[m\r\n\u001b[17;1H           Add the user to the supplementary group(s). Use only\u001b[m\r\n\u001b[18;1H\u001b[1;1H\u001b[4mUSERMOD\u001b[24m(8)         System Management Commands         \u001b[4mUSERMOD\u001b[24m(8)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       usermod - modify a user account\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[m\r\n\u001b[8;1H       \u001b[1musermod \u001b[22m[\u001b[4moptions\u001b[24m] \u001b[4m\u001b[7mLOGIN\u001b[27m\u001b[m\r\n\u001b[9;1H\u001b[m\r\n\u001b[10;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[11;1H       The \u001b[1musermod \u001b[22mcommand modifies the system account files.\u001b[m"]
[754.680132, "o", "\r\n\u001b[12;1H\u001b[m\r\n\u001b[13;1H\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[14;1H       The options which apply to the \u001b[1musermod \u001b[22mcommand are:\u001b[m\r\n\u001b[15;1H\u001b[m\r\n\u001b[16;1H       \u001b[1m-a\u001b[22m, \u001b[1m--append\u001b[0m\u001b[m\r\n\u001b[17;1H           Add the user to the supplementary group(s). Use only\u001b[m"]
[754.680231, "o", "\r\n\u001b[18;1H           with the \u001b[1m-G \u001b[22moption.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-b\u001b[22m, \u001b[1m--badname\u001b[0m\u001b[m\r\n           Allow names that do not conform to standards.\u001b[m"]
[754.680305, "o", "\r\n\u001b[m\r\n       \u001b[1m-c\u001b[22m, \u001b[1m--comment \u001b[4m\u001b[22mCOMMENT\u001b[0m\u001b[m\r\n           update the comment field of the user in /etc/passwd,\u001b[m\r\n\u001b[7mal page usermod(8) line 8/374 5% (press h for help or q to quit)\u001b[27m\u001b[K"]
[755.354751, "o", "\r\u001b[K/\r\u001b[K...skipping...\r\n       \u001b[1m-l\u001b[22m, \u001b[1m--login \u001b[4m\u001b[22mNEW_\u001b[7mLOGIN\u001b[27m\u001b[m\r\n           The name of the user will be changed from \u001b[4m\u001b[7mLOGIN\u001b[27m\u001b[24m to\u001b[m\r\n           \u001b[4mNEW_\u001b[7mLOGIN\u001b[27m\u001b[24m. Nothing else is changed. In particular,\u001b[m\r\n           the user's home directory or mail spool should\u001b[m\r\n           probably be renamed manually to reflect the new login\u001b[m\r\n           name.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-L\u001b[22m, \u001b[1m--lock\u001b[0m\u001b[m\r\n           Lock a user's password. This puts a '!' in front of\u001b[m\r\n           the encrypted password, effectively disabling the\u001b[m\r\n           password. You can't use this option with \u001b[1m-p \u001b[22mor \u001b[1m-U\u001b[22m.\u001b[m"]
[755.355051, "o", "\r\n\u001b[m\r\n           Note: if you wish to lock the account (not only\u001b[m\r\n           access with a password), you should also set the\u001b[m\r\n           \u001b[4mEXPIRE_DATE\u001b[24m to \u001b[4m1\u001b[24m.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-m\u001b[22m, \u001b[1m--move-home\u001b[0m\u001b[m\r\n\u001b[7m page usermod(8) line 92/374 29% (press h for help or q to quit)\u001b[27m\u001b[K"]
[758.048156, "o", "\r\u001b[K/\r\u001b[K           moves the content of the user's home directory to the\u001b[m\r\n\u001b[7m page usermod(8) line 93/374 29% (press h for help or q to quit)\u001b[27m\u001b[K"]
[758.579768, "o", "\r\u001b[K/\r\u001b[K           new location. If the current home directory does not\u001b[m\r\n\u001b[7m page usermod(8) line 94/374 30% (press h for help or q to quit)\u001b[27m\u001b[K"]
[759.112769, "o", "\r\u001b[K/\r\u001b[K...skipping...\r\n           defines the SELinux user to be mapped with \u001b[4m\u001b[7mLOGIN\u001b[27m\u001b[24m. An\u001b[m\r\n           empty string (\"\") will remove the respective entry\u001b[m\r\n           (if any). Note that the shadow system doesn't store\u001b[m\r\n           the selinux-user, it uses semanage(8) for that.\u001b[m\r\n\u001b[m\r\n\u001b[1mCAVEATS\u001b[0m\u001b[m\r\n       You must make certain that the named user is not\u001b[m\r\n       executing any processes when this command is being\u001b[m\r\n       executed if the user's numerical user ID, the user's\u001b[m\r\n       name, or the user's home directory is being changed.\u001b[m\r\n       \u001b[1musermod \u001b[22mchecks this on Linux. On other operating systems\u001b[m\r\n       it only uses utmp to check if the user is logged in.\u001b[m\r\n\u001b[m\r\n       You must change the owner of any \u001b[1mcrontab \u001b[22mfiles or \u001b[1mat \u001b[22mjobs\u001b[m\r\n       manually.\u001b[m\r\n\u001b[m\r\n       You must make any changes involving NIS on the NIS\u001b[m\r\n\u001b[7mpage usermod(8) line 253/374 74% (press h for help or q to quit)\u001b[27m\u001b[K"]
[760.208391, "o", "\r\u001b[K/\r\u001b[K\r\u001b[K\u001b[7mPattern not found  (press RETURN)\u001b[27m"]
[760.754759, "o", "\u001b[18;1H\u001b[K\r\u001b[K/\r\u001b[K"]
[760.7548, "o", "\r\u001b[K\u001b[7mPattern not found  (press RETURN)\u001b[27m"]
[761.519697, "o", "\u001b[18;1H\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m-Z\u001b[22m, \u001b[1m--selinux-user \u001b[4m\u001b[22mSEUSER\u001b[0m\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mpage usermod(8) line 252/374 73% (press h for help or q to quit)\u001b[27m\u001b[K"]
[762.119945, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mpage usermod(8) line 251/374 73% (press h for help or q to quit)\u001b[27m\u001b[K"]
[762.620626, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           /etc/login.defs.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mpage usermod(8) line 250/374 73% (press h for help or q to quit)\u001b[27m\u001b[K"]
