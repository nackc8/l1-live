[912.074376, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --53%-----------\u001b[0m\u001b[1;1H\u001b[K\u001b[2;1H‘-c’\u001b[3;3H-changes’\u001b[4;1H     Verbosely describe the action for each FILE whose permission\u001b[4;66H\\\u001b[5;1Hs\u001b[K\u001b[6;1H     actually change.\u001b[7;1H\u001b[K\u001b[8;1H‘-f’\u001b[9;3H-silent’\u001b[10;4Hquiet’\u001b[K\u001b[11;1H     Do not print error messages about files whose permissions ca\u001b[11;66H\\\u001b[12;1Hnnot be\u001b[K\u001b[13;1H     changed.\u001b[14;1H\u001b[K\u001b[15;1H‘--preserve-root’\u001b[16;1H     Fail upon any attempt to recursively change the root directo\u001b[16;66H\\\u001b[16;1H\u001b[4;66H\\\u001b[11;66H\\\u001b[16;66H\\\u001b[16;1H"]
[912.105201, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --54%-----------\u001b[0m\u001b[1;1H‘-c’\u001b[2;3H-changes’\u001b[3;1H     Verbosely describe the action for each FILE whose permission\u001b[3;66H\\\u001b[4;1Hs\u001b[K\u001b[5;1H     actually change.\u001b[6;1H\u001b[K\u001b[7;1H‘-f’\u001b[8;3H-silent’\u001b[9;4Hquiet’\u001b[K\u001b[10;1H     Do not print error messages about files whose permissions ca\u001b[10;66H\\\u001b[11;1Hnnot be\u001b[K\u001b[12;1H     changed.\u001b[13;1H\u001b[K\u001b[14;1H‘--preserve-root’\u001b[15;1H     Fail upon any attempt to recursively change the root directo\u001b[15;66H\\\u001b[16;1Hry,\u001b[K\u001b[16;1H\u001b[3;66H\\\u001b[10;66H\\\u001b[15;66H\\\u001b[16;1H"]
[912.137223, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --55%-----------\u001b[0m\u001b[1;3H-changes’\u001b[2;1H     Verbosely describe the action for each FILE whose permission\u001b[2;66H\\\u001b[3;1Hs\u001b[K\u001b[4;1H     actually change.\u001b[5;1H\u001b[K\u001b[6;1H‘-f’\u001b[7;3H-silent’\u001b[8;4Hquiet’\u001b[K\u001b[9;1H     Do not print error messages about files whose permissions ca\u001b[9;66H\\\u001b[10;1Hnnot be\u001b[K\u001b[11;1H     changed.\u001b[12;1H\u001b[K\u001b[13;1H‘--preserve-root’\u001b[14;1H     Fail upon any attempt to recursively change the root directo\u001b[14;66H\\\u001b[15;1Hry,\u001b[K\u001b[16;1H     ‘/’.  Without ‘--recursive’, this option has no effect.  \u001b[1m*No\u001b[0m\u001b[K\u001b[16;66H\\\u001b[16;1H\u001b[2;66H\\\u001b[9;66H\\\u001b[14;66H\\\u001b[16;66H\\\u001b[16;1H"]
