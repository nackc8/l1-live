[895.367089, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m00755\u001b[22m, leading minus like \u001b[1m-6000\u001b[22m, or leading  equals  like\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 87/162 75% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.398028, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       numeric  mode  requires  an  additional leading zero like\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 86/162 74% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.429569, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mu+s \u001b[22mand \u001b[1mg-s\u001b[22m.  To clear these bits for directories with  a\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 85/162 74% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.461517, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       You  can  set  or clear the bits with symbolic modes like\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 84/162 74% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.493441, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       group-ID bits unless you  explicitly  specify  otherwise.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 83/162 73% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.525151, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       For  directories  \u001b[1mchmod  \u001b[22mpreserves  set-user-ID  and set-\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 82/162 72% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.556093, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 81/162 71% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.587831, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       system behavior.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 80/162 70% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.618781, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mchmod \u001b[22msystem call.  When in doubt, check  the  underlying\u001b[m"]
[895.618966, "o", "\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 79/162 69% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.649676, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       pends  on  the policy and functionality of the underlying\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 78/162 68% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.681229, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       bits of \u001b[4mMODE\u001b[24m or \u001b[4mRFILE\u001b[24m to be ignored.  This  behavior  de‐\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 77/162 67% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.712125, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       restrictions  may  cause the set-user-ID and set-group-ID\u001b[m"]
