[901.520435, "o", "\u001b[?1h\u001b=\u001b[?1049h\u001b[22;0;0t\u001b[H\u001b[2J\u001b[18;1HWelcome to Info version 7.1.  Type H for help, h for tutorial.\u001b[18;1Hgzip -d < /usr/share/info/coreutils.info.gz...\u001b[K"]
[901.527925, "o", "\u001b[18;1HWelcome to Info version 7.1.  Type H for help, h for tutorial.\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --Top-----------\u001b[0m\u001b[1;1HNext: touch invocation,  Prev: chgrp invocation,  Up: Changing fi\u001b[1;66H\\\u001b[2;1Hle attributes\u001b[4;1H13.3 ‘chmod’: Change access permissions\u001b[5;1H=======================================\u001b[7;1H‘chmod’ changes the access permissions of the named files.  Synop\u001b[7;66H\\\u001b[8;1Hsis:\u001b[10;1H     chmod [OPTION]... {MODE | --reference=REF_FILE} FILE...\u001b[12;1H   ‘chmod’ never changes the permissions of symbolic links, since\u001b[12;66H\\\u001b[13;1H the\u001b[14;1H‘chmod’ system call cannot change their permissions.  This is not\u001b[14;66H\\\u001b[15;1H a\u001b[16;1Hproblem since the permissions of symbolic links are never used.\u001b[1;66H\\\u001b[7;66H\\\u001b[12;66H\\\u001b[14;66H\\\u001b[1;1H"]
[903.74373, "o", "\u001b[1;1H\u001b[18;1H\u001b[K\u001b[2;1H\u001b[1;66H\\\u001b[7;66H\\\u001b[12;66H\\\u001b[14;66H\\\u001b[2;1H"]
