[913.516396, "o", "\u001b[4;1H\u001b[K\u001b[5;1H     # Change file permissions of FOO to be world readable\u001b[6;8Hand user writable, with no other permissions.\u001b[K\u001b[7;6Hchmod 644 foo\u001b[K\u001b[8;12Ha=r,u+w foo"]
[913.516714, "o", "\u001b[9;1H\u001b[K\u001b[10;1H     # Add user and group execute permissions to FOO.\u001b[11;6Hchmod +110 file\u001b[K\u001b[12;12Hug+x file\u001b[13;1H\u001b[K\u001b[14;1H     # Set file permissions of DIR and subsidiary files to\u001b[15;8Hbe the umask default, assuming execute permissions for\u001b[16;8Hdirectories and for files already executable.\u001b[K\u001b[16;1H\u001b[16;1H"]
[913.547462, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --99%-----------\u001b[0m\u001b[1;1H\u001b[K\u001b[2;1H   Examples:\u001b[3;1H\u001b[K\u001b[4;1H     # Change file permissions of FOO to be world readable\u001b[5;8Hand user writable, with no other permissions.\u001b[K\u001b[6;6Hchmod 644 foo\u001b[K\u001b[7;12Ha=r,u+w foo\u001b[8;1H\u001b[K\u001b[9;1H     # Add user and group execute permissions to FOO.\u001b[10;6Hchmod +110 file\u001b[K\u001b[11;12Hug+x file\u001b[12;1H\u001b[K\u001b[13;1H     # Set file permissions of DIR and subsidiary files to\u001b[14;8Hbe the umask default, assuming execute permissions for\u001b[15;8Hdirectories and for files already executable.\u001b[K\u001b[16;6Hchmod -R a=,+rwX dir\u001b[K\u001b[16;1H\u001b[16;1H"]
[913.579439, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)chmod invocation, 120 lines --Bot-----------\u001b[0m\u001b[1;1H   Examples:\u001b[2;1H\u001b[K\u001b[3;1H     # Change file permissions of FOO to be world readable\u001b[4;8Hand user writable, with no other permissions.\u001b[K\u001b[5;6Hchmod 644 foo\u001b[K\u001b[6;12Ha=r,u+w foo\u001b[7;1H\u001b[K\u001b[8;1H     # Add user and group execute permissions to FOO.\u001b[9;6Hchmod +110 file\u001b[K\u001b[10;12Hug+x file\u001b[11;1H\u001b[K\u001b[12;1H     # Set file permissions of DIR and subsidiary files to\u001b[13;8Hbe the umask default, assuming execute permissions for\u001b[14;8Hdirectories and for files already executable.\u001b[K\u001b[15;6Hchmod -R a=,+rwX dir\u001b[K\u001b[16;1H\u001b[K\u001b[16;1H\u001b[16;1H"]
[913.610802, "o", "\u001b[16;1H\u001b[17;1H\u001b[7m-----Info: (coreutils)touch invocation, 173 lines --Top-----------\u001b[0m\u001b[1;1HPrev: chmod invocation,  Up: Changing file attributes\u001b[3;1H13.4 ‘touch’: Change file timestamps\u001b[K\u001b[4;1H====================================\u001b[K\u001b[5;1H\u001b[K\u001b[6;1H‘touch’ changes the access and/or modification timestamps of the\u001b[7;1Hspecified files.  Synopsis:\u001b[8;1H\u001b[K\u001b[9;6Htouch [OPTION]... FILE...\u001b[10;1H\u001b[K\u001b[11;1H   Any FILE argument that does not exist is created empty, unless\u001b[11;66H\\\u001b[12;2Hoption\u001b[K\u001b[13;1H‘--no-create’ (‘-c’) or ‘--no-dereference’ (‘-h’) was in effect.\u001b[14;1H\u001b[K\u001b[15;4HA FILE argument string of ‘-’ is handled specially and causes \u001b[15;66H\\\u001b[16;1H‘touch’\u001b[1;1H\u001b[11;66H\\\u001b[15;66H\\\u001b[1;1H"]
