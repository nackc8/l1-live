[893.219208, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       change the mode of each FILE to that of RFILE.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7ml page chmod(1) line 104/162 82% (press h for help or q to quit)\u001b[27m\u001b[K"]
[893.249915, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       Change the mode of each FILE to MODE.  With  \u001b[1m--reference\u001b[22m,\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7ml page chmod(1) line 103/162 82% (press h for help or q to quit)\u001b[27m\u001b[K"]
[893.73058, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7ml page chmod(1) line 102/162 81% (press h for help or q to quit)\u001b[27m\u001b[K"]
[893.940278, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7ml page chmod(1) line 101/162 81% (press h for help or q to quit)\u001b[27m\u001b[K"]
[894.105231, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       when run; this is called the \u001b[4msticky\u001b[24m \u001b[4mbit\u001b[24m.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7ml page chmod(1) line 100/162 81% (press h for help or q to quit)\u001b[27m\u001b[K"]
[894.262464, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       image  on  the  swap  device so it will load more quickly\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 99/162 80% (press h for help or q to quit)\u001b[27m\u001b[K"]
[894.443001, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       on some older systems, the bit saves the  program's  text\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 98/162 79% (press h for help or q to quit)\u001b[27m\u001b[K"]
[894.584562, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       world-writable  directories like \u001b[1m/tmp\u001b[22m.  For regular files\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 97/162 79% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.085458, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[4mdeletion\u001b[24m \u001b[4mflag\u001b[24m for the directory, and is commonly found on\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 96/162 79% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.11651, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       file or the directory;  this  is  called  the  \u001b[4mrestricted\u001b[0m\u001b[m"]
[895.116536, "o", "\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 95/162 78% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.148086, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       or  renaming  a file in the directory unless they own the\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 94/162 78% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.179109, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       directories, it prevents unprivileged users from removing\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 93/162 78% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.210353, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       bit, whose interpretation depends on the file type.   For\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 92/162 77% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.241186, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       The  restricted  deletion  flag or sticky bit is a single\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 91/162 77% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.273427, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[1mRESTRICTED DELETION FLAG OR STICKY BIT\u001b[0m\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 90/162 76% (press h for help or q to quit)\u001b[27m\u001b[K"]
[895.304181, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mal page chmod(1) line 89/162 76% (press h for help or q to quit)\u001b[27m\u001b[K"]
