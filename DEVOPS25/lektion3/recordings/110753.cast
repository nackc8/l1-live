[681.518413, "o", "\r\u001b[K\u001b[1;1H\u001b[m\r\n\u001b[2;1H       \u001b[1m--backup-suffix \u001b[22mstr\u001b[m"]
[681.518536, "o", "\r\n\u001b[3;1H              Select  compression algorithm for a home directory\u001b[m\r\n\u001b[4;1H              backup.  Can be set to any  suffix  recognized  by\u001b[m"]
[681.518755, "o", "\r\n\u001b[5;1H              \u001b[1mtar  --auto-compress\u001b[22m.   Defaults  to  \u001b[4m.gz\u001b[24m.   Valid\u001b[m\r\n\u001b[6;1H              Modes: \u001b[1mdeluser\u001b[22m, \u001b[1mdeluser --system\u001b[22m,\u001b[m\r\n\u001b[7;1H\u001b[m\r\n\u001b[8;1H       \u001b[1m--backup-to \u001b[4m\u001b[22mdir\u001b[0m\u001b[m\r\n\u001b[9;1H              Place the backup files not in the  current  direc‐\u001b[m\r\n\u001b[10;1H              tory  but  in  \u001b[4mdir\u001b[24m.  This implicitly sets \u001b[1m--backup\u001b[0m\u001b[m\r\n\u001b[11;1H              also.  (defaulting to the current  working  direc‐\u001b[m\r\n\u001b[12;1H              tory).  Valid Modes: \u001b[1mdeluser\u001b[22m, \u001b[1mdeluser --system\u001b[22m,\u001b[m\r\n\u001b[13;1H\u001b[m\r\n\u001b[14;1H       \u001b[1m--conf \u001b[4m\u001b[22mfile\u001b[0m\u001b[m\r\n\u001b[15;1H              Use    \u001b[4mfile\u001b[24m   instead   of   the   default   files\u001b[m\r\n\u001b[16;1H              \u001b[4m/etc/deluser.conf\u001b[24m and \u001b[4m/etc/adduser.conf\u001b[24m.  Multiple\u001b[m\r\n\u001b[17;1H              --conf options may be given.\u001b[m\r\n\u001b[18;1H\u001b[1;1H\u001b[m\r\n\u001b[2;1H       \u001b[1m--backup-suffix \u001b[22mstr\u001b[m\r\n\u001b[3;1H              Select  compression algorithm for a home directory\u001b[m\r\n\u001b[4;1H              ba"]
[681.518775, "o", "ckup.  Can be set to any  suffix  recognized  by\u001b[m\r\n\u001b[5;1H              \u001b[1mtar  --auto-compress\u001b[22m.   Defaults  to  \u001b[4m.gz\u001b[24m.   Valid\u001b[m\r\n\u001b[6;1H              Modes: \u001b[1mdeluser\u001b[22m, \u001b[1mdeluser --system\u001b[22m,\u001b[m\r\n\u001b[7;1H\u001b[m\r\n\u001b[8;1H       \u001b[1m--backup-to \u001b[4m\u001b[22mdir\u001b[0m\u001b[m\r\n\u001b[9;1H              Place the backup files not in the  current  direc‐\u001b[m\r\n\u001b[10;1H              tory  but  in  \u001b[4mdir\u001b[24m.  This implicitly sets \u001b[1m--backup\u001b[0m\u001b[m\r\n\u001b[11;1H              also.  (defaulting to the current  working  direc‐\u001b[m\r\n\u001b[12;1H              tory).  Valid Modes: \u001b[1mdeluser\u001b[22m, \u001b[1mdeluser --system\u001b[22m,\u001b[m\r\n\u001b[13;1H\u001b[m\r\n\u001b[14;1H       \u001b[1m--conf \u001b[4m\u001b[22mfile\u001b[0m\u001b[m\r\n\u001b[15;1H              Use    \u001b[4mfile\u001b[24m   instead   of   the   default   files\u001b[m\r\n\u001b[16;1H              \u001b[4m/etc/deluser.conf\u001b[24m and \u001b[4m/etc/adduser.conf\u001b[24m.  Multiple\u001b[m\r\n\u001b[17;1H              --conf options may be given.\u001b[m\r\n\u001b[18;1H...skipping...\r\n              \u001b[7mRemove\u001b[27m a group.  This is the default action if the\u001b[m\r\n         "]
[681.518785, "o", "     program  is  invoked  as  \u001b[4mdelgroup\u001b[24m.   Valid  Mode:\u001b[m\r\n              \u001b[1mdeluser\u001b[22m.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--help \u001b[22mDisplay brief instructions.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--only-if-empty\u001b[0m\u001b[m\r\n              Only  \u001b[7mremove\u001b[27m if no members are left.  Valid Modes:\u001b[m\r\n              \u001b[1mdeluser --group\u001b[22m, \u001b[1mdelgroup\u001b[22m,\u001b[m\r\n\u001b[m\r\n       \u001b[1m--quiet\u001b[0m\u001b[m\r\n              Synonymous to --stdoutmsglevel=warn. Deprecated.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--\u001b[7mremove\u001b[27m\u001b[1m-all-files\u001b[0m\u001b[m\r\n              \u001b[7mRemove\u001b[27m all files from the  system  owned  by  this\u001b[m\r\n              user.  Note: --\u001b[7mremove\u001b[27m-home does not have an effect\u001b[m\r\n              any more.  If \u001b[1m--backup \u001b[22mis specified, the files are\u001b[m\r\n\u001b[7mpage deluser(8) line 142/219 73% (press h for help or q to quit)\u001b[27m\u001b[K"]
[684.391194, "o", "\r\u001b[K/\r\u001b[K              deleted  after having performed the backup.  Valid\u001b[m\r\n              Modes: \u001b[1mdeluser\u001b[22m, \u001b[1mdeluser --system\u001b[22m,\u001b[m\r\n\u001b[m\r\n       \u001b[1m--\u001b[7mremove\u001b[27m\u001b[1m-home\u001b[0m\u001b[m\r\n              \u001b[7mRemove\u001b[27m the home directory  of  the  user  and  its\u001b[m\r\n              mailspool.   If  \u001b[1m--backup  \u001b[22mis specified, the files\u001b[m\r\n              are deleted after  having  performed  the  backup.\u001b[m\r\n\u001b[7mpage deluser(8) line 149/219 77% (press h for help or q to quit)\u001b[27m\u001b[K"]
[684.796256, "o", "\r\u001b[K/\r\u001b[K              Valid Modes: \u001b[1mdeluser\u001b[22m, \u001b[1mdeluser --system\u001b[22m,\u001b[m\r\n\u001b[m\r\n       \u001b[1m--system\u001b[0m\u001b[m\r\n              Only  delete if user/group is a system user/group.\u001b[m\r\n              If the user does not exist, no error value is  re‐\u001b[m\r\n              turned.  Valid Modes: \u001b[1mdeluser\u001b[22m, \u001b[1mdeluser --system\u001b[22m,\u001b[m\r\n\u001b[7mpage deluser(8) line 155/219 80% (press h for help or q to quit)\u001b[27m\u001b[K"]
[692.812154, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mpage deluser(8) line 154/219 79% (press h for help or q to quit)\u001b[27m\u001b[K"]
