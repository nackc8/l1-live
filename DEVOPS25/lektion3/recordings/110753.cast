[646.720527, "o", "\u001b[4mDELUSER\u001b[24m(8)           System Manager's Manual          \u001b[4mDELUSER\u001b[24m(8)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       deluser,  delgroup - remove a user or group from the sys‐\u001b[m\r\n       tem\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mdeluser \u001b[22m[\u001b[1m--backup\u001b[22m] [\u001b[1m--backup-suffix \u001b[4m\u001b[22mstr\u001b[24m]\u001b[m\r\n               [\u001b[1m--backup-to \u001b[4m\u001b[22mdir\u001b[24m] [\u001b[1m--conf \u001b[4m\u001b[22mfile\u001b[24m] [\u001b[1m--debug\u001b[22m]\u001b[m\r\n               [\u001b[1m--remove-all-files\u001b[22m] [\u001b[1m--remove-home\u001b[22m] [\u001b[1m--quiet\u001b[22m]\u001b[m\r\n               [\u001b[1m--verbose\u001b[22m] [\u001b[1m--stdoutmsglevel \u001b[4m\u001b[22mprio\u001b[24m]\u001b[m\r\n               [\u001b[1m--stderrmsglevel \u001b[4m\u001b[22mprio\u001b[24m] [\u001b[1m--logmsglevel \u001b[4m\u001b[22mprio\u001b[24m] \u001b[1muser\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1mdeluser \u001b[22m[\u001b[1m--system\u001b[22m] [\u001b[1m--backup\u001b[22m] [\u001b[1m--backup-suffix \u001b[4m\u001b[22mstr\u001b[24m]\u001b[m\r\n               [\u001b[1m--backup-to \u001b[4m\u001b[22mdir\u001b[24m] [\u001b[1m--conf \u001b[4m\u001b[22mfile\u001b[24m] [\u001b[1m--debug\u001b[22m]\u001b[m\r\n               [\u001b[1m--remove-all-files\u001b[22m] [\u001b[1m--remove-home\u001b[22m] [\u001b[1m--quiet\u001b[22m]\u001b[m\r\n         "]
[646.720559, "o", "      [\u001b[1m--verbose\u001b[22m] [\u001b[1m--stdoutmsglevel \u001b[4m\u001b[22mprio\u001b[24m]\u001b[m\r\n\u001b[7m Manual page deluser(8) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[675.022929, "o", "\r\u001b[K               [\u001b[1m--stderrmsglevel \u001b[4m\u001b[22mprio\u001b[24m] [\u001b[1m--logmsglevel \u001b[4m\u001b[22mprio\u001b[24m] \u001b[1muser\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1mdeluser --group \u001b[22m[\u001b[1m--conf \u001b[4m\u001b[22mfile\u001b[24m] [\u001b[1m--debug\u001b[22m] [\u001b[1m--only-if-empty\u001b[22m]\u001b[m\r\n               [\u001b[1m--quiet\u001b[22m] [\u001b[1m--verbose\u001b[22m] [\u001b[1m--stdoutmsglevel \u001b[4m\u001b[22mprio\u001b[24m]\u001b[m\r\n               [\u001b[1m--stderrmsglevel \u001b[4m\u001b[22mprio\u001b[24m] [\u001b[1m--logmsglevel \u001b[4m\u001b[22mprio\u001b[24m]\u001b[m\r\n               \u001b[1mgroup\u001b[0m\u001b[m\r\n       \u001b[1mdelgroup \u001b[22m[\u001b[1m--system\u001b[22m] [\u001b[1m--conf \u001b[4m\u001b[22mfile\u001b[24m] [\u001b[1m--debug\u001b[22m]\u001b[m\r\n                [\u001b[1m--only-if-empty\u001b[22m] [\u001b[1m--quiet\u001b[22m] [\u001b[1m--verbose\u001b[22m]\u001b[m\r\n                [\u001b[1m--stdoutmsglevel \u001b[4m\u001b[22mprio\u001b[24m] [\u001b[1m--stderrmsglevel \u001b[4m\u001b[22mprio\u001b[24m]\u001b[m\r\n                [\u001b[1m--logmsglevel \u001b[4m\u001b[22mprio\u001b[24m] \u001b[1mgroup\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1mdeluser \u001b[22m[\u001b[1m--conf \u001b[4m\u001b[22mfile\u001b[24m] [\u001b[1m--debug\u001b[22m] [\u001b[1m--quiet\u001b[22m] [\u001b[1m--verbose\u001b[22m]\u001b[m\r\n               [\u001b[1m--stdoutmsglevel \u001b[4m\u001b[22mprio\u001b[24m] [\u001b[1m--st"]
[675.022955, "o", "derrmsglevel \u001b[4m\u001b[22mprio\u001b[24m]\u001b[m\r\n               [\u001b[1m--logmsglevel \u001b[4m\u001b[22mprio\u001b[24m] \u001b[1muser group\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1mdeluser --help\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page deluser(8) line 18 (press h for help or q to quit)\u001b[27m\u001b[K"]
[676.124799, "o", "\r\u001b[K       \u001b[1mdeluser --version\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n"]
[676.124883, "o", "       \u001b[1mdeluser \u001b[22mand \u001b[1mdelgroup \u001b[22mremove users  and  groups  from  the\u001b[m\r\n       system  according  to command line options and configura‐\u001b[m\r\n       tion  information  in  \u001b[4m/etc/deluser.conf\u001b[24m   and   \u001b[4m/etc/ad‐\u001b[0m\u001b[m\r\n       \u001b[4mduser.conf\u001b[24m.\u001b[m\r\n\u001b[m\r\n       They  are  friendlier  front  ends  to  the  \u001b[1muserdel  \u001b[22mand\u001b[m\r\n       \u001b[1mgroupdel \u001b[22mprograms, removing the home directory as  option\u001b[m\r\n       or  even  all files on the system owned by the user to be\u001b[m\r\n       removed, running a custom script, and other features.\u001b[m\r\n\u001b[m\r\n       For a full list and explanations of all options, see  the\u001b[m\r\n       OPTIONS section.\u001b[m\r\n\u001b[m\r\n       \u001b[1mdeluser \u001b[22mand \u001b[1mdelgroup \u001b[22mcan be run in one of three modes:\u001b[m\r\n\u001b[7m Manual page deluser(8) line 35 (press h for help or q to quit)\u001b[27m\u001b[K"]
[676.687864, "o", "\r\u001b[K\u001b[m\r\n   \u001b[1mRemove a user\u001b[0m\u001b[m\r\n       If  called  with  one non-option argument and without the\u001b[m\r\n       \u001b[1m--group \u001b[22moption, \u001b[1mdeluser \u001b[22mwill remove a non-system user.\u001b[m\r\n\u001b[m\r\n       By default, \u001b[1mdeluser \u001b[22mwill remove the user without removing\u001b[m\r\n       the home directory, the mail spool or any other files  on\u001b[m\r\n       the  system  owned by the user.  Removing the home direc‐\u001b[m\r\n       tory and mail spool  can  be  achieved  using  the  \u001b[1m--re‐\u001b[0m\u001b[m\r\n       \u001b[1mmove-home \u001b[22moption.\u001b[m\r\n\u001b[m\r\n       The   \u001b[1m--remove-all-files  \u001b[22moption removes all files on the\u001b[m\r\n       system owned by the user.  Note that if you activate both\u001b[m\r\n       options \u001b[1m--remove-home \u001b[22mwill have no additional effect  be‐\u001b[m\r\n       cause  all  files  including  the home directory and mail\u001b[m\r\n       spool are already covered by the  \u001b[1m--remove-all-files  \u001b[22mop‐\u001b[m\r\n       tion.\u001b[m\r\n\u001b[7m Manual page deluser(8) line 52 (press h for help or q to quit)\u001b[27m\u001b[K"]
[677.302944, "o", "\r\u001b[K\u001b[m\r\n       If  you want to backup all files before deleting them you\u001b[m\r\n       can activate the \u001b[1m--backup \u001b[22moption which will create a file\u001b[m\r\n       \u001b[4musername.tar(.gz|.bz2)\u001b[24m in the directory specified by  the\u001b[m\r\n       \u001b[1m--backup-to \u001b[22moption.\u001b[m\r\n\u001b[m\r\n       By   default,  the  backup  archive  is  compressed  with\u001b[m\r\n       \u001b[1mgzip\u001b[22m(1).  To change this, the \u001b[1m--backup-suffix \u001b[22moption  can\u001b[m\r\n       be  set  to  any  suffix supported by \u001b[1mtar --auto-compress\u001b[0m\u001b[m\r\n       (e.g. .gz, .bz2, .xz).\u001b[m\r\n\u001b[m\r\n       \u001b[1mdeluser \u001b[22mwill refuse to remove the root account.\u001b[m\r\n\u001b[m\r\n       If the \u001b[1m--system \u001b[22moption is given on the command line,  the\u001b[m\r\n       delete operation is actually executed only if the user is\u001b[m\r\n       a  system  user.   This avoids accidentally deleting non-\u001b[m\r\n       system users.  Additionally, if the user does not  exist,\u001b[m\r\n\u001b[7m Manual page deluser(8) line 69 (press h for help or q to quit)\u001b[27m\u001b[K"]
[677.918286, "o", "\r\u001b[K       no  error  value  is returned.  Debian package maintainer\u001b[m\r\n       scripts may use this  flag  to  remove  system  users  or\u001b[m\r\n       groups  while ignoring the case where the removal already\u001b[m\r\n       occurred.\u001b[m\r\n\u001b[m\r\n   \u001b[1mRemove a group\u001b[0m\u001b[m\r\n       If \u001b[1mdeluser \u001b[22mis called with the \u001b[1m--group   \u001b[22moption,  or  \u001b[1mdel‐\u001b[0m\u001b[m\r\n       \u001b[1mgroup  \u001b[22mis  called,  a group will be removed.  The primary\u001b[m\r\n       group of an existing user cannot be removed.  If the  op‐\u001b[m\r\n       tion \u001b[1m--only-if-empty \u001b[22mis given, the group won't be removed\u001b[m\r\n       if it has any members left.\u001b[m\r\n"]
[677.918456, "o", "\u001b[m\r\n       The  \u001b[1m--system  \u001b[22moption  adds the same functionality as for\u001b[m\r\n       users, respectively.\u001b[m\r\n\u001b[m\r\n   \u001b[1mRemove a user from a specific group\u001b[0m\u001b[m\r\n       If called with two non-option arguments, \u001b[1mdeluser \u001b[22mwill re‐\u001b[m\r\n\u001b[7m Manual page deluser(8) line 86 (press h for help or q to quit)\u001b[27m\u001b[K"]
[678.968457, "o", "\r\u001b[K       move a user from a specific group.\u001b[m\r\n\u001b[m\r\n\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n       Different modes of \u001b[1mdeluser \u001b[22mallow different  options.   If\u001b[m\r\n       no valid modes are listed for a option, it is accepted in\u001b[m\r\n       all modes.\u001b[m\r\n\u001b[m\r\n       Short versions for certain options may exist for histori‐\u001b[m\r\n       cal  reasons.   They are going to stay supported, but are\u001b[m\r\n       removed from the documentation.  Users are advised to mi‐\u001b[m\r\n       grate to the long version of options.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--backup\u001b[0m\u001b[m\r\n              Backup all files contained in the userhome and the\u001b[m\r\n              mailspool file to a file named \u001b[4musername.tar.bz2\u001b[24m or\u001b[m\r\n              \u001b[4musername.tar.gz\u001b[24m.  Valid  Modes:  \u001b[1mdeluser\u001b[22m,  \u001b[1mdeluser\u001b[0m\u001b[m\r\n              \u001b[1m--system\u001b[22m,\u001b[m\r\n\u001b[7m Manual page deluser(8) line 103 (press h for help or q to quit)\u001b[27m\u001b[K"]
[679.98042, "o", "\r\u001b[K\u001b[m\r\n       \u001b[1m--backup-suffix \u001b[22mstr\u001b[m\r\n              Select  compression algorithm for a home directory\u001b[m\r\n              backup.  Can be set to any  suffix  recognized  by\u001b[m\r\n              \u001b[1mtar  --auto-compress\u001b[22m.   Defaults  to  \u001b[4m.gz\u001b[24m.   Valid\u001b[m\r\n              Modes: \u001b[1mdeluser\u001b[22m, \u001b[1mdeluser --system\u001b[22m,\u001b[m\r\n\u001b[m\r\n       \u001b[1m--backup-to \u001b[4m\u001b[22mdir\u001b[0m\u001b[m\r\n              Place the backup files not in the  current  direc‐\u001b[m\r\n              tory  but  in  \u001b[4mdir\u001b[24m.  This implicitly sets \u001b[1m--backup\u001b[0m\u001b[m\r\n              also.  (defaulting to the current  working  direc‐\u001b[m\r\n              tory).  Valid Modes: \u001b[1mdeluser\u001b[22m, \u001b[1mdeluser --system\u001b[22m,\u001b[m\r\n\u001b[m\r\n       \u001b[1m--conf \u001b[4m\u001b[22mfile\u001b[0m\u001b[m\r\n              Use    \u001b[4mfile\u001b[24m   instead   of   the   default   files\u001b[m\r\n              \u001b[4m/etc/deluser.conf\u001b[24m and \u001b[4m/etc/adduser.conf\u001b[24m.  Multiple\u001b[m\r\n              --conf options may be given.\u001b[m\r\n\u001b[7m Manual page deluser(8) line 120 (press h for help or q to"]
[679.980443, "o", " quit)\u001b[27m\u001b[K"]
[680.468349, "o", "\r\u001b[K/"]
