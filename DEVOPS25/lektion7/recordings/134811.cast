[3512.003247, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              is \u001b[1m@\u001b[0m or \u001b[1m*\u001b[0m, an indexed array subscripted by \u001b[1m@\u001b[0m or \u001b[1m*\u001b[0m,\u001b[m\r\n\u001b[7m page bash(1) line 2102/8010 27% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3512.034582, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              or an associative array name, the  results  differ\u001b[m\r\n\u001b[7m page bash(1) line 2103/8010 27% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3512.066109, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              as described below.  If \u001b[4mlength\u001b[24m is omitted, expands\u001b[m\r\n\u001b[7m page bash(1) line 2104/8010 27% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3512.49703, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              to the substring of the value of \u001b[4mparameter\u001b[24m  start‐\u001b[m\r\n\u001b[7m page bash(1) line 2105/8010 27% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3512.661681, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              ing  at  the character specified by \u001b[4moffset\u001b[24m and ex‐\u001b[m\r\n\u001b[7m page bash(1) line 2106/8010 27% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3512.781642, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              tending to the end of the value.  \u001b[4mlength\u001b[24m and  \u001b[4moff‐\u001b[24m\u001b[m\r\n\u001b[7m page bash(1) line 2107/8010 27% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3512.939453, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
