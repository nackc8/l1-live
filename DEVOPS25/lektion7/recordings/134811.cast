[3449.102319, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       or  disable brace expansion with the \u001b[1m+B\u001b[0m option to the \u001b[1mset\u001b[0m\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1994/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3449.134075, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       bility with \u001b[1msh\u001b[0m is desired, start \u001b[1mbash\u001b[0m with the \u001b[1m+B\u001b[0m  option\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1993/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3449.165544, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[4mfile1\u001b[24m  \u001b[4mfile2\u001b[24m after expansion by \u001b[1mbash\u001b[0m.  If strict compati‐\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1992/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3449.197592, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       identically in the output.  The same word  is  output  as\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1991/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3449.228462, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[3449.228535, "o", "\u001b[H\u001bM       For  example,  a  word entered to \u001b[1msh\u001b[0m as \u001b[4mfile{1,2}\u001b[24m appears\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1990/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3449.260448, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       braces from words as a consequence  of  brace  expansion.\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1989/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3449.291722, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       word,  and  preserves  them  in the output.  \u001b[1mBash\u001b[0m removes\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1988/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3449.322695, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       closing braces specially when they appear as  part  of  a\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1987/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3449.354203, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       historical  versions of \u001b[1msh\u001b[0m.  \u001b[1msh\u001b[0m does not treat opening or\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1986/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3449.517165, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       Brace expansion introduces a slight incompatibility  with\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1985/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3449.681135, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1984/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3450.182351, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              /usr/{ucb/{ex,edit},lib/{ex?.?*,how_ex}}\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1983/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
