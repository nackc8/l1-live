[3450.338592, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       than in the above example:\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1978/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3450.370422, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       common prefix of the strings to be  generated  is  longer\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1977/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3450.619113, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       This  construct  is  typically used as shorthand when the\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1976/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3450.792022, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1975/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3450.97904, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       until the closing \u001b[1m}\u001b[0m.\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1974/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3451.16691, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       gible for brace expansion, and inhibits  brace  expansion\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1973/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3451.362146, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[7mparameter expansion\u001b[27m, the string \u001b[1m${\u001b[0m is not considered eli‐\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1972/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3451.542036, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       ered part of a brace expression.  To avoid conflicts with\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1971/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3452.042758, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[3452.042882, "o", "\u001b[H\u001bM       be  quoted  with a backslash to prevent its being consid‐\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1970/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3452.07423, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       formed brace expansion is left unchanged.  A \u001b[1m{\u001b[0m or  \u001b[1m,\u001b[0m  may\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1969/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3452.105834, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       comma  or  a  valid sequence expression.  Any incorrectly\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1968/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3452.136793, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[3452.136921, "o", "\u001b[H\u001bM       opening and closing braces, and  at  least  one  unquoted\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1967/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3452.168186, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       A  correctly-formed brace expansion must contain unquoted\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1966/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3452.19996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1965/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3452.230924, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       the expansion or the text between the braces.\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1964/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3452.59882, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       not apply any syntactic interpretation to the context  of\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1963/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.099995, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       served in the result.  It is strictly textual.  \u001b[1mBash\u001b[0m does\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1962/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.131358, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       and any characters special to other expansions  are  pre‐\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1961/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.162315, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       Brace expansion is performed before any other expansions,\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1960/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.194553, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1959/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.22559, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       ate.\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1958/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.256632, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[3453.256723, "o", "\u001b[H\u001bM       each term.  The default increment is 1 or -1 as appropri‐\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1957/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.288848, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       ment  is  supplied,  it is used as the difference between\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1956/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.320183, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       be of the same type (integer or letter).  When the incre‐\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1955/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.351106, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       using  the default C locale.  Note that both \u001b[4mx\u001b[24m and \u001b[4my\u001b[24m must\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1954/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.382493, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       character lexicographically between \u001b[4mx\u001b[24m and  \u001b[4my\u001b[24m,  inclusive,\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1953/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.413613, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       letters  are  supplied,  the  expression  expands to each\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1952/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.445366, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       number of digits,  zero-padding  where  necessary.   When\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1951/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.476835, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       attempts to force all generated terms to contain the same\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1950/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.508707, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       width.  When either \u001b[4mx\u001b[24m or \u001b[4my\u001b[24m begins with a zero, the  shell\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1949/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3453.897395, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       prefixed  with  \u001b[4m0\u001b[24m  to  force  each  term to have the same\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1948/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
