[3450.275859, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              mkdir /usr/local/src/bash/{old,new,dist,bugs}\u001b[m\r\n\u001b[13;1H\r\u001b[K\u001b[7m page bash(1) line 1980/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
