[3426.769987, "o", "\u001b[1;1HBASH(1)              General Commands Manual             BASH(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       bash - GNU Bourne-Again SHell\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1mbash\u001b[0m [options] [command_string | file]\u001b[m\r\n\u001b[8;1H\u001b[m\r\n\u001b[9;1H\u001b[1mCOPYRIGHT\u001b[0m\u001b[m\r\n\u001b[10;1H       Bash  is  Copyright  (C)  1989-2022  by the Free Software\u001b[m\r\n\u001b[11;1H\u001b[1;1HBASH(1)              General Commands Manual             BASH(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       bash - GNU Bourne-Again SHell\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1mbash\u001b[0m [options] [command_string | file]\u001b[m\r\n\u001b[8;1H\u001b[m\r\n\u001b[9;1H\u001b[1mCOPYRIGHT\u001b[0m\u001b[m\r\n\u001b[10;1H       Bash  is  Copyright  (C)  1989-2022  by the Free Software\u001b[m\r\n\u001b[11;1H...skipping...\r\n       prevent \u001b[7mparameter expansion\u001b[27m.\u001b[m\r\n\u001b[m\r\n       Each of the \u001b[4mmetacharacters\u001b[24m listed above under \u001b[1mDEFINITIONS\u001b[0m\u001b[m\r\n       has special meaning to the shell and must be quoted if it\u001b[m\r\n       is to represent itself.\u001b[m\r\n\u001b[m\r"]
[3426.770004, "o", "\n       When the command h"]
[3426.771316, "o", "istory expansion facilities  are  being\u001b[m\r\n       used (see \u001b[1mHISTORY\u001b[0m \u001b[1mEXPANSION\u001b[0m below), the \u001b[4mhistory\u001b[24m \u001b[4mexpansion\u001b[24m\u001b[m\r\n       character, usually \u001b[1m!\u001b[0m, must be quoted to  prevent  history\u001b[m\r\n       expansion.\u001b[m\r\n\u001b[7mal page bash(1) line 724/8010 9% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3427.675492, "o", "\r\u001b[K/\r\u001b[K"]
[3427.676539, "o", "...skipping...\r\n              jected  to  \u001b[7mparameter expansion\u001b[27m, command substitu‐\u001b[m\r\n              tion, and arithmetic expansion before being inter‐\u001b[m\r\n              preted  as a filename.  \u001b[1mPATH\u001b[0m is not used to search\u001b[m\r\n              for the resultant filename.\u001b[m\r\n       \u001b[1mBASH_XTRACEFD\u001b[0m\u001b[m\r\n              If set to an integer corresponding to a valid file\u001b[m\r\n              descriptor,  \u001b[1mbash\u001b[0m will write the trace output gen‐\u001b[m\r\n              erated when \u001b[4mset\u001b[24m \u001b[4m-x\u001b[24m is enabled  to  that  file  de‐\u001b[m\r\n              scriptor.   The  file  descriptor  is  closed when\u001b[m\r\n              \u001b[1mBASH_XTRACEFD\u001b[0m is unset or assigned  a  new  value.\u001b[m\r\n\u001b[7m page bash(1) line 1370/8010 18% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3428.200809, "o", "\r\u001b[K/\r\u001b[K"]
[3428.201821, "o", "...skipping...\r\n       \u001b[7mparameter expansion\u001b[27m, the string \u001b[1m${\u001b[0m is not considered eli‐\u001b[m\r\n       gible for brace expansion, and inhibits  brace  expansion\u001b[m\r\n       until the closing \u001b[1m}\u001b[0m.\u001b[m\r\n\u001b[m\r\n       This  construct  is  typically used as shorthand when the\u001b[m\r\n       common prefix of the strings to be  generated  is  longer\u001b[m\r\n       than in the above example:\u001b[m\r\n\u001b[m\r\n              mkdir /usr/local/src/bash/{old,new,dist,bugs}\u001b[m\r\n       or\u001b[m\r\n\u001b[7m page bash(1) line 1972/8010 25% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3428.755832, "o", "\r\u001b[K/\r\u001b[K"]
[3428.756067, "o", "...skipping...\r\n   \u001b[1m\u001b[7mParameter\u001b[27m\u001b[0m\u001b[7m \u001b[27m\u001b[1m\u001b[7mExpansion\u001b[27m\u001b[0m\u001b[m\r\n       The `\u001b[1m$\u001b[0m' character introduces \u001b[7mparameter expansion\u001b[27m, command\u001b[m\r\n       substitution,  or  arithmetic  expansion.   The parameter\u001b[m\r\n       name or symbol to be expanded may be enclosed in  braces,\u001b[m\r\n       which  are  optional but serve to protect the variable to\u001b[m\r\n       be expanded  from  characters  immediately  following  it\u001b[m\r\n       which could be interpreted as part of the name.\u001b[m\r\n\u001b[m\r\n       When  braces  are  used, the matching ending brace is the\u001b[m\r\n       first `\u001b[1m}\u001b[0m' not escaped by a backslash or within  a  quoted\u001b[m\r\n\u001b[7m page bash(1) line 2040/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
[3434.546967, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[11;1H\r\u001b[K\u001b[7m page bash(1) line 2039/8010 26% (press h for help or q to quit)\u001b[27m\u001b[K"]
