[301.717427, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1madduser \u001b[22mand \u001b[1maddgroup \u001b[22mcan be run in one of five modes:\u001b[m\r\n\u001b[7m Manual page adduser(8) line 44 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.738369, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page adduser(8) line 45 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K   \u001b[1mAdd a regular (non-system) user\u001b[0m\u001b[m\r\n\u001b[7m Manual page adduser(8) line 46 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.758272, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       If  called  with  one non-option argument and without the \u001b[1m--system \u001b[22mor\u001b[m\r\n\u001b[7m Manual page adduser(8) line 47 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--group \u001b[22moptions, \u001b[1madduser \u001b[22mwill add a regular user, that means a \u001b[4mdynam‐\u001b[0m\u001b[m\r\n\u001b[7m Manual page adduser(8) line 48 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.777891, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[4mically\u001b[24m \u001b[4mallocated\u001b[24m \u001b[4muser\u001b[24m \u001b[4maccount\u001b[24m in the sense of Debian Policy.  This is\u001b[m\r\n\u001b[7m Manual page adduser(8) line 49 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       commonly referred to in \u001b[1madduser \u001b[22mas a \u001b[4mnon-system\u001b[24m \u001b[4muser.\u001b[0m\u001b[m\r\n\u001b[7m Manual page adduser(8) line 50 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.797612, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page adduser(8) line 51 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1madduser \u001b[22mwill choose the first available UID from the range  specified\u001b[m\r\n\u001b[7m Manual page adduser(8) line 52 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.837122, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       by  \u001b[1mFIRST_UID  \u001b[22mand \u001b[1mLAST_UID \u001b[22min the configuration file.  The range may\u001b[m\r\n\u001b[7m Manual page adduser(8) line 53 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[301.837244, "o", "       be overridden with the \u001b[1m--firstuid \u001b[22mand  \u001b[1m--lastuid  \u001b[22moptions.   Finally,\u001b[m\r\n\u001b[7m Manual page adduser(8) line 54 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.856378, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       the UID can be set fully manually with the \u001b[1m--uid \u001b[22moption.\u001b[m\r\n\u001b[7m Manual page adduser(8) line 55 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page adduser(8) line 56 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.875837, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       By  default,  each  user is given a corresponding group with the same\u001b[m\r\n\u001b[7m Manual page adduser(8) line 57 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.89514, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       name.  This is commonly called \u001b[4mUsergroups\u001b[24m and allows  group  writable\u001b[m\r\n\u001b[7m Manual page adduser(8) line 58 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.915821, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       directories  to be easily maintained by placing the appropriate users\u001b[m\r\n\u001b[7m Manual page adduser(8) line 59 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       in the new group, setting the set-group-ID bit in the directory,  and\u001b[m\r\n\u001b[7m Manual page adduser(8) line 60 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.935327, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       ensuring that all users use a umask of 002.\u001b[m\r\n\u001b[7m Manual page adduser(8) line 61 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.95419, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page adduser(8) line 62 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       For a usergroup, \u001b[1madduser \u001b[22mwill choose the first available GID from the\u001b[m\r\n\u001b[7m Manual page adduser(8) line 63 (press h for help or q to quit)\u001b[27m\u001b[K"]
[301.994371, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       range  specified by \u001b[1mFIRST_GID \u001b[22mand \u001b[1mLAST_GID \u001b[22min the configuration file.\u001b[m\r\n\u001b[7m Manual page adduser(8) line 64 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       The range may be overridden with the  \u001b[1m--firstgid  \u001b[22mand  \u001b[1m--lastgid  \u001b[22mop‐\u001b[m\r\n\u001b[7m Manual page adduser(8) line 65 (press h for help or q to quit)\u001b[27m\u001b[K"]
[302.013377, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       tions.  Finally, the GID can be set fully manually with the \u001b[1m--gid \u001b[22mop‐\u001b[m\r\n\u001b[7m Manual page adduser(8) line 66 (press h for help or q to quit)\u001b[27m\u001b[K"]
[302.032339, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       tion.\u001b[m\r\n\u001b[7m Manual page adduser(8) line 67 (press h for help or q to quit)\u001b[27m\u001b[K"]
