[300.337138, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1madduser \u001b[22mand \u001b[1maddgroup \u001b[22mby default choose Debian policy  conformant  UID\u001b[m\r\n\u001b[7m Manual page adduser(8) line 25 (press h for help or q to quit)\u001b[27m\u001b[K"]
[300.357336, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       and  GID values, create a home directory with skeletal configuration,\u001b[m\r\n\u001b[7m Manual page adduser(8) line 26 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       run a custom script, and have other features.\u001b[m\r\n\u001b[7m Manual page adduser(8) line 27 (press h for help or q to quit)\u001b[27m\u001b[K"]
[300.378164, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page adduser(8) line 28 (press h for help or q to quit)\u001b[27m\u001b[K"]
[300.760118, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1madduser \u001b[22mand \u001b[1maddgroup \u001b[22mare intended as a policy layer, making it easier\u001b[m\r\n\u001b[7m Manual page adduser(8) line 29 (press h for help or q to quit)\u001b[27m\u001b[K"]
[300.779884, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       for package maintainers and local administrators to create local sys‐\u001b[m\r\n\u001b[7m Manual page adduser(8) line 30 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       tem accounts in the way Debian expects them to be created, taking the\u001b[m\r\n\u001b[7m Manual page adduser(8) line 31 (press h for help or q to quit)\u001b[27m\u001b[K"]
[300.799821, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       burden to adapt to the probably  changing  specifications  of  Debian\u001b[m\r\n\u001b[7m Manual page adduser(8) line 32 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       policy.   \u001b[1madduser  --system \u001b[22mtakes special attention on just needing a\u001b[m\r\n\u001b[7m Manual page adduser(8) line 33 (press h for help or q to quit)\u001b[27m\u001b[K"]
[300.819116, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       single call in the package maintainer scripts without any conditional\u001b[m\r\n\u001b[7m Manual page adduser(8) line 34 (press h for help or q to quit)\u001b[27m\u001b[K"]
