[302.073656, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       The interaction between \u001b[1mUSERS_GID\u001b[22m, \u001b[1mUSERS_GROUP\u001b[22m, and \u001b[1mUSERGROUPS \u001b[22mis ex‐\u001b[m\r\n\u001b[7m Manual page adduser(8) line 69 (press h for help or q to quit)\u001b[27m\u001b[K"]
[302.093371, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       plained in detail in \u001b[1madduser.conf\u001b[22m(5).\u001b[m\r\n\u001b[7m Manual page adduser(8) line 70 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page adduser(8) line 71 (press h for help or q to quit)\u001b[27m\u001b[K"]
[302.113802, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       The  new user's primary group can also be overridden from the command\u001b[m\r\n\u001b[7m Manual page adduser(8) line 72 (press h for help or q to quit)\u001b[27m\u001b[K"]
[302.133208, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       line with the \u001b[1m--gid \u001b[22mor \u001b[1m--ingroup \u001b[22moptions to set the group  by  id  or\u001b[m\r\n\u001b[7m Manual page adduser(8) line 73 (press h for help or q to quit)\u001b[27m\u001b[K"]
[302.154107, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       name,  respectively.  Also, users can be added to one or more supple‐\u001b[m\r\n\u001b[7m Manual page adduser(8) line 74 (press h for help or q to quit)\u001b[27m\u001b[K"]
[302.656015, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page adduser(8) line 73 (press h for help or q to quit)\u001b[27m\u001b[K"]
[302.674969, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       commonly referred to in \u001b[1madduser \u001b[22mas a \u001b[4mnon-system\u001b[24m \u001b[4muser.\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page adduser(8) line 72 (press h for help or q to quit)\u001b[27m\u001b[K"]
[302.714416, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[4mically\u001b[24m \u001b[4mallocated\u001b[24m \u001b[4muser\u001b[24m \u001b[4maccount\u001b[24m in the sense of Debian Policy.  This is\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page adduser(8) line 71 (press h for help or q to quit)\u001b[27m\u001b[K"]
[302.734484, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m--group \u001b[22moptions, \u001b[1madduser \u001b[22mwill add a regular user, that means a \u001b[4mdynam‐\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page adduser(8) line 70 (press h for help or q to quit)\u001b[27m\u001b[K"]
[302.775014, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       If  called  with  one non-option argument and without the \u001b[1m--system \u001b[22mor\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page adduser(8) line 69 (press h for help or q to quit)\u001b[27m\u001b[K"]
[303.071338, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM   \u001b[1mAdd a regular (non-system) user\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page adduser(8) line 68 (press h for help or q to quit)\u001b[27m\u001b[K"]
[303.091062, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page adduser(8) line 67 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1madduser \u001b[22mand \u001b[1maddgroup \u001b[22mcan be run in one of five modes:\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page adduser(8) line 66 (press h for help or q to quit)\u001b[27m\u001b[K"]
