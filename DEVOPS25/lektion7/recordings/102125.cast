[811.872339, "o", "\u001b[4mDASH\u001b[24m(1)                    General Commands Manual                   \u001b[4mDASH\u001b[24m(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       dash — command interpreter (shell)\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mdash   \u001b[22m[\u001b[1m-aCefnuvxIimqVEbp\u001b[22m]   [\u001b[1m+aCefnuvxIimqVEbp\u001b[22m]   [\u001b[1m-o   \u001b[4m\u001b[22moption_name\u001b[24m]\u001b[m\r\n            [\u001b[1m+o \u001b[4m\u001b[22moption_name\u001b[24m] [\u001b[4mcommand_file\u001b[24m [\u001b[4margument\u001b[24m \u001b[4m...\u001b[24m]]\u001b[m\r\n       \u001b[1mdash  -c  \u001b[22m[\u001b[1m-aCefnuvxIimqVEbp\u001b[22m]  [\u001b[1m+aCefnuvxIimqVEbp\u001b[22m]  [\u001b[1m-o  \u001b[4m\u001b[22moption_name\u001b[24m]\u001b[m\r\n            [\u001b[1m+o \u001b[4m\u001b[22moption_name\u001b[24m] \u001b[4mcommand_string\u001b[24m [\u001b[4mcommand_name\u001b[24m [\u001b[4margument\u001b[24m \u001b[4m...\u001b[24m]]\u001b[m\r\n       \u001b[1mdash  -s  \u001b[22m[\u001b[1m-aCefnuvxIimqVEbp\u001b[22m]  [\u001b[1m+aCefnuvxIimqVEbp\u001b[22m]  [\u001b[1m-o  \u001b[4m\u001b[22moption_name\u001b[24m]\u001b[m\r\n            [\u001b[1m+o \u001b[4m\u001b[22moption_name\u001b[24m] [\u001b[4margument\u001b[24m \u001b[4m...\u001b[24m]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       \u001b[1mdash \u001b[22mis the standard command interpreter for the system.  The current\u001b[m\r\n       version of \u001b[1mdash \u001b[22mis in the process of being changed  to  conform  with\u001b[m\r\n       the POSIX 1003.2 and 1003.2a specifications for the shell.  This ver‐\u001b[m\r\n       sion  has many features which make it appear similar in some respects\u001b[m\r\n       to the Korn shell, but it is not a Korn  shell  clone  (see  \u001b[4mksh\u001b[24m(1)).\u001b[m\r\n       Only  features  designated  by POSIX, plus a few Berkeley extensions,\u001b[m\r\n       are being incorporated into this shell.  This man  page  is  not  in‐\u001b[m\r\n       tended to be a tutorial or a complete specification of the shell.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page dash(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
