[1437.888043, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page useradd(8) line 113 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1437.928491, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           By default, the user's entries in the lastlog and faillog\u001b[m\r\n\u001b[7m Manual page useradd(8) line 114 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1437.947937, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           databases are reset to avoid reusing the entry from a previously\u001b[m\r\n\u001b[7m Manual page useradd(8) line 115 (press h for help or q to quit)\u001b[27m\u001b[K"]
