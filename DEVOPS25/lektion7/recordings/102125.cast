[1901.517483, "o", "\u001b[4Dls --version \r\n\u001b[1m\u001b[4m-\u001b[m-block-size                                          (\u001b[33m\u001b[3mSet block size\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-color  \u001b[1m\u001b[4m-\u001b[m-color=                                         (\u001b[33m\u001b[3mUse colors\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-dereference-command-line-symlink-to-dir                             \r\n\u001b[1m\u001b[4m-\u001b[m-format                                                 (\u001b[33m\u001b[3mList format\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-full-time                               (\u001b[33m\u001b[3mLong format, full-iso time\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-group-directories-first             (\u001b[33m\u001b[3mGroup directories before files\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-help                                         (\u001b[33m\u001b[3mDisplay help and exit\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-hide  (\u001b[33m\u001b[3mDo not list implied entries matching specified shell pattern\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-lcontext                                  (\u001b[33m\u001b[3mDisplay security context\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-quoting-style                                 (\u001b[33m\u001b[3mSelect quoting style\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-scontext               (\u001b[33m\u001b[3mDisplay only security context and file name\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-show-control-chars            (\u001b[33m\u001b[3mNon-graphic characters printed as-is\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-si                            (\u001b[33m\u001b[3mHuman readable sizes, powers of 1000\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-sort                                                 (\u001b[33m\u001b[3mSort criteria\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-time                                                (\u001b[33m\u001b[3mShow time type\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[m-time-style            