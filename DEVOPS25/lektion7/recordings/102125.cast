[1906.751255, "o", "\u001b[13Dls -1 \u001b[K\r\n\u001b[1m\u001b[4m\u001b[7m-\u001b[m\u001b[7m1                                           (\u001b[33m\u001b[3mList one entry per line\u001b[m\u001b[7m)\u001b[m\r\n\u001b[1m\u001b[4m-\u001b[mA  \u001b[1m\u001b[4m-\u001b[m-almost-all                         (\u001b[33m\u001b[3mShow hidden except . and ..\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[ma  \u001b[1m\u001b[4m-\u001b[m-all                                                (\u001b[33m\u001b[3mShow hidden\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mB  \u001b[1m\u001b[4m-\u001b[m-ignore-backups                      (\u001b[33m\u001b[3mIgnore files ending with ~\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mb  \u001b[1m\u001b[4m-\u001b[m-escape                (\u001b[33m\u001b[3mOctal escapes for non-graphic characters\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mC                                         (\u001b[33m\u001b[3mForce multi-column output\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mc                             (\u001b[33m\u001b[3mSort by changed time, (-l) show ctime\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mD  \u001b[1m\u001b[4m-\u001b[m-dired                                    (\u001b[33m\u001b[3mGenerate dired output\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[md  \u001b[1m\u001b[4m-\u001b[m-directory                  (\u001b[33m\u001b[3mList directories, not their content\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mF  \u001b[1m\u001b[4m-\u001b[m-classify                    (\u001b[33m\u001b[3mAppend filetype indicator (*/=>@|)\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mf                                       (\u001b[33m\u001b[3mUnsorted output, enables -a\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mG  \u001b[1m\u001b[4m-\u001b[m-no-group                         (\u001b[33m\u001b[3mDon't print group information\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mH  \u001b[1m\u001b[4m-\u001b[mL  \u001b[1m\u001b[4m-\u001b[m-dereference  \u001b[1m\u001b[4m-\u001b[m-dereference-command-line    (\u001b[33m\u001b[3mFollow symlinks\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mh  \u001b[1m\u001b[4m-\u001b[m-human-readable                            (\u001b[33m\u001b[3mHuman readable sizes\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mI  \u001b[1m\u001b[4m-\u001b[m-ignore                           (\u001b[33m\u001b[3mSkip entries matching pattern\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mi  \u001b[1m\u001b[4m-\u001b[m-inode                              (\u001b[33m\u001b[3mPrint inode number of files\u001b[m)\r\n\u001b[1m\u001b[4m-\u001b[mk                                              (\u001b[33m\u001b[3mSet blocksize to 1kB\u001b[m)\r\n\u001b[5C\u001b[97m\u001b[46m\u001b[1m1 to 17 of 56\u001b[m\u001b[K\r\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[21C"]
