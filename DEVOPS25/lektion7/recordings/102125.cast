[1979.598064, "o", "\u001b[4mUSERDEL\u001b[24m(8)               System Management Commands               \u001b[4mUSERDEL\u001b[24m(8)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       userdel - delete a user account and related files\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1muserdel \u001b[22m[options] \u001b[4mLOGIN\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       \u001b[1muserdel \u001b[22mis a low level utility for removing users. On Debian,\u001b[m\r\n       administrators should usually use \u001b[1mdeluser\u001b[22m(8) instead.\u001b[m\r\n\u001b[m\r\n       The \u001b[1muserdel \u001b[22mcommand modifies the system account files, deleting all\u001b[m\r\n       entries that refer to the user name \u001b[4mLOGIN\u001b[24m. The named user must exist.\u001b[m\r\n\u001b[m\r\n\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n       The options which apply to the \u001b[1muserdel \u001b[22mcommand are:\u001b[m\r\n\u001b[7m Manual page userdel(8) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1981.157083, "o", "\r\u001b[K\u001b[m\r\n       \u001b[1m-f\u001b[22m, \u001b[1m--force\u001b[0m\u001b[m\r\n           This option forces the removal of the user account and any other\u001b[m\r\n           requested actions, skipping any safety checks.\u001b[m\r\n\u001b[m\r\n           \u001b[4mNote:\u001b[24m This option is dangerous and may leave your system in an\u001b[m\r\n           inconsistent state.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-h\u001b[22m, \u001b[1m--help\u001b[0m\u001b[m\r\n           Display help message and exit.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-r\u001b[22m, \u001b[1m--remove\u001b[0m\u001b[m\r\n           Files in the user's home directory will be removed along with the\u001b[m\r\n           home directory itself and the user's mail spool. Files located in\u001b[m\r\n           other file systems will have to be searched for and deleted\u001b[m\r\n           manually.\u001b[m\r\n\u001b[m\r\n           The mail spool is defined by the \u001b[1mMAIL_DIR \u001b[22mvariable in the\u001b[m\r\n\u001b[7m Manual page userdel(8) line 19 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1984.883172, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           login.defs file.\u001b[m\r\n\u001b[7m Manual page userdel(8) line 20 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1984.944972, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page userdel(8) line 21 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1984.986818, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-R\u001b[22m, \u001b[1m--root \u001b[4m\u001b[22mCHROOT_DIR\u001b[0m\u001b[m\r\n\u001b[7m Manual page userdel(8) line 22 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1985.050877, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Apply changes in the \u001b[4mCHROOT_DIR\u001b[24m directory and use the\u001b[m\r\n\u001b[7m Manual page userdel(8) line 23 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1985.557377, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           configuration files from the \u001b[4mCHROOT_DIR\u001b[24m directory. Only absolute\u001b[m\r\n\u001b[7m Manual page userdel(8) line 24 (press h for help or q to quit)\u001b[27m\u001b[K"]
