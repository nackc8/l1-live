[299.731157, "o", "\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[7m Manual page adduser(8) line 20 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1madduser  \u001b[22mand \u001b[1maddgroup \u001b[22madd users and groups to the system according to\u001b[m\r\n\u001b[7m Manual page adduser(8) line 21 (press h for help or q to quit)\u001b[27m\u001b[K"]
[299.752195, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       command  line  options  and  configuration  information  in  \u001b[4m/etc/ad‐\u001b[0m\u001b[m\r\n\u001b[7m Manual page adduser(8) line 22 (press h for help or q to quit)\u001b[27m\u001b[K"]
[300.316163, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[4mduser.conf\u001b[24m.  They are more Debian specific front ends to the \u001b[1museradd\u001b[22m,\u001b[m\r\n\u001b[7m Manual page adduser(8) line 23 (press h for help or q to quit)\u001b[27m\u001b[K"]
