[1438.215681, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Create the user's home directory if it does not exist. The files\u001b[m\r\n\u001b[7m Manual page useradd(8) line 123 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1438.233907, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           and directories contained in the skeleton directory (which can be\u001b[m\r\n\u001b[7m Manual page useradd(8) line 124 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1438.273703, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           defined with the \u001b[1m-k \u001b[22moption) will be copied to the home directory.\u001b[m\r\n\u001b[7m Manual page useradd(8) line 125 (press h for help or q to quit)\u001b[27m\u001b[K"]
