[1653.445325, "o", "\u001b[?1049h\u001b[22;0;0t\u001b[24;1H\u001b[?1h\u001b=\r"]
[1653.457616, "o", "\u001b[4mUSERMOD\u001b[24m(8)               System Management Commands               \u001b[4mUSERMOD\u001b[24m(8)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       usermod - modify a user account\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1musermod \u001b[22m[\u001b[4moptions\u001b[24m] \u001b[4mLOGIN\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       The \u001b[1musermod \u001b[22mcommand modifies the system account files.\u001b[m\r\n\u001b[m\r\n\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n       The options which apply to the \u001b[1musermod \u001b[22mcommand are:\u001b[m\r\n\u001b[m\r\n       \u001b[1m-a\u001b[22m, \u001b[1m--append\u001b[0m\u001b[m\r\n           Add the user to the supplementary group(s). Use only with the \u001b[1m-G\u001b[0m\u001b[m\r\n           option.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-b\u001b[22m, \u001b[1m--badname\u001b[0m\u001b[m\r\n           Allow names that do not conform to standards.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-c\u001b[22m, \u001b[1m--comment \u001b[4m\u001b[22mCOMMENT\u001b[0m\u001b[m\r\n\u001b[7m Manual page usermod(8) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1662.318062, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           update the comment field of the user in /etc/passwd, which is\u001b[m\r\n\u001b[7m Manual page usermod(8) line 2 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1662.399352, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           normally modified using the \u001b[1mchfn\u001b[22m(1) utility.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 3 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1662.480597, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 4 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1662.579639, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-d\u001b[22m, \u001b[1m--home \u001b[4m\u001b[22mHOME_DIR\u001b[0m\u001b[m\r\n\u001b[7m Manual page usermod(8) line 5 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1662.943484, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The user's new login directory.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 6 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 7 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1662.983991, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If the \u001b[1m-m \u001b[22moption is given, the contents of the current home\u001b[m\r\n\u001b[7m Manual page usermod(8) line 8 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1681.873812, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           directory will be moved to the new home directory, which is\u001b[m\r\n\u001b[7m Manual page usermod(8) line 9 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1682.029059, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           created if it does not already exist. If the current home\u001b[m\r\n\u001b[7m Manual page usermod(8) line 10 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1682.067539, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           directory does not exist the new home directory will not be\u001b[m\r\n\u001b[7m Manual page usermod(8) line 11 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1682.128838, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           created.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 12 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1682.169209, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 13 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1682.187894, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-e\u001b[22m, \u001b[1m--expiredate \u001b[4m\u001b[22mEXPIRE_DATE\u001b[0m\u001b[m\r\n\u001b[7m Manual page usermod(8) line 14 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1682.207464, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The date on which the user account will be disabled. The date is\u001b[m\r\n\u001b[7m Manual page usermod(8) line 15 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1682.541204, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           specified in the format \u001b[4mYYYY-MM-DD\u001b[24m. Integers as input are\u001b[m\r\n\u001b[7m Manual page usermod(8) line 16 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1682.581394, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           interpreted as days after 1970-01-01.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 17 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 18 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1682.601125, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           An input of -1 or an empty string will blank the account\u001b[m\r\n\u001b[7m Manual page usermod(8) line 19 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1682.640975, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           expiration field in the shadow password file. The account will\u001b[m\r\n\u001b[7m Manual page usermod(8) line 20 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1683.95218, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           remain available with no date limit.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 21 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1683.992013, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 22 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[1683.992081, "o", "           This option requires a /etc/shadow file. A /etc/shadow entry will\u001b[m\r\n\u001b[7m Manual page usermod(8) line 23 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1684.011305, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[1684.01161, "o", "           be created if there were none.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 24 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1684.031061, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 25 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1684.092445, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-f\u001b[22m, \u001b[1m--inactive \u001b[4m\u001b[22mINACTIVE\u001b[0m\u001b[m\r\n\u001b[7m Manual page usermod(8) line 26 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1684.435257, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           defines the number of days after the password exceeded its\u001b[m\r\n\u001b[7m Manual page usermod(8) line 27 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1684.454621, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           maximum age during which the user may still login by immediately\u001b[m\r\n\u001b[7m Manual page usermod(8) line 28 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1684.454806, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           replacing the password. This grace period before the account\u001b[m\r\n\u001b[7m Manual page usermod(8) line 29 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1684.475053, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           becomes inactive is stored in the shadow password file. An input\u001b[m\r\n\u001b[7m Manual page usermod(8) line 30 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1684.937448, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           of 0 will disable an expired password with no delay. An input of\u001b[m\r\n\u001b[7m Manual page usermod(8) line 31 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1684.957361, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           -1 will blank the respective field in the shadow password file.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 32 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1684.957441, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           See \u001b[1mshadow\u001b[22m(5) for more information.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 33 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1684.997679, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 34 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1685.444222, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option requires a /etc/shadow file. A /etc/shadow entry will\u001b[m\r\n\u001b[7m Manual page usermod(8) line 35 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1685.46298, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           be created if there were none.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 36 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1685.482514, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 37 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1685.503645, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-g\u001b[22m, \u001b[1m--gid \u001b[4m\u001b[22mGROUP\u001b[0m\u001b[m\r\n\u001b[7m Manual page usermod(8) line 38 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1685.9121, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The name or numerical ID of the user's new primary group. The\u001b[m\r\n\u001b[7m Manual page usermod(8) line 39 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           group must exist.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 40 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1685.932502, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 41 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Any file from the user's home directory owned by the previous\u001b[m\r\n\u001b[7m Manual page usermod(8) line 42 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1685.953167, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           primary group of the user will be owned by this new group.\u001b[m\r\n\u001b[7m Manual page usermod(8) line 43 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1685.953241, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page usermod(8) line 44 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1686.013222, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The group ownership of files outside of the user's home directory\u001b[m\r\n\u001b[7m Manual page usermod(8) line 45 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1687.48302, "o", "\r\u001b[K           must be fixed manually.\u001b[m\r\n\u001b[m\r\n           The change of the group ownership of files inside of the user's\u001b[m\r\n           home directory is also not done if the home dir owner uid is\u001b[m\r\n           different from the current or new user id. This is a safety\u001b[m\r\n           measure for special home directories such as /.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-G\u001b[22m, \u001b[1m--groups \u001b[4m\u001b[22mGROUP1\u001b[24m[\u001b[4m,GROUP2,...\u001b[24m[\u001b[4m,GROUPN\u001b[24m]]]\u001b[m\r\n           A list of supplementary groups which the user is also a member\u001b[m\r\n           of. Each group is separated from the next by a comma, with no\u001b[m\r\n           intervening whitespace. The groups must exist.\u001b[m\r\n\u001b[m\r\n           If the user is currently a member of a group which is not listed,\u001b[m\r\n           the user will be removed from the group. This behaviour can be\u001b[m\r\n           changed via the \u001b[1m-a \u001b[22moption, which appends the user to the current\u001b[m\r\n           supplementary group list.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-l\u001b[22m, \u001b[1m--login \u001b[4m\u001b[22mNEW_LOGIN\u001b[0m\u001b[m\r\n           The name of the user will be changed from \u001b[4mLOGIN\u001b[24m to \u001b[4mNEW_LOGIN\u001b[24m.\u001b[m\r\n           Nothing else is changed. In particular, the user's home directory\u001b[m\r\n           or mail spool should probably be renamed manually to reflect the\u001b[m\r\n           new login name.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page usermod(8) line 68 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1690.234883, "o", "\r\u001b[K       \u001b[1m-L\u001b[22m, \u001b[1m--lock\u001b[0m\u001b[m\r\n           Lock a user's password. This puts a '!' in front of the encrypted\u001b[m\r\n           password, effectively disabling the password. You can't use this\u001b[m\r\n           option with \u001b[1m-p \u001b[22mor \u001b[1m-U\u001b[22m.\u001b[m\r\n\u001b[m\r\n           Note: if you wish to lock the account (not only access with a\u001b[m\r\n           password), you should also set the \u001b[4mEXPIRE_DATE\u001b[24m to \u001b[4m1\u001b[24m.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-m\u001b[22m, \u001b[1m--move-home\u001b[0m\u001b[m\r\n           moves the content of the user's home directory to the new\u001b[m\r\n           location. If the current home directory does not exist the new\u001b[m\r\n           home directory will not be created.\u001b[m\r\n\u001b[m\r\n           This option is only valid in combination with the \u001b[1m-d \u001b[22m(or \u001b[1m--home\u001b[22m)\u001b[m\r\n           option.\u001b[m\r\n\u001b[m\r\n           \u001b[1musermod \u001b[22mwill try to adapt the ownership of the files and to copy\u001b[m\r\n           the modes, ACL and extended attributes, but manual changes might\u001b[m\r\n           be needed afterwards.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-o\u001b[22m, \u001b[1m--non-unique\u001b[0m\u001b[m\r\n           allows to change the user ID to a non-unique value.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page usermod(8) line 91 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1692.867672, "o", "\r\u001b[K           This option is only valid in combination with the \u001b[1m-u \u001b[22moption. As a\u001b[m\r\n           user identity serves as key to map between users on one hand and\u001b[m\r\n           permissions, file ownerships and other aspects that determine the\u001b[m\r\n           system's behavior on the other hand, more than one login name\u001b[m\r\n           will access the account of the given UID.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-p\u001b[22m, \u001b[1m--password \u001b[4m\u001b[22mPASSWORD\u001b[0m\u001b[m\r\n           defines a new password for the user. PASSWORD is expected to be\u001b[m\r\n           encrypted, as returned by \u001b[1mcrypt \u001b[22m(3).\u001b[m\r\n\u001b[m\r\n           \u001b[1mNote: \u001b[22mAvoid this option on the command line because the password\u001b[m\r\n           (or encrypted password) will be visible by users listing the\u001b[m\r\n           processes.\u001b[m\r\n\u001b[m\r\n           The password will be written in the local /etc/passwd or\u001b[m\r\n           /etc/shadow file. This might differ from the password database\u001b[m\r\n           configured in your PAM configuration.\u001b[m\r\n\u001b[m\r\n           You should make sure the password respects the system's password\u001b[m\r\n           policy.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-r\u001b[22m, \u001b[1m--remove\u001b[0m\u001b[m\r\n           Remove the user from named supplementary group(s). Use only with\u001b[m\r\n\u001b[7m Manual page usermod(8) line 114 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1694.656462, "o", "\r\u001b[K           the \u001b[1m-G \u001b[22moption.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-R\u001b[22m, \u001b[1m--root \u001b[4m\u001b[22mCHROOT_DIR\u001b[0m\u001b[m\r\n           Apply changes in the \u001b[4mCHROOT_DIR\u001b[24m directory and use the\u001b[m\r\n           configuration files from the \u001b[4mCHROOT_DIR\u001b[24m directory. Only absolute\u001b[m\r\n           paths are supported.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-P\u001b[22m, \u001b[1m--prefix \u001b[4m\u001b[22mPREFIX_DIR\u001b[0m\u001b[m\r\n           Apply changes within the directory tree starting with \u001b[4mPREFIX_DIR\u001b[0m\u001b[m\r\n           and use as well the configuration files located there. This\u001b[m\r\n           option does not chroot and is intended for preparing a\u001b[m\r\n           cross-compilation target. Some limitations: NIS and LDAP\u001b[m\r\n           users/groups are not verified. PAM authentication is using the\u001b[m\r\n           host files. No SELINUX support.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-s\u001b[22m, \u001b[1m--shell \u001b[4m\u001b[22mSHELL\u001b[0m\u001b[m\r\n           changes the user's login shell. An empty string for SHELL blanks\u001b[m\r\n           the field in /etc/passwd and logs the user into the system's\u001b[m\r\n           default shell.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-u\u001b[22m, \u001b[1m--uid \u001b[4m\u001b[22mUID\u001b[0m\u001b[m\r\n           The new value of the user's ID.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page usermod(8) line 137 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1699.363486, "o", "\r\u001b[K\u001b[?1l\u001b>\u001b[?1049l\u001b[23;0;0t"]
