[1438.370811, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           not enabled, no home directories are created.\u001b[m\r\n\u001b[7m Manual page useradd(8) line 128 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1438.40894, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page useradd(8) line 129 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1438.428527, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The directory where the user's home directory is created must\u001b[m\r\n\u001b[7m Manual page useradd(8) line 130 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1438.875072, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           exist and have proper SELinux context and permissions. Otherwise\u001b[m\r\n\u001b[7m Manual page useradd(8) line 131 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1439.363329, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           the user's home directory cannot be created or accessed.\u001b[m\r\n\u001b[7m Manual page useradd(8) line 132 (press h for help or q to quit)\u001b[27m\u001b[K"]
