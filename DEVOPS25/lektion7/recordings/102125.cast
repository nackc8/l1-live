[1434.110941, "o", "\u001b]3008;start=7833b0f7-e8dc-4cc5-93b7-294dfee7ebf0;machineid=99989d8765784683978eb13428149c42;user=kent;hostname=ubse;bootid=d931ba01-ba68-4e26-9234-e474d333f75b;pid=00000000000000002633;type=command;cwd=/home/kent\u001b\\man useradd\r\n\u001b[?1049h\u001b[22;0;0t\u001b[24;1H\u001b[?1h\u001b=\r\u001b[H\u001b[2J\u001b[H       \u001b[1m-h\u001b[22m, \u001b[1m--help\u001b[0m\u001b[m\r\n           Display help message and exit.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-k\u001b[22m, \u001b[1m--skel \u001b[4m\u001b[22mSKEL_DIR\u001b[0m\u001b[m\r\n           The skeleton directory, which contains files and directories to\u001b[m\r\n           be copied in the user's home directory, when the home directory\u001b[m\r\n           is created by \u001b[1museradd\u001b[22m.\u001b[m\r\n\u001b[m\r\n           This option is only valid if the \u001b[1m-m \u001b[22m(or \u001b[1m--create-home\u001b[22m) option is\u001b[m\r\n           specified.\u001b[m\r\n\u001b[m\r\n           If this option is not set, the skeleton directory is defined by\u001b[m\r\n           the \u001b[1mSKEL \u001b[22mvariable in /etc/default/useradd or, by default,\u001b[m\r\n           /etc/skel.\u001b[m\r\n\u001b[m\r\n           Absolute symlinks that link back to the skel directory will have\u001b[m\r\n           the /etc/skel prefix replaced with the user's home directory.\u001b[m\r\n\u001b[m\r\n           If possible, the ACLs and extended attributes are copied.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-K\u001b[22m, \u001b[1m--key \u001b[4m\u001b[22mKEY\u001b[24m=\u001b[4mVALUE\u001b[0m\u001b[m\r\n           Overrides /etc/login.defs defaults (\u001b[1mUID_MIN\u001b[22m, \u001b[1mUID_MAX\u001b[22m, \u001b[1mUMASK\u001b[22m,\u001b[m\r\n           \u001b[1mPASS_MAX_DAYS \u001b[22mand others).\u001b[m\r\n\u001b[7m Manual page useradd(8) line 105 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1437.190669, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page useradd(8) line 106 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1437.696042, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Example: \u001b[1m-K \u001b[4m\u001b[22mPASS_MAX_DAYS\u001b[24m =\u001b[4m-1\u001b[24m can be used when creating an\u001b[m\r\n\u001b[7m Manual page useradd(8) line 107 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1437.735491, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           account to turn off password aging. Multiple \u001b[1m-K \u001b[22moptions can be\u001b[m\r\n\u001b[7m Manual page useradd(8) line 108 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1437.773892, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           specified, e.g.: \u001b[1m-K \u001b[4m\u001b[22mUID_MIN\u001b[24m =\u001b[4m100\u001b[24m \u001b[1m-K  \u001b[4m\u001b[22mUID_MAX\u001b[24m=\u001b[4m499\u001b[0m\u001b[m\r\n\u001b[7m Manual page useradd(8) line 109 (press h for help or q to quit)\u001b[27m\u001b[K"]
