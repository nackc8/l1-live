[1438.02308, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page useradd(8) line 117 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1438.04221, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[1438.042658, "o", "           If this option is not specified, \u001b[1museradd \u001b[22mwill also consult the\u001b[m\r\n\u001b[7m Manual page useradd(8) line 118 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1438.081378, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           variable \u001b[1mLOG_INIT \u001b[22min the /etc/default/useradd if set to no the\u001b[m\r\n\u001b[7m Manual page useradd(8) line 119 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1438.118901, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           user will not be added to the lastlog and faillog databases.\u001b[m\r\n\u001b[7m Manual page useradd(8) line 120 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1438.138103, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page useradd(8) line 121 (press h for help or q to quit)\u001b[27m\u001b[K"]
