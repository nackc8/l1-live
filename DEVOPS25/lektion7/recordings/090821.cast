[386.034853, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K        while ! mkdir \"$___BASHRC_FOREGROUND_FILE_LOCK_DIR\" 2> \b:\u001b[K"]
[386.045895, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K/dev/null; do\r\n:\u001b[K"]
