[386.112494, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[386.112594, "o", "            \"${COMPLETE_LINE_QUOTED} | tee '$IN_PROGRESS' && m \b:\u001b[K"]
[386.123702, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[386.123791, "o", "v '$IN_PROGRESS' '$CACHED'\" \\\r\n:\u001b[K"]
[386.134778, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K            \"rm -f '$IN_PROGRESS'\"\r\n:\u001b[K"]
[386.14591, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
