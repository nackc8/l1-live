[386.457341, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K    for FILE in $(ls -1t ___BASHRC_*); do\r\n:\u001b[K"]
[386.47985, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K        [[ -f $FILE ]] || continue\r\n:\u001b[K"]
[386.490977, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\r\n:\u001b[K"]
[386.501894, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K        if [[ -z $DELETE_PIDS ]]; then\r\n:\u001b[K"]
[386.513189, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K            MTIME=$(stat -c %Y \"$FILE\")\r\n:\u001b[K"]
[386.524232, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K            ((NOW - MTIME >= 600)) && DELETE_PIDS=1\r\n:\u001b[K"]
[386.534974, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[386.535003, "o", "        fi\r\n:\u001b[K"]
