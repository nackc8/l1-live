[369.650203, "o", "\r\n\u001b[?2004l\r"]
[369.653424, "o", "\u001b[?1049h\u001b[22;0;0t\u001b[?1h\u001b=\r# shellcheck shell=bash\r\n\r\n# shellcheck disable=SC1090,SC2155\r\n\r\n# Do not execute this script if it's not an interactive shell\r\n[[ $- != *i* ]] && return\r\n\r\n__BASHRC_DEBUG_OUTPUT() {\r\n    if [ -z \"$__BASHRC_START_TIME_MS\" ]; then\r\n        __BASHRC_START_TIME_MS=\"$(($(date +%s%N) / 1000000))\"\r\n    fi\r\n\r\n    if [ -n \"$__BASHRC_DEBUG\" ]; then\r\n        __BASHRC_TIME_MS=$((($(date +%s%N) / 1000000) - __BASH \b\u001b[7m.bashrc\u001b[27m\u001b[K"]
[376.914607, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[KRC_START_TIME_MS))\r\n:\u001b[K"]
[377.1802, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\r\n:\u001b[K"]
[377.261461, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K        printf \"%04d: %s\\n\" \"$__BASHRC_TIME_MS\" \"$1\" 1>&2\r\n:\u001b[K"]
[377.315624, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K    fi\r\n:\u001b[K"]
[377.40436, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[377.404379, "o", "}\r\n:\u001b[K"]
[379.160918, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[379.160993, "o", "\r\n:\u001b[K"]
[379.183497, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[Kexport -f __BASHRC_DEBUG_OUTPUT\r\n:\u001b[K"]
[379.217587, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\r\n:\u001b[K"]
[379.255919, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[379.25605, "o", "___BASHRC_GET_GUARD_ID() {\r\n:\u001b[K"]
[379.289196, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K    echo \"___BASHRC_${1%.*}\" | tr ' /' '__' | tr '[:lower:]' ' \b:\u001b[K"]
[379.330709, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K[:upper:]' | tr -d -c '[:upper:]_'\r\n:\u001b[K"]
[379.429637, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K}\r\n:\u001b[K"]
[379.819455, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\r\n:\u001b[K"]
[379.850696, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K__BASHRC_SOURCE() {\r\n:\u001b[K"]
[379.872568, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K    local GUARD_ID=\"$(___BASHRC_GET_GUARD_ID \"$1\")\"\r\n:\u001b[K"]
[379.88647, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K    __BASHRC_DEBUG_OUTPUT \"'$1' has GUARD_ID '$GUARD_ID'\"\r\n:\u001b[K"]
[380.276548, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\r\n:\u001b[K"]
