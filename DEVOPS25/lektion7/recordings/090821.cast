[386.213138, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K    while ! mkdir \"$___BASHRC_BACKGROUND_PIDS_FILE_LOCK_DIR\" 2 \b:\u001b[K"]
