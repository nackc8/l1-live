[1076.494316, "o", "TREE(1)            General Commands Manual           TREE(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       tree  -  list  contents of directories in a tree-like\u001b[m\r\n       format.\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mtree\u001b[0m [\u001b[1m-acdfghilnpqrstuvxACDFJQNSUX\u001b[0m] [\u001b[1m-L\u001b[0m  \u001b[4mlevel\u001b[24m  [\u001b[1m-R\u001b[0m]]\u001b[m\r\n       [\u001b[1m-H\u001b[0m  \u001b[4mbaseHREF\u001b[24m]  [\u001b[1m-T\u001b[0m \u001b[4mtitle\u001b[24m] [\u001b[1m-o\u001b[0m \u001b[4mfilename\u001b[24m] [\u001b[1m-P\u001b[0m \u001b[4mpattern\u001b[24m]\u001b[m\r\n       [\u001b[1m-I\u001b[0m   \u001b[4mpattern\u001b[24m]    [\u001b[1m--gitignore\u001b[0m]    [\u001b[1m--gitfile\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mfile\u001b[24m]\u001b[m\r\n       [\u001b[1m--matchdirs\u001b[0m]  [\u001b[1m--metafirst\u001b[0m]  [\u001b[1m--ignore-case\u001b[0m]  [\u001b[1m--noвЂђ\u001b[0m\u001b[m\r\n       \u001b[1mlinks\u001b[0m] [\u001b[1m--hintro\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mfile\u001b[24m] [\u001b[1m--houtro\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mfile\u001b[24m] [\u001b[1m--inodes\u001b[0m]\u001b[m\r\n       [\u001b[1m--device\u001b[0m]  [\u001b[1m--sort\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mname\u001b[24m]  [\u001b[1m--dirsfirst\u001b[0m]  [\u001b[1m--filesвЂђ\u001b[0m\u001b[m\r\n       \u001b[1mfirst\u001b[0m]  [\u001b[1m--filelimit\u001b[0m  \u001b[4m#\u001b[24m]  [\u001b[1m--si\u001b[0m]   [\u001b[1m--du\u001b[0m]   [\u001b[1m--prune\u001b[0m]\u001b[m\r\n\u001b[7m Manual p"]
[1076.494341, "o", "age tree(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1077.063421, "o", "\r\u001b[K"]
[1077.063557, "o", "       [\u001b[1m--charset[=]X]\u001b[0m   \u001b[1m[--timefmt[=]\u001b[0m\u001b[4mformat\u001b[24m\u001b[1m]\u001b[0m   \u001b[1m[--fromfile]\u001b[0m\u001b[m\r\n       \u001b[1m[--fflinks]\u001b[0m \u001b[1m[--info]\u001b[0m \u001b[1m[--infofile[=]\u001b[0m\u001b[4mfile\u001b[24m\u001b[1m]\u001b[0m \u001b[1m[--noreport]\u001b[0m\u001b[m\r\n       \u001b[1m[--version]\u001b[0m \u001b[1m[--help]\u001b[0m \u001b[1m[--]\u001b[0m \u001b[1m[\u001b[0m\u001b[4mdirectory\u001b[24m \u001b[1m...]\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       \u001b[4mTree\u001b[24m  is  a  recursive directory listing program that\u001b[m\r\n       produces a depth indented listing of files, which  is\u001b[m\r\n       colorized  ala \u001b[4mdircolors\u001b[24m if the \u001b[1mLS_COLORS\u001b[0m environment\u001b[m\r\n       variable is set and output is to tty.  With no  arguвЂђ\u001b[m\r\n       ments, \u001b[4mtree\u001b[24m lists the files in the current directory.\u001b[m\r\n       When directory arguments are given,  \u001b[4mtree\u001b[24m  lists  all\u001b[m\r\n       the  files  and/or directories found in the given diвЂђ\u001b[m\r\n       rectories each in turn.  Upon completion  of  listing\u001b[m\r\n       all  files/directories  found, \u001b[4mtree\u001b[24m returns the total\u001b[m\r\n\u001b[7m Manual page tree(1) line 1"]
[1077.063572, "o", "5 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1077.520502, "o", "\r\u001b[K"]
[1077.520591, "o", "       number of files and/or directories listed.\u001b[m\r\n\u001b[m\r\n       By default, when a symbolic link is encountered,  the\u001b[m\r\n       path  that the symbolic link refers to is printed afвЂђ\u001b[m\r\n       ter the name of the link in the format:\u001b[m\r\n\u001b[m\r\n           name -> real-path\u001b[m\r\n\u001b[m\r\n       If the `\u001b[1m-l\u001b[0m' option is given  and  the  symbolic  link\u001b[m\r\n       refers  to an actual directory, then \u001b[4mtree\u001b[24m will follow\u001b[m\r\n       the path of the symbolic link as if it  were  a  real\u001b[m\r\n       directory.\u001b[m\r\n\u001b[m\r\n\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[7m Manual page tree(1) line 29 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1077.977398, "o", "\r\u001b[K"]
[1077.977534, "o", "       \u001b[4mTree\u001b[24m understands the following command line switches:\u001b[m\r\n\u001b[m\r\n\u001b[1mLISTING\u001b[0m \u001b[1mOPTIONS\u001b[0m\u001b[m\r\n       \u001b[1m-a\u001b[0m     All  files  are printed.  By default tree does\u001b[m\r\n              not print hidden files (those beginning with a\u001b[m\r\n              dot  `.').   In  no  event does tree print the\u001b[m\r\n              file system constructs `.' (current directory)\u001b[m\r\n              and `..' (previous directory).\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[0m     List directories only.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-l\u001b[0m     Follows symbolic links if they point to direcвЂђ\u001b[m\r\n              tories, as if they were directories.  Symbolic\u001b[m\r\n              links   that  will  result  in  recursion  are\u001b[m\r\n\u001b[7m Manual page tree(1) line 43 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1081.49474, "o", "\r\u001b[K              avoided when detected.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-f\u001b[0m     Prints the full path prefix for each file.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-x\u001b[0m     Stay on the  current  file-system  only.   Ala\u001b[m\r\n              \u001b[1mfind\u001b[0m \u001b[4m-xdev\u001b[24m\u001b[1m.\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1m-L\u001b[0m \u001b[4mlevel\u001b[24m\u001b[m\r\n              Max display depth of the directory tree.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-R\u001b[0m     Recursively cross down the tree each \u001b[4mlevel\u001b[24m diвЂђ\u001b[m\r\n              rectories (see \u001b[1m-L\u001b[0m option), and at  each  level\u001b[m\r\n              outputting  to  a  file named \u001b[1m00Tree.html\u001b[0m (ala\u001b[m\r\n              \u001b[1m-o\u001b[0m).\u001b[m\r\n\u001b[7m Manual page tree(1) line 57 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1081.893535, "o", "\r\u001b[K\u001b[m\r\n       \u001b[1m-P\u001b[0m \u001b[4mpattern\u001b[24m\u001b[m\r\n              List only those files that match the wild-card\u001b[m\r\n              \u001b[4mpattern\u001b[24m.   You  may  have multiple -P options.\u001b[m\r\n"]
[1081.893775, "o", "              Note: you must use the \u001b[4m-a\u001b[24m option to also  conвЂђ\u001b[m\r\n              sider those files beginning with a dot `.' for\u001b[m\r\n              matching.  Valid wildcard  operators  are  `*'\u001b[m\r\n              (any  zero or more characters), `**` (any zero\u001b[m\r\n              or more characters as well as null  /'s,  i.e.\u001b[m\r\n              /**/  may  match  a single /), `?' (any single\u001b[m\r\n              character),  `[...]'  (any  single   character\u001b[m\r\n              listed between brackets (optional - (dash) for\u001b[m\r\n              character range may be used: ex:  [A-Z]),  and\u001b[m\r\n              `[^...]'  (any  single character not listed in\u001b[m\r\n\u001b[7m Manual page tree(1) line 71 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1084.839606, "o", "\r\u001b[K"]
[1084.83973, "o", "              brackets) and  `|'  separates  alternate  patвЂђ\u001b[m\r\n              terns. A '/' at the end of the pattern matches\u001b[m\r\n              directories, but not files.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-I\u001b[0m \u001b[4mpattern\u001b[24m\u001b[m\r\n              Do not list those files that match  the  wild-\u001b[m\r\n              card  \u001b[4mpattern\u001b[24m.   You  may have multiple -I opвЂђ\u001b[m\r\n              tions.  See \u001b[4m-P\u001b[24m above for information on  wildвЂђ\u001b[m\r\n              card patterns.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--gitignore\u001b[0m\u001b[m\r\n              Uses  git \u001b[1m.gitignore\u001b[0m files for filtering files\u001b[m\r\n              and directories.  Also uses  \u001b[1m$GIT_DIR/info/exвЂђ\u001b[0m\u001b[m\r\n              \u001b[1mclude\u001b[0m if present.\u001b[m\r\n\u001b[7m Manual page tree(1) line 85 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1086.092498, "o", "\r\u001b[K\u001b[m\r\n       \u001b[1m--gitfile\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mfile\u001b[24m\u001b[m\r\n              Use \u001b[4mfile\u001b[24m explicitly as a gitignore file.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--ignore-case\u001b[0m\u001b[m"]
[1086.092589, "o", "\r\n              If  a  match pattern is specified by the \u001b[1m-P\u001b[0m or\u001b[m\r\n              \u001b[1m-I\u001b[0m option, this  will  cause  the  pattern  to\u001b[m\r\n              match  without regard to the case of each letвЂђ\u001b[m\r\n              ter.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--matchdirs\u001b[0m\u001b[m\r\n              If a match pattern is specified by the \u001b[1m-P\u001b[0m  opвЂђ\u001b[m\r\n              tion,  this  will  cause the pattern to be apвЂђ\u001b[m\r\n              plied to directory names (in addition to fileвЂђ\u001b[m\r\n\u001b[7m Manual page tree(1) line 99 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1089.391924, "o", "\r\u001b[K"]
[1089.391995, "o", "              names).  In the event of a match on the direcвЂђ\u001b[m\r\n              tory name, matching is disabled for the direcвЂђ\u001b[m\r\n              tory's  contents.  If  the  \u001b[1m--prune\u001b[0m  option is\u001b[m\r\n              used, empty folders  that  match  the  pattern\u001b[m\r\n              will not be pruned.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--metafirst\u001b[0m\u001b[m\r\n              Print  the meta-data information at the beginвЂђ\u001b[m\r\n              ning of the line rather than after the  indenвЂђ\u001b[m\r\n              tation lines.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--prune\u001b[0m\u001b[m\r\n              Makes  tree  prune  empty directories from the\u001b[m\r\n              output, useful when used in  conjunction  with\u001b[m\r\n\u001b[7mManual page tree(1) line 113 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1090.720505, "o", "\r\u001b[K              \u001b[1m-P\u001b[0m  or  \u001b[1m-I\u001b[0m.  See \u001b[1mBUGS\u001b[0m \u001b[1mAND\u001b[0m \u001b[1mNOTES\u001b[0m below for more\u001b[m\r\n              information on this option.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--info\u001b[0m Prints file comments  found  in  .info  files.\u001b[m\r\n              See  \u001b[1m.INFO\u001b[0m \u001b[1mFILES\u001b[0m below for more information on\u001b[m\r\n              the format of .info files.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--infofile\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mfile\u001b[24m\u001b[m\r\n              Use \u001b[4mfile\u001b[24m explicitly as a info file.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--noreport\u001b[0m\u001b[m\r\n              Omits printing of the file and  directory  reвЂђ\u001b[m\r\n              port at the end of the tree listing.\u001b[m\r\n\u001b[m\r\n\u001b[7mManual page tree(1) line 127 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1091.305479, "o", "\r\u001b[K       \u001b[1m--charset\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mcharset\u001b[24m\u001b[m\r\n              Set  the  character set to use when outputting\u001b[m\r\n              HTML and for line drawing.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--filelimit\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4m#\u001b[24m\u001b[m\r\n              Do not descend directories that  contain  more\u001b[m\r\n              than \u001b[4m#\u001b[24m entries.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--timefmt\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mformat\u001b[24m\u001b[m\r\n              Prints  (implies  -D) and formats the date acвЂђ\u001b[m\r\n              cording to the format string  which  uses  the\u001b[m\r\n              \u001b[1mstrftime\u001b[0m(3) syntax.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-o\u001b[0m \u001b[4mfilename\u001b[24m\u001b[m\r\n\u001b[7mManual page tree(1) line 141 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1093.128412, "o", "\r\u001b[K"]
[1093.128449, "o", "              Send output to \u001b[4mfilename\u001b[24m.\u001b[m\r\n\u001b[m\r\n\u001b[1mFILE\u001b[0m \u001b[1mOPTIONS\u001b[0m\u001b[m\r\n       \u001b[1m-q\u001b[0m     Print non-printable characters in filenames as\u001b[m\r\n              question marks instead of the default.\u001b[m\r\n\u001b[m\r\n"]
[1093.128453, "o", "       \u001b[1m-N\u001b[0m     Print non-printable characters as  is  instead\u001b[m\r\n              of as escaped octal numbers.\u001b[m\r\n\u001b[m\r\n"]
[1093.128525, "o", "       \u001b[1m-Q\u001b[0m     Quote the names of files in double quotes.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-p\u001b[0m     Print  the  file type and permissions for each\u001b[m\r\n              file (as per ls -l).\u001b[m\r\n\u001b[m\r\n\u001b[7mManual page tree(1) line 155 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1095.093412, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m-o\u001b[0m \u001b[4mfilename\u001b[24m\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page tree(1) line 154 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1095.266702, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page tree(1) line 153 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1095.386618, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              \u001b[1mstrftime\u001b[0m(3) syntax.\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page tree(1) line 152 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1095.887532, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              cording to the format string  which  uses  the\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page tree(1) line 151 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1095.918758, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[1095.918951, "o", "\u001b[H\u001bM              Prints  (implies  -D) and formats the date acвЂђ\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page tree(1) line 150 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1095.950032, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m--timefmt\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mformat\u001b[24m\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page tree(1) line 149 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1095.981426, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page tree(1) line 148 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1096.011837, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              than \u001b[4m#\u001b[24m entries.\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page tree(1) line 147 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1096.043807, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              Do not descend directories that  contain  more\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page tree(1) line 146 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1096.07525, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m--filelimit\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4m#\u001b[24m\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page tree(1) line 145 (press h for help or q to quit)\u001b[27m\u001b[K"]
