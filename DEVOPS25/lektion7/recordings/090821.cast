[385.924584, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K            else\r\n:\u001b[K"]
[385.95475, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                __BASHRC_DEBUG_OUTPUT \"Command '$COMPLETE_LINE \b:\u001b[K"]
[385.965845, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K_QUOTED' finished after sending INT signal.\"\r\n:\u001b[K"]
