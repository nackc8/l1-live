[399.487412, "o", "\u001b[1;1HBASH(1)            General Commands Manual           BASH(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       bash - GNU Bourne-Again SHell\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1mbash\u001b[0m [options] [command_string | file]\u001b[m\r\n\u001b[8;1H\u001b[m\r\n\u001b[9;1H\u001b[1mCOPYRIGHT\u001b[0m\u001b[m\r\n\u001b[10;1H       Bash  is Copyright (C) 1989-2022 by the Free Software\u001b[m\r\n\u001b[11;1H       Foundation, Inc.\u001b[m\r\n\u001b[12;1H\u001b[m\r\n\u001b[13;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[14;1H       \u001b[1mBash\u001b[0m is an \u001b[1msh\u001b[0m-compatible command language interpreter\u001b[m\r\n\u001b[15;1H       that  executes  commands read from the standard input\u001b[m\r\n\u001b[16;1H       or from a file.  \u001b[1mBash\u001b[0m also incorporates  useful  fea‐\u001b[m\r\n\u001b[17;1H       tures from the \u001b[4mKorn\u001b[24m and \u001b[4mC\u001b[24m shells (\u001b[1mksh\u001b[0m and \u001b[1mcsh\u001b[0m).\u001b[m\r\n\u001b[18;1H\u001b[1;1HBASH(1)            General Commands Manual           BASH(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       bash - GNU Bourne-Again SHell\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1mbash\u001b[0m [options] [comma"]
[399.487519, "o", "nd_string | file]\u001b[m\r\n\u001b"]
[399.487746, "o", "[8;1H\u001b[m\r\n\u001b[9;1H\u001b[1mCOPYRIGHT\u001b[0m\u001b[m\r\n\u001b[10;1H       Bash  is Copyright (C) 1989-2022 by the Free Software\u001b[m\r\n\u001b[11;1H       Foundation, Inc.\u001b[m\r\n\u001b[12;1H\u001b[m\r\n\u001b[13;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[14;1H       \u001b[1mBash\u001b[0m is an \u001b[1msh\u001b[0m-compatible command language interpreter\u001b[m\r\n\u001b[15;1H       that  executes  commands read from the standard input\u001b[m\r\n\u001b[16;1H       or from a file.  \u001b[1mBash\u001b[0m also incorporates  useful  fea‐\u001b[m\r\n\u001b[17;1H       tures from the \u001b[4mKorn\u001b[24m and \u001b[4mC\u001b[24m shells (\u001b[1mksh\u001b[0m and \u001b[1mcsh\u001b[0m).\u001b[m\r\n\u001b[18;1H"]
[399.489497, "o", "...skipping...\r\n       ing  used  (see \u001b[1m\u001b[7mHISTORY\u001b[27m\u001b[0m \u001b[1mEXPANSION\u001b[0m below), the \u001b[4mhistory\u001b[24m\u001b[m\r\n       \u001b[4mexpansion\u001b[24m character, usually \u001b[1m!\u001b[0m,  must  be  quoted  to\u001b[m\r\n       prevent history expansion.\u001b[m\r\n\u001b[m\r\n       There  are three quoting mechanisms: the \u001b[4mescape\u001b[24m \u001b[4mchar‐\u001b[24m\u001b[m\r\n       \u001b[4macter\u001b[24m, single quotes, and double quotes.\u001b[m\r\n\u001b[m\r\n       A non-quoted backslash (\u001b[1m\\\u001b[0m) is the  \u001b[4mescape\u001b[24m  \u001b[4mcharacter\u001b[24m.\u001b[m\r\n       It  preserves the literal value of the next character\u001b[m\r\n       that follows, with the exception of <newline>.  If  a\u001b[m\r\n       \u001b[1m\\\u001b[0m<newline> pair appears, and the backslash is not it‐\u001b[m\r\n       self quoted, the \u001b[1m\\\u001b[0m<newline> is treated as a line con‐\u001b[m\r\n       tinuation  (that  is,  it  is  removed from the input\u001b[m\r\n       stream and effectively ignored).\u001b[m\r\n\u001b[m\r\n       Enclosing characters in single quotes  preserves  the\u001b[m\r\n       literal value of each character within the quotes.  A\u001b[m\r\n\u001b[7mManual page ba"]
