[1024.635617, "o", "\u001b[4mCUT\u001b[24m(1)                         User Commands                         \u001b[4mCUT\u001b[24m(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       cut - remove sections from each line of files\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mcut \u001b[4m\u001b[22mOPTION\u001b[24m... [\u001b[4mFILE\u001b[24m]...\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       Print selected parts of lines from each FILE to standard output.\u001b[m\r\n\u001b[m\r\n       With no FILE, or when FILE is -, read standard input.\u001b[m\r\n\u001b[m\r\n       Mandatory  arguments to long options are mandatory for short options\u001b[m\r\n       too.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-b\u001b[22m, \u001b[1m--bytes\u001b[22m=\u001b[4mLIST\u001b[0m\u001b[m\r\n              select only these bytes\u001b[m\r\n\u001b[m\r\n       \u001b[1m-c\u001b[22m, \u001b[1m--characters\u001b[22m=\u001b[4mLIST\u001b[0m\u001b[m\r\n              select only these characters\u001b[m\r\n\u001b[7m Manual page cut(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1031.467251, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page cut(1) line 2 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1031.534598, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-d\u001b[22m, \u001b[1m--delimiter\u001b[22m=\u001b[4mDELIM\u001b[0m\u001b[m\r\n\u001b[7m Manual page cut(1) line 3 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1031.590094, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              use DELIM instead of TAB for field delimiter\u001b[m\r\n\u001b[7m Manual page cut(1) line 4 (press h for help or q to quit)\u001b[27m\u001b[K"]
