[907.598132, "o", "\u001b[4mSORT\u001b[24m(1)                        User Commands                        \u001b[4mSORT\u001b[24m(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       sort - sort lines of text files\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1msort \u001b[22m[\u001b[4mOPTION\u001b[24m]... [\u001b[4mFILE\u001b[24m]...\u001b[m\r\n       \u001b[1msort \u001b[22m[\u001b[4mOPTION\u001b[24m]... \u001b[4m--files0-from=F\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       Write sorted concatenation of all FILE(s) to standard output.\u001b[m\r\n\u001b[m\r\n       With no FILE, or when FILE is -, read standard input.\u001b[m\r\n\u001b[m\r\n       Mandatory  arguments to long options are mandatory for short options\u001b[m\r\n       too.  Ordering options:\u001b[m\r\n\u001b[m\r\n       \u001b[1m-b\u001b[22m, \u001b[1m--ignore-leading-blanks\u001b[0m\u001b[m\r\n              ignore leading blanks\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[22m, \u001b[1m--dictionary-order\u001b[0m\u001b[m\r\n\u001b[7m Manual page sort(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[909.432502, "o", "\r\u001b[K              consider only blanks and alphanumeric characters\u001b[m\r\n\u001b[m\r\n       \u001b[1m-f\u001b[22m, \u001b[1m--ignore-case\u001b[0m\u001b[m\r\n              fold lower case to upper case characters\u001b[m\r\n\u001b[m\r\n       \u001b[1m-g\u001b[22m, \u001b[1m--general-numeric-sort\u001b[0m\u001b[m\r\n              compare according to general numerical value\u001b[m\r\n\u001b[m\r\n       \u001b[1m-i\u001b[22m, \u001b[1m--ignore-nonprinting\u001b[0m\u001b[m\r\n              consider only printable characters\u001b[m\r\n\u001b[m\r\n       \u001b[1m-M\u001b[22m, \u001b[1m--month-sort\u001b[0m\u001b[m\r\n              compare (unknown) < 'JAN' < ... < 'DEC'\u001b[m\r\n\u001b[m\r\n       \u001b[1m-h\u001b[22m, \u001b[1m--human-numeric-sort\u001b[0m\u001b[m\r\n              compare human readable numbers (e.g., 2K 1G)\u001b[m\r\n\u001b[m\r\n       \u001b[1m-n\u001b[22m, \u001b[1m--numeric-sort\u001b[0m\u001b[m\r\n              compare according to string numerical value; see  full  docu‐\u001b[m\r\n              mentation for supported strings\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page sort(1) line 22 (press h for help or q to quit)\u001b[27m\u001b[K"]
[910.886831, "o", "\r\u001b[K"]
[910.887185, "o", "       \u001b[1m-R\u001b[22m, \u001b[1m--random-sort\u001b[0m\u001b[m\r\n              shuffle, but group identical keys.  See \u001b[1mshuf\u001b[22m(1)\u001b[m\r\n\u001b[m\r\n       \u001b[1m--random-source\u001b[22m=\u001b[4mFILE\u001b[0m\u001b[m\r\n              get random bytes from FILE\u001b[m\r\n\u001b[m\r\n       \u001b[1m-r\u001b[22m, \u001b[1m--reverse\u001b[0m\u001b[m\r\n              reverse the result of comparisons\u001b[m\r\n\u001b[m\r\n       \u001b[1m--sort\u001b[22m=\u001b[4mWORD\u001b[0m\u001b[m\r\n              sort according to WORD: general-numeric \u001b[1m-g\u001b[22m, human-numeric \u001b[1m-h\u001b[22m,\u001b[m\r\n              month \u001b[1m-M\u001b[22m, numeric \u001b[1m-n\u001b[22m, random \u001b[1m-R\u001b[22m, version \u001b[1m-V\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1m-V\u001b[22m, \u001b[1m--version-sort\u001b[0m\u001b[m\r\n              natural sort of (version) numbers within text\u001b[m\r\n\u001b[m\r\n       Other options:\u001b[m\r\n\u001b[m\r\n       \u001b[1m--batch-size\u001b[22m=\u001b[4mNMERGE\u001b[0m\u001b[m\r\n              merge at most NMERGE inputs at once; for more use temp files\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page sort(1) line 43 (press h for help or q to quit)\u001b[27m\u001b[K"]
[912.702984, "o", "\r\u001b[K"]
[912.703085, "o", "       \u001b[1m-c\u001b[22m, \u001b[1m--check\u001b[22m, \u001b[1m--check\u001b[22m=\u001b[4mdiagnose-first\u001b[0m\u001b[m\r\n              check for sorted input; do not sort\u001b[m\r\n\u001b[m\r\n       \u001b[1m-C\u001b[22m, \u001b[1m--check\u001b[22m=\u001b[4mquiet\u001b[24m, \u001b[1m--check\u001b[22m=\u001b[4msilent\u001b[0m\u001b[m\r\n              like \u001b[1m-c\u001b[22m, but do not report first bad line\u001b[m\r\n\u001b[m\r\n       \u001b[1m--compress-program\u001b[22m=\u001b[4mPROG\u001b[0m\u001b[m\r\n              compress temporaries with PROG; decompress them with PROG \u001b[1m-d\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1m--debug\u001b[0m\u001b[m\r\n              annotate  the  part  of the line used to sort, and warn about\u001b[m\r\n              questionable usage to stderr\u001b[m\r\n\u001b[m\r\n       \u001b[1m--files0-from\u001b[22m=\u001b[4mF\u001b[0m\u001b[m\r\n              read input from the files specified by  NUL-terminated  names\u001b[m\r\n              in file F; If F is - then read names from standard input\u001b[m\r\n\u001b[m\r\n       \u001b[1m-k\u001b[22m, \u001b[1m--key\u001b[22m=\u001b[4mKEYDEF\u001b[0m\u001b[m\r\n              sort via a key; KEYDEF gives location and type\u001b[m\r\n\u001b[m\r\n       \u001b[1m-m\u001b[22m, \u001b[1m--merge\u001b[0m\u001b[m\r\n\u001b[7m Manual page sort(1) line 64 (press h for help or q to quit)\u001b[27m\u001b[K"]
[913.482769, "o", "\r\u001b[K"]
[913.482863, "o", "              merge already sorted files; do not sort\u001b[m\r\n\u001b[m\r\n       \u001b[1m-o\u001b[22m, \u001b[1m--output\u001b[22m=\u001b[4mFILE\u001b[0m\u001b[m\r\n              write result to FILE instead of standard output\u001b[m\r\n\u001b[m\r\n       \u001b[1m-s\u001b[22m, \u001b[1m--stable\u001b[0m\u001b[m\r\n              stabilize sort by disabling last-resort comparison\u001b[m\r\n\u001b[m\r\n       \u001b[1m-S\u001b[22m, \u001b[1m--buffer-size\u001b[22m=\u001b[4mSIZE\u001b[0m\u001b[m\r\n              use SIZE for main memory buffer\u001b[m\r\n\u001b[m\r\n       \u001b[1m-t\u001b[22m, \u001b[1m--field-separator\u001b[22m=\u001b[4mSEP\u001b[0m\u001b[m\r\n              use SEP instead of non-blank to blank transition\u001b[m\r\n\u001b[m\r\n       \u001b[1m-T\u001b[22m, \u001b[1m--temporary-directory\u001b[22m=\u001b[4mDIR\u001b[0m\u001b[m\r\n              use  DIR  for  temporaries, not $TMPDIR or \u001b[4m/tmp\u001b[24m; multiple op‐\u001b[m\r\n              tions specify multiple directories\u001b[m\r\n\u001b[m\r\n       \u001b[1m--parallel\u001b[22m=\u001b[4mN\u001b[0m\u001b[m\r\n              change the number of sorts run concurrently to N\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page sort(1) line 85 (press h for help or q to quit)\u001b[27m\u001b[K"]
[915.558222, "o", "\r\u001b[K       \u001b[1m-u\u001b[22m, \u001b[1m--unique\u001b[0m\u001b[m\r\n              output only the first of lines  with  equal  keys;  with  \u001b[1m-c\u001b[22m,\u001b[m\r\n              check for strict ordering\u001b[m\r\n\u001b[m\r\n       \u001b[1m-z\u001b[22m, \u001b[1m--zero-terminated\u001b[0m\u001b[m\r\n"]
[915.558484, "o", "              line delimiter is NUL, not newline\u001b[m\r\n\u001b[m\r\n       \u001b[1m--help \u001b[22mdisplay this help and exit\u001b[m\r\n\u001b[m\r\n       \u001b[1m--version\u001b[0m\u001b[m\r\n              output version information and exit\u001b[m\r\n\u001b[m\r\n       KEYDEF  is  F[.C][OPTS][,F[.C][OPTS]]  for  start and stop position,\u001b[m\r\n       where F is a field number and C a character position in  the  field;\u001b[m\r\n       both are origin 1, and the stop position defaults to the line's end.\u001b[m\r\n       If neither \u001b[1m-t \u001b[22mnor \u001b[1m-b \u001b[22mis in effect, characters in a field are counted\u001b[m\r\n       from the beginning of the preceding whitespace.  OPTS is one or more\u001b[m\r\n       single-letter  ordering options [bdfgiMhnRrV], which override global\u001b[m\r\n       ordering options for that key.  If no key is given, use  the  entire\u001b[m\r\n       line as the key.  Use \u001b[1m--debug \u001b[22mto diagnose incorrect key usage.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page sort(1) line 106 (press h for help or q to quit)\u001b[27m\u001b[K"]
