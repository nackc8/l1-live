[195.009188, "o", " [\u001b[1m--prune\u001b[0m]\u001b[m\r\n\u001b[12;1H       [\u001b[1m--charset[=]X]\u001b[0m \u001b[1m[--timefmt[=]\u001b[0m\u001b[4mformat\u001b[24m\u001b[1m]\u001b[0m  \u001b[1m[--fromfile]\u001b[0m  \u001b[1m[--fflinks]\u001b[0m  \u001b[1m[--info]\u001b[0m\u001b[m\r\n\u001b[13;1H       \u001b[1m[--infofile[=]\u001b[0m\u001b[4mfile\u001b[24m\u001b[1m]\u001b[0m  \u001b[1m[--noreport]\u001b[0m  \u001b[1m[--version]\u001b[0m  \u001b[1m[--help]\u001b[0m  \u001b[1m[--]\u001b[0m \u001b[1m[\u001b[0m\u001b[4mdirectory\u001b[24m\u001b[m\r\n\u001b[14;1H       \u001b[1m...]\u001b[0m\u001b[m\r\n\u001b[15;1H\u001b[m\r\n\u001b[16;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[17;1H       \u001b[4mTree\u001b[24m is a recursive directory listing program that produces a  depth  inвЂђ\u001b[m\r\n\u001b[18;1H\u001b[1;1HTREE(1)                      General Commands Manual                     TREE(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       tree - list contents of directories in a tree-like format.\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1mtree\u001b[0m [\u001b[1m-acdfghilnpqrstuvxACDFJQNSUX\u001b[0m] [\u001b[1m\u001b[7m-L\u001b[27m\u001b[0m \u001b[4mlevel\u001b[24m [\u001b[1m-R\u001b[0m]] [\u001b[1m-H\u001b[0m \u001b[4mbaseHREF\u001b[24m] [\u001b[1m-T\u001b[0m \u001b[4mtiвЂђ\u001b[24m\u001b[m\r\n\u001b[8;1H       \u001b[4mtle\u001b[24m] [\u001b[1m-o\u001b[0m  \u001b[4mfilename\u001b[24m]  [\u001b[1m-P\u001b[0m  \u001b[4mpattern\u001b["]
[195.009246, "o", "24m]  [\u001b[1m-I\u001b[0m  \u001b[4mpattern\u001b[24m]  [\u001b[1m--gitignore\u001b[0m]  [\u001b[1m--gitвЂђ\u001b[0m\u001b[m\r\n\u001b[9;1H       \u001b[1mfile\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mfile\u001b[24m]   [\u001b[1m--matchdirs\u001b[0m]  [\u001b[1m--metafirst\u001b[0m]  [\u001b[1m--ignore-case\u001b[0m]  [\u001b[1m--nolinks\u001b[0m]\u001b[m\r\n\u001b[10;1H       [\u001b[1m--hintro\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mfile\u001b[24m] [\u001b[1m--houtro\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mfile\u001b[24m] [\u001b[1m--inodes\u001b[0m] [\u001b[1m--device\u001b[0m] [\u001b[1m--sort\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mname\u001b[24m]\u001b[m\r\n\u001b[11;1H       [\u001b[1m--dirsfirst\u001b[0m]  [\u001b[1m--filesfirst\u001b[0m]  [\u001b[1m--filelimit\u001b[0m  \u001b[4m#\u001b[24m]  [\u001b[1m--si\u001b[0m]  [\u001b[1m--du\u001b[0m] [\u001b[1m--prune\u001b[0m]\u001b[m\r\n\u001b[12;1H       [\u001b[1m--charset[=]X]\u001b[0m \u001b[1m[--timefmt[=]\u001b[0m\u001b[4mformat\u001b[24m\u001b[1m]\u001b[0m  \u001b[1m[--fromfile]\u001b[0m  \u001b[1m[--fflinks]\u001b[0m  \u001b[1m[--info]\u001b[0m\u001b[m\r\n\u001b[13;1H       \u001b[1m[--infofile[=]\u001b[0m\u001b[4mfile\u001b[24m\u001b[1m]\u001b[0m  \u001b[1m[--noreport]\u001b[0m  \u001b[1m[--version]\u001b[0m  \u001b[1m[--help]\u001b[0m  \u001b[1m[--]\u001b[0m \u001b[1m[\u001b[0m\u001b[4mdirectory\u001b[24m\u001b[m\r\n\u001b[14;1H       \u001b[1m...]\u001b[0m\u001b[m\r\n\u001b[15;1H\u001b[m\r\n\u001b[16;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[17;1H       \u001b[4mTree\u001b[24m is a recursive directory listing program tha"]
[195.009389, "o", "t produces a  depth  inвЂђ\u001b[m\r\n\u001b[18;1H       dented  listing of files, which is colorized ala \u001b[4mdircolors\u001b[24m if the \u001b[1mLS_COLвЂђ\u001b[0m\u001b[m\r\n       \u001b[1mORS\u001b[0m environment variable is set and output is to tty.  With no arguments,\u001b[m\r\n       \u001b[4mtree\u001b[24m  lists the files in the current directory.  When directory arguments\u001b[m\r\n       are given, \u001b[4mtree\u001b[24m lists all the files and/or directories found in the given\u001b[m\r\n       directories  each in turn.  Upon completion of listing all files/directoвЂђ\u001b[m\r\n       ries found, \u001b[4mtree\u001b[24m returns the total number  of  files  and/or  directories\u001b[m\r\n\u001b[7m Manual page tree(1) line 7 (press h for help or q to quit)\u001b[27m\u001b[K"]
[199.598398, "o", "\r\u001b[K/\r\u001b[K"]
[199.598634, "o", "...skipping...\r\n       \u001b[1m\u001b[7m-L\u001b[27m\u001b[0m \u001b[4mlevel\u001b[24m\u001b[m\r\n              Max display depth of the directory tree.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-R\u001b[0m     Recursively cross down the tree each \u001b[4mlevel\u001b[24m directories (see \u001b[1m\u001b[7m-L\u001b[27m\u001b[0m opвЂђ\u001b[m\r\n              tion), and at each level outputting to a  file  named  \u001b[1m00Tree.html\u001b[0m\u001b[m\r\n              (ala \u001b[1m-o\u001b[0m).\u001b[m\r\n\u001b[m\r\n       \u001b[1m-P\u001b[0m \u001b[4mpattern\u001b[24m\u001b[m\r\n              List  only  those files that match the wild-card \u001b[4mpattern\u001b[24m.  You may\u001b[m\r\n              have multiple -P options. Note: you must use the \u001b[4m-a\u001b[24m option to also\u001b[m\r\n              consider those files beginning with a dot `.' for matching.  Valid\u001b[m\r\n              wildcard operators are `*' (any zero  or  more  characters),  `**`\u001b[m\r\n              (any  zero  or  more characters as well as null /'s, i.e. /**/ may\u001b[m\r\n              match a single /), `?' (any single character), `[...]' (any single\u001b[m\r\n              character listed between brackets (optional - (dash) for chara"]
[199.598649, "o", "cter\u001b[m\r\n              range may be used: ex: [A-Z]), and `[^...]' (any single  character\u001b[m\r\n              not  listed  in  brackets) and `|' separates alternate patterns. A\u001b[m\r\n\u001b[7m Manual page tree(1) line 54 (press h for help or q to quit)\u001b[27m\u001b[K"]
