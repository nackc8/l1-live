[195.008997, "o", "\u001b[1;1HTREE(1)                      General Commands Manual                     TREE(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       tree - list contents of directories in a tree-like format.\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1mtree\u001b[0m [\u001b[1m-acdfghilnpqrstuvxACDFJQNSUX\u001b[0m] [\u001b[1m-L\u001b[0m \u001b[4mlevel\u001b[24m [\u001b[1m-R\u001b[0m]] [\u001b[1m-H\u001b[0m \u001b[4mbaseHREF\u001b[24m] [\u001b[1m-T\u001b[0m \u001b[4mtiвЂђ\u001b[24m\u001b[m\r\n\u001b[8;1H       \u001b[4mtle\u001b[24m] [\u001b[1m-o\u001b[0m  \u001b[4mfilename\u001b[24m]  [\u001b[1m-P\u001b[0m  \u001b[4mpattern\u001b[24m]  [\u001b[1m-I\u001b[0m  \u001b[4mpattern\u001b[24m]  [\u001b[1m--gitignore\u001b[0m]  [\u001b[1m--gitвЂђ\u001b[0m\u001b[m\r\n\u001b[9;1H       \u001b[1mfile\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mfile\u001b[24m]   [\u001b[1m--matchdirs\u001b[0m]  [\u001b[1m--metafirst\u001b[0m]  [\u001b[1m--ignore-case\u001b[0m]  [\u001b[1m--nolinks\u001b[0m]\u001b[m\r\n\u001b[10;1H       [\u001b[1m--hintro\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mfile\u001b[24m] [\u001b[1m--houtro\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mfile\u001b[24m] [\u001b[1m--inodes\u001b[0m] [\u001b[1m--device\u001b[0m] [\u001b[1m--sort\u001b[0m[\u001b[1m=\u001b[0m]\u001b[4mname\u001b[24m]\u001b[m\r\n\u001b[11;1H       [\u001b[1m--dirsfirst\u001b[0m]  [\u001b[1m--filesfirst\u001b[0m]  [\u001b[1m--filelimit\u001b[0m  \u001b[4m#\u001b[24m]  [\u001b[1m--si\u001b[0m]  [\u001b[1m"]
