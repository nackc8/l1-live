[811.866371, "o", "\u001b[H\u001bM              \u001b[1m-d\u001b[0m \u001b[1mrecurse\u001b[0m option.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 437 (press h for help or q to quit)\u001b[27m\u001b[K"]
[811.904844, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              directory.  This is equivalent to the\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 436 (press h for help or q to quit)\u001b[27m\u001b[K"]
[811.965564, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              given,   \u001b[1mgrep\u001b[0m  searches  the  working\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 435 (press h for help or q to quit)\u001b[27m\u001b[K"]
[812.332398, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              Note  that  if  no  file  operand  is\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 434 (press h for help or q to quit)\u001b[27m\u001b[K"]
[812.343764, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              only if they are on the command line.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 433 (press h for help or q to quit)\u001b[27m\u001b[K"]
[812.388347, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              recursively, following symbolic links\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 432 (press h for help or q to quit)\u001b[27m\u001b[K"]
[812.399336, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              Read  all files under each directory,\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 431 (press h for help or q to quit)\u001b[27m\u001b[K"]
[812.410278, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m-r\u001b[0m, \u001b[1m--recursive\u001b[0m\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 430 (press h for help or q to quit)\u001b[27m\u001b[K"]
[812.551244, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 429 (press h for help or q to quit)\u001b[27m\u001b[K"]
