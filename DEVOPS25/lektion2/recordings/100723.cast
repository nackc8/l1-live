[812.654218, "o", "\u001b[H\u001bM              is \u001b[1m--include\u001b[0m.\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 428 (press h for help or q to quit)\u001b[27m\u001b[K"]
[812.673988, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              included unless the first such option\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 427 (press h for help or q to quit)\u001b[27m\u001b[K"]
[812.690297, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[812.690393, "o", "\u001b[H\u001bM              \u001b[1m--exclude\u001b[0m  options  match,  a file is\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 426 (press h for help or q to quit)\u001b[27m\u001b[K"]
[812.71241, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              one  wins.   If   no   \u001b[1m--include\u001b[0m   or\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 425 (press h for help or q to quit)\u001b[27m\u001b[K"]
[813.825441, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM              options  are given, the last matching\u001b[m\r\n\u001b[18;1H\r\u001b[K\u001b[7mge grep(1) line 424 (press h for help or q to quit)\u001b[27m\u001b[K"]
[825.855313, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KC\bC\u001b[H\u001b[2J\u001b[H given, the last matching\u001b[m\r\n If   no   \u001b[1m--include\u001b[0m   or\u001b[m\r\nptions  match,  a file is\u001b[m\r\ness the first such option\u001b[m\r\n.\u001b[m\r\n\u001b[m\r\n\u001b[m\r\nles under each directory,\u001b[m\r\n following symbolic links\u001b[m\r\n are on the command line.\u001b[m\r\nif  no  file  operand  is\u001b[m\r\n\u001b[1mp\u001b[0m  searches  the  working\u001b[m\r\nThis is equivalent to the\u001b[m\r\nption.\u001b[m\r\n\u001b[m\r\n\u001b[1mecursive\u001b[0m\u001b[m\r\nles under each directory,\u001b[m\r\n\u001b[7mge grep(1) line 424 (press h for help or q to quit)\u001b[27m\u001b[K"]
[826.013486, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KC\bC\u001b[H\u001b[2J\u001b[H\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[m\r\n\u001b[7mge grep(1) line 424 (press h for help or q to quit)\u001b[27m\u001b[K"]
[826.553039, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KD\bD\u001b[H\u001b[2J\u001b[H given, the last matching\u001b[m\r\n If   no   \u001b[1m--include\u001b[0m   or\u001b[m\r\nptions  match,  a file is\u001b[m\r\ness the first such option\u001b[m\r\n.\u001b[m\r\n\u001b[m\r\n\u001b[m\r\nles under each directory,\u001b[m\r\n following symbolic links\u001b[m\r\n are on the command line.\u001b[m\r\nif  no  file  operand  is\u001b[m\r\n\u001b[1mp\u001b[0m  searches  the  working\u001b[m\r\nThis is equivalent to the\u001b[m\r\nption.\u001b[m\r\n\u001b[m\r\n\u001b[1mecursive\u001b[0m\u001b[m\r\nles under each directory,\u001b[m\r\n\u001b[7mge grep(1) line 424 (press h for help or q to quit)\u001b[27m\u001b[K"]
[826.846086, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KD\bD\u001b[H\u001b[2J\u001b[H              options  are given, the last matching\u001b[m\r\n              one  wins.   If   no   \u001b[1m--include\u001b[0m   or\u001b[m\r\n              \u001b[1m--exclude\u001b[0m  options  match,  a file is\u001b[m\r\n              included unless the first such option\u001b[m\r\n              is \u001b[1m--include\u001b[0m.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-r\u001b[0m, \u001b[1m--recursive\u001b[0m\u001b[m\r\n              Read  all files under each directory,\u001b[m\r\n              recursively, following symbolic links\u001b[m\r\n              only if they are on the command line.\u001b[m\r\n              Note  that  if  no  file  operand  is\u001b[m\r\n              given,   \u001b[1mgrep\u001b[0m  searches  the  working\u001b[m\r\n              directory.  This is equivalent to the\u001b[m\r\n              \u001b[1m-d\u001b[0m \u001b[1mrecurse\u001b[0m option.\u001b[m\r\n\u001b[m\r\n       \u001b[1m\u001b[7m-R\u001b[27m\u001b[0m, \u001b[1m--dereference-recursive\u001b[0m\u001b[m\r\n              Read  all files under each directory,\u001b[m\r\n\u001b[7mge grep(1) line 424 (press h for help or q to quit)\u001b[27m\u001b[K"]
[826.981023, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              recursively.   Follow  all   symbolic\u001b[m\r\n\u001b[7mge grep(1) line 425 (press h for help or q to quit)\u001b[27m\u001b[K"]
[827.131268, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              links, unlike \u001b[1m-r\u001b[0m.\u001b[m\r\n\u001b[7mge grep(1) line 426 (press h for help or q to quit)\u001b[27m\u001b[K"]
[827.235778, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7mge grep(1) line 427 (press h for help or q to quit)\u001b[27m\u001b[K"]
[827.401211, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KD\bD\u001b[H\u001b[2J\u001b[H              included unless the first such option\u001b[m\r\n              is \u001b[1m--include\u001b[0m.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-r\u001b[0m, \u001b[1m--recursive\u001b[0m\u001b[m\r\n              Read  all files under each directory,\u001b[m\r\n              recursively, following symbolic links\u001b[m\r\n              only if they are on the command line.\u001b[m\r\n              Note  that  if  no  file  operand  is\u001b[m\r\n              given,   \u001b[1mgrep\u001b[0m  searches  the  working\u001b[m\r\n              directory.  This is equivalent to the\u001b[m\r\n              \u001b[1m-d\u001b[0m \u001b[1mrecurse\u001b[0m option.\u001b[m\r\n\u001b[m\r\n       \u001b[1m\u001b[7m-R\u001b[27m\u001b[0m, \u001b[1m--dereference-recursive\u001b[0m\u001b[m\r\n              Read  all files under each directory,\u001b[m\r\n              recursively.   Follow  all   symbolic\u001b[m\r\n              links, unlike \u001b[1m-r\u001b[0m.\u001b[m\r\n\u001b[m\r\n\u001b[7mge grep(1) line 427 (press h for help or q to quit)\u001b[27m\u001b[K"]
[827.603074, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K   \u001b[1mOther\u001b[0m \u001b[1mOptions\u001b[0m\u001b[m\r\n\u001b[7mge grep(1) line 428 (press h for help or q to quit)\u001b[27m\u001b[K"]
[827.798076, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--line-buffered\u001b[0m\u001b[m\r\n\u001b[7mge grep(1) line 429 (press h for help or q to quit)\u001b[27m\u001b[K"]
