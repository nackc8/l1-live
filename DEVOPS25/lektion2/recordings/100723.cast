[8.074004, "o", "FIND(1)                      General Commands Manual                     FIND(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       find - search for files in a directory hierarchy\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mfind\u001b[0m [-H] [-L] [-P] [-D debugopts] [-Olevel] [starting-point...] [expres‐\u001b[m\r\n       sion]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       This manual page documents the GNU version of \u001b[1mfind\u001b[0m.   GNU  \u001b[1mfind\u001b[0m  searches\u001b[m\r\n       the  directory tree rooted at each given starting-point by evaluating the\u001b[m\r\n       given expression from left to right, according to the rules of precedence\u001b[m\r\n       (see  section  OPERATORS), until the outcome is known (the left hand side\u001b[m\r\n       is false for \u001b[4mand\u001b[24m operations, true for \u001b[4mor\u001b[24m), at which point \u001b[1mfind\u001b[0m  moves  on\u001b[m\r\n       to  the  next  file  name.  If no starting-point is specified, `.' is as‐\u001b[m\r\n       sumed.\u001b[m\r\n\u001b[7m Manual page find(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[18.197592, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page find(1) line 2 (press h for help or q to quit)\u001b[27m\u001b[K"]
[18.292423, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       If you are using \u001b[1mfind\u001b[0m in an environment where security is important  (for\u001b[m\r\n\u001b[7m Manual page find(1) line 3 (press h for help or q to quit)\u001b[27m\u001b[K"]
[19.436271, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       example  if  you  are using it to search directories that are writable by\u001b[m\r\n\u001b[7m Manual page find(1) line 4 (press h for help or q to quit)\u001b[27m\u001b[K"]
[19.491994, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       other users), you should read the `Security  Considerations'  chapter  of\u001b[m\r\n\u001b[7m Manual page find(1) line 5 (press h for help or q to quit)\u001b[27m\u001b[K"]
[19.525171, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       the findutils documentation, which is called \u001b[1mFinding\u001b[0m \u001b[1mFiles\u001b[0m and comes with\u001b[m\r\n\u001b[7m Manual page find(1) line 6 (press h for help or q to quit)\u001b[27m\u001b[K"]
[19.589426, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       findutils.  That document also includes a lot more detail and  discussion\u001b[m\r\n\u001b[7m Manual page find(1) line 7 (press h for help or q to quit)\u001b[27m\u001b[K"]
[19.947645, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       than  this manual page, so you may find it a more useful source of infor‐\u001b[m\r\n\u001b[7m Manual page find(1) line 8 (press h for help or q to quit)\u001b[27m\u001b[K"]
[19.980989, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       mation.\u001b[m\r\n\u001b[7m Manual page find(1) line 9 (press h for help or q to quit)\u001b[27m\u001b[K"]
[20.339431, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page find(1) line 10 (press h for help or q to quit)\u001b[27m\u001b[K"]
[20.392436, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[7m Manual page find(1) line 11 (press h for help or q to quit)\u001b[27m\u001b[K"]
[20.504656, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       The \u001b[1m-H\u001b[0m, \u001b[1m-L\u001b[0m and \u001b[1m-P\u001b[0m options control the treatment of symbolic links.   Com‐\u001b[m\r\n\u001b[7m Manual page find(1) line 12 (press h for help or q to quit)\u001b[27m\u001b[K"]
[20.707524, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       mand-line arguments following these are taken to be names of files or di‐\u001b[m\r\n\u001b[7m Manual page find(1) line 13 (press h for help or q to quit)\u001b[27m\u001b[K"]
[20.7444, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       rectories to be examined, up to the first argument that begins with  `-',\u001b[m\r\n\u001b[7m Manual page find(1) line 14 (press h for help or q to quit)\u001b[27m\u001b[K"]
[20.782405, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       or  the  argument  `(' or `!'.  That argument and any following arguments\u001b[m\r\n\u001b[7m Manual page find(1) line 15 (press h for help or q to quit)\u001b[27m\u001b[K"]
[21.112715, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[21.11275, "o", "       are taken to be the expression describing what is to be searched for.  If\u001b[m\r\n\u001b[7m Manual page find(1) line 16 (press h for help or q to quit)\u001b[27m\u001b[K"]
[21.14647, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       no  paths  are given, the current directory is used.  If no expression is\u001b[m\r\n\u001b[7m Manual page find(1) line 17 (press h for help or q to quit)\u001b[27m\u001b[K"]
[21.185391, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       given, the expression \u001b[1m-print\u001b[0m is used (but you  should  probably  consider\u001b[m\r\n\u001b[7m Manual page find(1) line 18 (press h for help or q to quit)\u001b[27m\u001b[K"]
[21.241069, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       using \u001b[1m-print0\u001b[0m instead, anyway).\u001b[m\r\n\u001b[7m Manual page find(1) line 19 (press h for help or q to quit)\u001b[27m\u001b[K"]
[21.307726, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page find(1) line 20 (press h for help or q to quit)\u001b[27m\u001b[K"]
[21.374441, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[21.374459, "o", "       This manual page talks about `options' within the expression list.  These\u001b[m\r\n\u001b[7m Manual page find(1) line 21 (press h for help or q to quit)\u001b[27m\u001b[K"]
[21.517944, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       options control the behaviour of \u001b[1mfind\u001b[0m but are specified immediately after\u001b[m\r\n\u001b[7m Manual page find(1) line 22 (press h for help or q to quit)\u001b[27m\u001b[K"]
[21.813411, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       the  last  path name.  The five `real' options \u001b[1m-H\u001b[0m, \u001b[1m-L\u001b[0m, \u001b[1m-P\u001b[0m, \u001b[1m-D\u001b[0m and \u001b[1m-O\u001b[0m must\u001b[m\r\n\u001b[7m Manual page find(1) line 23 (press h for help or q to quit)\u001b[27m\u001b[K"]
[21.858148, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       appear before the first path name, if at all.  A  double  dash  \u001b[1m--\u001b[0m  could\u001b[m\r\n\u001b[7m Manual page find(1) line 24 (press h for help or q to quit)\u001b[27m\u001b[K"]
[22.717881, "o", "\r\u001b[K       theoretically  be used to signal that any remaining arguments are not op‐\u001b[m\r\n       tions, but this does not really work due to the way \u001b[1mfind\u001b[0m  determines  the\u001b[m\r\n       end of the following path arguments: it does that by reading until an ex‐\u001b[m\r\n       pression argument comes (which also starts with a `-').  Now, if  a  path\u001b[m\r\n       argument  would  start with a `-', then \u001b[1mfind\u001b[0m would treat it as expression\u001b[m\r\n       argument instead.  Thus, to ensure that all start  points  are  taken  as\u001b[m\r\n       such,  and  especially  to prevent that wildcard patterns expanded by the\u001b[m\r\n       calling shell are not mistakenly treated as expression arguments,  it  is\u001b[m\r\n       generally  safer  to  prefix  wildcards or dubious path names with either\u001b[m\r\n       `./' or to use absolute path names starting with '/'.  Alternatively,  it\u001b[m\r\n       is  generally safe though non-portable to use the GNU option \u001b[1m-files0-from\u001b[0m\u001b[m\r\n       to pass arbitrary starting points to \u001b[1mfind\u001b[0m."]
[22.717913, "o", "\u001b[m\r\n\u001b[m\r\n       -P     Never follow symbolic links.  This is the default behaviour.  When\u001b[m\r\n              \u001b[1mfind\u001b[0m examines or prints information about files, and the file is a\u001b[m\r\n              symbolic link, the information used shall be taken from the  prop‐\u001b[m\r\n              erties of the symbolic link itself.\u001b[m\r\n\u001b[7m Manual page find(1) line 41 (press h for help or q to quit)\u001b[27m\u001b[K"]
[23.204969, "o", "\r\u001b[K\u001b[m\r\n       -L     Follow  symbolic  links.  When \u001b[1mfind\u001b[0m examines or prints information\u001b[m\r\n              about files, the information used shall be taken from the  proper‐\u001b[m\r\n              ties  of  the file to which the link points, not from the link it‐\u001b[m\r\n              self (unless it is a broken symbolic link or \u001b[1mfind\u001b[0m is unable to ex‐\u001b[m\r\n              amine  the file to which the link points).  Use of this option im‐\u001b[m\r\n              plies \u001b[1m-noleaf\u001b[0m.  If you later use the \u001b[1m-P\u001b[0m option, \u001b[1m-noleaf\u001b[0m will still\u001b[m\r\n              be  in  effect.   If \u001b[1m-L\u001b[0m is in effect and \u001b[1mfind\u001b[0m discovers a symbolic\u001b[m\r\n              link to a subdirectory during its search, the subdirectory pointed\u001b[m\r\n              to by the symbolic link will be searched.\u001b[m\r\n\u001b[m\r\n              When  the  \u001b[1m-L\u001b[0m option is in effect, the \u001b[1m-type\u001b[0m predicate will always\u001b[m\r\n              match against the type of the file that a symbolic link points  to\u001b[m\r\n              rather"]
[23.204991, "o", "  than the link itself (unless the symbolic link is broken).\u001b[m\r\n              Actions that can cause symbolic links to become broken while  \u001b[1mfind\u001b[0m\u001b[m\r\n              is  executing (for example \u001b[1m-delete\u001b[0m) can give rise to confusing be‐\u001b[m\r\n              haviour.  Using \u001b[1m-L\u001b[0m causes the \u001b[1m-lname\u001b[0m and \u001b[1m-ilname\u001b[0m predicates always\u001b[m\r\n\u001b[7m Manual page find(1) line 58 (press h for help or q to quit)\u001b[27m\u001b[K"]
[24.802546, "o", "\r\u001b[K              to return false.\u001b[m\r\n\u001b[m\r\n       -H     Do  not follow symbolic links, except while processing the command\u001b[m\r\n              line arguments.  When \u001b[1mfind\u001b[0m examines or  prints  information  about\u001b[m\r\n              files,  the information used shall be taken from the properties of\u001b[m\r\n              the symbolic link itself.  The only exception to this behaviour is\u001b[m\r\n              when  a file specified on the command line is a symbolic link, and\u001b[m\r\n              the link can be resolved.  For  that  situation,  the  information\u001b[m\r\n              used  is taken from whatever the link points to (that is, the link\u001b[m\r\n              is followed).  The information about the link itself is used as  a\u001b[m\r\n              fallback if the file pointed to by the symbolic link cannot be ex‐\u001b[m\r\n              amined.  If \u001b[1m-H\u001b[0m is in effect and one of the paths specified on  the\u001b[m\r\n              command  line  is  a symbolic link to a directory, the contents of\u001b[m\r\n              that director"]
[24.802568, "o", "y will be  examined  (though  of  course  \u001b[1m-maxdepth\u001b[0m \u001b[1m0\u001b[0m\u001b[m\r\n              would prevent this).\u001b[m\r\n\u001b[m\r\n       If  more  than one of \u001b[1m-H\u001b[0m, \u001b[1m-L\u001b[0m and \u001b[1m-P\u001b[0m is specified, each overrides the oth‐\u001b[m\r\n\u001b[7m Manual page find(1) line 75 (press h for help or q to quit)\u001b[27m\u001b[K"]
[25.36501, "o", "\r\u001b[K       ers; the last one appearing on the command line takes effect.   Since  it\u001b[m\r\n       is the default, the \u001b[1m-P\u001b[0m option should be considered to be in effect unless\u001b[m\r\n       either \u001b[1m-H\u001b[0m or \u001b[1m-L\u001b[0m is specified.\u001b[m\r\n\u001b[m\r\n       GNU \u001b[1mfind\u001b[0m frequently stats files during the processing of the command line\u001b[m\r\n       itself,  before  any  searching has begun.  These options also affect how\u001b[m\r\n       those arguments are processed.  Specifically, there are a number of tests\u001b[m\r\n       that  compare files listed on the command line against a file we are cur‐\u001b[m\r\n       rently considering.  In each case, the file specified on the command line\u001b[m\r\n       will  have been examined and some of its properties will have been saved.\u001b[m\r\n       If the named file is in fact a symbolic link, and the \u001b[1m-P\u001b[0m option is in ef‐\u001b[m\r\n       fect  (or  if neither \u001b[1m-H\u001b[0m nor \u001b[1m-L\u001b[0m were specified), the information used for\u001b[m\r\n       the comparison will be taken from the properties of  the "]
[25.365109, "o", " symbolic  link.\u001b[m\r\n       Otherwise,  it  will  be  taken  from the properties of the file the link\u001b[m\r\n       points to.  If \u001b[1mfind\u001b[0m cannot follow the link (for example  because  it  has\u001b[m\r\n       insufficient  privileges  or  the  link points to a nonexistent file) the\u001b[m\r\n       properties of the link itself will be used.\u001b[m\r\n\u001b[7m Manual page find(1) line 92 (press h for help or q to quit)\u001b[27m\u001b[K"]
[25.934431, "o", "\r\u001b[K"]
[25.934552, "o", "\u001b[m\r\n       When the \u001b[1m-H\u001b[0m or \u001b[1m-L\u001b[0m options are in effect, any symbolic links listed as the\u001b[m\r\n       argument  of \u001b[1m-newer\u001b[0m will be dereferenced, and the timestamp will be taken\u001b[m\r\n       from the file to which the symbolic link points.  The same  consideration\u001b[m\r\n       applies to \u001b[1m-newerXY\u001b[0m, \u001b[1m-anewer\u001b[0m and \u001b[1m-cnewer\u001b[0m.\u001b[m\r\n\u001b[m\r\n       The  \u001b[1m-follow\u001b[0m option has a similar effect to \u001b[1m-L\u001b[0m, though it takes effect at\u001b[m\r\n       the point where it appears (that is, if \u001b[1m-L\u001b[0m is not used  but  \u001b[1m-follow\u001b[0m  is,\u001b[m\r\n       any  symbolic  links  appearing after \u001b[1m-follow\u001b[0m on the command line will be\u001b[m\r\n       dereferenced, and those before it will not).\u001b[m\r\n\u001b[m\r\n       -D debugopts\u001b[m\r\n              Print diagnostic information; this  can  be  helpful  to  diagnose\u001b[m\r\n              problems  with  why  \u001b[1mfind\u001b[0m is not doing what you want.  The list of\u001b[m\r\n              debug options should be comma separated.  Compatibility of the de‐\u001b[m\r\n             "]
[25.934596, "o", " bug  options is not guaranteed between releases of findutils.  For\u001b[m\r\n              a complete list of valid debug options, see  the  output  of  \u001b[1mfind\u001b[0m\u001b[m\r\n\u001b[7m Manual page find(1) line 109 (press h for help or q to quit)\u001b[27m\u001b[K"]
[26.669345, "o", "\r\u001b[K              \u001b[1m-D\u001b[0m \u001b[1mhelp\u001b[0m.  Valid debug options include\u001b[m\r\n\u001b[m\r\n              exec   Show  diagnostic  information  relating to -exec, -execdir,\u001b[m\r\n                     -ok and -okdir\u001b[m\r\n\u001b[m\r\n              opt    Prints diagnostic information relating to the  optimisation\u001b[m\r\n                     of the expression tree; see the -O option.\u001b[m\r\n\u001b[m\r\n              rates  Prints  a  summary indicating how often each predicate suc‐\u001b[m\r\n                     ceeded or failed.\u001b[m\r\n\u001b[m\r\n              search Navigate the directory tree verbosely.\u001b[m\r\n\u001b[m\r\n              stat   Print messages as files are  examined  with  the  \u001b[1mstat\u001b[0m  and\u001b[m\r\n                     \u001b[1mlstat\u001b[0m  system  calls.   The  \u001b[1mfind\u001b[0m program tries to minimise\u001b[m\r\n                     such calls.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 126 (press h for help or q to quit)\u001b[27m\u001b[K"]
[27.180047, "o", "\r\u001b[K              tree   Show the expression tree  in  its  original  and  optimised\u001b[m\r\n                     form.\u001b[m\r\n\u001b[m\r\n              all    Enable all of the other debug options (but \u001b[1mhelp\u001b[0m).\u001b[m\r\n\u001b[m\r\n              help   Explain the debugging options.\u001b[m\r\n\u001b[m\r\n       -Olevel\u001b[m\r\n              Enables  query  optimisation.   The \u001b[1mfind\u001b[0m program reorders tests to\u001b[m\r\n              speed up execution while preserving the overall effect;  that  is,\u001b[m\r\n              predicates  with  side  effects are not reordered relative to each\u001b[m\r\n              other.  The optimisations performed at each optimisation level are\u001b[m\r\n              as follows.\u001b[m\r\n\u001b[m\r\n              0      Equivalent to optimisation level 1.\u001b[m\r\n\u001b[m\r\n              1      This  is  the default optimisation level and corresponds to\u001b[m\r\n\u001b[7m Manual page find(1) line 143 (press h for help or q to quit)\u001b[27m\u001b[K"]
[27.697729, "o", "\r\u001b[K                     the traditional behaviour.  Expressions  are  reordered  so\u001b[m\r\n                     that  tests  based  only on the names of files (for example\u001b[m\r\n                     \u001b[1m-name\u001b[0m and \u001b[1m-regex\u001b[0m) are performed first.\u001b[m\r\n\u001b[m\r\n              2      Any \u001b[1m-type\u001b[0m or \u001b[1m-xtype\u001b[0m tests are  performed  after  any  tests\u001b[m\r\n                     based only on the names of files, but before any tests that\u001b[m\r\n                     require information from the inode.  On  many  modern  ver‐\u001b[m\r\n                     sions  of Unix, file types are returned by \u001b[1mreaddir()\u001b[0m and so\u001b[m\r\n                     these predicates are faster  to  evaluate  than  predicates\u001b[m\r\n                     which  need  to  stat  the  file  first.   If  you  use the\u001b[m\r\n                     \u001b[1m-fstype\u001b[0m \u001b[4mFOO\u001b[24m predicate and specify  a  filesystem  type  \u001b[4mFOO\u001b[24m\u001b[m\r\n                     which is not known (that is, present in `/etc/mtab') at the\u001b[m\r\n                     time \u001b[1mfin"]
[27.697758, "o", "d\u001b[0m starts, that predicate is equivalent to \u001b[1m-false\u001b[0m.\u001b[m\r\n\u001b[m\r\n              3      At this optimisation level, the full cost-based query opti‐\u001b[m\r\n                     miser  is  enabled.  The order of tests is modified so that\u001b[m\r\n                     cheap (i.e. fast) tests are performed first and more expen‐\u001b[m\r\n\u001b[7m Manual page find(1) line 160 (press h for help or q to quit)\u001b[27m\u001b[K"]
[28.199636, "o", "\r\u001b[K"]
[28.199752, "o", "                     sive  ones  are performed later, if necessary.  Within each\u001b[m\r\n                     cost band, predicates are evaluated earlier  or  later  ac‐\u001b[m\r\n                     cording  to whether they are likely to succeed or not.  For\u001b[m\r\n                     \u001b[1m-o\u001b[0m, predicates which are likely to  succeed  are  evaluated\u001b[m\r\n                     earlier,  and  for  \u001b[1m-a\u001b[0m, predicates which are likely to fail\u001b[m\r\n                     are evaluated earlier.\u001b[m\r\n\u001b[m\r\n              The cost-based optimiser has a fixed idea of how likely any  given\u001b[m\r\n              test  is  to succeed.  In some cases the probability takes account\u001b[m\r\n              of the specific nature of the test (for example,  \u001b[1m-type\u001b[0m \u001b[1mf\u001b[0m  is  as‐\u001b[m\r\n              sumed  to be more likely to succeed than \u001b[1m-type\u001b[0m \u001b[1mc\u001b[0m).  The cost-based\u001b[m\r\n              optimiser is currently being evaluated.  If it does  not  actually\u001b[m\r\n              improve  the  performance of \u001b[1mfind\u001b[0m, it will be r"]
[28.199787, "o", "emoved again.  Con‐\u001b[m\r\n              versely, optimisations that prove to be reliable, robust  and  ef‐\u001b[m\r\n              fective  may  be  enabled  at lower optimisation levels over time.\u001b[m\r\n              However, the default behaviour (i.e. optimisation  level  1)  will\u001b[m\r\n              not  be  changed  in the 4.3.x release series.  The findutils test\u001b[m\r\n\u001b[7m Manual page find(1) line 177 (press h for help or q to quit)\u001b[27m\u001b[K"]
[28.64306, "o", "\r\u001b[K"]
[28.643114, "o", "              suite runs all the tests on \u001b[1mfind\u001b[0m at each  optimisation  level  and\u001b[m\r\n              ensures that the result is the same.\u001b[m\r\n\u001b[m\r\n\u001b[1mEXPRESSION\u001b[0m\u001b[m\r\n       The part of the command line after the list of starting points is the \u001b[4mex‐\u001b[24m\u001b[m\r\n       \u001b[4mpression\u001b[24m.  This is a kind of query specification describing how we  match\u001b[m\r\n       files  and what we do with the files that were matched.  An expression is\u001b[m\r\n       composed of a sequence of things:\u001b[m\r\n\u001b[m\r\n       Tests  Tests return a true or false value, usually on the basis  of  some\u001b[m\r\n              property  of a file we are considering.  The \u001b[1m-empty\u001b[0m test for exam‐\u001b[m\r\n              ple is true only when the current file is empty.\u001b[m\r\n\u001b[m\r\n       Actions\u001b[m\r\n              Actions have side effects (such as printing something on the stan‐\u001b[m\r\n              dard  output)  and  return  either true or false, usually based on\u001b[m\r\n              whether or not they are successful.  The \u001b[1m-print\u001b[0m action for"]
[28.643122, "o", " example\u001b[m\r\n\u001b[7m Manual page find(1) line 194 (press h for help or q to quit)\u001b[27m\u001b[K"]
[29.047254, "o", "\r\u001b[K"]
[29.04729, "o", "              prints the name of the current file on the standard output.\u001b[m\r\n\u001b[m\r\n       Global options\u001b[m\r\n              Global options affect the operation of tests and actions specified\u001b[m\r\n              on any part of the command line.   Global  options  always  return\u001b[m\r\n              true.   The \u001b[1m-depth\u001b[0m option for example makes \u001b[1mfind\u001b[0m traverse the file\u001b[m\r\n              system in a depth-first order.\u001b[m\r\n\u001b[m\r\n       Positional options\u001b[m\r\n              Positional options affect only tests or actions which follow them.\u001b[m\r\n              Positional  options always return true.  The \u001b[1m-regextype\u001b[0m option for\u001b[m\r\n              example is positional, specifying the regular  expression  dialect\u001b[m\r\n              for regular expressions occurring later on the command line.\u001b[m\r\n\u001b[m\r\n       Operators\u001b[m\r\n              Operators  join  together  the  other items within the expression.\u001b[m\r\n              They include for example \u001b[1m-o\u001b[0m (meaning logical OR) and  \u001b[1m-a\u001b[0m  (meaning\u001b[m\r\n\u001b[7m M"]
[29.047297, "o", "anual page find(1) line 211 (press h for help or q to quit)\u001b[27m\u001b[K"]
[29.609594, "o", "\r\u001b[K"]
[29.609687, "o", "              logical AND).  Where an operator is missing, \u001b[1m-a\u001b[0m is assumed.\u001b[m\r\n\u001b[m\r\n       The  \u001b[1m-print\u001b[0m  action is performed on all files for which the whole expres‐\u001b[m\r\n       sion is true, unless it contains an action other than  \u001b[1m-prune\u001b[0m  or  \u001b[1m-quit\u001b[0m.\u001b[m\r\n       Actions  which  inhibit  the default \u001b[1m-print\u001b[0m are \u001b[1m-delete\u001b[0m, \u001b[1m-exec\u001b[0m, \u001b[1m-execdir\u001b[0m,\u001b[m\r\n       \u001b[1m-ok\u001b[0m, \u001b[1m-okdir\u001b[0m, \u001b[1m-fls\u001b[0m, \u001b[1m-fprint\u001b[0m, \u001b[1m-fprintf\u001b[0m, \u001b[1m-ls\u001b[0m, \u001b[1m-print\u001b[0m and \u001b[1m-printf\u001b[0m.\u001b[m\r\n\u001b[m\r\n       The \u001b[1m-delete\u001b[0m action also acts like an option (since it implies \u001b[1m-depth\u001b[0m).\u001b[m\r\n\u001b[m\r\n   \u001b[1mPOSITIONAL\u001b[0m \u001b[1mOPTIONS\u001b[0m\u001b[m\r\n       Positional options always return true.  They affect only tests  occurring\u001b[m\r\n       later on the command line.\u001b[m\r\n\u001b[m\r\n       -daystart\u001b[m\r\n              Measure  times  (for  \u001b[1m-amin\u001b[0m,  \u001b[1m-atime\u001b[0m,  \u001b[1m-cmin\u001b[0m,  \u001b[1m-ctime\u001b[0m,  \u001b[1m-mmin\u001b[0m, and\u001b[m\r\n              \u001b[1m-mtime\u001b[0m) from the beginning of today "]
[29.609715, "o", "rather than from 24 hours ago.\u001b[m\r\n              This  option  only affects tests which appear later on the command\u001b[m\r\n\u001b[7m Manual page find(1) line 228 (press h for help or q to quit)\u001b[27m\u001b[K"]
[30.224589, "o", "\r\u001b[K              line.\u001b[m\r\n\u001b[m\r\n       -follow\u001b[m\r\n              Deprecated; use  the  \u001b[1m-L\u001b[0m  option  instead.   Dereference  symbolic\u001b[m\r\n              links.   Implies  \u001b[1m-noleaf\u001b[0m.   The \u001b[1m-follow\u001b[0m option affects only those\u001b[m\r\n              tests which appear after it on the command line.  Unless the \u001b[1m-H\u001b[0m or\u001b[m\r\n              \u001b[1m-L\u001b[0m  option  has been specified, the position of the \u001b[1m-follow\u001b[0m option\u001b[m\r\n              changes the behaviour of the \u001b[1m-newer\u001b[0m predicate; any files listed as\u001b[m\r\n"]
[30.224809, "o", "              the  argument  of \u001b[1m-newer\u001b[0m will be dereferenced if they are symbolic\u001b[m\r\n              links.  The same consideration applies to  \u001b[1m-newerXY\u001b[0m,  \u001b[1m-anewer\u001b[0m  and\u001b[m\r\n              \u001b[1m-cnewer\u001b[0m.  Similarly, the \u001b[1m-type\u001b[0m predicate will always match against\u001b[m\r\n              the type of the file that a symbolic link points  to  rather  than\u001b[m\r\n              the  link  itself.   Using  \u001b[1m-follow\u001b[0m  causes the \u001b[1m-lname\u001b[0m \u001b[1mand\u001b[0m \u001b[1m-ilname\u001b[0m\u001b[m\r\n              predicates always to return false.\u001b[m\r\n\u001b[m\r\n       -regextype \u001b[4mtype\u001b[24m\u001b[m\r\n              Changes the regular expression syntax  understood  by  \u001b[1m-regex\u001b[0m  and\u001b[m\r\n\u001b[7m Manual page find(1) line 245 (press h for help or q to quit)\u001b[27m\u001b[K"]
[31.274541, "o", "\r\u001b[K"]
[31.274621, "o", "              \u001b[1m-iregex\u001b[0m tests which occur later on the command line.  To see which\u001b[m\r\n              regular expression types are known, use \u001b[1m-regextype\u001b[0m \u001b[1mhelp\u001b[0m.  The Tex‐\u001b[m\r\n              info documentation (see \u001b[1mSEE\u001b[0m \u001b[1mALSO\u001b[0m) explains the meaning of and dif‐\u001b[m\r\n              ferences between the various types of regular expression.\u001b[m\r\n\u001b[m\r\n       -warn, -nowarn\u001b[m\r\n              Turn warning messages on or off.  These warnings apply only to the\u001b[m\r\n              command  line  usage,  not  to  any conditions that \u001b[1mfind\u001b[0m might en‐\u001b[m\r\n              counter when it searches directories.  The default behaviour  cor‐\u001b[m\r\n              responds  to \u001b[1m-warn\u001b[0m if standard input is a tty, and to \u001b[1m-nowarn\u001b[0m oth‐\u001b[m\r\n              erwise.  If a warning message relating to  command-line  usage  is\u001b[m\r\n              produced,  the  exit  status  of  \u001b[1mfind\u001b[0m  is  not  affected.  If the\u001b[m\r\n              \u001b[1mPOSIXLY_CORRECT\u001b[0m environment variable is set,  an"]
[31.27465, "o", "d  \u001b[1m-war"]
[31.274706, "o", "n\u001b[0m  is  also\u001b[m\r\n              used, it is not specified which, if any, warnings will be active.\u001b[m\r\n\u001b[m\r\n   \u001b[1mGLOBAL\u001b[0m \u001b[1mOPTIONS\u001b[0m\u001b[m\r\n       Global  options  always return true.  Global options take effect even for\u001b[m\r\n\u001b[7m Manual page find(1) line 262 (press h for help or q to quit)\u001b[27m\u001b[K"]
[32.18262, "o", "\r\u001b[K"]
[32.182754, "o", "       tests which occur earlier on the command  line.   To  prevent  confusion,\u001b[m\r\n       global  options  should  specified  on the command-line after the list of\u001b[m\r\n       start points, just before the first test, positional  option  or  action.\u001b[m\r\n       If  you  specify  a  global option in some other place, \u001b[1mfind\u001b[0m will issue a\u001b[m\r\n       warning message explaining that this can be confusing.\u001b[m\r\n\u001b[m\r\n       The global options occur after the list of start points, and so  are  not\u001b[m\r\n       the same kind of option as \u001b[1m-L\u001b[0m, for example.\u001b[m\r\n\u001b[m\r\n       -d     A  synonym  for  -depth,  for  compatibility with FreeBSD, NetBSD,\u001b[m\r\n              MacOS X and OpenBSD.\u001b[m\r\n\u001b[m\r\n       -depth Process each directory's contents  before  the  directory  itself.\u001b[m\r\n              The -delete action also implies \u001b[1m-depth\u001b[0m.\u001b[m\r\n\u001b[m\r\n       -files0-from \u001b[4mfile\u001b[24m\u001b[m\r\n              Read  the starting points from \u001b[4mfile\u001b[24m instead of getting them on the\u001b[m\r\n\u001b[7m Manual page find(1) line 279 ("]
[32.182807, "o", "press h for help or q to quit)\u001b[27m\u001b[K"]
[32.429488, "o", "\r\u001b[K"]
[32.429607, "o", "              command line.  In contrast to the  known  limitations  of  passing\u001b[m\r\n              starting points via arguments on the command line, namely the lim‐\u001b[m\r\n              itation of the amount of file names, and the inherent ambiguity of\u001b[m\r\n              file names clashing with option names, using this option allows to\u001b[m\r\n              safely pass an arbitrary number of starting points to \u001b[1mfind\u001b[0m.\u001b[m\r\n\u001b[m\r\n              Using this option and passing starting points on the command  line\u001b[m\r\n              is  mutually  exclusive,  and is therefore not allowed at the same\u001b[m\r\n              time.\u001b[m\r\n\u001b[m\r\n              The \u001b[4mfile\u001b[24m argument is mandatory.  One  can  use  \u001b[1m-files0-from\u001b[0m \u001b[1m-\u001b[0m  to\u001b[m\r\n              read  the  list of starting points from the \u001b[4mstandard\u001b[24m \u001b[4minput\u001b[24m stream,\u001b[m\r\n              and e.g. from a pipe.  In this case, the actions  \u001b[1m-ok\u001b[0m  and  \u001b[1m-okdir\u001b[0m\u001b[m\r\n              are not allowed, because they would obviously interfere with rea"]
[32.429631, "o", "d‐\u001b[m\r\n              ing from \u001b[4mstandard\u001b[24m \u001b[4minput\u001b[24m in order to get a user confirmation.\u001b[m\r\n\u001b[m\r\n              The starting points in \u001b[4mfile\u001b[24m have to  be  separated  by  ASCII  NUL\u001b[m\r\n\u001b[7m Manual page find(1) line 296 (press h for help or q to quit)\u001b[27m\u001b[K"]
[32.618092, "o", "\r\u001b[K"]
[32.618221, "o", "              characters.   Two  consecutive  NUL  characters,  i.e., a starting\u001b[m\r\n              point with a Zero-length file name is not allowed and will lead to\u001b[m\r\n              an error diagnostic followed by a non-Zero exit code later.\u001b[m\r\n\u001b[m\r\n              In  the  case  the  given \u001b[4mfile\u001b[24m is empty, \u001b[1mfind\u001b[0m does not process any\u001b[m\r\n              starting point and therefore will exit immediately  after  parsing\u001b[m\r\n              the  program  arguments.   This  is unlike the standard invocation\u001b[m\r\n              where \u001b[1mfind\u001b[0m assumes the current directory as starting point  if  no\u001b[m\r\n              path argument is passed.\u001b[m\r\n\u001b[m\r\n              The  processing of the starting points is otherwise as usual, e.g.\u001b[m\r\n              \u001b[1mfind\u001b[0m will recurse into subdirectories unless otherwise  prevented.\u001b[m\r\n              To  process  only  the  starting points, one can additionally pass\u001b[m\r\n              \u001b[1m-maxdepth\u001b[0m \u001b[1m0\u001b[0m.\u001b[m\r\n\u001b[m\r\n              Further notes: if a file is l"]
[32.618262, "o", "isted more than  once  in  the  input\u001b[m\r\n              file,  it is unspecified whether it is visited more than once.  If\u001b[m\r\n\u001b[7m Manual page find(1) line 313 (press h for help or q to quit)\u001b[27m\u001b[K"]
[32.812214, "o", "\r\u001b[K              the \u001b[4mfile\u001b[24m is mutated during the operation of \u001b[1mfind\u001b[0m,  the  result  is\u001b[m\r\n              unspecified  as well.  Finally, the seek position within the named\u001b[m\r\n              \u001b[4mfile\u001b[24m at the time \u001b[1mfind\u001b[0m exits, be it with \u001b[1m-quit\u001b[0m or in any other way,\u001b[m\r\n              is  also  unspecified.  By \"unspecified\" here is meant that it may\u001b[m\r\n              or may not work or do any specific thing, and  that  the  behavior\u001b[m\r\n              may change from platform to platform, or from \u001b[1mfindutils\u001b[0m release to\u001b[m\r\n              release.\u001b[m\r\n\u001b[m\r\n       -help, --help\u001b[m\r\n              Print a summary of the command-line usage of \u001b[1mfind\u001b[0m and exit.\u001b[m\r\n\u001b[m\r\n       -ignore_readdir_race\u001b[m\r\n              Normally, \u001b[1mfind\u001b[0m will emit an error message when it fails to stat  a\u001b[m\r\n              file.   If  you give this option and a file is deleted between the\u001b[m\r\n              time \u001b[1mfind\u001b[0m reads the name of the file from the  directory  and  the\u001b[m\r\n         "]
[32.812239, "o", "     time  it  tries to stat the file, no error message will be issued.\u001b[m\r\n              This also applies to files or directories whose names are given on\u001b[m\r\n\u001b[7m Manual page find(1) line 330 (press h for help or q to quit)\u001b[27m\u001b[K"]
[33.014492, "o", "\r\u001b[K"]
[33.014582, "o", "              the  command  line.  This option takes effect at the time the com‐\u001b[m\r\n              mand line is read, which means that you cannot search one part  of\u001b[m\r\n              the filesystem with this option on and part of it with this option\u001b[m\r\n              off (if you need to do that, you will need to issue two \u001b[1mfind\u001b[0m  com‐\u001b[m\r\n              mands instead, one with the option and one without it).\u001b[m\r\n\u001b[m\r\n              Furthermore, \u001b[1mfind\u001b[0m with the \u001b[1m-ignore_readdir_race\u001b[0m option will ignore\u001b[m\r\n              errors of the \u001b[1m-delete\u001b[0m action in the case the file has  disappeared\u001b[m\r\n              since  the  parent directory was read: it will not output an error\u001b[m\r\n              diagnostic, and the return code of  the  \u001b[1m-delete\u001b[0m  action  will  be\u001b[m\r\n              true.\u001b[m\r\n\u001b[m\r\n       -maxdepth \u001b[4mlevels\u001b[24m\u001b[m\r\n              Descend at most \u001b[4mlevels\u001b[24m (a non-negative integer) levels of directo‐\u001b[m\r\n              ries below the starting-points.  Using \u001b[1m-m"]
[33.014681, "o", "axdepth\u001b[0m \u001b[1m0\u001b[0m means only  ap‐\u001b[m\r\n              ply the tests and actions to the starting-points themselves.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 347 (press h for help or q to quit)\u001b[27m\u001b[K"]
[33.203111, "o", "\r\u001b[K"]
[33.203146, "o", "       -mindepth \u001b[4mlevels\u001b[24m\u001b[m\r\n              Do  not  apply  any tests or actions at levels less than \u001b[4mlevels\u001b[24m (a\u001b[m\r\n              non-negative integer).  Using \u001b[1m-mindepth\u001b[0m \u001b[1m1\u001b[0m means process all  files\u001b[m\r\n              except the starting-points.\u001b[m\r\n\u001b[m\r\n       -mount Don't descend directories on other filesystems.  An alternate name\u001b[m\r\n              for \u001b[1m-xdev\u001b[0m, for compatibility with some other versions of \u001b[1mfind\u001b[0m.\u001b[m\r\n\u001b[m\r\n       -noignore_readdir_race\u001b[m\r\n              Turns off the effect of \u001b[1m-ignore_readdir_race\u001b[0m.\u001b[m\r\n\u001b[m\r\n       -noleaf\u001b[m\r\n              Do not optimize by assuming that directories contain 2 fewer  sub‐\u001b[m\r\n              directories  than  their  hard  link count.  This option is needed\u001b[m\r\n              when searching filesystems that do not follow the Unix  directory-\u001b[m\r\n              link  convention, such as CD-ROM or MS-DOS filesystems or AFS vol‐\u001b[m\r\n              ume mount points.  Each directory on a normal Unix filesystem  has"]
[33.203162, "o", "\u001b[m\r\n\u001b[7m Manual page find(1) line 364 (press h for help or q to quit)\u001b[27m\u001b[K"]
[33.359576, "o", "\r\u001b[K              at  least 2 hard links: its name and its `.' entry.  Additionally,\u001b[m\r\n              its subdirectories (if any) each have a `..' entry linked to  that\u001b[m\r\n              directory.  When \u001b[1mfind\u001b[0m is examining a directory, after it has stat‐\u001b[m\r\n              ted 2 fewer subdirectories than the  directory's  link  count,  it\u001b[m\r\n              knows that the rest of the entries in the directory are non-direc‐\u001b[m\r\n              tories (`leaf' files in the directory tree).  If only  the  files'\u001b[m\r\n              names  need  to  be  examined, there is no need to stat them; this\u001b[m\r\n              gives a significant increase in search speed.\u001b[m\r\n\u001b[m\r\n       -version, --version\u001b[m\r\n              Print the \u001b[1mfind\u001b[0m version number and exit.\u001b[m\r\n\u001b[m\r\n       -xdev  Don't descend directories on other filesystems.\u001b[m\r\n\u001b[m\r\n   \u001b[1mTESTS\u001b[0m\u001b[m\r\n       Some tests, for example \u001b[1m-newerXY\u001b[0m and \u001b[1m-samefile\u001b[0m, allow comparison  between\u001b[m\r\n       the  file  currently  being examined and s"]
[33.359598, "o", "ome reference file specified on\u001b[m\r\n\u001b[7m Manual page find(1) line 381 (press h for help or q to quit)\u001b[27m\u001b[K"]
[33.548165, "o", "\r\u001b[K"]
[33.548264, "o", "       the command line.  When these tests are used, the interpretation  of  the\u001b[m\r\n       reference  file is determined by the options \u001b[1m-H\u001b[0m, \u001b[1m-L\u001b[0m and \u001b[1m-P\u001b[0m and any previ‐\u001b[m\r\n       ous \u001b[1m-follow\u001b[0m, but the reference file is only examined once,  at  the  time\u001b[m\r\n       the  command  line  is  parsed.  If the reference file cannot be examined\u001b[m\r\n       (for example, the \u001b[1mstat\u001b[0m(2) system call fails for it), an error message  is\u001b[m\r\n       issued, and \u001b[1mfind\u001b[0m exits with a nonzero status.\u001b[m\r\n\u001b[m\r\n       A numeric argument \u001b[4mn\u001b[24m can be specified to tests (like \u001b[1m-amin\u001b[0m, \u001b[1m-mtime\u001b[0m, \u001b[1m-gid\u001b[0m,\u001b[m\r\n       \u001b[1m-inum\u001b[0m, \u001b[1m-links\u001b[0m, \u001b[1m-size\u001b[0m, \u001b[1m-uid\u001b[0m and \u001b[1m-used\u001b[0m) as\u001b[m\r\n\u001b[m\r\n       \u001b[4m+n\u001b[24m     for greater than \u001b[4mn\u001b[24m,\u001b[m\r\n\u001b[m\r\n       \u001b[4m-n\u001b[24m     for less than \u001b[4mn\u001b[24m,\u001b[m\r\n\u001b[m\r\n       \u001b[4mn\u001b[24m      for exactly \u001b[4mn\u001b[24m.\u001b[m\r\n\u001b[m\r\n       Supported tests:\u001b[m\r\n\u001b[7m Manual page find(1) line 398 (press h for help or q to quit)\u001b[27"]
[33.548352, "o", "m\u001b[K"]
[33.71973, "o", "\r\u001b[K\u001b[m\r\n       -amin \u001b[4mn\u001b[24m\u001b[m\r\n              File was last accessed less than, more than or exactly  \u001b[4mn\u001b[24m  minutes\u001b[m\r\n              ago.\u001b[m\r\n\u001b[m\r\n       -anewer \u001b[4mreference\u001b[24m\u001b[m\r\n              Time  of  the  last access of the current file is more recent than\u001b[m\r\n              that of the last data modification of the \u001b[4mreference\u001b[24m file.  If \u001b[4mref‐\u001b[24m\u001b[m\r\n              \u001b[4merence\u001b[24m is a symbolic link and the \u001b[1m-H\u001b[0m option or the \u001b[1m-L\u001b[0m option is in\u001b[m\r\n              effect, then the time of the last data modification of the file it\u001b[m\r\n              points to is always used.\u001b[m\r\n\u001b[m\r\n       -atime \u001b[4mn\u001b[24m\u001b[m\r\n              File  was last accessed less than, more than or exactly \u001b[4mn\u001b[24m*24 hours\u001b[m\r\n              ago.  When find figures out how many 24-hour periods ago the  file\u001b[m\r\n              was  last  accessed,  any  fractional part is ignored, so to match\u001b[m\r\n              \u001b[1m-atime\u001b[0m \u001b[1m+1\u001b[0m, a file has to have been accessed at least \u001b[4mtwo\u001b[24m days"]
[33.71975, "o", " ago.\u001b[m\r\n\u001b[7m Manual page find(1) line 415 (press h for help or q to quit)\u001b[27m\u001b[K"]
[33.907763, "o", "\r\u001b[K\u001b[m\r\n       -cmin \u001b[4mn\u001b[24m\u001b[m\r\n              File's status was last changed less than, more than or  exactly  \u001b[4mn\u001b[24m\u001b[m\r\n              minutes ago.\u001b[m\r\n\u001b[m\r\n       -cnewer \u001b[4mreference\u001b[24m\u001b[m\r\n              Time  of the last status change of the current file is more recent\u001b[m\r\n              than that of the last data modification of the \u001b[4mreference\u001b[24m file.  If\u001b[m\r\n              \u001b[4mreference\u001b[24m is a symbolic link and the \u001b[1m-H\u001b[0m option or the \u001b[1m-L\u001b[0m option is\u001b[m\r\n              in effect, then the time of the last data modification of the file\u001b[m\r\n              it points to is always used.\u001b[m\r\n\u001b[m\r\n       -ctime \u001b[4mn\u001b[24m\u001b[m\r\n              File's  status  was  last  changed less than, more than or exactly\u001b[m\r\n              \u001b[4mn\u001b[24m*24 hours ago.  See the comments for  \u001b[1m-atime\u001b[0m  to  understand  how\u001b[m\r\n              rounding affects the interpretation of file status change times.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 432 (press h for help or q to quit)\u001b[27m\u001b[K"]
[34.086567, "o", "\r\u001b[K"]
[34.086694, "o", "       -empty File is empty and is either a regular file or a directory.\u001b[m\r\n\u001b[m\r\n       -executable\u001b[m\r\n              Matches  files  which  are  executable  and  directories which are\u001b[m\r\n              searchable (in a file name resolution sense) by the current  user.\u001b[m\r\n              This takes into account access control lists and other permissions\u001b[m\r\n              artefacts which the \u001b[1m-perm\u001b[0m test ignores.  This test  makes  use  of\u001b[m\r\n              the  \u001b[1maccess\u001b[0m(2)  system  call,  and so can be fooled by NFS servers\u001b[m\r\n              which do UID mapping (or root-squashing), since many  systems  im‐\u001b[m\r\n              plement \u001b[1maccess\u001b[0m(2) in the client's kernel and so cannot make use of\u001b[m\r\n              the UID mapping information held on the server.  Because this test\u001b[m\r\n              is based only on the result of the \u001b[1maccess\u001b[0m(2) system call, there is\u001b[m\r\n              no guarantee that a file for which this test succeeds can actually\u001b[m\r\n              be executed.\u001b[m\r\n\u001b[m\r"]
[34.086708, "o", "\n       -false Always false.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 449 (press h for help or q to quit)\u001b[27m\u001b[K"]
[34.267956, "o", "\r\u001b[K"]
[34.267984, "o", "       -fstype \u001b[4mtype\u001b[24m\u001b[m\r\n              File  is on a filesystem of type \u001b[4mtype\u001b[24m.  The valid filesystem types\u001b[m\r\n              vary among different versions  of  Unix;  an  incomplete  list  of\u001b[m\r\n              filesystem  types that are accepted on some version of Unix or an‐\u001b[m\r\n              other is: ufs, 4.2, 4.3, nfs, tmp, mfs, S51K, S52K.  You  can  use\u001b[m\r\n              \u001b[1m-printf\u001b[0m  with  the  %F directive to see the types of your filesys‐\u001b[m\r\n              tems.\u001b[m\r\n\u001b[m\r\n       -gid \u001b[4mn\u001b[24m File's numeric group ID is less than, more than or exactly \u001b[4mn\u001b[24m.\u001b[m\r\n\u001b[m\r\n       -group \u001b[4mgname\u001b[24m\u001b[m\r\n              File belongs to group \u001b[4mgname\u001b[24m (numeric group ID allowed).\u001b[m\r\n\u001b[m\r\n       -ilname \u001b[4mpattern\u001b[24m\u001b[m\r\n              Like \u001b[1m-lname\u001b[0m, but the match is case insensitive.  If the \u001b[1m-L\u001b[0m  option\u001b[m\r\n              or the \u001b[1m-follow\u001b[0m option is in effect, this test returns false unless\u001b[m\r\n              the symbolic link is broken.\u001b[m\r\n\u001b[7m Manual pag"]
[34.26799, "o", "e find(1) line 466 (press h for help or q to quit)\u001b[27m\u001b[K"]
[34.500596, "o", "\r\u001b[K"]
[34.500773, "o", "\u001b[m\r\n       -iname \u001b[4mpattern\u001b[24m\u001b[m\r\n              Like \u001b[1m-name\u001b[0m, but the match is case insensitive.  For  example,  the\u001b[m\r\n              patterns `fo*' and `F??' match the file names `Foo', `FOO', `foo',\u001b[m\r\n              `fOo', etc.  The pattern `*foo*` will also  match  a  file  called\u001b[m\r\n              '.foobar'.\u001b[m\r\n\u001b[m\r\n       -inum \u001b[4mn\u001b[24m\u001b[m\r\n              File has inode number smaller than, greater than or exactly \u001b[4mn\u001b[24m.  It\u001b[m\r\n              is normally easier to use the \u001b[1m-samefile\u001b[0m test instead.\u001b[m\r\n\u001b[m\r\n       -ipath \u001b[4mpattern\u001b[24m\u001b[m\r\n              Like \u001b[1m-path\u001b[0m.  but the match is case insensitive.\u001b[m\r\n\u001b[m\r\n       -iregex \u001b[4mpattern\u001b[24m\u001b[m\r\n              Like \u001b[1m-regex\u001b[0m, but the match is case insensitive.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 483 (press h for help or q to quit)\u001b[27m\u001b[K"]
[34.709617, "o", "\r\u001b[K"]
[34.7097, "o", "       -iwholename \u001b[4mpattern\u001b[24m\u001b[m\r\n              See -ipath.  This alternative is less portable than \u001b[1m-ipath\u001b[0m.\u001b[m\r\n\u001b[m\r\n       -links \u001b[4mn\u001b[24m\u001b[m\r\n              File has less than, more than or exactly \u001b[4mn\u001b[24m hard links.\u001b[m\r\n\u001b[m\r\n       -lname \u001b[4mpattern\u001b[24m\u001b[m\r\n              File is a symbolic link whose contents match  shell  pattern  \u001b[4mpat‐\u001b[24m\u001b[m\r\n              \u001b[4mtern\u001b[24m.   The  metacharacters do not treat `/' or `.' specially.  If\u001b[m\r\n              the \u001b[1m-L\u001b[0m option or the \u001b[1m-follow\u001b[0m option is in effect,  this  test  re‐\u001b[m\r\n              turns false unless the symbolic link is broken.\u001b[m\r\n\u001b[m\r\n       -mmin \u001b[4mn\u001b[24m\u001b[m\r\n              File's  data  was  last modified less than, more than or exactly \u001b[4mn\u001b[24m\u001b[m\r\n              minutes ago.\u001b[m\r\n\u001b[m\r\n       -mtime \u001b[4mn\u001b[24m\u001b[m\r\n\u001b[7m Manual page find(1) line 500 (press h for help or q to quit)\u001b[27m\u001b[K"]
[34.904808, "o", "\r\u001b[K"]
[34.904835, "o", "              File's data was last modified less than, more than or exactly \u001b[4mn\u001b[24m*24\u001b[m\r\n              hours ago.  See the comments for \u001b[1m-atime\u001b[0m to understand how rounding\u001b[m\r\n              affects the interpretation of file modification times.\u001b[m\r\n\u001b[m\r\n       -name \u001b[4mpattern\u001b[24m\u001b[m\r\n              Base of file name (the path with the leading directories  removed)\u001b[m\r\n              matches  shell  pattern  \u001b[4mpattern\u001b[24m.  Because the leading directories\u001b[m\r\n              are removed, the file names considered for a match with \u001b[1m-name\u001b[0m will\u001b[m\r\n              never  include  a  slash, so `-name a/b' will never match anything\u001b[m\r\n              (you probably need to use \u001b[1m-path\u001b[0m instead).  A warning is issued  if\u001b[m\r\n              you  try  to do this, unless the environment variable \u001b[1mPOSIXLY_COR‐\u001b[0m\u001b[m\r\n              \u001b[1mRECT\u001b[0m is set.  The metacharacters (`*', `?', and `[]') match a  `.'\u001b[m\r\n              at  the  start  of  the  base  name  (this  is  a change in findu‐\u001b[m\r\n"]
[34.904946, "o", "              tils-4.2.2; see section STANDARDS CONFORMANCE below).  To ignore a\u001b[m\r\n              directory  and the files under it, use \u001b[1m-prune\u001b[0m rather than checking\u001b[m\r\n              every file in the tree; see an example in the description of  that\u001b[m\r\n              action.   Braces  are not recognised as being special, despite the\u001b[m\r\n\u001b[7m Manual page find(1) line 517 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.099767, "o", "\r\u001b[K"]
[35.099869, "o", "              fact that some shells including Bash imbue braces with  a  special\u001b[m\r\n              meaning  in  shell  patterns.   The filename matching is performed\u001b[m\r\n              with the use of the \u001b[1mfnmatch\u001b[0m(3) library function.  Don't forget  to\u001b[m\r\n              enclose  the  pattern in quotes in order to protect it from expan‐\u001b[m\r\n              sion by the shell.\u001b[m\r\n\u001b[m\r\n       -newer \u001b[4mreference\u001b[24m\u001b[m\r\n              Time of the last data modification of the current file is more re‐\u001b[m\r\n              cent  than  that  of  the  last data modification of the \u001b[4mreference\u001b[24m\u001b[m\r\n              file.  If \u001b[4mreference\u001b[24m is a symbolic link and the \u001b[1m-H\u001b[0m option or the \u001b[1m-L\u001b[0m\u001b[m\r\n              option  is  in effect, then the time of the last data modification\u001b[m\r\n              of the file it points to is always used.\u001b[m\r\n\u001b[m\r\n       -newerXY \u001b[4mreference\u001b[24m\u001b[m\r\n              Succeeds if timestamp \u001b[4mX\u001b[24m of the file being considered is newer than\u001b[m\r\n              timestam"]
[35.099969, "o", "p \u001b[4mY\u001b[24m of the file \u001b[4mreference\u001b[24m.  The letters \u001b[4mX\u001b[24m and \u001b[4mY\u001b[24m can be any\u001b[m\r\n              of the following letters:\u001b[m\r\n\u001b[7m Manual page find(1) line 534 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.294617, "o", "\r\u001b[K"]
[35.294733, "o", "\u001b[m\r\n              a   The access time of the file \u001b[4mreference\u001b[24m\u001b[m\r\n              B   The birth time of the file \u001b[4mreference\u001b[24m\u001b[m\r\n              c   The inode status change time of \u001b[4mreference\u001b[24m\u001b[m\r\n              m   The modification time of the file \u001b[4mreference\u001b[24m\u001b[m\r\n              t   \u001b[4mreference\u001b[24m is interpreted directly as a time\u001b[m\r\n\u001b[m\r\n              Some combinations are invalid; for example, it is invalid for \u001b[4mX\u001b[24m to\u001b[m\r\n              be  \u001b[4mt\u001b[24m.   Some combinations are not implemented on all systems; for\u001b[m\r\n              example \u001b[4mB\u001b[24m is not supported on all systems.  If an invalid  or  un‐\u001b[m\r\n              supported  combination  of \u001b[4mXY\u001b[24m is specified, a fatal error results.\u001b[m\r\n              Time specifications are interpreted as for the argument to the  \u001b[1m-d\u001b[0m\u001b[m\r\n              option  of GNU \u001b[1mdate\u001b[0m.  If you try to use the birth time of a refer‐\u001b[m\r\n              ence file, and the birth time cannot be determined, a fatal  error\u001b[m\r\n   "]
[35.294747, "o", "           message  results.  If you specify a test which refers to the birth\u001b[m\r\n              time of files being examined, this test will fail  for  any  files\u001b[m\r\n              where the birth time is unknown.\u001b[m\r\n\u001b[7m Manual page find(1) line 551 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.796017, "o", "\r\u001b[K\u001b[m\r\n       -nogroup\u001b[m\r\n              No group corresponds to file's numeric group ID.\u001b[m\r\n\u001b[m\r\n       -nouser\u001b[m\r\n              No user corresponds to file's numeric user ID.\u001b[m\r\n\u001b[m\r\n       -path \u001b[4mpattern\u001b[24m\u001b[m\r\n              File  name  matches  shell pattern \u001b[4mpattern\u001b[24m.  The metacharacters do\u001b[m\r\n              not treat `/' or `.' specially; so, for example,\u001b[m\r\n                  find . -path \"./sr*sc\"\u001b[m\r\n              will print an entry for a directory called \u001b[4m./src/misc\u001b[24m (if one  ex‐\u001b[m\r\n              ists).   To  ignore a whole directory tree, use \u001b[1m-prune\u001b[0m rather than\u001b[m\r\n              checking every file in the tree.  Note that the pattern match test\u001b[m\r\n              applies  to  the  whole  file name, starting from one of the start\u001b[m\r\n              points named on the command line.  It would only make sense to use\u001b[m\r\n              an  absolute path name here if the relevant start point is also an\u001b[m\r\n\u001b[7m Manual page find(1) line 568 (press h for help or q to quit)"]
[35.796042, "o", "\u001b[27m\u001b[K"]
[35.827491, "o", "\r\u001b[K              absolute path.  This means that this command will never match any‐\u001b[m\r\n              thing:\u001b[m\r\n                  find bar -path /foo/bar/myfile -print\u001b[m\r\n              Find  compares  the \u001b[1m-path\u001b[0m argument with the concatenation of a di‐\u001b[m\r\n              rectory name and the base name of the file it's examining.   Since\u001b[m\r\n              the  concatenation  will  never  end with a slash, \u001b[1m-path\u001b[0m arguments\u001b[m\r\n              ending in a slash will match nothing (except perhaps a start point\u001b[m\r\n              specified  on the command line).  The predicate \u001b[1m-path\u001b[0m is also sup‐\u001b[m\r\n"]
[35.827528, "o", "              ported by HP-UX \u001b[1mfind\u001b[0m and is part of the POSIX 2008 standard.\u001b[m\r\n\u001b[m\r\n       -perm \u001b[4mmode\u001b[24m\u001b[m\r\n              File's permission bits  are  exactly  \u001b[4mmode\u001b[24m  (octal  or  symbolic).\u001b[m\r\n              Since an exact match is required, if you want to use this form for\u001b[m\r\n              symbolic modes, you may have to  specify  a  rather  complex  mode\u001b[m\r\n              string.   For example `-perm g=w' will only match files which have\u001b[m\r\n              mode 0020 (that is, ones for which group write permission  is  the\u001b[m\r\n              only permission set).  It is more likely that you will want to use\u001b[m\r\n\u001b[7m Manual page find(1) line 585 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.858199, "o", "\r\u001b[K"]
[35.858243, "o", "              the `/' or `-' forms, for example `-perm -g=w', which matches  any\u001b[m\r\n              file  with  group  write permission.  See the \u001b[1mEXAMPLES\u001b[0m section for\u001b[m\r\n              some illustrative examples.\u001b[m\r\n\u001b[m\r\n       -perm -\u001b[4mmode\u001b[24m\u001b[m\r\n              All of the permission bits \u001b[4mmode\u001b[24m are set for  the  file.   Symbolic\u001b[m\r\n              modes  are  accepted  in this form, and this is usually the way in\u001b[m\r\n              which you would want to use them.  You must specify  `u',  `g'  or\u001b[m\r\n              `o' if you use a symbolic mode.  See the \u001b[1mEXAMPLES\u001b[0m section for some\u001b[m\r\n              illustrative examples.\u001b[m\r\n\u001b[m\r\n       -perm /\u001b[4mmode\u001b[24m\u001b[m\r\n              Any of the permission bits \u001b[4mmode\u001b[24m are set for  the  file.   Symbolic\u001b[m\r\n              modes are accepted in this form.  You must specify `u', `g' or `o'\u001b[m\r\n              if you use a symbolic mode.  See the \u001b[1mEXAMPLES\u001b[0m section for some il‐\u001b[m\r\n"]
[35.858381, "o", "              lustrative  examples.  If no permission bits in \u001b[4mmode\u001b[24m are set, this\u001b[m\r\n              test matches any file (the idea here is to be consistent with  the\u001b[m\r\n\u001b[7m Manual page find(1) line 602 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.889439, "o", "\r\u001b[K"]
[35.889467, "o", "              behaviour of \u001b[1m-perm\u001b[0m \u001b[1m-000\u001b[0m).\u001b[m\r\n\u001b[m\r\n       -perm +\u001b[4mmode\u001b[24m\u001b[m\r\n              This  is no longer supported (and has been deprecated since 2005).\u001b[m\r\n              Use \u001b[1m-perm\u001b[0m \u001b[1m/\u001b[0m\u001b[4mmode\u001b[24m instead.\u001b[m\r\n\u001b[m\r\n       -readable\u001b[m\r\n              Matches files which are readable by the current user.  This  takes\u001b[m\r\n              into  account access control lists and other permissions artefacts\u001b[m\r\n              which the \u001b[1m-perm\u001b[0m test ignores.  This test  makes  use  of  the  \u001b[1mac‐\u001b[0m\u001b[m\r\n              \u001b[1mcess\u001b[0m(2)  system call, and so can be fooled by NFS servers which do\u001b[m\r\n              UID mapping (or root-squashing), since many systems implement  \u001b[1mac‐\u001b[0m\u001b[m\r\n              \u001b[1mcess\u001b[0m(2)  in  the client's kernel and so cannot make use of the UID\u001b[m\r\n              mapping information held on the server.\u001b[m\r\n\u001b[m\r\n       -regex \u001b[4mpattern\u001b[24m\u001b[m\r\n              File name matches regular expression \u001b[4mpattern\u001b[24m.  This is a match  on\u001b[m\r\n\u001b["]
[35.889489, "o", "7m Manual page find(1) line 619 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.920353, "o", "\r\u001b[K"]
[35.920445, "o", "              the  whole path, not a search.  For example, to match a file named\u001b[m\r\n              \u001b[4m./fubar3,\u001b[24m you can use the regular expression `.*bar.' or `.*b.*3',\u001b[m\r\n              but  not  `f.*r3'.  The regular expressions understood by \u001b[1mfind\u001b[0m are\u001b[m\r\n              by default Emacs Regular Expressions (except that `.' matches new‐\u001b[m\r\n              line), but this can be changed with the \u001b[1m-regextype\u001b[0m option.\u001b[m\r\n\u001b[m\r\n       -samefile \u001b[4mname\u001b[24m\u001b[m\r\n              File refers to the same inode as \u001b[4mname\u001b[24m.  When \u001b[1m-L\u001b[0m is in effect, this\u001b[m\r\n              can include symbolic links.\u001b[m\r\n\u001b[m\r\n       -size \u001b[4mn\u001b[24m[cwbkMG]\u001b[m\r\n              File uses less than, more than or exactly \u001b[4mn\u001b[24m units of space, round‐\u001b[m\r\n              ing up.  The following suffixes can be used:\u001b[m\r\n\u001b[m\r\n              `b'    for  512-byte  blocks  (this is the default if no suffix is\u001b[m\r\n                     used)\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 636 (press h for help or q to quit)\u001b"]
[35.92047, "o", "[27m\u001b[K"]
[35.952016, "o", "\r\u001b[K              `c'    for bytes\u001b[m\r\n\u001b[m\r\n              `w'    for two-byte words\u001b[m\r\n\u001b[m\r\n              `k'    for kibibytes (KiB, units of 1024 bytes)\u001b[m\r\n\u001b[m\r\n              `M'    for mebibytes (MiB, units of 1024 * 1024 = 1048576 bytes)\u001b[m\r\n\u001b[m\r\n              `G'    for  gibibytes  (GiB,  units  of  1024  *  1024  *  1024  =\u001b[m\r\n                     1073741824 bytes)\u001b[m\r\n\u001b[m\r\n"]
[35.952116, "o", "              The size is simply the st_size member of the struct stat populated\u001b[m\r\n              by the lstat (or stat) system call, rounded up as shown above.  In\u001b[m\r\n              other  words,  it's  consistent with the result you get for \u001b[1mls\u001b[0m \u001b[1m-l\u001b[0m.\u001b[m\r\n              Bear in mind that the `%k' and `%b' format specifiers  of  \u001b[1m-printf\u001b[0m\u001b[m\r\n              handle  sparse  files  differently.  The `b' suffix always denotes\u001b[m\r\n              512-byte blocks and never 1024-byte blocks, which is different  to\u001b[m\r\n\u001b[7m Manual page find(1) line 653 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.983146, "o", "\r\u001b[K"]
[35.983259, "o", "              the behaviour of \u001b[1m-ls\u001b[0m.\u001b[m\r\n\u001b[m\r\n              The + and - prefixes signify greater than and less than, as usual;\u001b[m\r\n              i.e., an exact size of \u001b[4mn\u001b[24m units does not match.  Bear in mind  that\u001b[m\r\n              the  size  is rounded up to the next unit.  Therefore \u001b[1m-size\u001b[0m \u001b[1m-1M\u001b[0m is\u001b[m\r\n              not equivalent to \u001b[1m-size\u001b[0m \u001b[1m-1048576c\u001b[0m.  The former only matches  empty\u001b[m\r\n              files, the latter matches files from 0 to 1,048,575 bytes.\u001b[m\r\n\u001b[m\r\n       -true  Always true.\u001b[m\r\n\u001b[m\r\n       -type \u001b[4mc\u001b[24m\u001b[m\r\n              File is of type \u001b[4mc\u001b[24m:\u001b[m\r\n\u001b[m\r\n              b      block (buffered) special\u001b[m\r\n\u001b[m\r\n              c      character (unbuffered) special\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 670 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.014539, "o", "\r\u001b[K"]
[36.014759, "o", "              d      directory\u001b[m\r\n\u001b[m\r\n              p      named pipe (FIFO)\u001b[m\r\n\u001b[m\r\n              f      regular file\u001b[m\r\n\u001b[m\r\n              l      symbolic  link;  this is never true if the \u001b[1m-L\u001b[0m option or the\u001b[m\r\n                     \u001b[1m-follow\u001b[0m option is in effect, unless the  symbolic  link  is\u001b[m\r\n                     broken.   If  you want to search for symbolic links when \u001b[1m-L\u001b[0m\u001b[m\r\n                     is in effect, use \u001b[1m-xtype\u001b[0m.\u001b[m\r\n\u001b[m\r\n              s      socket\u001b[m\r\n\u001b[m\r\n              D      door (Solaris)\u001b[m\r\n\u001b[m\r\n              To search for more than one type at once, you can supply the  com‐\u001b[m\r\n              bined  list  of  type letters separated by a comma `,' (GNU exten‐\u001b[m\r\n\u001b[7m Manual page find(1) line 687 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.046543, "o", "\r\u001b[K"]
[36.046567, "o", "              sion).\u001b[m\r\n\u001b[m\r\n       -uid \u001b[4mn\u001b[24m File's numeric user ID is less than, more than or exactly \u001b[4mn\u001b[24m.\u001b[m\r\n\u001b[m\r\n       -used \u001b[4mn\u001b[24m\u001b[m\r\n              File was last accessed less than, more than or exactly \u001b[4mn\u001b[24m days  af‐\u001b[m\r\n              ter its status was last changed.\u001b[m\r\n\u001b[m\r\n       -user \u001b[4muname\u001b[24m\u001b[m\r\n              File is owned by user \u001b[4muname\u001b[24m (numeric user ID allowed).\u001b[m\r\n\u001b[m\r\n       -wholename \u001b[4mpattern\u001b[24m\u001b[m\r\n              See -path.  This alternative is less portable than \u001b[1m-path\u001b[0m.\u001b[m\r\n\u001b[m\r\n       -writable\u001b[m\r\n              Matches  files which are writable by the current user.  This takes\u001b[m\r\n              into account access control lists and other permissions  artefacts\u001b[m\r\n\u001b[7m Manual page find(1) line 704 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.077598, "o", "\r\u001b[K"]
[36.077726, "o", "              which  the  \u001b[1m-perm\u001b[0m  test  ignores.   This test makes use of the \u001b[1mac‐\u001b[0m\u001b[m\r\n              \u001b[1mcess\u001b[0m(2) system call, and so can be fooled by NFS servers which  do\u001b[m\r\n              UID  mapping (or root-squashing), since many systems implement \u001b[1mac‐\u001b[0m\u001b[m\r\n              \u001b[1mcess\u001b[0m(2) in the client's kernel and so cannot make use of  the  UID\u001b[m\r\n              mapping information held on the server.\u001b[m\r\n\u001b[m\r\n       -xtype \u001b[4mc\u001b[24m\u001b[m\r\n              The  same  as  \u001b[1m-type\u001b[0m unless the file is a symbolic link.  For sym‐\u001b[m\r\n              bolic links: if the \u001b[1m-H\u001b[0m or \u001b[1m-P\u001b[0m option was  specified,  true  if  the\u001b[m\r\n              file  is  a  link  to  a file of type \u001b[4mc\u001b[24m; if the \u001b[1m-L\u001b[0m option has been\u001b[m\r\n              given, true if \u001b[4mc\u001b[24m is `l'.  In  other  words,  for  symbolic  links,\u001b[m\r\n              \u001b[1m-xtype\u001b[0m checks the type of the file that \u001b[1m-type\u001b[0m does not check.\u001b[m\r\n\u001b[m\r\n       -context \u001b[4mpattern\u001b[24m\u001b[m\r\n              (SEL"]
[36.077739, "o", "inux only) Security context of the file matches glob \u001b[4mpattern\u001b[24m.\u001b[m\r\n\u001b[m\r\n   \u001b[1mACTIONS\u001b[0m\u001b[m\r\n\u001b[7m Manual page find(1) line 721 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.107882, "o", "\r\u001b[K"]
[36.107964, "o", "       -delete\u001b[m\r\n              Delete  files  or  directories; true if removal succeeded.  If the\u001b[m\r\n              removal failed, an error message is issued and \u001b[1mfind\u001b[0m's exit  status\u001b[m\r\n              will be nonzero (when it eventually exits).\u001b[m\r\n\u001b[m\r\n              \u001b[1mWarning\u001b[0m:  Don't  forget that \u001b[1mfind\u001b[0m evaluates the command line as an\u001b[m\r\n              expression, so putting \u001b[1m-delete\u001b[0m first will make \u001b[1mfind\u001b[0m try to  delete\u001b[m\r\n              everything below the starting points you specified.\u001b[m\r\n\u001b[m\r\n              The  use  of  the \u001b[1m-delete\u001b[0m action on the command line automatically\u001b[m\r\n              turns on the \u001b[1m-depth\u001b[0m option.  As in turn \u001b[1m-depth\u001b[0m makes \u001b[1m-prune\u001b[0m  inef‐\u001b[m\r\n              fective,  the  \u001b[1m-delete\u001b[0m  action  cannot  usefully  be combined with\u001b[m\r\n              \u001b[1m-prune\u001b[0m.\u001b[m\r\n\u001b[m\r\n              Often, the user might want to test a find command line with \u001b[1m-print\u001b[0m\u001b[m\r\n              prior to adding \u001b[1m-delete\u001b[0m for the "]
[36.107969, "o", "actual removal"]
[36.108003, "o", " run.  To avoid sur‐\u001b[m\r\n              prising results, it is usually best to remember to use \u001b[1m-depth\u001b[0m  ex‐\u001b[m\r\n\u001b[7m Manual page find(1) line 738 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.139283, "o", "\r\u001b[K"]
[36.139313, "o", "              plicitly during those earlier test runs.\u001b[m\r\n\u001b[m\r\n              The  \u001b[1m-delete\u001b[0m  action  will fail to remove a directory unless it is\u001b[m\r\n              empty.\u001b[m\r\n\u001b[m\r\n              Together with the \u001b[1m-ignore_readdir_race\u001b[0m option,  \u001b[1mfind\u001b[0m  will  ignore\u001b[m\r\n              errors  of the \u001b[1m-delete\u001b[0m action in the case the file has disappeared\u001b[m\r\n              since the parent directory was read: it will not output  an  error\u001b[m\r\n              diagnostic,  not  change  the exit code to nonzero, and the return\u001b[m\r\n              code of the \u001b[1m-delete\u001b[0m action will be true.\u001b[m\r\n\u001b[m\r\n       -exec \u001b[4mcommand\u001b[24m ;\u001b[m\r\n              Execute \u001b[4mcommand\u001b[24m; true if 0 status is returned.  All following  ar‐\u001b[m\r\n              guments  to \u001b[1mfind\u001b[0m are taken to be arguments to the command until an\u001b[m\r\n              argument consisting of `;' is encountered.  The string `{}' is re‐\u001b[m\r\n              placed  by the current file name being processed everywhere it oc‐\u001b[m\r\n  "]
[36.139341, "o", "            curs in the arguments to the command, not just in arguments  where\u001b[m\r\n\u001b[7m Manual page find(1) line 755 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.171142, "o", "\r\u001b[K"]
[36.171171, "o", "              it is alone, as in some versions of \u001b[1mfind\u001b[0m.  Both of these construc‐\u001b[m\r\n              tions might need to be escaped (with a `\\') or quoted  to  protect\u001b[m\r\n              them  from  expansion  by the shell.  See the \u001b[1mEXAMPLES\u001b[0m section for\u001b[m\r\n              examples of the use of the \u001b[1m-exec\u001b[0m option.  The specified command is\u001b[m\r\n              run  once  for  each matched file.  The command is executed in the\u001b[m\r\n              starting directory.  There are unavoidable security problems  sur‐\u001b[m\r\n              rounding  use of the \u001b[1m-exec\u001b[0m action; you should use the \u001b[1m-execdir\u001b[0m op‐\u001b[m\r\n              tion instead.\u001b[m\r\n\u001b[m\r\n       -exec \u001b[4mcommand\u001b[24m {} +\u001b[m\r\n              This variant of the \u001b[1m-exec\u001b[0m action runs the specified command on the\u001b[m\r\n              selected  files,  but  the command line is built by appending each\u001b[m\r\n              selected file name at the end; the total number of invocations  of\u001b[m\r\n              the  command  will  be much le"]
[36.171183, "o", "ss than the number of matched files.\u001b[m\r\n              The command line is built in much the same way that  \u001b[1mxargs\u001b[0m  builds\u001b[m\r\n              its  command  lines.   Only one instance of `{}' is allowed within\u001b[m\r\n              the command, and it must appear at the end, immediately before the\u001b[m\r\n\u001b[7m Manual page find(1) line 772 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.203059, "o", "\r\u001b[K"]
[36.20319, "o", "              `+';  it  needs to be escaped (with a `\\') or quoted to protect it\u001b[m\r\n              from interpretation by the shell.  The command is executed in  the\u001b[m\r\n              starting directory.  If any invocation with the `+' form returns a\u001b[m\r\n              non-zero value as exit status, then \u001b[1mfind\u001b[0m returns a  non-zero  exit\u001b[m\r\n              status.   If \u001b[1mfind\u001b[0m encounters an error, this can sometimes cause an\u001b[m\r\n              immediate exit, so some pending commands may not be  run  at  all.\u001b[m\r\n              For  this reason \u001b[1m-exec\u001b[0m \u001b[4mmy-command\u001b[24m \u001b[1m...\u001b[0m \u001b[1m{}\u001b[0m \u001b[1m+\u001b[0m \u001b[1m-quit\u001b[0m may not result in\u001b[m\r\n              \u001b[4mmy-command\u001b[24m actually being run.  This variant of \u001b[1m-exec\u001b[0m  always  re‐\u001b[m\r\n              turns true.\u001b[m\r\n\u001b[m\r\n       -execdir \u001b[4mcommand\u001b[24m ;\u001b[m\r\n\u001b[m\r\n       -execdir \u001b[4mcommand\u001b[24m {} +\u001b[m\r\n              Like \u001b[1m-exec\u001b[0m, but the specified command is run from the subdirectory\u001b[m\r\n              containing the matched file, whi"]
[36.203203, "o", "ch is not normally  the  directory\u001b[m\r\n              in which you started \u001b[1mfind\u001b[0m.  As with -exec, the {} should be quoted\u001b[m\r\n              if find is being invoked from a shell.  This a  much  more  secure\u001b[m\r\n\u001b[7m Manual page find(1) line 789 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.234507, "o", "\r\u001b[K"]
[36.23461, "o", "              method  for invoking commands, as it avoids race conditions during\u001b[m\r\n              resolution of the paths to the matched files.  As with  the  \u001b[1m-exec\u001b[0m\u001b[m\r\n              action,  the  `+'  form  of  \u001b[1m-execdir\u001b[0m will build a command line to\u001b[m\r\n              process more than one matched file, but any  given  invocation  of\u001b[m\r\n              \u001b[4mcommand\u001b[24m  will only list files that exist in the same subdirectory.\u001b[m\r\n              If you use this option, you must ensure that your \u001b[1mPATH\u001b[0m environment\u001b[m\r\n              variable  does  not  reference `.'; otherwise, an attacker can run\u001b[m\r\n              any commands they like by leaving an appropriately-named file in a\u001b[m\r\n              directory  in  which  you  will run \u001b[1m-execdir\u001b[0m.  The same applies to\u001b[m\r\n              having entries in \u001b[1mPATH\u001b[0m which are empty or which are  not  absolute\u001b[m\r\n              directory  names.   If  any invocation with the `+' form returns a\u001b[m\r\n              non-zero value as exit sta"]
[36.234654, "o", "tus, then \u001b[1mfind\u001b[0m returns a  non-zero  exit\u001b[m\r\n              status.   If \u001b[1mfind\u001b[0m encounters an error, this can sometimes cause an\u001b[m\r\n              immediate exit, so some pending commands may not be  run  at  all.\u001b[m\r\n              The result of the action depends on whether the \u001b[1m+\u001b[0m or the \u001b[1m;\u001b[0m variant\u001b[m\r\n              is being used; \u001b[1m-execdir\u001b[0m \u001b[4mcommand\u001b[24m \u001b[1m{}\u001b[0m \u001b[1m+\u001b[0m always  returns  true,  while\u001b[m\r\n              \u001b[1m-execdir\u001b[0m \u001b[4mcommand\u001b[24m \u001b[1m{}\u001b[0m \u001b[1m;\u001b[0m returns true only if \u001b[4mcommand\u001b[24m returns 0.\u001b[m\r\n\u001b[7m Manual page find(1) line 806 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.26549, "o", "\r\u001b[K"]
[36.265587, "o", "\u001b[m\r\n       -fls \u001b[4mfile\u001b[24m\u001b[m\r\n              True; like \u001b[1m-ls\u001b[0m but write to \u001b[4mfile\u001b[24m like \u001b[1m-fprint\u001b[0m.  The output file is\u001b[m\r\n              always created, even if the predicate is never matched.   See  the\u001b[m\r\n              \u001b[1mUNUSUAL\u001b[0m  \u001b[1mFILENAMES\u001b[0m section for information about how unusual char‐\u001b[m\r\n              acters in filenames are handled.\u001b[m\r\n\u001b[m\r\n       -fprint \u001b[4mfile\u001b[24m\u001b[m\r\n              True; print the full file name into file \u001b[4mfile\u001b[24m.  If \u001b[4mfile\u001b[24m  does  not\u001b[m\r\n              exist  when  \u001b[1mfind\u001b[0m  is  run, it is created; if it does exist, it is\u001b[m\r\n              truncated.  The file names \u001b[4m/dev/stdout\u001b[24m and \u001b[4m/dev/stderr\u001b[24m are handled\u001b[m\r\n              specially;  they  refer  to the standard output and standard error\u001b[m\r\n              output, respectively.  The output file is always created, even  if\u001b[m\r\n              the predicate is never matched.  See the \u001b[1mUNUSUAL\u001b[0m \u001b[1mFILENAMES\u001b[0m section\u001b[m\r\n              for information ab"]
[36.265599, "o", "out how unusual characters in filenames are han‐\u001b[m\r\n              dled.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 823 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.296223, "o", "\r\u001b[K"]
[36.296399, "o", "       -fprint0 \u001b[4mfile\u001b[24m\u001b[m\r\n              True;  like  \u001b[1m-print0\u001b[0m  but  write to \u001b[4mfile\u001b[24m like \u001b[1m-fprint\u001b[0m.  The output\u001b[m\r\n              file is always created, even if the predicate  is  never  matched.\u001b[m\r\n              See  the  \u001b[1mUNUSUAL\u001b[0m  \u001b[1mFILENAMES\u001b[0m section for information about how un‐\u001b[m\r\n              usual characters in filenames are handled.\u001b[m\r\n\u001b[m\r\n       -fprintf \u001b[4mfile\u001b[24m \u001b[4mformat\u001b[24m\u001b[m\r\n              True; like \u001b[1m-printf\u001b[0m but write to \u001b[4mfile\u001b[24m  like  \u001b[1m-fprint\u001b[0m.   The  output\u001b[m\r\n              file  is  always  created, even if the predicate is never matched.\u001b[m\r\n              See the \u001b[1mUNUSUAL\u001b[0m \u001b[1mFILENAMES\u001b[0m section for information  about  how  un‐\u001b[m\r\n              usual characters in filenames are handled.\u001b[m\r\n\u001b[m\r\n       -ls    True;  list  current  file  in \u001b[1mls\u001b[0m \u001b[1m-dils\u001b[0m format on standard output.\u001b[m\r\n              The block counts are of 1 KB blocks, unless the environment  vari‐\u001b[m\r\n              able  \u001b[1m"]
[36.296417, "o", "POSIXLY_CORRECT\u001b[0m  is  set,  in which case 512-byte blocks are\u001b[m\r\n              used.  See the \u001b[1mUNUSUAL\u001b[0m \u001b[1mFILENAMES\u001b[0m section for information about how\u001b[m\r\n              unusual characters in filenames are handled.\u001b[m\r\n\u001b[7m Manual page find(1) line 840 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.32838, "o", "\r\u001b[K"]
[36.328514, "o", "\u001b[m\r\n       -ok \u001b[4mcommand\u001b[24m ;\u001b[m\r\n              Like  \u001b[1m-exec\u001b[0m  but  ask the user first.  If the user agrees, run the\u001b[m\r\n              command.  Otherwise just return false.  If the command is run, its\u001b[m\r\n              standard  input is redirected from \u001b[4m/dev/null\u001b[24m.  This action may not\u001b[m\r\n              be specified together with the \u001b[1m-files0-from\u001b[0m option.\u001b[m\r\n\u001b[m\r\n              The response to the prompt is matched against a  pair  of  regular\u001b[m\r\n              expressions  to  determine if it is an affirmative or negative re‐\u001b[m\r\n              sponse.  This regular expression is obtained from  the  system  if\u001b[m\r\n              the \u001b[1mPOSIXLY_CORRECT\u001b[0m environment variable is set, or otherwise from\u001b[m\r\n              \u001b[1mfind\u001b[0m's message translations.  If the system has no suitable  defi‐\u001b[m\r\n              nition,  \u001b[1mfind\u001b[0m's  own definition will be used.  In either case, the\u001b[m\r\n              interpretation of the regular expression itself will  be  affected\u001b[m\r\n       "]
[36.32853, "o", "       by  the  environment  variables  \u001b[1mLC_CTYPE\u001b[0m  (character classes) and\u001b[m\r\n              \u001b[1mLC_COLLATE\u001b[0m (character ranges and equivalence classes).\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 857 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.359643, "o", "\r\u001b[K       -okdir \u001b[4mcommand\u001b[24m ;\u001b[m\r\n              Like \u001b[1m-execdir\u001b[0m but ask the user first in the same way as  for  \u001b[1m-ok\u001b[0m.\u001b[m\r\n              If  the user does not agree, just return false.  If the command is\u001b[m\r\n              run, its standard input is redirected from \u001b[4m/dev/null\u001b[24m.  This action\u001b[m\r\n              may not be specified together with the \u001b[1m-files0-from\u001b[0m option.\u001b[m\r\n\u001b[m\r\n       -print True; print the full file name on the standard output, followed by\u001b[m\r\n              a newline.  If you are piping the output of \u001b[1mfind\u001b[0m into another pro‐\u001b[m\r\n              gram  and  there  is the faintest possibility that the files which\u001b[m\r\n              you are searching for might contain a newline, then you should se‐\u001b[m\r\n              riously  consider using the \u001b[1m-print0\u001b[0m option instead of \u001b[1m-print\u001b[0m.  See\u001b[m\r\n              the \u001b[1mUNUSUAL\u001b[0m \u001b[1mFILENAMES\u001b[0m section for information  about  how  unusual\u001b[m\r\n              characters in filenames are handled.\u001b[m\r\n\u001b[m"]
[36.359672, "o", "\r\n       -print0\u001b[m\r\n              True; print the full file name on the standard output, followed by\u001b[m\r\n              a null character (instead of the  newline  character  that  \u001b[1m-print\u001b[0m\u001b[m\r\n\u001b[7m Manual page find(1) line 874 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.391038, "o", "\r\u001b[K"]
[36.391195, "o", "              uses).   This  allows  file  names  that contain newlines or other\u001b[m\r\n              types of white space to be correctly interpreted by programs  that\u001b[m\r\n              process the \u001b[1mfind\u001b[0m output.  This option corresponds to the \u001b[1m-0\u001b[0m option\u001b[m\r\n              of \u001b[1mxargs\u001b[0m.\u001b[m\r\n\u001b[m\r\n       -printf \u001b[4mformat\u001b[24m\u001b[m\r\n              True; print \u001b[4mformat\u001b[24m on the standard output,  interpreting  `\\'  es‐\u001b[m\r\n              capes  and  `%'  directives.   Field  widths and precisions can be\u001b[m\r\n              specified as with the \u001b[1mprintf\u001b[0m(3) C function.  Please note that many\u001b[m\r\n              of  the fields are printed as %s rather than %d, and this may mean\u001b[m\r\n              that flags don't work as you might expect.  This also  means  that\u001b[m\r\n              the `-' flag does work (it forces fields to be left-aligned).  Un‐\u001b[m\r\n              like \u001b[1m-print\u001b[0m, \u001b[1m-printf\u001b[0m does not add a newline  at  the  end  of  the\u001b[m\r\n              string.  The escapes and direct"]
[36.391295, "o", "ives are:\u001b[m\r\n\u001b[m\r\n              \\a     Alarm bell.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 891 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.422396, "o", "\r\u001b[K"]
[36.422492, "o", "              \\b     Backspace.\u001b[m\r\n\u001b[m\r\n              \\c     Stop  printing  from  this format immediately and flush the\u001b[m\r\n                     output.\u001b[m\r\n\u001b[m\r\n              \\f     Form feed.\u001b[m\r\n\u001b[m\r\n              \\n     Newline.\u001b[m\r\n\u001b[m\r\n              \\r     Carriage return.\u001b[m\r\n\u001b[m\r\n              \\t     Horizontal tab.\u001b[m\r\n\u001b[m\r\n              \\v     Vertical tab.\u001b[m\r\n\u001b[m\r\n              \\0     ASCII NUL.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 908 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.453335, "o", "\r\u001b[K              \\\\     A literal backslash (`\\').\u001b[m\r\n\u001b[m\r\n              \\NNN   The character whose ASCII code is NNN (octal).\u001b[m\r\n\u001b[m\r\n              A `\\' character followed by any other character is treated  as  an\u001b[m\r\n              ordinary character, so they both are printed.\u001b[m\r\n\u001b[m\r\n              %%     A literal percent sign.\u001b[m\r\n\u001b[m\r\n              %a     File's  last  access  time  in the format returned by the C\u001b[m\r\n"]
[36.453366, "o", "                     \u001b[1mctime\u001b[0m(3) function.\u001b[m\r\n\u001b[m\r\n              %A\u001b[4mk\u001b[24m    File's last access time in the format specified by \u001b[4mk\u001b[24m, which\u001b[m\r\n                     is  either  `@'  or a directive for the C \u001b[1mstrftime\u001b[0m(3) func‐\u001b[m\r\n                     tion.  The following shows an incomplete list  of  possible\u001b[m\r\n                     values  for  \u001b[4mk\u001b[24m.  Please refer to the documentation of \u001b[1mstrf‐\u001b[0m\u001b[m\r\n                     \u001b[1mtime\u001b[0m(3) for the full list.  Some of the conversion specifi‐\u001b[m\r\n\u001b[7m Manual page find(1) line 925 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.485407, "o", "\r\u001b[K                     cation  characters  might  not be available on all systems,\u001b[m\r\n                     due to differences in the implementation of the \u001b[1mstrftime\u001b[0m(3)\u001b[m\r\n                     library function.\u001b[m\r\n\u001b[m\r\n                     @      seconds  since  Jan.  1, 1970, 00:00 GMT, with frac‐\u001b[m\r\n                            tional part.\u001b[m\r\n\u001b[m\r\n                     Time fields:\u001b[m\r\n\u001b[m\r\n                     H      hour (00..23)\u001b[m\r\n\u001b[m\r\n                     I      hour (01..12)\u001b[m\r\n\u001b[m\r\n                     k      hour ( 0..23)\u001b[m\r\n\u001b[m\r\n                     l      hour ( 1..12)\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 942 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.516537, "o", "\r\u001b[K"]
[36.516752, "o", "                     M      minute (00..59)\u001b[m\r\n\u001b[m\r\n                     p      locale's AM or PM\u001b[m\r\n\u001b[m\r\n                     r      time, 12-hour (hh:mm:ss [AP]M)\u001b[m\r\n\u001b[m\r\n                     S      Second (00.00 ..  61.00).   There  is  a  fractional\u001b[m\r\n                            part.\u001b[m\r\n\u001b[m\r\n                     T      time, 24-hour (hh:mm:ss.xxxxxxxxxx)\u001b[m\r\n\u001b[m\r\n                     +      Date   and  time,  separated  by  `+',  for  example\u001b[m\r\n                            `2004-04-28+22:22:05.0'.  This is a  GNU  extension.\u001b[m\r\n                            The time is given in the current timezone (which may\u001b[m\r\n                            be affected by setting the \u001b[1mTZ\u001b[0m environment variable).\u001b[m\r\n                            The seconds field includes a fractional part.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 959 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.547656, "o", "\r\u001b[K"]
[36.547919, "o", "                     X      locale's  time  representation (H:M:S).  The seconds\u001b[m\r\n                            field includes a fractional part.\u001b[m\r\n\u001b[m\r\n                     Z      time zone (e.g., EDT), or nothing if no time zone is\u001b[m\r\n                            determinable\u001b[m\r\n\u001b[m\r\n                     Date fields:\u001b[m\r\n\u001b[m\r\n                     a      locale's abbreviated weekday name (Sun..Sat)\u001b[m\r\n\u001b[m\r\n                     A      locale's  full  weekday  name, variable length (Sun‐\u001b[m\r\n                            day..Saturday)\u001b[m\r\n\u001b[m\r\n                     b      locale's abbreviated month name (Jan..Dec)\u001b[m\r\n\u001b[m\r\n                     B      locale's full month  name,  variable  length  (Janu‐\u001b[m\r\n                            ary..December)\u001b[m\r\n\u001b[7m Manual page find(1) line 976 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.579697, "o", "\r\u001b[K"]
[36.579836, "o", "\u001b[m\r\n                     c      locale's  date  and  time  (Sat  Nov 04 12:02:33 EST\u001b[m\r\n                            1989).  The format is the same as for  \u001b[1mctime\u001b[0m(3)  and\u001b[m\r\n                            so to preserve compatibility with that format, there\u001b[m\r\n                            is no fractional part in the seconds field.\u001b[m\r\n\u001b[m\r\n                     d      day of month (01..31)\u001b[m\r\n\u001b[m\r\n                     D      date (mm/dd/yy)\u001b[m\r\n\u001b[m\r\n                     F      date (yyyy-mm-dd)\u001b[m\r\n\u001b[m\r\n                     h      same as b\u001b[m\r\n\u001b[m\r\n                     j      day of year (001..366)\u001b[m\r\n\u001b[m\r\n                     m      month (01..12)\u001b[m\r\n\u001b[7m Manual page find(1) line 993 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.610371, "o", "\r\u001b[K"]
[36.610449, "o", "\u001b[m\r\n                     U      week number of year with Sunday as first day of week\u001b[m\r\n                            (00..53)\u001b[m\r\n\u001b[m\r\n                     w      day of week (0..6)\u001b[m\r\n\u001b[m\r\n                     W      week number of year with Monday as first day of week\u001b[m\r\n                            (00..53)\u001b[m\r\n\u001b[m\r\n                     x      locale's date representation (mm/dd/yy)\u001b[m\r\n\u001b[m\r\n                     y      last two digits of year (00..99)\u001b[m\r\n\u001b[m\r\n                     Y      year (1970...)\u001b[m\r\n\u001b[m\r\n              %b     The amount of disk space used for  this  file  in  512-byte\u001b[m\r\n                     blocks.   Since disk space is allocated in multiples of the\u001b[m\r\n\u001b[7m Manual page find(1) line 1010 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.643074, "o", "\r\u001b[K"]
[36.643105, "o", "                     filesystem block size this is usually greater than  %s/512,\u001b[m\r\n                     but it can also be smaller if the file is a sparse file.\u001b[m\r\n\u001b[m\r\n              %B\u001b[4mk\u001b[24m    File's  birth  time, i.e., its creation time, in the format\u001b[m\r\n                     specified by \u001b[4mk\u001b[24m, which is the same as for %A.   This  direc‐\u001b[m\r\n                     tive  produces  an empty string if the underlying operating\u001b[m\r\n                     system or filesystem does not support birth times.\u001b[m\r\n\u001b[m\r\n              %c     File's last status change time in the  format  returned  by\u001b[m\r\n                     the C \u001b[1mctime\u001b[0m(3) function.\u001b[m\r\n\u001b[m\r\n              %C\u001b[4mk\u001b[24m    File's  last  status change time in the format specified by\u001b[m\r\n                     \u001b[4mk\u001b[24m, which is the same as for %A.\u001b[m\r\n\u001b[m\r\n              %d     File's depth in the directory tree; 0 means the file  is  a\u001b[m\r\n                     starting-point.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 1027 (press h for help"]
[36.643109, "o", " or q to quit)\u001b[27m\u001b[K"]
[36.673153, "o", "\r\u001b[K"]
[36.673293, "o", "              %D     The  device  number  on  which  the file exists (the st_dev\u001b[m\r\n                     field of struct stat), in decimal.\u001b[m\r\n\u001b[m\r\n              %f     Print the basename; the file's name with any leading direc‐\u001b[m\r\n                     tories  removed (only the last element).  For \u001b[1m/\u001b[0m, the result\u001b[m\r\n                     is `/'.  See the \u001b[1mEXAMPLES\u001b[0m section for an example.\u001b[m\r\n\u001b[m\r\n              %F     Type of the filesystem the file is on; this  value  can  be\u001b[m\r\n                     used for -fstype.\u001b[m\r\n\u001b[m\r\n              %g     File's  group name, or numeric group ID if the group has no\u001b[m\r\n                     name.\u001b[m\r\n\u001b[m\r\n              %G     File's numeric group ID.\u001b[m\r\n\u001b[m\r\n              %h     Dirname; the Leading directories of the  file's  name  (all\u001b[m\r\n                     but  the  last  element).   If  the  file  name contains no\u001b[m\r\n\u001b[7m Manual page find(1) line 1044 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.70403, "o", "\r\u001b[K"]
[36.704063, "o", "                     slashes (since it is in the current directory) the %h spec‐\u001b[m\r\n                     ifier  expands  to `.'.  For files which are themselves di‐\u001b[m\r\n                     rectories and contain a slash (including \u001b[1m/\u001b[0m), %h expands  to\u001b[m\r\n                     the empty string.  See the \u001b[1mEXAMPLES\u001b[0m section for an example.\u001b[m\r\n\u001b[m\r\n              %H     Starting-point under which file was found.\u001b[m\r\n\u001b[m\r\n              %i     File's inode number (in decimal).\u001b[m\r\n\u001b[m\r\n              %k     The amount of disk space used for this file in 1 KB blocks.\u001b[m\r\n                     Since disk space is allocated in multiples of the  filesys‐\u001b[m\r\n                     tem block size this is usually greater than %s/1024, but it\u001b[m\r\n                     can also be smaller if the file is a sparse file.\u001b[m\r\n\u001b[m\r\n              %l     Object of symbolic link (empty string if file is not a sym‐\u001b[m\r\n                     bolic link).\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 1061 (press h for help or"]
[36.704067, "o", " q to quit)\u001b[27m\u001b[K"]
[36.735193, "o", "\r\u001b[K"]
[36.73522, "o", "              %m     File's  permission  bits  (in octal).  This option uses the\u001b[m\r\n                     `traditional' numbers which most Unix implementations  use,\u001b[m\r\n                     but  if  your particular implementation uses an unusual or‐\u001b[m\r\n                     dering of octal permissions bits, you will see a difference\u001b[m\r\n                     between  the actual value of the file's mode and the output\u001b[m\r\n                     of %m.  Normally you will want to have a  leading  zero  on\u001b[m\r\n                     this  number, and to do this, you should use the \u001b[1m#\u001b[0m flag (as\u001b[m\r\n                     in, for example, `%#m').\u001b[m\r\n\u001b[m\r\n              %M     File's permissions (in symbolic form, as for \u001b[1mls\u001b[0m).  This di‐\u001b[m\r\n                     rective is supported in findutils 4.2.5 and later.\u001b[m\r\n\u001b[m\r\n              %n     Number of hard links to file.\u001b[m\r\n\u001b[m\r\n              %p     File's name.\u001b[m\r\n\u001b[m\r\n              %P     File's name with the name of the starting-point under which\u001b[m\r\n"]
[36.735224, "o", "\u001b[7m Manual page find(1) line 1078 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.766481, "o", "\r\u001b[K"]
[36.766578, "o", "                     it was found removed.\u001b[m\r\n\u001b[m\r\n              %s     File's size in bytes.\u001b[m\r\n\u001b[m\r\n              %S     File's  sparseness.   This   is   calculated   as   (BLOCK‐\u001b[m\r\n                     SIZE*st_blocks  /  st_size).   The exact value you will get\u001b[m\r\n                     for an ordinary file of a certain length  is  system-depen‐\u001b[m\r\n                     dent.  However, normally sparse files will have values less\u001b[m\r\n                     than 1.0, and files which use indirect blocks  may  have  a\u001b[m\r\n                     value  which is greater than 1.0.  In general the number of\u001b[m\r\n                     blocks used by a file is file system dependent.  The  value\u001b[m\r\n                     used  for BLOCKSIZE is system-dependent, but is usually 512\u001b[m\r\n                     bytes.  If the file size is zero, the value printed is  un‐\u001b[m\r\n                     defined.   On  systems  which lack support for st_blocks, a\u001b[m\r\n"]
[36.766618, "o", "                     file's sparseness is assumed to be 1.0.\u001b[m\r\n\u001b[m\r\n              %t     File's last modification time in the format returned by the\u001b[m\r\n\u001b[7m Manual page find(1) line 1095 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.797393, "o", "\r\u001b[K                     C \u001b[1mctime\u001b[0m(3) function.\u001b[m\r\n\u001b[m\r\n              %T\u001b[4mk\u001b[24m    File's last modification time in the format specified by \u001b[4mk\u001b[24m,\u001b[m\r\n                     which is the same as for %A.\u001b[m\r\n\u001b[m\r\n              %u     File's user name, or numeric user ID if  the  user  has  no\u001b[m\r\n                     name.\u001b[m\r\n\u001b[m\r\n              %U     File's numeric user ID.\u001b[m\r\n\u001b[m\r\n              %y     File's type (like in \u001b[1mls\u001b[0m \u001b[1m-l\u001b[0m), U=unknown type (shouldn't hap‐\u001b[m\r\n                     pen)\u001b[m\r\n\u001b[m\r\n              %Y     File's  type  (like  %y),  plus  follow   symbolic   links:\u001b[m\r\n                     `L'=loop, `N'=nonexistent, `?' for any other error when de‐\u001b[m\r\n                     termining the type of the target of a symbolic link.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 1112 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.829192, "o", "\r\u001b[K"]
[36.829334, "o", "              %Z     (SELinux only) file's security context.\u001b[m\r\n\u001b[m\r\n              %{ %[ %(\u001b[m\r\n                     Reserved for future use.\u001b[m\r\n\u001b[m\r\n              A `%' character followed by any other character is discarded,  but\u001b[m\r\n              the  other  character  is  printed (don't rely on this, as further\u001b[m\r\n              format characters may be introduced).  A `%' at  the  end  of  the\u001b[m\r\n              format  argument causes undefined behaviour since there is no fol‐\u001b[m\r\n              lowing character.  In some locales, it may hide  your  door  keys,\u001b[m\r\n              while  in  others  it may remove the final page from the novel you\u001b[m\r\n              are reading.\u001b[m\r\n\u001b[m\r\n              The %m and %d directives support the \u001b[1m#\u001b[0m, \u001b[1m0\u001b[0m and  \u001b[1m+\u001b[0m  flags,  but  the\u001b[m\r\n              other  directives do not, even if they print numbers.  Numeric di‐\u001b[m\r\n              rectives that do not support these flags include \u001b[1mG\u001b[0m, \u001b[1mU\u001b[0m, \u001b[1mb\u001b[0m, \u001b[1mD\u001b[0m, \u001b[1mk\u001b[0m and\u001b[m\r\n   "]
[36.829366, "o", "           \u001b[1mn\u001b[0m.   The `-' format flag is supported and changes the alignment of\u001b[m\r\n\u001b[7m Manual page find(1) line 1129 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.860576, "o", "\r\u001b[K              a field from right-justified (which is the default) to left-justi‐\u001b[m\r\n              fied.\u001b[m\r\n\u001b[m\r\n              See  the  \u001b[1mUNUSUAL\u001b[0m  \u001b[1mFILENAMES\u001b[0m section for information about how un‐\u001b[m\r\n              usual characters in filenames are handled.\u001b[m\r\n\u001b[m\r\n       -prune True; if the file is a directory, do  not  descend  into  it.   If\u001b[m\r\n              \u001b[1m-depth\u001b[0m  is  given, then \u001b[1m-prune\u001b[0m has no effect.  Because \u001b[1m-delete\u001b[0m im‐\u001b[m\r\n              plies \u001b[1m-depth\u001b[0m, you cannot usefully use \u001b[1m-prune\u001b[0m and \u001b[1m-delete\u001b[0m together.\u001b[m\r\n              For example, to skip the directory \u001b[4msrc/emacs\u001b[24m and all files and di‐\u001b[m\r\n              rectories under it, and print the names of the other files  found,\u001b[m\r\n              do something like this:\u001b[m\r\n                  find . -path ./src/emacs -prune -o -print\u001b[m\r\n\u001b[m\r\n       -quit  Exit  immediately  (with  return  value zero if no errors have oc‐\u001b[m\r\n              curred).  This is different to \u001b[1m-p"]
[36.860601, "o", "rune\u001b[0m because \u001b[1m-prune\u001b[0m only  applies\u001b[m\r\n              to  the  contents  of pruned directories, while \u001b[1m-quit\u001b[0m simply makes\u001b[m\r\n\u001b[7m Manual page find(1) line 1146 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.891784, "o", "\r\u001b[K              \u001b[1mfind\u001b[0m stop immediately.  No child processes will be  left  running.\u001b[m\r\n              Any  command  lines  which  have been built by \u001b[1m-exec\u001b[0m \u001b[1m...\u001b[0m \u001b[1m+\u001b[0m or \u001b[1m-ex‐\u001b[0m\u001b[m\r\n              \u001b[1mecdir\u001b[0m \u001b[1m...\u001b[0m \u001b[1m+\u001b[0m are invoked before the program is exited.  After \u001b[1m-quit\u001b[0m\u001b[m\r\n              is  executed,  no more files specified on the command line will be\u001b[m\r\n              processed.   For  example,   `\u001b[1mfind\u001b[0m \u001b[4m/tmp/foo\u001b[24m \u001b[4m/tmp/bar\u001b[24m \u001b[1m-print\u001b[0m \u001b[1m-quit\u001b[0m`\u001b[m\r\n              will print only `/tmp/foo`.\u001b[m\r\n              One  common use of \u001b[1m-quit\u001b[0m is to stop searching the file system once\u001b[m\r\n              we have found what we want.  For example, if we want to find  just\u001b[m\r\n              a single file we can do this:\u001b[m\r\n                  find / -name needle -print -quit\u001b[m\r\n\u001b[m\r\n   \u001b[1mOPERATORS\u001b[0m\u001b[m\r\n       Listed in order of decreasing precedence:\u001b[m\r\n\u001b[m\r\n       ( \u001b[4mexpr\u001b[24m )\u001b[m\r\n              Force precedence.  Si"]
[36.891812, "o", "nce parentheses are special to the shell, you\u001b[m\r\n              will normally need to quote them.  Many of the  examples  in  this\u001b[m\r\n\u001b[7m Manual page find(1) line 1163 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.92278, "o", "\r\u001b[K"]
[36.922841, "o", "              manual page use backslashes for this purpose: `\\(...\\)' instead of\u001b[m\r\n              `(...)'.\u001b[m\r\n\u001b[m\r\n       ! \u001b[4mexpr\u001b[24m True if \u001b[4mexpr\u001b[24m is false.  This character will also usually need pro‐\u001b[m\r\n              tection from interpretation by the shell.\u001b[m\r\n\u001b[m\r\n       -not \u001b[4mexpr\u001b[24m\u001b[m\r\n              Same as ! \u001b[4mexpr\u001b[24m, but not POSIX compliant.\u001b[m\r\n\u001b[m\r\n       \u001b[4mexpr1\u001b[24m \u001b[4mexpr2\u001b[24m\u001b[m\r\n              Two  expressions  in  a row are taken to be joined with an implied\u001b[m\r\n              \u001b[1m-a\u001b[0m; \u001b[4mexpr2\u001b[24m is not evaluated if \u001b[4mexpr1\u001b[24m is false.\u001b[m\r\n\u001b[m\r\n       \u001b[4mexpr1\u001b[24m -a \u001b[4mexpr2\u001b[24m\u001b[m\r\n              Same as \u001b[4mexpr1\u001b[24m \u001b[4mexpr2\u001b[24m.\u001b[m\r\n\u001b[m\r\n       \u001b[4mexpr1\u001b[24m -and \u001b[4mexpr2\u001b[24m\u001b[m\r\n\u001b[7m Manual page find(1) line 1180 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.954292, "o", "\r\u001b[K"]
[36.954393, "o", "              Same as \u001b[4mexpr1\u001b[24m \u001b[4mexpr2\u001b[24m, but not POSIX compliant.\u001b[m\r\n\u001b[m\r\n       \u001b[4mexpr1\u001b[24m -o \u001b[4mexpr2\u001b[24m\u001b[m\r\n              Or; \u001b[4mexpr2\u001b[24m is not evaluated if \u001b[4mexpr1\u001b[24m is true.\u001b[m\r\n\u001b[m\r\n       \u001b[4mexpr1\u001b[24m -or \u001b[4mexpr2\u001b[24m\u001b[m\r\n              Same as \u001b[4mexpr1\u001b[24m \u001b[1m-o\u001b[0m \u001b[4mexpr2\u001b[24m, but not POSIX compliant.\u001b[m\r\n\u001b[m\r\n       \u001b[4mexpr1\u001b[24m , \u001b[4mexpr2\u001b[24m\u001b[m\r\n              List; both \u001b[4mexpr1\u001b[24m and \u001b[4mexpr2\u001b[24m are always  evaluated.   The  value  of\u001b[m\r\n              \u001b[4mexpr1\u001b[24m  is  discarded; the value of the list is the value of \u001b[4mexpr2\u001b[24m.\u001b[m\r\n              The comma operator can be useful for searching for several differ‐\u001b[m\r\n              ent  types  of thing, but traversing the filesystem hierarchy only\u001b[m\r\n              once.  The \u001b[1m-fprintf\u001b[0m action can be used to list the various matched\u001b[m\r\n              items into several different output files.\u001b[m\r\n\u001b[m\r\n       Please  note  that \u001b[1m-a\u001b[0m when specified implicitly (for example by two t"]
[36.954425, "o", "ests\u001b[m\r\n\u001b[7m Manual page find(1) line 1197 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.985747, "o", "\r\u001b[K"]
[36.985776, "o", "       appearing without an explicit operator between them)  or  explicitly  has\u001b[m\r\n       higher  precedence  than \u001b[1m-o\u001b[0m.  This means that \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-name\u001b[0m \u001b[1mafile\u001b[0m \u001b[1m-o\u001b[0m \u001b[1m-name\u001b[0m\u001b[m\r\n       \u001b[1mbfile\u001b[0m \u001b[1m-print\u001b[0m will never print \u001b[4mafile\u001b[24m.\u001b[m\r\n\u001b[m\r\n\u001b[1mUNUSUAL\u001b[0m \u001b[1mFILENAMES\u001b[0m\u001b[m\r\n       Many of the actions of \u001b[1mfind\u001b[0m result in the printing of data which is under\u001b[m\r\n       the  control  of other users.  This includes file names, sizes, modifica‐\u001b[m\r\n       tion times and so forth.  File names are a potential problem  since  they\u001b[m\r\n       can  contain  any  character  except `\\0' and `/'.  Unusual characters in\u001b[m\r\n       file names can do unexpected and often undesirable things to your  termi‐\u001b[m\r\n       nal  (for  example,  changing  the settings of your function keys on some\u001b[m\r\n       terminals).  Unusual characters are handled differently  by  various  ac‐\u001b[m\r\n       tions, as described below.\u001b[m\r\n\u001b[m\r\n       -print0, -fprint0\u001b[m\r\n "]
[36.985784, "o", "             Always  print the exact filename, unchanged, even if the output is\u001b[m\r\n              going to a terminal.\u001b[m\r\n\u001b[7m Manual page find(1) line 1214 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.017393, "o", "\r\u001b[K"]
[37.017421, "o", "\u001b[m\r\n       -ls, -fls\u001b[m\r\n              Unusual characters are always escaped.   White  space,  backslash,\u001b[m\r\n              and  double  quote  characters  are printed using C-style escaping\u001b[m\r\n              (for example `\\f', `\\\"').  Other unusual  characters  are  printed\u001b[m\r\n              using  an  octal  escape.  Other printable characters (for \u001b[1m-ls\u001b[0m and\u001b[m\r\n              \u001b[1m-fls\u001b[0m these are the characters between  octal  041  and  0176)  are\u001b[m\r\n              printed as-is.\u001b[m\r\n\u001b[m\r\n       -printf, -fprintf\u001b[m\r\n              If  the  output  is  not going to a terminal, it is printed as-is.\u001b[m\r\n              Otherwise, the result depends on which directive is in  use.   The\u001b[m\r\n              directives  %D,  %F, %g, %G, %H, %Y, and %y expand to values which\u001b[m\r\n              are not under control of files' owners, and so are printed  as-is.\u001b[m\r\n              The  directives %a, %b, %c, %d, %i, %k, %m, %M, %n, %s, %t, %u and\u001b[m\r\n              %U have values which are under the control of  file"]
[37.017426, "o", "s'  owners  but\u001b[m\r\n              which  cannot  be used to send arbitrary data to the terminal, and\u001b[m\r\n\u001b[7m Manual page find(1) line 1231 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.048404, "o", "\r\u001b[K              so these are printed as-is.  The directives %f, %h, %l, %p and  %P\u001b[m\r\n              are  quoted.  This quoting is performed in the same way as for GNU\u001b[m\r\n              \u001b[1mls\u001b[0m.  This is not the same quoting mechanism as the  one  used  for\u001b[m\r\n"]
[37.048557, "o", "              \u001b[1m-ls\u001b[0m  and  \u001b[1m-fls\u001b[0m.   If you are able to decide what format to use for\u001b[m\r\n              the output of \u001b[1mfind\u001b[0m then it is normally better to  use  `\\0'  as  a\u001b[m\r\n              terminator  than  to  use newline, as file names can contain white\u001b[m\r\n              space and newline characters.  The setting of the  \u001b[1mLC_CTYPE\u001b[0m  envi‐\u001b[m\r\n              ronment  variable is used to determine which characters need to be\u001b[m\r\n              quoted.\u001b[m\r\n\u001b[m\r\n       -print, -fprint\u001b[m\r\n              Quoting is handled in the same way as for  \u001b[1m-printf\u001b[0m  and  \u001b[1m-fprintf\u001b[0m.\u001b[m\r\n              If  you  are  using  \u001b[1mfind\u001b[0m  in a script or in a situation where the\u001b[m\r\n              matched files might have arbitrary names, you should consider  us‐\u001b[m\r\n              ing \u001b[1m-print0\u001b[0m instead of \u001b[1m-print\u001b[0m.\u001b[m\r\n\u001b[m\r\n       The  \u001b[1m-ok\u001b[0m  and  \u001b[1m-okdir\u001b[0m actions print the current filename as-is.  This may\u001b[m\r\n\u001b[7m Manual page find(1) line 1248 (press h for help or"]
[37.048571, "o", " q to quit)\u001b[27m\u001b[K"]
[37.079957, "o", "\r\u001b[K       change in a future release.\u001b[m\r\n\u001b[m\r\n\u001b[1mSTANDARDS\u001b[0m \u001b[1mCONFORMANCE\u001b[0m\u001b[m\r\n       For closest  compliance  to  the  POSIX  standard,  you  should  set  the\u001b[m\r\n       \u001b[1mPOSIXLY_CORRECT\u001b[0m  environment  variable.  The following options are speci‐\u001b[m\r\n       fied in the POSIX standard (IEEE Std 1003.1-2008, 2016 Edition):\u001b[m\r\n\u001b[m\r\n       \u001b[1m-H\u001b[0m     This option is supported.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-L\u001b[0m     This option is supported.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-name\u001b[0m  This option is supported, but POSIX  conformance  depends  on  the\u001b[m\r\n              POSIX conformance of the system's \u001b[1mfnmatch\u001b[0m(3) library function.  As\u001b[m\r\n              of findutils-4.2.2, shell metacharacters (`*', `?' or `[]' for ex‐\u001b[m\r\n              ample)  match  a leading `.', because IEEE PASC interpretation 126\u001b[m\r\n              requires this.  This is a change from previous versions of  findu‐\u001b[m\r\n              tils.\u001b[m\r\n\u001b[7m Manual page find(1) line 1265 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.111125, "o", "\r\u001b[K"]
[37.111151, "o", "\u001b[m\r\n       \u001b[1m-type\u001b[0m  Supported.   POSIX specifies `b', `c', `d', `l', `p', `f' and `s'.\u001b[m\r\n              GNU find also supports `D', representing a Door, where the OS pro‐\u001b[m\r\n              vides  these.   Furthermore,  GNU find allows multiple types to be\u001b[m\r\n"]
[37.111157, "o", "              specified at once in a comma-separated list.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-ok\u001b[0m    Supported.  Interpretation of the response  is  according  to  the\u001b[m\r\n              `yes'  and `no' patterns selected by setting the \u001b[1mLC_MESSAGES\u001b[0m envi‐\u001b[m\r\n              ronment variable.  When the \u001b[1mPOSIXLY_CORRECT\u001b[0m  environment  variable\u001b[m\r\n              is set, these patterns are taken system's definition of a positive\u001b[m\r\n              (yes) or negative (no) response.  See the  system's  documentation\u001b[m\r\n              for  \u001b[1mnl_langinfo\u001b[0m(3),  in  particular  YESEXPR  and  NOEXPR.   When\u001b[m\r\n              \u001b[1mPOSIXLY_CORRECT\u001b[0m is not set, the patterns are  instead  taken  from\u001b[m\r\n              \u001b[1mfind\u001b[0m's own message catalogue.\u001b[m\r\n\u001b[m\r\n  "]
[37.111258, "o", "     \u001b[1m-newer\u001b[0m Supported.  If the file specified is a symbolic link, it is always\u001b[m\r\n              dereferenced.  This is a change  from  previous  behaviour,  which\u001b[m\r\n\u001b[7m Manual page find(1) line 1282 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.141986, "o", "\r\u001b[K"]
[37.142236, "o", "              used  to  take  the  relevant time from the symbolic link; see the\u001b[m\r\n              HISTORY section below.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-perm\u001b[0m  Supported.  If the \u001b[1mPOSIXLY_CORRECT\u001b[0m  environment  variable  is  not\u001b[m\r\n              set, some mode arguments (for example +a+x) which are not valid in\u001b[m\r\n              POSIX are supported for backward-compatibility.\u001b[m\r\n\u001b[m\r\n       Other primaries\u001b[m\r\n              The primaries  \u001b[1m-atime\u001b[0m,  \u001b[1m-ctime\u001b[0m,  \u001b[1m-depth\u001b[0m,  \u001b[1m-exec\u001b[0m,  \u001b[1m-group\u001b[0m,  \u001b[1m-links\u001b[0m,\u001b[m\r\n              \u001b[1m-mtime\u001b[0m,  \u001b[1m-nogroup\u001b[0m,  \u001b[1m-nouser\u001b[0m,  \u001b[1m-ok\u001b[0m,  \u001b[1m-path\u001b[0m,  \u001b[1m-print\u001b[0m, \u001b[1m-prune\u001b[0m, \u001b[1m-size\u001b[0m,\u001b[m\r\n              \u001b[1m-user\u001b[0m and \u001b[1m-xdev\u001b[0m are all supported.\u001b[m\r\n\u001b[m\r\n       The POSIX standard specifies parentheses `(', `)', negation `!'  and  the\u001b[m\r\n       logical AND/OR operators \u001b[1m-a\u001b[0m and \u001b[1m-o\u001b[0m.\u001b[m\r\n\u001b[m\r\n       All  other  options,  predicates, expressions and so forth are extensions\u001b[m\r\n       beyond t"]
[37.142277, "o", "he POSIX standard.  Many of these extensions are  not  unique  to\u001b[m\r\n\u001b[7m Manual page find(1) line 1299 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.173745, "o", "\r\u001b[K"]
[37.173771, "o", "       GNU find, however.\u001b[m\r\n\u001b[m\r\n       The POSIX standard requires that \u001b[1mfind\u001b[0m detects loops:\u001b[m\r\n\u001b[m\r\n              The  \u001b[1mfind\u001b[0m utility shall detect infinite loops; that is, entering a\u001b[m\r\n              previously visited directory that is an ancestor of the last  file\u001b[m\r\n              encountered.  When it detects an infinite loop, find shall write a\u001b[m\r\n              diagnostic message to standard error and shall either recover  its\u001b[m\r\n              position in the hierarchy or terminate.\u001b[m\r\n\u001b[m\r\n       GNU \u001b[1mfind\u001b[0m complies with these requirements.  The link count of directories\u001b[m\r\n       which contain entries which are hard links to an ancestor will  often  be\u001b[m\r\n       lower  than  they  otherwise should be.  This can mean that GNU find will\u001b[m\r\n       sometimes optimise away the visiting of a subdirectory which is  actually\u001b[m\r\n       a  link to an ancestor.  Since \u001b[1mfind\u001b[0m does not actually enter such a subdi‐\u001b[m\r\n       rectory, it is allowed to avoid emitting a diagnost"]
[37.173775, "o", "ic message.   "]
[37.173947, "o", "Although\u001b[m\r\n       this behaviour may be somewhat confusing, it is unlikely that anybody ac‐\u001b[m\r\n\u001b[7m Manual page find(1) line 1316 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.20529, "o", "\r\u001b[K"]
[37.205412, "o", "       tually depends on this behaviour.  If  the  leaf  optimisation  has  been\u001b[m\r\n       turned  off with \u001b[1m-noleaf\u001b[0m, the directory entry will always be examined and\u001b[m\r\n       the diagnostic message will be issued where it is appropriate.   Symbolic\u001b[m\r\n       links  cannot  be used to create filesystem cycles as such, but if the \u001b[1m-L\u001b[0m\u001b[m\r\n       option or the \u001b[1m-follow\u001b[0m option is in use, a diagnostic  message  is  issued\u001b[m\r\n       when  \u001b[1mfind\u001b[0m encounters a loop of symbolic links.  As with loops containing\u001b[m\r\n       hard links, the leaf optimisation will often mean that \u001b[1mfind\u001b[0m knows that it\u001b[m\r\n       doesn't  need to call \u001b[4mstat()\u001b[24m or \u001b[4mchdir()\u001b[24m on the symbolic link, so this di‐\u001b[m\r\n       agnostic is frequently not necessary.\u001b[m\r\n\u001b[m\r\n       The \u001b[1m-d\u001b[0m option is supported for compatibility with  various  BSD  systems,\u001b[m\r\n       but you should use the POSIX-compliant option \u001b[1m-depth\u001b[0m instead.\u001b[m\r\n\u001b[m\r\n       The \u001b[1mPOSIXLY_CORRECT\u001b[0m environment vari"]
[37.205426, "o", "able does not affect the behaviour of\u001b[m\r\n       the \u001b[1m-regex\u001b[0m or \u001b[1m-iregex\u001b[0m tests because those tests aren't specified  in  the\u001b[m\r\n       POSIX standard.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 1333 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.236202, "o", "\r\u001b[K"]
[37.236246, "o", "\u001b[1mENVIRONMENT\u001b[0m \u001b[1mVARIABLES\u001b[0m\u001b[m\r\n       LANG   Provides  a  default  value for the internationalization variables\u001b[m\r\n              that are unset or null.\u001b[m\r\n\u001b[m\r\n       LC_ALL If set to a non-empty string value, override the values of all the\u001b[m\r\n              other internationalization variables.\u001b[m\r\n\u001b[m\r\n       LC_COLLATE\u001b[m\r\n              The  POSIX  standard specifies that this variable affects the pat‐\u001b[m\r\n              tern matching to be used for the \u001b[1m-name\u001b[0m option.  GNU find uses  the\u001b[m\r\n              \u001b[1mfnmatch\u001b[0m(3) library function, and so support for \u001b[1mLC_COLLATE\u001b[0m depends\u001b[m\r\n              on the system library.  This variable also affects the interpreta‐\u001b[m\r\n              tion  of  the  response to \u001b[1m-ok\u001b[0m; while the \u001b[1mLC_MESSAGES\u001b[0m variable se‐\u001b[m\r\n              lects the actual pattern used to interpret the  response  to  \u001b[1m-ok\u001b[0m,\u001b[m\r\n              the  interpretation of any bracket expressions in the pattern will\u001b[m\r\n              be affected by \u001b[1m"]
[37.236252, "o", "LC_COLLATE\u001b[0m.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 1350 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.268173, "o", "\r\u001b[K"]
[37.2683, "o", "       LC_CTYPE\u001b[m\r\n              This variable affects the treatment of character classes  used  in\u001b[m\r\n              regular  expressions and also with the \u001b[1m-name\u001b[0m test, if the system's\u001b[m\r\n              \u001b[1mfnmatch\u001b[0m(3) library function supports this.  This variable also af‐\u001b[m\r\n              fects  the  interpretation of any character classes in the regular\u001b[m\r\n              expressions used to interpret the response to the prompt issued by\u001b[m\r\n              \u001b[1m-ok\u001b[0m.   The  \u001b[1mLC_CTYPE\u001b[0m  environment  variable will also affect which\u001b[m\r\n              characters are considered to be  unprintable  when  filenames  are\u001b[m\r\n              printed; see the section UNUSUAL FILENAMES.\u001b[m\r\n\u001b[m\r\n       LC_MESSAGES\u001b[m\r\n              Determines  the  locale to be used for internationalised messages.\u001b[m\r\n              If the \u001b[1mPOSIXLY_CORRECT\u001b[0m environment variable is set, this also  de‐\u001b[m\r\n              termines  the interpretation of the response to the prompt made by\u001b[m\r\n              the \u001b["]
[37.268319, "o", "1m-ok\u001b[0m action.\u001b[m\r\n\u001b[m\r\n       NLSPATH\u001b[m\r\n\u001b[7m Manual page find(1) line 1367 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.299171, "o", "\r\u001b[K"]
[37.299197, "o", "              Determines the location of the internationalisation message  cata‐\u001b[m\r\n              logues.\u001b[m\r\n\u001b[m\r\n       PATH   Affects the directories which are searched to find the executables\u001b[m\r\n              invoked by \u001b[1m-exec\u001b[0m, \u001b[1m-execdir\u001b[0m, \u001b[1m-ok\u001b[0m and \u001b[1m-okdir\u001b[0m.\u001b[m\r\n\u001b[m\r\n       POSIXLY_CORRECT\u001b[m\r\n              Determines the block size used by \u001b[1m-ls\u001b[0m and \u001b[1m-fls\u001b[0m.   If  \u001b[1mPOSIXLY_COR‐\u001b[0m\u001b[m\r\n              \u001b[1mRECT\u001b[0m  is  set,  blocks are units of 512 bytes.  Otherwise they are\u001b[m\r\n              units of 1024 bytes.\u001b[m\r\n\u001b[m\r\n              Setting this variable also turns off warning  messages  (that  is,\u001b[m\r\n              implies  \u001b[1m-nowarn\u001b[0m)  by  default,  because POSIX requires that apart\u001b[m\r\n              from the output for \u001b[1m-ok\u001b[0m, all messages printed on stderr are  diag‐\u001b[m\r\n              nostics and must result in a non-zero exit status.\u001b[m\r\n\u001b[m\r\n              When  \u001b[1mPOSIXLY_CORRECT\u001b[0m  is not set, \u001b[1m-perm\u001b[0m \u001b[4m+zzz\u001b[24m is treated just"]
[37.299202, "o", " like\u001b[m\r\n\u001b[7m Manual page find(1) line 1384 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.330042, "o", "\r\u001b[K"]
[37.330182, "o", "              \u001b[1m-perm\u001b[0m  \u001b[4m/zzz\u001b[24m  if  \u001b[4m+zzz\u001b[24m  is  not  a  valid  symbolic   mode.    When\u001b[m\r\n              \u001b[1mPOSIXLY_CORRECT\u001b[0m is set, such constructs are treated as an error.\u001b[m\r\n\u001b[m\r\n              When  \u001b[1mPOSIXLY_CORRECT\u001b[0m  is  set, the response to the prompt made by\u001b[m\r\n              the \u001b[1m-ok\u001b[0m action is interpreted according to  the  system's  message\u001b[m\r\n              catalogue,  as opposed to according to \u001b[1mfind\u001b[0m's own message transla‐\u001b[m\r\n              tions.\u001b[m\r\n\u001b[m\r\n       TZ     Affects the time zone used for some of the time-related format di‐\u001b[m\r\n              rectives of \u001b[1m-printf\u001b[0m and \u001b[1m-fprintf\u001b[0m.\u001b[m\r\n\u001b[m\r\n\u001b[1mEXAMPLES\u001b[0m\u001b[m\r\n   \u001b[1mSimple\u001b[0m \u001b[1m`find|xargs`\u001b[0m \u001b[1mapproach\u001b[0m\u001b[m\r\n       •      Find  files  named  \u001b[4mcore\u001b[24m in or below the directory \u001b[4m/tmp\u001b[24m and delete\u001b[m\r\n              them.\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m/tmp\u001b[0m \u001b[1m-name\u001b[0m \u001b[1mcore\u001b[0m \u001b[1m-type\u001b[0m \u001b[1mf\u001b[0m \u001b[1m-print\u001b[0m \u001b[1m|\u001b[0m \u001b"]
[37.330194, "o", "[1mxargs\u001b[0m \u001b[1m/bin/rm\u001b[0m \u001b[1m-f\u001b[0m\u001b[m\r\n\u001b[7m Manual page find(1) line 1401 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.361141, "o", "\r\u001b[K"]
[37.361289, "o", "\u001b[m\r\n              Note that this will work incorrectly if there  are  any  filenames\u001b[m\r\n              containing newlines, single or double quotes, or spaces.\u001b[m\r\n\u001b[m\r\n   \u001b[1mSafer\u001b[0m \u001b[1m`find\u001b[0m \u001b[1m-print0\u001b[0m \u001b[1m|\u001b[0m \u001b[1mxargs\u001b[0m \u001b[1m-0`\u001b[0m \u001b[1mapproach\u001b[0m\u001b[m\r\n       •      Find  files  named  \u001b[4mcore\u001b[24m in or below the directory \u001b[4m/tmp\u001b[24m and delete\u001b[m\r\n              them, processing filenames in such a way that  file  or  directory\u001b[m\r\n              names  containing  single or double quotes, spaces or newlines are\u001b[m\r\n              correctly handled.\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m/tmp\u001b[0m \u001b[1m-name\u001b[0m \u001b[1mcore\u001b[0m \u001b[1m-type\u001b[0m \u001b[1mf\u001b[0m \u001b[1m-print0\u001b[0m \u001b[1m|\u001b[0m \u001b[1mxargs\u001b[0m \u001b[1m-0\u001b[0m \u001b[1m/bin/rm\u001b[0m \u001b[1m-f\u001b[0m\u001b[m\r\n\u001b[m\r\n              The \u001b[1m-name\u001b[0m test comes before the \u001b[1m-type\u001b[0m test in order to avoid  hav‐\u001b[m\r\n              ing to call \u001b[1mstat\u001b[0m(2) on every file.\u001b[m\r\n\u001b[m\r\n       Note that there is still a race between the time \u001b[1mfind\u001b[0m tra"]
[37.36137, "o", "verses the hier‐\u001b[m\r\n       archy printing the matching filenames, and the time the process  executed\u001b[m\r\n\u001b[7m Manual page find(1) line 1418 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.392942, "o", "\r\u001b[K"]
[37.393035, "o", "       by \u001b[1mxargs\u001b[0m works with that file.\u001b[m\r\n\u001b[m\r\n   \u001b[1mProcessing\u001b[0m \u001b[1marbitrary\u001b[0m \u001b[1mstarting\u001b[0m \u001b[1mpoints\u001b[0m\u001b[m\r\n       •      Given  that  another program \u001b[4mproggy\u001b[24m pre-filters and creates a huge\u001b[m\r\n              NUL-separated list of files, process those as starting points, and\u001b[m\r\n              find all regular, empty files among them:\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mproggy\u001b[0m \u001b[1m|\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m-files0-from\u001b[0m \u001b[1m-\u001b[0m \u001b[1m-maxdepth\u001b[0m \u001b[1m0\u001b[0m \u001b[1m-type\u001b[0m \u001b[1mf\u001b[0m \u001b[1m-empty\u001b[0m\u001b[m\r\n\u001b[m\r\n              The  use of \u001b[1m`-files0-from\u001b[0m \u001b[1m-`\u001b[0m means to read the names of the start‐\u001b[m\r\n              ing  points  from  \u001b[4mstandard\u001b[24m  \u001b[4minput\u001b[24m,  i.e.,  from  the  pipe;   and\u001b[m\r\n              \u001b[1m-maxdepth\u001b[0m \u001b[1m0\u001b[0m  ensures  that only explicitly those entries are exam‐\u001b[m\r\n              ined without recursing into directories (in the case  one  of  the\u001b[m\r\n              starting points is one).\u001b[m\r\n\u001b[m\r\n   \u001b[1mExecuting\u001b[0m \u001b[1ma\u001b[0m \u001b"]
[37.393103, "o", "[1mcommand\u001b[0m \u001b[1mfor\u001b[0m \u001b[1meach\u001b[0m \u001b[1mfile\u001b[0m\u001b[m\r\n       •      Run \u001b[4mfile\u001b[24m on every file in or below the current directory.\u001b[m\r\n\u001b[7m Manual page find(1) line 1435 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.423962, "o", "\r\u001b[K"]
[37.424108, "o", "\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-type\u001b[0m \u001b[1mf\u001b[0m \u001b[1m-exec\u001b[0m \u001b[1mfile\u001b[0m \u001b[1m'{}'\u001b[0m \u001b[1m\\;\u001b[0m\u001b[m\r\n\u001b[m\r\n              Notice  that the braces are enclosed in single quote marks to pro‐\u001b[m\r\n              tect them from interpretation as shell  script  punctuation.   The\u001b[m\r\n              semicolon is similarly protected by the use of a backslash, though\u001b[m\r\n              single quotes could have been used in that case also.\u001b[m\r\n\u001b[m\r\n       In many cases, one might prefer the \u001b[1m`-exec\u001b[0m \u001b[1m...\u001b[0m \u001b[1m+`\u001b[0m  or  better  the  \u001b[1m`-ex‐\u001b[0m\u001b[m\r\n       \u001b[1mecdir\u001b[0m \u001b[1m...\u001b[0m \u001b[1m+`\u001b[0m syntax for performance and security reasons.\u001b[m\r\n\u001b[m\r\n   \u001b[1mTraversing\u001b[0m \u001b[1mthe\u001b[0m \u001b[1mfilesystem\u001b[0m \u001b[1mjust\u001b[0m \u001b[1monce\u001b[0m \u001b[1m-\u001b[0m \u001b[1mfor\u001b[0m \u001b[1m2\u001b[0m \u001b[1mdifferent\u001b[0m \u001b[1mactions\u001b[0m\u001b[m\r\n       •      Traverse  the  filesystem just once, listing set-user-ID files and\u001b[m\r\n              directories   into   \u001b[4m/root/suid.txt\u001b[24m   and   large    files    into\u001b[m\r\n   "]
[37.424125, "o", "           \u001b[4m/root/big.txt\u001b[24m.\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m/\u001b[0m \u001b[1m\\\u001b[0m\u001b[m\r\n\u001b[7m Manual page find(1) line 1452 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.455264, "o", "\r\u001b[K"]
[37.455423, "o", "                      \u001b[1m\\(\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m-4000\u001b[0m \u001b[1m-fprintf\u001b[0m \u001b[1m/root/suid.txt\u001b[0m \u001b[1m'%#m\u001b[0m \u001b[1m%u\u001b[0m \u001b[1m%p\\n'\u001b[0m \u001b[1m\\)\u001b[0m \u001b[1m,\u001b[0m \u001b[1m\\\u001b[0m\u001b[m\r\n                      \u001b[1m\\(\u001b[0m \u001b[1m-size\u001b[0m \u001b[1m+100M\u001b[0m \u001b[1m-fprintf\u001b[0m \u001b[1m/root/big.txt\u001b[0m \u001b[1m'%-10s\u001b[0m \u001b[1m%p\\n'\u001b[0m \u001b[1m\\)\u001b[0m\u001b[m\r\n\u001b[m\r\n              This example uses the line-continuation character '\\' on the first\u001b[m\r\n              two lines to instruct the shell to continue reading the command on\u001b[m\r\n              the next line.\u001b[m\r\n\u001b[m\r\n   \u001b[1mSearching\u001b[0m \u001b[1mfiles\u001b[0m \u001b[1mby\u001b[0m \u001b[1mage\u001b[0m\u001b[m\r\n       •      Search  for  files in your home directory which have been modified\u001b[m\r\n              in the last twenty-four hours.\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m$HOME\u001b[0m \u001b[1m-mtime\u001b[0m \u001b[1m0\u001b[0m\u001b[m\r\n\u001b[m\r\n              This command works this way because the time since each  file  was\u001b[m\r\n              last  modified  is  divided  by 24 hours and any remainder is dis‐\u001b[m\r\n              carded.  That m"]
[37.455439, "o", "eans that to match \u001b[1m-mtime\u001b[0m \u001b[1m0\u001b[0m, a file  will  have  to\u001b[m\r\n              have a modification in the past which is less than 24 hours ago.\u001b[m\r\n\u001b[7m Manual page find(1) line 1469 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.48595, "o", "\r\u001b[K"]
[37.486054, "o", "\u001b[m\r\n   \u001b[1mSearching\u001b[0m \u001b[1mfiles\u001b[0m \u001b[1mby\u001b[0m \u001b[1mpermissions\u001b[0m\u001b[m\r\n       •      Search for files which are executable but not readable.\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m/sbin\u001b[0m \u001b[1m/usr/sbin\u001b[0m \u001b[1m-executable\u001b[0m \u001b[1m\\!\u001b[0m \u001b[1m-readable\u001b[0m \u001b[1m-print\u001b[0m\u001b[m\r\n\u001b[m\r\n       •      Search  for  files  which have read and write permission for their\u001b[m\r\n              owner, and group, but which other users can read but not write to.\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m664\u001b[0m\u001b[m\r\n\u001b[m\r\n              Files which meet these criteria but have  other  permissions  bits\u001b[m\r\n              set  (for  example  if  someone  can execute the file) will not be\u001b[m\r\n              matched.\u001b[m\r\n\u001b[m\r\n       •      Search for files which have read and write  permission  for  their\u001b[m\r\n              owner and group, and which other users can read, without regard to\u001b[m\r\n\u001b[7m Manual page find(1) line 1486 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.517606, "o", "\r\u001b[K              the presence of any extra permission bits (for  example  the  exe‐\u001b[m\r\n              cutable bit).\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m-664\u001b[0m\u001b[m\r\n\u001b[m\r\n              This will match a file which has mode \u001b[4m0777\u001b[24m, for example.\u001b[m\r\n\u001b[m\r\n       •      Search  for  files which are writable by somebody (their owner, or\u001b[m\r\n              their group, or anybody else).\u001b[m\r\n\u001b[m\r\n"]
[37.517725, "o", "                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m/222\u001b[0m\u001b[m\r\n\u001b[m\r\n       •      Search for files which are writable by either their owner or their\u001b[m\r\n              group.\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m/220\u001b[0m\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m/u+w,g+w\u001b[0m\u001b[m\r\n\u001b[7m Manual page find(1) line 1503 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.549375, "o", "\r\u001b[K                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m/u=w,g=w\u001b[0m\u001b[m\r\n\u001b[m\r\n              All  three  of these commands do the same thing, but the first one\u001b[m\r\n              uses the octal representation of the file mode, and the other  two\u001b[m\r\n              use  the  symbolic  form.   The files don't have to be writable by\u001b[m\r\n              both the owner and group to be matched; either will do.\u001b[m\r\n\u001b[m\r\n       •      Search for files which are writable by both their owner and  their\u001b[m\r\n              group.\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m-220\u001b[0m\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m-g+w,u+w\u001b[0m\u001b[m\r\n\u001b[m\r\n              Both these commands do the same thing.\u001b[m\r\n\u001b[m\r\n       •      A more elaborate search on permissions.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 1520 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.580316, "o", "\r\u001b[K"]
[37.580457, "o", "                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m-444\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m/222\u001b[0m \u001b[1m\\!\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m/111\u001b[0m\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m-a+r\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m/a+w\u001b[0m \u001b[1m\\!\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m/a+x\u001b[0m\u001b[m\r\n\u001b[m\r\n              These two commands both search for files that are readable for ev‐\u001b[m\r\n              erybody (\u001b[1m-perm\u001b[0m \u001b[1m-444\u001b[0m or \u001b[1m-perm\u001b[0m \u001b[1m-a+r\u001b[0m), have at least  one  write  bit\u001b[m\r\n              set  (\u001b[1m-perm\u001b[0m \u001b[1m/222\u001b[0m or \u001b[1m-perm\u001b[0m \u001b[1m/a+w\u001b[0m) but are not executable for anybody\u001b[m\r\n              (\u001b[1m!\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m/111\u001b[0m or \u001b[1m!\u001b[0m \u001b[1m-perm\u001b[0m \u001b[1m/a+x\u001b[0m respectively).\u001b[m\r\n\u001b[m\r\n   \u001b[1mPruning\u001b[0m \u001b[1m-\u001b[0m \u001b[1momitting\u001b[0m \u001b[1mfiles\u001b[0m \u001b[1mand\u001b[0m \u001b[1msubdirectories\u001b[0m\u001b[m\r\n       •      Copy the contents of \u001b[4m/source-dir\u001b[24m to \u001b[4m/dest-dir\u001b[24m, but omit files  and\u001b[m\r\n              directories named \u001b[4m.snapshot\u001b[24m (and anything in them).  It also "]
[37.580477, "o", "omits\u001b[m\r\n              files or directories whose name ends in `~', but  not  their  con‐\u001b[m\r\n              tents.\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mcd\u001b[0m \u001b[1m/source-dir\u001b[0m\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-name\u001b[0m \u001b[1m.snapshot\u001b[0m \u001b[1m-prune\u001b[0m \u001b[1m-o\u001b[0m \u001b[1m\\(\u001b[0m \u001b[1m\\!\u001b[0m \u001b[1m-name\u001b[0m \u001b[1m'*~'\u001b[0m \u001b[1m-print0\u001b[0m \u001b[1m\\)\u001b[0m \u001b[1m\\\u001b[0m\u001b[m\r\n                      \u001b[1m|\u001b[0m \u001b[1mcpio\u001b[0m \u001b[1m-pmd0\u001b[0m \u001b[1m/dest-dir\u001b[0m\u001b[m\r\n\u001b[7m Manual page find(1) line 1537 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.611703, "o", "\r\u001b[K\u001b[m\r\n              The  construct  \u001b[1m-prune\u001b[0m \u001b[1m-o\u001b[0m \u001b[1m\\(\u001b[0m \u001b[1m...\u001b[0m \u001b[1m-print0\u001b[0m \u001b[1m\\)\u001b[0m  is quite common.  The\u001b[m\r\n              idea here is that the  expression  before  \u001b[1m-prune\u001b[0m  matches  things\u001b[m\r\n              which are to be pruned.  However, the \u001b[1m-prune\u001b[0m action itself returns\u001b[m\r\n              true, so the following \u001b[1m-o\u001b[0m ensures that  the  right  hand  side  is\u001b[m\r\n              evaluated  only for those directories which didn't get pruned (the\u001b[m\r\n              contents of the pruned directories are not even visited, so  their\u001b[m\r\n              contents  are  irrelevant).  The expression on the right hand side\u001b[m\r\n              of the \u001b[1m-o\u001b[0m is in parentheses only for clarity.  It emphasises  that\u001b[m\r\n              the  \u001b[1m-print0\u001b[0m  action  takes place only for things that didn't have\u001b[m\r\n              \u001b[1m-prune\u001b[0m applied to them.  Because the default `and'  condition  be‐\u001b[m\r\n              tween  tests  binds more tightly than \u001b[1m-o\u001b[0m, thi"]
[37.611822, "o", "s is the default any‐\u001b[m\r\n              way, but the parentheses help to show what is going on.\u001b[m\r\n\u001b[m\r\n       •      Given the following directory of projects and their associated SCM\u001b[m\r\n              administrative  directories,  perform  an efficient search for the\u001b[m\r\n              projects' roots:\u001b[m\r\n\u001b[7m Manual page find(1) line 1554 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.643886, "o", "\r\u001b[K"]
[37.643916, "o", "\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1mrepo/\u001b[0m \u001b[1m\\\u001b[0m\u001b[m\r\n                      \u001b[1m\\(\u001b[0m \u001b[1m-exec\u001b[0m \u001b[1mtest\u001b[0m \u001b[1m-d\u001b[0m \u001b[1m'{}/.svn'\u001b[0m \u001b[1m\\;\u001b[0m \u001b[1m\\\u001b[0m\u001b[m\r\n                      \u001b[1m-or\u001b[0m \u001b[1m-exec\u001b[0m \u001b[1mtest\u001b[0m \u001b[1m-d\u001b[0m \u001b[1m'{}/.git'\u001b[0m \u001b[1m\\;\u001b[0m \u001b[1m\\\u001b[0m\u001b[m\r\n                      \u001b[1m-or\u001b[0m \u001b[1m-exec\u001b[0m \u001b[1mtest\u001b[0m \u001b[1m-d\u001b[0m \u001b[1m'{}/CVS'\u001b[0m \u001b[1m\\;\u001b[0m \u001b[1m\\\u001b[0m\u001b[m\r\n                      \u001b[1m\\)\u001b[0m \u001b[1m-print\u001b[0m \u001b[1m-prune\u001b[0m\u001b[m\r\n\u001b[m\r\n              Sample output:\u001b[m\r\n\u001b[m\r\n                  \u001b[1mrepo/project1/CVS\u001b[0m\u001b[m\r\n                  \u001b[1mrepo/gnu/project2/.svn\u001b[0m\u001b[m\r\n                  \u001b[1mrepo/gnu/project3/.svn\u001b[0m\u001b[m\r\n                  \u001b[1mrepo/gnu/project3/src/.svn\u001b[0m\u001b[m\r\n                  \u001b[1mrepo/project4/.git\u001b[0m\u001b[m\r\n\u001b[m\r\n              In this example, \u001b[1m-prune\u001b[0m prevents unnecessary descent into directo‐\u001b[m\r\n              ries  that  have  already  been  discovered (for example we do not\u001b[m\r\n\u001b[7m Manual page find(1) line 1571 (press h for help"]
[37.643924, "o", " or q to quit)\u001b[27m\u001b[K"]
[37.674332, "o", "\r\u001b[K"]
[37.674485, "o", "              search \u001b[4mproject3/src\u001b[24m because we already found  \u001b[4mproject3/.svn\u001b[24m),  but\u001b[m\r\n              ensures sibling directories (\u001b[4mproject2\u001b[24m and \u001b[4mproject3\u001b[24m) are found.\u001b[m\r\n\u001b[m\r\n   \u001b[1mOther\u001b[0m \u001b[1museful\u001b[0m \u001b[1mexamples\u001b[0m\u001b[m\r\n       •      Search for several file types.\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m/tmp\u001b[0m \u001b[1m-type\u001b[0m \u001b[1mf,d,l\u001b[0m\u001b[m\r\n\u001b[m\r\n              Search for files, directories, and symbolic links in the directory\u001b[m\r\n              \u001b[4m/tmp\u001b[24m passing these types as a  comma-separated  list  (GNU  exten‐\u001b[m\r\n              sion),  which is otherwise equivalent to the longer, yet more por‐\u001b[m\r\n              table:\u001b[m\r\n\u001b[m\r\n"]
[37.674526, "o", "                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m/tmp\u001b[0m \u001b[1m\\(\u001b[0m \u001b[1m-type\u001b[0m \u001b[1mf\u001b[0m \u001b[1m-o\u001b[0m \u001b[1m-type\u001b[0m \u001b[1md\u001b[0m \u001b[1m-o\u001b[0m \u001b[1m-type\u001b[0m \u001b[1ml\u001b[0m \u001b[1m\\)\u001b[0m\u001b[m\r\n\u001b[m\r\n       •      Search for files with the particular name \u001b[4mneedle\u001b[24m and stop  immedi‐\u001b[m\r\n              ately when we find the first one.\u001b[m\r\n\u001b[7m Manual page find(1) line 1588 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.705966, "o", "\r\u001b[K"]
[37.706111, "o", "\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m/\u001b[0m \u001b[1m-name\u001b[0m \u001b[1mneedle\u001b[0m \u001b[1m-print\u001b[0m \u001b[1m-quit\u001b[0m\u001b[m\r\n\u001b[m\r\n       •      Demonstrate  the interpretation of the \u001b[1m%f\u001b[0m and \u001b[1m%h\u001b[0m format directives\u001b[m\r\n              of the \u001b[1m-printf\u001b[0m action for some corner-cases.  Here is  an  example\u001b[m\r\n              including some output.\u001b[m\r\n\u001b[m\r\n                  \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m..\u001b[0m \u001b[1m/\u001b[0m \u001b[1m/tmp\u001b[0m \u001b[1m/tmp/TRACE\u001b[0m \u001b[1mcompile\u001b[0m \u001b[1mcompile/64/tests/find\u001b[0m \u001b[1m-maxd\u001b[0m\u001b[m \b\u001b[1mepth\u001b[0m \u001b[1m0\u001b[0m \u001b[1m-printf\u001b[0m \u001b[1m'[%h][%f]\\n'\u001b[0m\u001b[m\r\n                  \u001b[1m[.][.]\u001b[0m\u001b[m\r\n                  \u001b[1m[.][..]\u001b[0m\u001b[m\r\n                  \u001b[1m[][/]\u001b[0m\u001b[m\r\n                  \u001b[1m[][tmp]\u001b[0m\u001b[m\r\n                  \u001b[1m[/tmp][TRACE]\u001b[0m\u001b[m\r\n                  \u001b[1m[.][compile]\u001b[0m\u001b[m\r\n                  \u001b[1m[compile/64/tests][find]\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page find(1) line 1605 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.737684, "o", "\r\u001b[K"]
[37.737839, "o", "\u001b[1mEXIT\u001b[0m \u001b[1mSTATUS\u001b[0m\u001b[m\r\n       \u001b[1mfind\u001b[0m exits with status 0 if all files are processed successfully, greater\u001b[m\r\n       than 0 if errors occur.  This is deliberately a very  broad  description,\u001b[m\r\n       but  if the return value is non-zero, you should not rely on the correct‐\u001b[m\r\n       ness of the results of \u001b[1mfind\u001b[0m.\u001b[m\r\n\u001b[m\r\n       When some error occurs, \u001b[1mfind\u001b[0m may stop immediately, without completing all\u001b[m\r\n       the  actions  specified.   For example, some starting points may not have\u001b[m\r\n       been examined or some pending program invocations for  \u001b[1m-exec\u001b[0m \u001b[1m...\u001b[0m \u001b[1m{}\u001b[0m \u001b[1m+\u001b[0m  or\u001b[m\r\n       \u001b[1m-execdir\u001b[0m \u001b[1m...\u001b[0m \u001b[1m{}\u001b[0m \u001b[1m+\u001b[0m may not have been performed.\u001b[m\r\n\u001b[m\r\n\u001b[1mHISTORY\u001b[0m\u001b[m\r\n       As  of  findutils-4.2.2, shell metacharacters (`*', `?' or `[]' for exam‐\u001b[m\r\n       ple) used in filename patterns match a leading `.',  because  IEEE  POSIX\u001b[m\r\n       interpretation 126 requires this.\u001b[m\r\n\u001b[m\r\n       As of findutils-4.3.3, \u001b[1m-perm\u001b[0"]
[37.737991, "o", "m \u001b[1m/000\u001b[0m now matches all files instead of none.\u001b[m\r\n\u001b[7m Manual page find(1) line 1621 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.768342, "o", "\r\u001b[K\u001b[m\r\n       Nanosecond-resolution timestamps were implemented in findutils-4.3.3.\u001b[m\r\n\u001b[m\r\n       As  of  findutils-4.3.11, the \u001b[1m-delete\u001b[0m action sets \u001b[1mfind\u001b[0m's exit status to a\u001b[m\r\n       nonzero value when it fails.  However, \u001b[1mfind\u001b[0m will  not  exit  immediately.\u001b[m\r\n       Previously, \u001b[1mfind\u001b[0m's exit status was unaffected by the failure of \u001b[1m-delete\u001b[0m.\u001b[m\r\n\u001b[m\r\n"]
[37.768452, "o", "       Feature                Added in   Also occurs in\u001b[m\r\n       -files0-from           4.9.0\u001b[m\r\n       -newerXY               4.3.3      BSD\u001b[m\r\n       -D                     4.3.1\u001b[m\r\n       -O                     4.3.1\u001b[m\r\n       -readable              4.3.0\u001b[m\r\n       -writable              4.3.0\u001b[m\r\n       -executable            4.3.0\u001b[m\r\n       -regextype             4.2.24\u001b[m\r\n       -exec ... +            4.2.12     POSIX\u001b[m\r\n\u001b[7m Manual page find(1) line 1638 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.799805, "o", "\r\u001b[K"]
[37.799862, "o", "       -execdir               4.2.12     BSD\u001b[m\r\n       -okdir                 4.2.12\u001b[m\r\n       -samefile              4.2.11\u001b[m\r\n       -H                     4.2.5      POSIX\u001b[m\r\n       -L                     4.2.5      POSIX\u001b[m\r\n       -P                     4.2.5      BSD\u001b[m\r\n       -delete                4.2.3\u001b[m\r\n       -quit                  4.2.3\u001b[m\r\n       -d                     4.2.3      BSD\u001b[m\r\n       -wholename             4.2.0\u001b[m\r\n       -iwholename            4.2.0\u001b[m\r\n       -ignore_readdir_race   4.2.0\u001b[m"]
[37.799869, "o", "\r\n       -fls                   4.0\u001b[m\r\n       -ilname                3.8\u001b[m\r\n       -iname                 3.8\u001b[m\r\n       -ipath                 3.8\u001b[m\r\n       -iregex                3.8\u001b[m\r\n\u001b[7m Manual page find(1) line 1655 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.830868, "o", "\r\u001b[K"]
[37.831053, "o", "\u001b[m\r\n       The  syntax  \u001b[1m-perm\u001b[0m  \u001b[1m+MODE\u001b[0m  was  removed in findutils-4.5.12, in favour of\u001b[m\r\n       \u001b[1m-perm\u001b[0m \u001b[1m/MODE\u001b[0m.  The \u001b[1m+MODE\u001b[0m syntax had been deprecated since findutils-4.2.21\u001b[m\r\n       which was released in 2005.\u001b[m\r\n\u001b[m\r\n\u001b[1mNON-BUGS\u001b[0m\u001b[m\r\n   \u001b[1mOperator\u001b[0m \u001b[1mprecedence\u001b[0m \u001b[1msurprises\u001b[0m\u001b[m\r\n       The  command  \u001b[1mfind\u001b[0m  \u001b[1m.\u001b[0m  \u001b[1m-name\u001b[0m \u001b[1mafile\u001b[0m \u001b[1m-o\u001b[0m \u001b[1m-name\u001b[0m \u001b[1mbfile\u001b[0m \u001b[1m-print\u001b[0m will never print\u001b[m\r\n       \u001b[4mafile\u001b[24m because this is actually equivalent to \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m  \u001b[1m-name\u001b[0m  \u001b[1mafile\u001b[0m  \u001b[1m-o\u001b[0m  \u001b[1m\\(\u001b[0m\u001b[m\r\n       \u001b[1m-name\u001b[0m  \u001b[1mbfile\u001b[0m  \u001b[1m-a\u001b[0m \u001b[1m-print\u001b[0m \u001b[1m\\)\u001b[0m.  Remember that the precedence of \u001b[1m-a\u001b[0m is higher\u001b[m\r\n       than that of \u001b[1m-o\u001b[0m and when there is no operator specified between tests, \u001b[1m-a\u001b[0m\u001b[m\r\n       is assumed.\u001b[m\r\n\u001b[m\r\n   \u001b[1m“paths\u001b[0m \u001b[1mmust\u001b[0m \u001b[1mprecede\u001b[0m \u001b[1mexpression”\u001b[0m \u001b[1merror\u001b[0m \u001b[1mmessage\u001b[0m\u001b[m\r\n       \u001b[1m$\u001b[0m \u001b[1mfind"]
[37.831108, "o", "\u001b[0m \u001b[1m.\u001b[0"]
[37.831145, "o", "m \u001b[1m-name\u001b[0m \u001b[1m*.c\u001b[0m \u001b[1m-print\u001b[0m\u001b[m\r\n       find: paths must precede expression\u001b[m\r\n       find: possible unquoted pattern after predicate `-name'?\u001b[m\r\n\u001b[7m Manual page find(1) line 1672 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.862583, "o", "\r\u001b[K"]
[37.862683, "o", "\u001b[m\r\n       This happens when the shell could expand the pattern \u001b[4m*.c\u001b[24m to more than one\u001b[m\r\n       file name existing in the current directory, and  passing  the  resulting\u001b[m\r\n       file names in the command line to \u001b[1mfind\u001b[0m like this:\u001b[m\r\n       \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-name\u001b[0m \u001b[1mfrcode.c\u001b[0m \u001b[1mlocate.c\u001b[0m \u001b[1mword_io.c\u001b[0m \u001b[1m-print\u001b[0m\u001b[m\r\n       That  command is of course not going to work, because the \u001b[1m-name\u001b[0m predicate\u001b[m\r\n       allows exactly only one pattern as argument.   Instead  of  doing  things\u001b[m\r\n       this  way,  you  should enclose the pattern in quotes or escape the wild‐\u001b[m\r\n       card, thus allowing \u001b[1mfind\u001b[0m to use the pattern with the wildcard during  the\u001b[m\r\n       search  for file name matching instead of file names expanded by the par‐\u001b[m\r\n       ent shell:\u001b[m\r\n       \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-name\u001b[0m \u001b[1m'*.c'\u001b[0m \u001b[1m-print\u001b[0m\u001b[m\r\n       \u001b[1m$\u001b[0m \u001b[1mfind\u001b[0m \u001b[1m.\u001b[0m \u001b[1m-name\u001b[0m \u001b[1m\\*.c\u001b[0m \u001b[1m-print\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[1mBUGS\u001b[0"]
[37.862691, "o", "m\u001b[m\r\n       There are security problems inherent in  the  behaviour  that  the  POSIX\u001b[m\r\n       standard  specifies for \u001b[1mfind\u001b[0m, which therefore cannot be fixed.  For exam‐\u001b[m\r\n\u001b[7m Manual page find(1) line 1689 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.893904, "o", "\r\u001b[K"]
[37.893987, "o", "       ple, the \u001b[1m-exec\u001b[0m action is inherently insecure, and \u001b[1m-execdir\u001b[0m should be used\u001b[m\r\n       instead.\u001b[m\r\n\u001b[m\r\n       The environment variable \u001b[1mLC_COLLATE\u001b[0m has no effect on the \u001b[1m-ok\u001b[0m action.\u001b[m\r\n\u001b[m\r\n\u001b[1mREPORTING\u001b[0m \u001b[1mBUGS\u001b[0m\u001b[m\r\n       GNU  findutils online help: <https://www.gnu.org/software/findutils/#get-\u001b[m\r\n       help>\u001b[m\r\n       Report any translation bugs to <https://translationproject.org/team/>\u001b[m\r\n\u001b[m\r\n       Report any other issue via the form at the GNU Savannah bug tracker:\u001b[m\r\n              <https://savannah.gnu.org/bugs/?group=findutils>\u001b[m\r\n       General topics about the GNU  findutils  package  are  discussed  at  the\u001b[m\r\n       \u001b[4mbug-findutils\u001b[24m mailing list:\u001b[m\r\n              <https://lists.gnu.org/mailman/listinfo/bug-findutils>\u001b[m\r\n\u001b[m\r\n\u001b[1mCOPYRIGHT\u001b[0m\u001b[m\r\n\u001b[7m Manual page find(1) line 1706 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.92561, "o", "\r\u001b[K       Copyright © 1990-2022 Free Software Foundation, Inc.  License GPLv3+: GNU\u001b[m\r\n       GPL version 3 or later <https://gnu.org/licenses/gpl.html>.\u001b[m\r\n       This is free software: you are free to change and redistribute it.  There\u001b[m\r\n       is NO WARRANTY, to the extent permitted by law.\u001b[m\r\n\u001b[m\r\n\u001b[1mSEE\u001b[0m \u001b[1mALSO\u001b[0m\u001b[m\r\n       \u001b[1mchmod\u001b[0m(1),  \u001b[1mlocate\u001b[0m(1),  \u001b[1mls\u001b[0m(1),  \u001b[1mupdatedb\u001b[0m(1),  \u001b[1mxargs\u001b[0m(1), \u001b[1mlstat\u001b[0m(2), \u001b[1mstat\u001b[0m(2),\u001b[m\r\n       \u001b[1mctime\u001b[0m(3) \u001b[1mfnmatch\u001b[0m(3), \u001b[1mprintf\u001b[0m(3), \u001b[1mstrftime\u001b[0m(3), \u001b[1mlocatedb\u001b[0m(5), \u001b[1mregex\u001b[0m(7)\u001b[m\r\n\u001b[m\r\n       Full documentation <https://www.gnu.org/software/findutils/find>\u001b[m\r\n       or available locally via: \u001b[1minfo\u001b[0m \u001b[1mfind\u001b[0m\u001b[m\r\n\u001b[m\r\n                                                                         FIND(1)\u001b[m\r\n"]
