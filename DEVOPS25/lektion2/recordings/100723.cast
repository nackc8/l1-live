[807.472713, "o", "\u001b[1;1H       \u001b[4mPATTERNS\u001b[24m  should be quoted when \u001b[1mgrep\u001b[0m is used\u001b[m\r\n\u001b[2;1H       in a shell command.\u001b[m\r\n\u001b[3;1H\u001b[m\r\n\u001b[4;1H       A \u001b[4mFILE\u001b[24m of “\u001b[1m-\u001b[0m” stands for standard input.  If\u001b[m\r\n\u001b[5;1H       no \u001b[4mFILE\u001b[24m is given, recursive searches examine\u001b[m\r\n\u001b[6;1H       the  working  directory,  and   nonrecursive\u001b[m\r\n\u001b[7;1H       searches read standard input.\u001b[m\r\n\u001b[8;1H\u001b[m\r\n\u001b[9;1H       Debian  also  includes  the variant programs\u001b[m\r\n\u001b[10;1H       \u001b[1megrep\u001b[0m, \u001b[1mfgrep\u001b[0m and \u001b[1mrgrep\u001b[0m.  These programs  are\u001b[m\r\n\u001b[11;1H       the  same  as \u001b[1mgrep\u001b[0m \u001b[1m-E\u001b[0m, \u001b[1mgrep\u001b[0m \u001b[1m-F\u001b[0m, and \u001b[1mgrep\u001b[0m \u001b[1m-r\u001b[0m,\u001b[m\r\n\u001b[12;1H       respectively.  These variants are deprecated\u001b[m\r\n\u001b[13;1H       upstream,  but  Debian provides for backward\u001b[m\r\n\u001b[14;1H       compatibility. For portability  reasons,  it\u001b[m\r\n\u001b[15;1H       is   recommended   to   avoid   the  variant\u001b[m\r\n\u001b[16;1H       programs, and  use  \u001b[1mgrep\u001b[0m  with  the  related\u001b[m\r\n\u001b[17;1H       option instead.\u001b[m\r\n\u001b[18;1"]
[807.472811, "o", "H\u001b[1;1H       \u001b["]
[807.472966, "o", "4mPATTERNS\u001b[24m  should be quoted when \u001b[1mgrep\u001b[0m is used\u001b[m\r\n\u001b[2;1H       in a shell command.\u001b[m\r\n\u001b[3;1H\u001b[m\r\n\u001b[4;1H       A \u001b[4mFILE\u001b[24m of “\u001b[1m-\u001b[0m” stands for standard input.  If\u001b[m\r\n\u001b[5;1H       no \u001b[4mFILE\u001b[24m is given, recursive searches examine\u001b[m\r\n\u001b[6;1H       the  working  directory,  and   nonrecursive\u001b[m\r\n\u001b[7;1H       searches read standard input.\u001b[m\r\n\u001b[8;1H\u001b[m\r\n\u001b[9;1H       Debian  also  includes  the variant programs\u001b[m\r\n\u001b[10;1H       \u001b[1megrep\u001b[0m, \u001b[1mfgrep\u001b[0m and \u001b[1mrgrep\u001b[0m.  These programs  are\u001b[m\r\n\u001b[11;1H       the  same  as \u001b[1mgrep\u001b[0m \u001b[1m-E\u001b[0m, \u001b[1mgrep\u001b[0m \u001b[1m-F\u001b[0m, and \u001b[1mgrep\u001b[0m \u001b[1m-r\u001b[0m,\u001b[m\r\n\u001b[12;1H       respectively.  These variants are deprecated\u001b[m\r\n\u001b[13;1H       upstream,  but  Debian provides for backward\u001b[m\r\n\u001b[14;1H       compatibility. For portability  reasons,  it\u001b[m\r\n\u001b[15;1H       is   recommended   to   avoid   the  variant\u001b[m\r\n\u001b[16;1H       programs, and  use  \u001b[1mgrep\u001b[0m  with  the  related\u001b[m\r\n\u001b[17;1H       option instead.\u001b[m\r\n\u001b[18;1H"]
[807.473568, "o", "...skipping...\r\n       \u001b[1m\u001b[7m-R\u001b[27m\u001b[0m, \u001b[1m--dereference-recursive\u001b[0m\u001b[m\r\n              Read  all files under each directory,\u001b[m\r\n              recursively.   Follow  all   symbolic\u001b[m\r\n              links, unlike \u001b[1m-r\u001b[0m.\u001b[m\r\n\u001b[m\r\n   \u001b[1mOther\u001b[0m \u001b[1mOptions\u001b[0m\u001b[m\r\n       \u001b[1m--line-buffered\u001b[0m\u001b[m\r\n              Use  line  buffering on output.  This\u001b[m\r\n              can cause a performance penalty.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-U\u001b[0m, \u001b[1m--binary\u001b[0m\u001b[m\r\n              Treat  the  file(s)  as  binary.   By\u001b[m\r\n              default, under MS-DOS and MS-Windows,\u001b[m\r\n              \u001b[1mgrep\u001b[0m guesses whether a file  is  text\u001b[m\r\n              or   binary   as  described  for  the\u001b[m\r\n              \u001b[1m--binary-files\u001b[0m   option.    If   \u001b[1mgrep\u001b[0m\u001b[m\r\n              decides  the  file is a text file, it\u001b[m\r\n\u001b[7mge grep(1) line 439 (press h for help or q to quit)\u001b[27m\u001b[K"]
[811.830003, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
