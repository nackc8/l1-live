[530.36161, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Prompt with \"[Press space to continue, 'q' to quit.]\", and display\u001b[m\r\n\u001b[7m Manual page more(1) line 7 (press h for help or q to quit)\u001b[27m\u001b[K"]
[530.393578, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \"[Press 'h' for instructions.]\" instead of ringing the bell when an\u001b[m\r\n\u001b[7m Manual page more(1) line 8 (press h for help or q to quit)\u001b[27m\u001b[K"]
