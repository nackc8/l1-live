[527.849395, "o", "MORE(1)                           User Commands                          MORE(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       more - file perusal filter for crt viewing\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mmore\u001b[0m [options] \u001b[4mfile\u001b[24m ...\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       \u001b[1mmore\u001b[0m is a filter for paging through text one screenful at a time. This\u001b[m\r\n       version is especially primitive. Users should realize that \u001b[1mless\u001b[0m(1)\u001b[m\r\n       provides \u001b[1mmore\u001b[0m(1) emulation plus extensive enhancements.\u001b[m\r\n\u001b[m\r\n\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[7m Manual page more(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[529.729508, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       Options are also taken from the environment variable \u001b[1mMORE\u001b[0m (make sure to\u001b[m\r\n\u001b[7m Manual page more(1) line 2 (press h for help or q to quit)\u001b[27m\u001b[K"]
[530.230917, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       precede them with a dash (\u001b[1m-\u001b[0m)) but command-line options will override\u001b[m\r\n\u001b[7m Manual page more(1) line 3 (press h for help or q to quit)\u001b[27m\u001b[K"]
[530.263259, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       those.\u001b[m\r\n\u001b[7m Manual page more(1) line 4 (press h for help or q to quit)\u001b[27m\u001b[K"]
[530.296254, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page more(1) line 5 (press h for help or q to quit)\u001b[27m\u001b[K"]
