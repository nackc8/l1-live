[940.215678, "o", "LN(1)                             User Commands                            LN(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       ln - make links between files\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mln\u001b[0m [\u001b[4mOPTION\u001b[24m]... [\u001b[4m-T\u001b[24m] \u001b[4mTARGET\u001b[24m \u001b[4mLINK_NAME\u001b[24m\u001b[m\r\n       \u001b[1mln\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mTARGET\u001b[24m\u001b[m\r\n       \u001b[1mln\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mTARGET\u001b[24m... \u001b[4mDIRECTORY\u001b[24m\u001b[m\r\n       \u001b[1mln\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4m-t\u001b[24m \u001b[4mDIRECTORY\u001b[24m \u001b[4mTARGET\u001b[24m...\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       In the 1st form, create a link to TARGET with the name LINK_NAME.  In the\u001b[m\r\n       2nd form, create a link to TARGET in the current directory.  In  the  3rd\u001b[m\r\n\u001b[7m Manual page ln(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[943.040699, "o", "\r\u001b[K       and  4th  forms,  create  links to each TARGET in DIRECTORY.  Create hard\u001b[m\r\n       links by default, symbolic links with \u001b[1m--symbolic\u001b[0m.  By default, each  des‐\u001b[m\r\n       tination (name of new link) should not already exist.  When creating hard\u001b[m\r\n       links, each TARGET must exist.  Symbolic links can hold  arbitrary  text;\u001b[m\r\n       if later resolved, a relative link is interpreted in relation to its par‐\u001b[m\r\n       ent directory.\u001b[m\r\n\u001b[m\r\n       Mandatory arguments to long options are mandatory for short options too.\u001b[m\r\n\u001b[m\r\n"]
[943.040821, "o", "       \u001b[1m--backup\u001b[0m[=\u001b[4mCONTROL\u001b[24m]\u001b[m\r\n              make a backup of each existing destination file\u001b[m\r\n\u001b[m\r\n       \u001b[1m-b\u001b[0m     like \u001b[1m--backup\u001b[0m but does not accept an argument\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ln(1) line 15 (press h for help or q to quit)\u001b[27m\u001b[K"]
[943.776109, "o", "\r\u001b[K       \u001b[1m-d\u001b[0m, \u001b[1m-F\u001b[0m, \u001b[1m--directory\u001b[0m\u001b[m\r\n              allow the superuser to attempt to  hard  link  directories  (note:\u001b[m\r\n              will  probably fail due to system restrictions, even for the supe‐\u001b[m\r\n              ruser)\u001b[m\r\n\u001b[m\r\n       \u001b[1m-f\u001b[0m, \u001b[1m--force\u001b[0m\u001b[m\r\n              remove existing destination files\u001b[m\r\n\u001b[m\r\n       \u001b[1m-i\u001b[0m, \u001b[1m--interactive\u001b[0m\u001b[m\r\n              prompt whether to remove destinations\u001b[m\r\n\u001b[m\r\n       \u001b[1m-L\u001b[0m, \u001b[1m--logical\u001b[0m\u001b[m\r\n              dereference TARGETs that are symbolic links\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ln(1) line 29 (press h for help or q to quit)\u001b[27m\u001b[K"]
[945.396438, "o", "\r\u001b[K       \u001b[1m-n\u001b[0m, \u001b[1m--no-dereference\u001b[0m\u001b[m\r\n              treat LINK_NAME as a normal file if it is a symbolic link to a di‐\u001b[m\r\n              rectory\u001b[m\r\n\u001b[m\r\n       \u001b[1m-P\u001b[0m, \u001b[1m--physical\u001b[0m\u001b[m\r\n              make hard links directly to symbolic links\u001b[m\r\n\u001b[m\r\n       \u001b[1m-r\u001b[0m, \u001b[1m--relative\u001b[0m\u001b[m\r\n              with \u001b[1m-s\u001b[0m, create links relative to link location\u001b[m\r\n\u001b[m\r\n       \u001b[1m-s\u001b[0m, \u001b[1m--symbolic\u001b[0m\u001b[m\r\n              make symbolic links instead of hard links\u001b[m\r\n\u001b[m\r\n       \u001b[1m-S\u001b[0m, \u001b[1m--suffix\u001b[0m=\u001b[4mSUFFIX\u001b[24m\u001b[m\r\n\u001b[7m Manual page ln(1) line 43 (press h for help or q to quit)\u001b[27m\u001b[K"]
[953.909539, "o", "\r\u001b[K\u001b[?1l\u001b>\u001b[?1049l\u001b[23;0;0t"]
