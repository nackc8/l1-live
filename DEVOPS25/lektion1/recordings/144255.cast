[157.222459, "o", "\u001b[1;1HLN(1)                             User Commands                            LN(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       ln - make links between files\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1mln\u001b[0m [\u001b[4mOPTION\u001b[24m]... [\u001b[4m-T\u001b[24m] \u001b[4mTARGET\u001b[24m \u001b[4mLINK_NAME\u001b[24m\u001b[m\r\n\u001b[8;1H       \u001b[1mln\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mTARGET\u001b[24m\u001b[m\r\n\u001b[9;1H       \u001b[1mln\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mTARGET\u001b[24m... \u001b[4mDIRECTORY\u001b[24m\u001b[m\r\n\u001b[10;1H       \u001b[1mln\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4m-t\u001b[24m \u001b[4mDIRECTORY\u001b[24m \u001b[4mTARGET\u001b[24m...\u001b[m\r\n\u001b[11;1H\u001b[m\r\n\u001b[12;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[13;1H       In the 1st form, create a link to TARGET with the name LINK_NAME.  In the\u001b[m\r\n\u001b[14;1H       2nd form, create a link to TARGET in the current directory.  In  the  3rd\u001b[m\r\n\u001b[15;1H\u001b[1;1HLN(1)                             User Commands                            LN(1)\u001b[m\r\n\u001b[2;1H\u001b[m\r\n\u001b[3;1H\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H       ln - make links between files\u001b[m\r\n\u001b[5;1H\u001b[m\r\n\u001b[6;1H\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H       \u001b[1mln\u001b"]
[157.222494, "o", "[0m [\u001b[4mOPTION\u001b[24"]
[157.222782, "o", "m]... [\u001b[4m-T\u001b[24m] \u001b[4mTARGET\u001b[24m \u001b[4mLINK_NAME\u001b[24m\u001b[m\r\n\u001b[8;1H       \u001b[1mln\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mTARGET\u001b[24m\u001b[m\r\n\u001b[9;1H       \u001b[1mln\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mTARGET\u001b[24m... \u001b[4mDIRECTORY\u001b[24m\u001b[m\r\n\u001b[10;1H       \u001b[1mln\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4m-t\u001b[24m \u001b[4mDIRECTORY\u001b[24m \u001b[4mTARGET\u001b[24m...\u001b[m\r\n\u001b[11;1H\u001b[m\r\n\u001b[12;1H\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[13;1H       In the 1st form, create a link to TARGET with the name LINK_NAME.  In the\u001b[m\r\n\u001b[14;1H       2nd form, create a link to TARGET in the current directory.  In  the  3rd\u001b[m\r\n\u001b[15;1H...skipping...\r\n       links by default, symbolic links with \u001b[1m-\u001b[0m\u001b[1m\u001b[7m-s\u001b[27m\u001b[0m\u001b[1mymbolic\u001b[0m.  By default, each  des‐\u001b[m\r\n       tination (name of new link) should not already exist.  When creating hard\u001b[m\r\n       links, each TARGET must exist.  Symbolic links can hold  arbitrary  text;\u001b[m\r\n       if later resolved, a relative link is interpreted in relation to its par‐\u001b[m\r\n       ent directory.\u001b[m\r\n\u001b[m\r\n       Mandatory arguments to long options are mandator"]
[157.222834, "o", "y for short op"]
[157.222883, "o", "tions too.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--backup\u001b[0m[=\u001b[4mCONTROL\u001b[24m]\u001b[m\r\n              make a backup of each existing destination file\u001b[m\r\n\u001b[m\r\n       \u001b[1m-b\u001b[0m     like \u001b[1m--backup\u001b[0m but does not accept an argument\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d\u001b[0m, \u001b[1m-F\u001b[0m, \u001b[1m--directory\u001b[0m\u001b[m\r\n\u001b[7m Manual page ln(1) line 16/112 31% (press h for help or q to quit)\u001b[27m\u001b[K"]
[164.292597, "o", "\r\u001b[K/\r\u001b[K"]
[164.293069, "o", "...skipping...\r\n              with \u001b[1m\u001b[7m-s\u001b[27m\u001b[0m, create links relative to link location\u001b[m\r\n\u001b[m\r\n       \u001b[1m\u001b[7m-s\u001b[27m\u001b[0m, \u001b[1m-\u001b[0m\u001b[1m\u001b[7m-s\u001b[27m\u001b[0m\u001b[1mymbolic\u001b[0m\u001b[m\r\n              make symbolic links instead of hard links\u001b[m\r\n\u001b[m\r\n       \u001b[1m\u001b[7m-S\u001b[27m\u001b[0m, \u001b[1m-\u001b[0m\u001b[1m\u001b[7m-s\u001b[27m\u001b[0m\u001b[1muffix\u001b[0m=\u001b[4mSUFFIX\u001b[24m\u001b[m\r\n              override the usual backup suffix\u001b[m\r\n\u001b[m\r\n       \u001b[1m-t\u001b[0m, \u001b[1m--target-directory\u001b[0m=\u001b[4mDIRECTORY\u001b[24m\u001b[m\r\n              specify the DIRECTORY in which to create the links\u001b[m\r\n\u001b[m\r\n       \u001b[1m-T\u001b[0m, \u001b[1m--no-target-directory\u001b[0m\u001b[m\r\n              treat LINK_NAME as a normal file always\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ln(1) line 51/112 60% (press h for help or q to quit)\u001b[27m\u001b[K"]
