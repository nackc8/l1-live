[4084.846375, "o", "\u001b[4mMKE2FS\u001b[24m(8)            System Manager's Manual           \u001b[4mMKE2FS\u001b[24m(8)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       mke2fs - create an ext2/ext3/ext4 file system\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mmke2fs  \u001b[22m[ \u001b[1m-c \u001b[22m| \u001b[1m-l \u001b[4m\u001b[22mfilename\u001b[24m ] [ \u001b[1m-b \u001b[4m\u001b[22mblock-size\u001b[24m ] [ \u001b[1m-C \u001b[4m\u001b[22mclus‐\u001b[0m\u001b[m\r\n       \u001b[4mter-size\u001b[24m ] [ \u001b[1m-d \u001b[4m\u001b[22mroot-directory\u001b[24m ] [ \u001b[1m-D \u001b[22m] [ \u001b[1m-g  \u001b[4m\u001b[22mblocks-per-\u001b[0m\u001b[m\r\n       \u001b[4mgroup\u001b[24m  ] [ \u001b[1m-G \u001b[4m\u001b[22mnumber-of-groups\u001b[24m ] [ \u001b[1m-i \u001b[4m\u001b[22mbytes-per-inode\u001b[24m ] [\u001b[m\r\n       \u001b[1m-I \u001b[4m\u001b[22minode-size\u001b[24m ] [ \u001b[1m-j \u001b[22m] [ \u001b[1m-J \u001b[4m\u001b[22mjournal-options\u001b[24m ] [  \u001b[1m-N  \u001b[4m\u001b[22mnum‐\u001b[0m\u001b[m\r\n       \u001b[4mber-of-inodes\u001b[24m  ] [ \u001b[1m-n \u001b[22m] [ \u001b[1m-m \u001b[4m\u001b[22mreserved-blocks-percentage\u001b[24m ]\u001b[m\r\n       [ \u001b[1m-o \u001b[4m\u001b[22mcreator-os\u001b[24m ] [ \u001b[1m-O \u001b[22m[^]\u001b[4mfeature\u001b[24m[,...]  ] [ \u001b[1m-q  \u001b[22m]  [  \u001b[1m-r\u001b[0m\u001b[m\r\n       \u001b[4mfs-revision-level\u001b[24m ] [ \u001b[1m-E \u001b[4m\u001b[22mextended-options\u001b[24m ] [ \u001b[1m-v \u001b[22m] [ \u001b[1m-F \u001b[22m]\u001b[m\r\n       [  \u001b[1m-L \u001b[4m\u001b[22mvolume-label\u001b[24m ] [ \u001b[1m-M \u001b[4m\u001b[22mlast-mounted-directory\u001b[24m ] [ \u001b[1m-S \u001b[22m]\u001b[m\r\n\u001b[7m Manual page mkfs.ext4(8) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4086.799988, "o", "\r\u001b[K       [ \u001b[1m-t \u001b[4m\u001b[22mfs-type\u001b[24m ] [ \u001b[1m-T \u001b[4m\u001b[22musage-type\u001b[24m ] [ \u001b[1m-U \u001b[4m\u001b[22mUUID\u001b[24m ] [ \u001b[1m-V \u001b[22m] [  \u001b[1m-e\u001b[0m\u001b[m\r\n       \u001b[4merrors-behavior\u001b[24m ] [ \u001b[1m-z \u001b[4m\u001b[22mundo_file\u001b[24m ] \u001b[4mdevice\u001b[24m [ \u001b[4mfs-size\u001b[24m ]\u001b[m\r\n\u001b[m\r\n       \u001b[1mmke2fs -O journal_dev \u001b[22m[ \u001b[1m-b \u001b[4m\u001b[22mblock-size\u001b[24m ] [ \u001b[1m-L \u001b[4m\u001b[22mvolume-label\u001b[0m\u001b[m\r\n       ] [ \u001b[1m-n \u001b[22m] [ \u001b[1m-q \u001b[22m] [ \u001b[1m-v \u001b[22m] \u001b[4mexternal-journal\u001b[24m [ \u001b[4mfs-size\u001b[24m ]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       \u001b[1mmke2fs \u001b[22mis used to create an ext2, ext3, or ext4 file sys‐\u001b[m\r\n       tem,  usually  in a disk partition (or file) named by \u001b[4mde‐\u001b[0m\u001b[m\r\n       \u001b[4mvice\u001b[24m.\u001b[m\r\n\u001b[m\r\n       The file system size is specified by \u001b[4mfs-size\u001b[24m.  If \u001b[4mfs-size\u001b[0m\u001b[m\r\n       does not have a suffix, it is interpreted as power-of-two\u001b[m\r\n       kilobytes, unless the \u001b[1m-b \u001b[4m\u001b[22mblocksize\u001b[24m option  is  specified,\u001b[m\r\n\u001b[7mManual page mkfs.ext4(8) line 15 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4087.221458, "o", "\r\u001b[K       in  which  case  \u001b[4mfs-size\u001b[24m  is interpreted as the number of\u001b[m\r\n       \u001b[4mblocksize\u001b[24m blocks.   If the fs-size is  suffixed  by  'k',\u001b[m\r\n       'm',  'g', 't' (either upper-case or lower-case), then it\u001b[m\r\n       is interpreted in power-of-two kilobytes, megabytes,  gi‐\u001b[m\r\n       gabytes,  terabytes,  etc.  If \u001b[4mfs-size\u001b[24m is omitted, \u001b[1mmke2fs\u001b[0m\u001b[m\r\n       will create the file system based on the device size.\u001b[m\r\n\u001b[m\r\n       If \u001b[1mmke2fs \u001b[22mis run as \u001b[1mmkfs.XXX \u001b[22m(i.e., \u001b[1mmkfs.ext2\u001b[22m, \u001b[1mmkfs.ext3\u001b[22m,\u001b[m\r\n       or \u001b[1mmkfs.ext4\u001b[22m) the option \u001b[1m-t \u001b[4m\u001b[22mXXX\u001b[24m is implied; so  \u001b[1mmkfs.ext3\u001b[0m\u001b[m\r\n       will  create  a  file system for use with ext3, \u001b[1mmkfs.ext4\u001b[0m\u001b[m\r\n       will create a file system for use with ext4, and so on.\u001b[m\r\n\u001b[m\r\n       The defaults of the parameters for the newly created file\u001b[m\r\n       system, if not overridden by the  options  listed  below,\u001b[m\r\n\u001b[7mManual page mkfs.ext4(8) line 29 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4089.583801, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       kilobytes, unless the \u001b[1m-b \u001b[4m\u001b[22mblocksize\u001b[24m option  is  specified,\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page mkfs.ext4(8) line 28 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4090.104712, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       does not have a suffix, it is interpreted as power-of-two\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page mkfs.ext4(8) line 27 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4090.124194, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       The file system size is specified by \u001b[4mfs-size\u001b[24m.  If \u001b[4mfs-size\u001b[0m\u001b[m\r\n\u001b[15;1H\r\u001b[K\u001b[7mManual page mkfs.ext4(8) line 26 (press h for help or q to quit)\u001b[27m\u001b[K"]
