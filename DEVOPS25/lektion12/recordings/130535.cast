[1662.502962, "o", "\r\n\u001b[?2004l\r"]
[1662.508491, "o", "\u001b[?2004h\u001b[?1049h\u001b[22;0;0t\u001b[1;15r\u001b(B\u001b[m\u001b[4l\u001b[?7h\u001b[39;49m\u001b[?1h\u001b=\u001b[?1h\u001b=\u001b[?25l\u001b[39;49m\u001b(B\u001b[m\u001b[H\u001b[2J\u001b[13;36H\u001b(B\u001b[0;7m[ Reading... ]\u001b(B\u001b[m\u001b[13;35H\u001b(B\u001b[0;7m[ Read 2 lines ]\u001b(B\u001b[m\u001b[H\u001b(B\u001b[0;7m  GNU nano 7.2                        /etc/crypttab                                  \u001b[1;84H\u001b(B\u001b[m\r\u001b[14d\u001b(B\u001b[0;7m^G\u001b(B\u001b[m Help\u001b[15G\u001b(B\u001b[0;7m^O\u001b(B\u001b[m Write Out  \u001b(B\u001b[0;7m^W\u001b(B\u001b[m Where Is   \u001b(B\u001b[0;7m^K\u001b(B\u001b[m Cut\u001b[14;57H\u001b(B\u001b[0;7m^T\u001b(B\u001b[m Execute    \u001b(B\u001b[0;7m^C\u001b(B\u001b[m Location\r\u001b[15d\u001b(B\u001b[0;7m^X\u001b(B\u001b[m Exit\u001b[15G\u001b(B\u001b[0;7m^R\u001b(B\u001b[m Read File  \u001b(B\u001b[0;7m^\\\u001b(B\u001b[m Replace    \u001b(B\u001b[0;7m^U\u001b(B\u001b[m Paste\u001b[57G\u001b(B\u001b[0;7m^J\u001b(B\u001b[m Justify    \u001b(B\u001b[0;7m^/\u001b(B\u001b[m Go To Line"]
[1662.508945, "o", "\r\u001b[2d\u001b[36m# <target name>\u001b[38;5;208m \u001b[36m<source device>\u001b[38;5;208m         \u001b[36m<key file>\u001b[38;5;208m      \u001b[36m<options>\r\u001b[3d\u001b[39m\u001b(B\u001b[mhemligt\u001b[3;17H/dev/vdb2\r\u001b[A\u001b[?12l\u001b[?25h"]
