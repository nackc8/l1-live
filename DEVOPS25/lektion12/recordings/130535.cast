[1592.281298, "o", "\u001b(B\u001b[0;7mSave modified buffer?                                                                \u001b[14;1H Y\u001b(B\u001b[m Yes\u001b[K\r\u001b[15d\u001b(B\u001b[0;7m N\u001b(B\u001b[m No  \u001b[15G  \u001b(B\u001b[0;7m^C\u001b(B\u001b[m Cancel\u001b[K\u001b[13;23H\u001b[?12l\u001b[?25h"]
[1592.530708, "o", "\u001b[?25l\r\u001b[14d\u001b(B\u001b[0;7m^G\u001b(B\u001b[m Help\u001b[14;22H\u001b(B\u001b[0;7mM-D\u001b(B\u001b[m DOS Format\u001b[43G\u001b(B\u001b[0;7mM-A\u001b(B\u001b[m Append\u001b[14;64H\u001b(B\u001b[0;7mM-B\u001b(B\u001b[m Backup File\r\u001b[15d\u001b(B\u001b[0;7m^C\u001b(B\u001b[m Cancel\u001b[17G     \u001b(B\u001b[0;7mM-M\u001b(B\u001b[m Mac Format\u001b[43G\u001b(B\u001b[0;7mM-P\u001b(B\u001b[m Prepend\u001b[15;64H\u001b(B\u001b[0;7m^T\u001b(B\u001b[m Browse\r\u001b[13d\u001b(B\u001b[0;7mFile Name to Write: /etc/crypttab\u001b(B\u001b[m\u001b[?12l\u001b[?25h"]
