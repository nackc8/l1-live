[1783.818278, "o", "CP(1)                     User Commands                    CP(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       cp - copy files and directories\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mcp\u001b[0m [\u001b[4mOPTION\u001b[24m]... [\u001b[4m-T\u001b[24m] \u001b[4mSOURCE\u001b[24m \u001b[4mDEST\u001b[24m\u001b[m\r\n       \u001b[1mcp\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4mSOURCE\u001b[24m... \u001b[4mDIRECTORY\u001b[24m\u001b[m\r\n       \u001b[1mcp\u001b[0m [\u001b[4mOPTION\u001b[24m]... \u001b[4m-t\u001b[24m \u001b[4mDIRECTORY\u001b[24m \u001b[4mSOURCE\u001b[24m...\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       Copy SOURCE to DEST, or multiple SOURCE(s) to DIRECTORY.\u001b[m\r\n\u001b[m\r\n       Mandatory  arguments  to  long  options are mandatory for\u001b[m\r\n       short options too.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-a\u001b[0m, \u001b[1m--archive\u001b[0m\u001b[m\r\n\u001b[7m Manual page cp(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
