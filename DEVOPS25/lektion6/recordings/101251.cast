[3624.305472, "o", "              Begin saving the characters typed into the current\u001b[m\r\n              keyboard macro.\u001b[m\r\n       \u001b[1mend-kbd-macro\u001b[0m \u001b[1m(C-x\u001b[0m \u001b[1m))\u001b[0m\u001b[m\r\n              Stop  saving the characters typed into the current\u001b[m\r\n              keyboard macro and store the definition.\u001b[m\r\n       \u001b[1mcall-last-kbd-macro\u001b[0m \u001b[1m(C-x\u001b[0m \u001b[1me)\u001b[0m\u001b[m\r\n              Re-execute the last  keyboard  macro  defined,  by\u001b[m\r\n              making  the  characters  in the macro appear as if\u001b[m\r\n              typed at the keyboard.\u001b[m\r\n       \u001b[1mprint-last-kbd-macro\u001b[0m \u001b[1m()\u001b[0m\u001b[m\r\n              Print the last keyboard macro defined in a  format\u001b[m\r\n              suitable for the \u001b[4minputrc\u001b[24m file.\u001b[m\r\n\u001b[m\r\n   \u001b[1mMiscellaneous\u001b[0m\u001b[m\r\n       \u001b[1mre-read-init-file\u001b[0m \u001b[1m(C-x\u001b[0m \u001b[1mC-r)\u001b[0m\u001b[m\r\n              Read  in the contents of the \u001b[4minputrc\u001b[24m file, and in‐\u001b[m\r\n              corporate any  bindings  or  variable  assignments\u001b[m\r\n              found there.\u001b[m\r\n       \u001b[1mabort\u001b[0m \u001b[1m(C-g)\u001b[0m\u001b[m\r\n"]
[3624.305489, "o", "              Abor"]
[3624.305509, "o", "t  the  current  editing  command and ring the\u001b[m\r\n              terminal's  bell  (subject  to  the   setting   of\u001b[m\r\n              \u001b[1mbell-style\u001b[0m).\u001b[m\r\n       \u001b[1mdo-lowercase-version\u001b[0m \u001b[1m(M-A,\u001b[0m \u001b[1mM-B,\u001b[0m \u001b[1mM-\u001b[0m\u001b[4mx\u001b[24m\u001b[1m,\u001b[0m \u001b[1m...)\u001b[0m\u001b[m\r\n              If  the metafied character \u001b[4mx\u001b[24m is uppercase, run the\u001b[m\r\n              command  that  is  bound  to   the   corresponding\u001b[m\r\n              metafied lowercase character.  The behavior is un‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 4811 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.336402, "o", "\r\u001b[K"]
[3624.336504, "o", "              defined if \u001b[4mx\u001b[24m is already lowercase.\u001b[m\r\n       \u001b[1mprefix-meta\u001b[0m \u001b[1m(ESC)\u001b[0m\u001b[m\r\n              Metafy the next character typed.  \u001b[1mESC\u001b[0m \u001b[1mf\u001b[0m is equiva‐\u001b[m\r\n              lent to \u001b[1mMeta-f\u001b[0m.\u001b[m\r\n       \u001b[1mundo\u001b[0m \u001b[1m(C-_,\u001b[0m \u001b[1mC-x\u001b[0m \u001b[1mC-u)\u001b[0m\u001b[m\r\n              Incremental  undo,  separately remembered for each\u001b[m\r\n              line.\u001b[m\r\n       \u001b[1mrevert-line\u001b[0m \u001b[1m(M-r)\u001b[0m\u001b[m\r\n              Undo all changes made to this line.  This is  like\u001b[m\r\n              executing  the \u001b[1mundo\u001b[0m command enough times to return\u001b[m\r\n              the line to its initial state.\u001b[m\r\n       \u001b[1mtilde-expand\u001b[0m \u001b[1m(M-&)\u001b[0m\u001b[m\r\n              Perform tilde expansion on the current word.\u001b[m\r\n       \u001b[1mset-mark\u001b[0m \u001b[1m(C-@,\u001b[0m \u001b[1mM-<space>)\u001b[0m\u001b[m\r\n              Set the mark to the point.  If a numeric  argument\u001b[m\r\n              is supplied, the mark is set to that position.\u001b[m\r\n       \u001b[1mexchange-point-and-mark\u001b[0m \u001b[1m(C-x\u001b[0m \u001b[1mC-x)\u001b[0m\u001b[m\r\n              Swap "]
[3624.336527, "o", " the point with "]
[3624.336553, "o", "the mark.  The current cursor\u001b[m\r\n              position is set to the saved position, and the old\u001b[m\r\n              cursor position is saved as the mark.\u001b[m\r\n       \u001b[1mcharacter-search\u001b[0m \u001b[1m(C-])\u001b[0m\u001b[m\r\n              A character is read and point is moved to the next\u001b[m\r\n              occurrence of that character.  A negative argument\u001b[m\r\n              searches for previous occurrences.\u001b[m\r\n       \u001b[1mcharacter-search-backward\u001b[0m \u001b[1m(M-C-])\u001b[0m\u001b[m\r\n              A character is read and point is moved to the pre‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 4837 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.368464, "o", "\r\u001b[K"]
[3624.368579, "o", "              vious occurrence of that  character.   A  negative\u001b[m\r\n              argument searches for subsequent occurrences.\u001b[m\r\n       \u001b[1mskip-csi-sequence\u001b[0m\u001b[m\r\n              Read  enough characters to consume a multi-key se‐\u001b[m\r\n              quence such as those defined for  keys  like  Home\u001b[m\r\n              and  End.  Such sequences begin with a Control Se‐\u001b[m\r\n              quence Indicator (CSI), usually  ESC-[.   If  this\u001b[m\r\n              sequence is bound to \"\\[\", keys producing such se‐\u001b[m\r\n              quences will  have  no  effect  unless  explicitly\u001b[m\r\n              bound  to a readline command, instead of inserting\u001b[m\r\n              stray characters into the editing buffer.  This is\u001b[m\r\n              unbound by default, but usually bound to ESC-[.\u001b[m\r\n       \u001b[1minsert-comment\u001b[0m \u001b[1m(M-#)\u001b[0m\u001b[m\r\n              Without a numeric argument, the value of the read‐\u001b[m\r\n              line \u001b[1mcomment-begin\u001b[0m variable is inserted at the be‐\u001b[m\r\n              ginning  of  the c"]
[3624.368598, "o", "urrent line.  If a numeric argu‐\u001b[m\r\n              ment is supplied, this command acts as  a  toggle:\u001b[m\r\n              if  the characters at the beginning of the line do\u001b[m\r\n              not match the value of \u001b[1mcomment-begin\u001b[0m, the value is\u001b[m\r\n              inserted,  otherwise the characters in \u001b[1mcomment-be‐\u001b[0m\u001b[m\r\n              \u001b[1mgin\u001b[0m are deleted from the beginning  of  the  line.\u001b[m\r\n              In  either case, the line is accepted as if a new‐\u001b[m\r\n              line had been typed.  The default  value  of  \u001b[1mcom‐\u001b[0m\u001b[m\r\n              \u001b[1mment-begin\u001b[0m causes this command to make the current\u001b[m\r\n              line a  shell  comment.   If  a  numeric  argument\u001b[m\r\n              causes  the  comment  character to be removed, the\u001b[m\r\n\u001b[7m Manual page bash(1) line 4863 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.399875, "o", "\r\u001b[K"]
[3624.399908, "o", "              line will be executed by the shell.\u001b[m\r\n       \u001b[1mspell-correct-word\u001b[0m \u001b[1m(C-x\u001b[0m \u001b[1ms)\u001b[0m\u001b[m\r\n              Perform spelling correction on the  current  word,\u001b[m\r\n              treating  it  as  a  directory or filename, in the\u001b[m\r\n              same way as the \u001b[1mcdspell\u001b[0m shell option.  Word bound‐\u001b[m\r\n              aries  are  the  same  as those used by \u001b[1mshell-for‐\u001b[0m\u001b[m\r\n              \u001b[1mward-word\u001b[0m.\u001b[m\r\n       \u001b[1mglob-complete-word\u001b[0m \u001b[1m(M-g)\u001b[0m\u001b[m\r\n              The word before point is treated as a pattern  for\u001b[m\r\n              pathname  expansion,  with  an asterisk implicitly\u001b[m\r\n              appended.  This pattern is used to generate a list\u001b[m\r\n              of matching filenames for possible completions.\u001b[m\r\n       \u001b[1mglob-expand-word\u001b[0m \u001b[1m(C-x\u001b[0m \u001b[1m*)\u001b[0m\u001b[m\r\n              The  word before point is treated as a pattern for\u001b[m\r\n              pathname expansion, and the list of matching file‐\u001b[m\r\n              names  is  inserted, replacing the w"]
[3624.400028, "o", "ord.  If a nu"]
[3624.400058, "o", "‐\u001b[m\r\n              meric argument is supplied,  an  asterisk  is  ap‐\u001b[m\r\n              pended before pathname expansion.\u001b[m\r\n       \u001b[1mglob-list-expansions\u001b[0m \u001b[1m(C-x\u001b[0m \u001b[1mg)\u001b[0m\u001b[m\r\n              The list of expansions that would have been gener‐\u001b[m\r\n              ated by \u001b[1mglob-expand-word\u001b[0m  is  displayed,  and  the\u001b[m\r\n              line  is  redrawn.   If a numeric argument is sup‐\u001b[m\r\n              plied, an asterisk is appended before pathname ex‐\u001b[m\r\n              pansion.\u001b[m\r\n       \u001b[1mdump-functions\u001b[0m\u001b[m\r\n              Print  all of the functions and their key bindings\u001b[m\r\n\u001b[7m Manual page bash(1) line 4889 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.430846, "o", "\r\u001b[K"]
[3624.430984, "o", "              to the readline output stream.  If a numeric argu‐\u001b[m\r\n              ment  is supplied, the output is formatted in such\u001b[m\r\n              a way that it can be made part of an \u001b[4minputrc\u001b[24m file.\u001b[m\r\n       \u001b[1mdump-variables\u001b[0m\u001b[m\r\n              Print all of the settable readline  variables  and\u001b[m\r\n              their  values to the readline output stream.  If a\u001b[m\r\n              numeric argument is supplied, the output  is  for‐\u001b[m\r\n              matted  in  such a way that it can be made part of\u001b[m\r\n              an \u001b[4minputrc\u001b[24m file.\u001b[m\r\n       \u001b[1mdump-macros\u001b[0m\u001b[m\r\n              Print all of the readline key sequences  bound  to\u001b[m\r\n              macros  and the strings they output.  If a numeric\u001b[m\r\n              argument is supplied, the output is  formatted  in\u001b[m\r\n              such  a way that it can be made part of an \u001b[4minputrc\u001b[24m\u001b[m\r\n              file.\u001b[m\r\n       \u001b[1mdisplay-shell-version\u001b[0m \u001b[1m(C-x\u001b[0m \u001b[1mC-v)\u001b[0m\u001b[m\r\n              Display version information a"]
[3624.431077, "o", "bout the current  in‐\u001b[m\r\n              stance of \u001b[1mbash\u001b[0m.\u001b[m\r\n\u001b[m\r\n   \u001b[1mProgrammable\u001b[0m \u001b[1mCompletion\u001b[0m\u001b[m\r\n       When  word  completion  is attempted for an argument to a\u001b[m\r\n       command for which a completion specification (a \u001b[4mcompspec\u001b[24m)\u001b[m\r\n       has  been  defined  using the \u001b[1mcomplete\u001b[0m builtin (see \u001b[1mSHELL\u001b[0m\u001b[m\r\n       \u001b[1mBUILTIN\u001b[0m \u001b[1mCOMMANDS\u001b[0m below), the programmable completion  fa‐\u001b[m\r\n       cilities are invoked.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page bash(1) line 4915 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.462317, "o", "\r\u001b[K"]
[3624.462349, "o", "       First,  the  command  name is identified.  If the command\u001b[m\r\n       word is the empty string (completion attempted at the be‐\u001b[m\r\n       ginning  of an empty line), any compspec defined with the\u001b[m\r\n       \u001b[1m-E\u001b[0m option to \u001b[1mcomplete\u001b[0m is used.  If a  compspec  has  been\u001b[m\r\n       defined  for that command, the compspec is used to gener‐\u001b[m\r\n       ate the list of possible completions for  the  word.   If\u001b[m\r\n       the  command  word is a full pathname, a compspec for the\u001b[m\r\n       full pathname is searched for first.  If no  compspec  is\u001b[m\r\n       found for the full pathname, an attempt is made to find a\u001b[m\r\n       compspec for the portion following the final  slash.   If\u001b[m\r\n       those  searches do not result in a compspec, any compspec\u001b[m\r\n       defined with the \u001b[1m-D\u001b[0m option to \u001b[1mcomplete\u001b[0m is used as the de‐\u001b[m\r\n       fault.   If  there  is no default compspec, \u001b[1mbash\u001b[0m attempts\u001b[m\r\n       alias expansion on the command word as  a  final  resort,\u001b[m\r\n       and a"]
[3624.462358, "o", "ttempts to fi"]
[3624.462394, "o", "nd a compspec for the command word from\u001b[m\r\n       any successful expansion.\u001b[m\r\n\u001b[m\r\n       Once a compspec has been found, it is  used  to  generate\u001b[m\r\n       the  list of matching words.  If a compspec is not found,\u001b[m\r\n       the default \u001b[1mbash\u001b[0m completion as described above under \u001b[1mCom‐\u001b[0m\u001b[m\r\n       \u001b[1mpleting\u001b[0m is performed.\u001b[m\r\n\u001b[m\r\n       First,  the  actions  specified by the compspec are used.\u001b[m\r\n       Only matches which are prefixed by the  word  being  com‐\u001b[m\r\n       pleted  are  returned.   When the \u001b[1m-f\u001b[0m or \u001b[1m-d\u001b[0m option is used\u001b[m\r\n       for filename or  directory  name  completion,  the  shell\u001b[m\r\n\u001b[7m Manual page bash(1) line 4941 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.494136, "o", "\r\u001b[K"]
[3624.494171, "o", "       variable \u001b[1mFIGNORE\u001b[0m is used to filter the matches.\u001b[m\r\n\u001b[m\r\n       Any completions specified by a pathname expansion pattern\u001b[m\r\n       to the \u001b[1m-G\u001b[0m option are generated next.  The words generated\u001b[m\r\n       by  the  pattern need not match the word being completed.\u001b[m\r\n       The \u001b[1mGLOBIGNORE\u001b[0m shell variable is not used to  filter  the\u001b[m\r\n       matches, but the \u001b[1mFIGNORE\u001b[0m variable is used.\u001b[m\r\n\u001b[m\r\n       Next,  the string specified as the argument to the \u001b[1m-W\u001b[0m op‐\u001b[m\r\n       tion is considered.  The string is first split using  the\u001b[m\r\n       characters  in  the  \u001b[1mIFS\u001b[0m  special variable as delimiters.\u001b[m\r\n       Shell quoting is honored.  Each word is then expanded us‐\u001b[m\r\n       ing brace expansion, tilde expansion, parameter and vari‐\u001b[m\r\n       able expansion, command substitution, and arithmetic  ex‐\u001b[m\r\n       pansion, as described above under \u001b[1mEXPANSION\u001b[0m.  The results\u001b[m\r\n       are split using the  rules  described  above  under  \u001b[1mWord\u001b[0m\u001b[m\r\n "]
[3624.494181, "o", "      \u001b[1mSplitting\u001b[0m.   The  results  of  the  expansion are prefix-\u001b[m\r\n       matched against the word being completed, and the  match‐\u001b[m\r\n       ing words become the possible completions.\u001b[m\r\n\u001b[m\r\n       After  these matches have been generated, any shell func‐\u001b[m\r\n       tion or command specified with the \u001b[1m-F\u001b[0m and \u001b[1m-C\u001b[0m  options  is\u001b[m\r\n       invoked.   When  the  command or function is invoked, the\u001b[m\r\n       \u001b[1mCOMP_LINE\u001b[0m, \u001b[1mCOMP_POINT\u001b[0m, \u001b[1mCOMP_KEY\u001b[0m, and \u001b[1mCOMP_TYPE\u001b[0m  variables\u001b[m\r\n"]
[3624.494331, "o", "       are  assigned values as described above under \u001b[1mShell\u001b[0m \u001b[1mVari‐\u001b[0m\u001b[m\r\n       \u001b[1mables\u001b[0m.   If  a  shell  function  is  being  invoked,  the\u001b[m\r\n\u001b[7m Manual page bash(1) line 4967 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.525433, "o", "\r\u001b[K"]
[3624.525558, "o", "       \u001b[1mCOMP_WORDS\u001b[0m  and  \u001b[1mCOMP_CWORD\u001b[0m variables are also set.  When\u001b[m\r\n       the function or command is invoked,  the  first  argument\u001b[m\r\n       (\u001b[1m$1\u001b[0m) is the name of the command whose arguments are being\u001b[m\r\n       completed, the second argument (\u001b[1m$2\u001b[0m)  is  the  word  being\u001b[m\r\n       completed,  and  the third argument (\u001b[1m$3\u001b[0m) is the word pre‐\u001b[m\r\n       ceding the word being completed on  the  current  command\u001b[m\r\n       line.   No filtering of the generated completions against\u001b[m\r\n       the word being completed is performed;  the  function  or\u001b[m\r\n       command has complete freedom in generating the matches.\u001b[m\r\n\u001b[m\r\n       Any  function  specified  with  \u001b[1m-F\u001b[0m is invoked first.  The\u001b[m\r\n       function may use any of the shell  facilities,  including\u001b[m\r\n       the  \u001b[1mcompgen\u001b[0m  builtin  described  below,  to generate the\u001b[m\r\n       matches.  It must put the  possible  completions  in  the\u001b[m\r\n       \u001b[1mCOMPREPLY\u001b[0m array variable, one per array element.\u001b[m"]
[3624.525592, "o", "\r\n\u001b[m\r\n       Next, any command specified with the \u001b[1m-C\u001b[0m option is invoked\u001b[m\r\n       in an environment equivalent to command substitution.  It\u001b[m\r\n       should  print a list of completions, one per line, to the\u001b[m\r\n       standard output.  Backslash may be used to escape a  new‐\u001b[m\r\n       line, if necessary.\u001b[m\r\n\u001b[m\r\n       After  all of the possible completions are generated, any\u001b[m\r\n       filter specified with the \u001b[1m-X\u001b[0m option  is  applied  to  the\u001b[m\r\n       list.   The  filter is a pattern as used for pathname ex‐\u001b[m\r\n       pansion; a \u001b[1m&\u001b[0m in the pattern is replaced with the text  of\u001b[m\r\n\u001b[7m Manual page bash(1) line 4993 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.556967, "o", "\r\u001b[K"]
[3624.557109, "o", "       the  word  being  completed.   A literal \u001b[1m&\u001b[0m may be escaped\u001b[m\r\n       with a backslash; the backslash  is  removed  before  at‐\u001b[m\r\n       tempting  a  match.  Any completion that matches the pat‐\u001b[m\r\n       tern will be removed from the list.  A leading \u001b[1m!\u001b[0m  negates\u001b[m\r\n       the pattern; in this case any completion not matching the\u001b[m\r\n       pattern will be removed.  If the \u001b[1mnocasematch\u001b[0m shell option\u001b[m\r\n       is  enabled, the match is performed without regard to the\u001b[m\r\n       case of alphabetic characters.\u001b[m\r\n\u001b[m\r\n       Finally, any prefix and suffix specified with the \u001b[1m-P\u001b[0m  and\u001b[m\r\n       \u001b[1m-S\u001b[0m  options  are  added  to each member of the completion\u001b[m\r\n       list, and the result is returned to the readline  comple‐\u001b[m\r\n       tion code as the list of possible completions.\u001b[m\r\n\u001b[m\r\n       If  the  previously-applied  actions  do not generate any\u001b[m\r\n       matches, and the \u001b[1m-o\u001b[0m \u001b[1mdirnames\u001b[0m option was supplied to  \u001b[1mcom‐\u001b[0m\u001b[m\r\n       \u001b[1mple"]
[3624.557145, "o", "te\u001b[0m  when the compspec was defined, directory name com‐\u001b[m\r\n       pletion is attempted.\u001b[m\r\n\u001b[m\r\n       If the \u001b[1m-o\u001b[0m \u001b[1mplusdirs\u001b[0m option was supplied to  \u001b[1mcomplete\u001b[0m  when\u001b[m\r\n       the  compspec  was  defined, directory name completion is\u001b[m\r\n       attempted and any matches are added to the results of the\u001b[m\r\n       other actions.\u001b[m\r\n\u001b[m\r\n       By default, if a compspec is found, whatever it generates\u001b[m\r\n       is returned to the completion code as  the  full  set  of\u001b[m\r\n\u001b[7m Manual page bash(1) line 5019 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.588227, "o", "\r\u001b[K"]
[3624.588374, "o", "       possible  completions.   The default \u001b[1mbash\u001b[0m completions are\u001b[m\r\n       not attempted, and the readline default of filename  com‐\u001b[m\r\n       pletion  is  disabled.   If the \u001b[1m-o\u001b[0m \u001b[1mbashdefault\u001b[0m option was\u001b[m\r\n       supplied to \u001b[1mcomplete\u001b[0m when the compspec was  defined,  the\u001b[m\r\n       \u001b[1mbash\u001b[0m  default  completions  are attempted if the compspec\u001b[m\r\n       generates no matches.  If the \u001b[1m-o\u001b[0m \u001b[1mdefault\u001b[0m option was  sup‐\u001b[m\r\n       plied  to  \u001b[1mcomplete\u001b[0m  when the compspec was defined, read‐\u001b[m\r\n       line's default completion will be performed if the  comp‐\u001b[m\r\n       spec  (and,  if  attempted, the default \u001b[1mbash\u001b[0m completions)\u001b[m\r\n       generate no matches.\u001b[m\r\n\u001b[m\r\n       When a compspec indicates that directory name  completion\u001b[m\r\n       is  desired,  the programmable completion functions force\u001b[m\r\n       readline to append a slash to completed names  which  are\u001b[m\r\n       symbolic  links  to  directories, subject to the value of\u001b[m\r\n       the"]
[3624.588388, "o", " \u001b[1mmark-directories\u001b[0m readline variable, regardless of the\u001b[m\r\n       setting  of the \u001b[1mmark-symlinked-directories\u001b[0m readline vari‐\u001b[m\r\n       able.\u001b[m\r\n\u001b[m\r\n       There is some support for dynamically  modifying  comple‐\u001b[m\r\n       tions.  This is most useful when used in combination with\u001b[m\r\n       a default completion specified with  \u001b[1mcomplete\u001b[0m  \u001b[1m-D\u001b[0m.   It's\u001b[m\r\n       possible  for shell functions executed as completion han‐\u001b[m\r\n       dlers to indicate that completion should  be  retried  by\u001b[m\r\n       returning an exit status of 124.  If a shell function re‐\u001b[m\r\n       turns 124, and changes the compspec associated  with  the\u001b[m\r\n\u001b[7m Manual page bash(1) line 5045 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.619345, "o", "\r\u001b[K"]
[3624.619457, "o", "       command  on which completion is being attempted (supplied\u001b[m\r\n       as the first argument when  the  function  is  executed),\u001b[m\r\n       programmable completion restarts from the beginning, with\u001b[m\r\n       an attempt to find a new compspec for that command.  This\u001b[m\r\n       allows  a  set  of completions to be built dynamically as\u001b[m\r\n       completion is attempted, rather than being loaded all  at\u001b[m\r\n       once.\u001b[m\r\n\u001b[m\r\n       For  instance,  assuming that there is a library of comp‐\u001b[m\r\n       specs, each kept in a file corresponding to the  name  of\u001b[m\r\n       the  command,  the  following default completion function\u001b[m\r\n       would load completions dynamically:\u001b[m\r\n\u001b[m\r\n       _completion_loader()\u001b[m\r\n       {\u001b[m\r\n            . \"/etc/bash_completion.d/$1.sh\" >/dev/null 2>&1  &&\u001b[m\r\n       return 124\u001b[m\r\n       }\u001b[m\r\n       complete  -D  -F _completion_loader -o bashdefault -o de‐\u001b[m\r\n       fault\u001b[m\r\n\u001b[m\r\n\u001b[1mHISTORY\u001b[0m\u001b[m\r\n       When the \u001b[1m-o\u001b[0m \u001b[1mhistory\u001b[0m option to the \u001b[1mset\u001b"]
[3624.619485, "o", "[0m builtin is enabled,\u001b[m\r\n       the  shell  provides  access  to the \u001b[4mcommand\u001b[24m \u001b[4mhistory\u001b[24m, the\u001b[m\r\n       list of commands previously  typed.   The  value  of  the\u001b[m\r\n       \u001b[1mHISTSIZE\u001b[0m  variable  is  used as the number of commands to\u001b[m\r\n\u001b[7m Manual page bash(1) line 5071 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.650809, "o", "\r\u001b[K       save in a history list.  The text of  the  last  \u001b[1mHISTSIZE\u001b[0m\u001b[m\r\n       commands  (default  500) is saved.  The shell stores each\u001b[m\r\n       command in the history list prior to parameter and  vari‐\u001b[m\r\n       able  expansion  (see  \u001b[1mEXPANSION\u001b[0m above) but after history\u001b[m\r\n       expansion is performed, subject  to  the  values  of  the\u001b[m\r\n       shell variables \u001b[1mHISTIGNORE\u001b[0m and \u001b[1mHISTCONTROL\u001b[0m.\u001b[m\r\n\u001b[m\r\n       On  startup,  the  history  is  initialized from the file\u001b[m\r\n       named by the variable \u001b[1mHISTFILE\u001b[0m (default \u001b[4m~/.bash_history\u001b[24m).\u001b[m\r\n       The  file named by the value of \u001b[1mHISTFILE\u001b[0m is truncated, if\u001b[m\r\n       necessary, to contain no more than the  number  of  lines\u001b[m\r\n       specified  by the value of \u001b[1mHISTFILESIZE\u001b[0m.  If \u001b[1mHISTFILESIZE\u001b[0m\u001b[m\r\n       is unset, or set to null, a non-numeric value, or  a  nu‐\u001b[m\r\n       meric value less than zero, the history file is not trun‐\u001b[m\r\n       cated.  When the history file is  read,  lines"]
[3624.650915, "o", "  beginning\u001b[m\r\n       with  the  history comment character followed immediately\u001b[m\r\n       by a digit are interpreted as timestamps for the  follow‐\u001b[m\r\n       ing  history  line.  These timestamps are optionally dis‐\u001b[m\r\n       played depending on the value of the \u001b[1mHISTTIMEFORMAT\u001b[0m vari‐\u001b[m\r\n       able.   When a shell with history enabled exits, the last\u001b[m\r\n       \u001b[1m$HISTSIZE\u001b[0m lines are  copied  from  the  history  list  to\u001b[m\r\n       \u001b[1m$HISTFILE\u001b[0m.   If  the  \u001b[1mhistappend\u001b[0m  shell option is enabled\u001b[m\r\n       (see the description of \u001b[1mshopt\u001b[0m under  \u001b[1mSHELL\u001b[0m  \u001b[1mBUILTIN\u001b[0m  \u001b[1mCOM‐\u001b[0m\u001b[m\r\n       \u001b[1mMANDS\u001b[0m below), the lines are appended to the history file,\u001b[m\r\n       otherwise the history file is overwritten.   If  \u001b[1mHISTFILE\u001b[0m\u001b[m\r\n       is  unset, or if the history file is unwritable, the his‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 5097 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.681736, "o", "\r\u001b[K"]
[3624.68186, "o", "       tory is not saved.  If  the  \u001b[1mHISTTIMEFORMAT\u001b[0m  variable  is\u001b[m\r\n       set,  time stamps are written to the history file, marked\u001b[m\r\n       with the history comment character, so they may  be  pre‐\u001b[m\r\n       served across shell sessions.  This uses the history com‐\u001b[m\r\n       ment character to distinguish timestamps from other  his‐\u001b[m\r\n       tory  lines.   After saving the history, the history file\u001b[m\r\n       is truncated to contain no more than \u001b[1mHISTFILESIZE\u001b[0m  lines.\u001b[m\r\n       If  \u001b[1mHISTFILESIZE\u001b[0m  is unset, or set to null, a non-numeric\u001b[m\r\n       value, or a numeric value less  than  zero,  the  history\u001b[m\r\n       file is not truncated.\u001b[m\r\n\u001b[m\r\n       The builtin command \u001b[1mfc\u001b[0m (see \u001b[1mSHELL\u001b[0m \u001b[1mBUILTIN\u001b[0m \u001b[1mCOMMANDS\u001b[0m below)\u001b[m\r\n       may be used to list or edit and re-execute a  portion  of\u001b[m\r\n       the  history  list.   The  \u001b[1mhistory\u001b[0m builtin may be used to\u001b[m\r\n       display or modify the history  list  and  manipulate  the\u001b[m\r\n       history  fi"]
[3624.681922, "o", "le.   When  using command-line editing, search\u001b[m\r\n       commands are available in each editing mode that  provide\u001b[m\r\n       access to the history list.\u001b[m\r\n\u001b[m\r\n       The shell allows control over which commands are saved on\u001b[m\r\n       the history list.  The \u001b[1mHISTCONTROL\u001b[0m and  \u001b[1mHISTIGNORE\u001b[0m  vari‐\u001b[m\r\n       ables may be set to cause the shell to save only a subset\u001b[m\r\n       of the commands entered.  The \u001b[1mcmdhist\u001b[0m  shell  option,  if\u001b[m\r\n       enabled, causes the shell to attempt to save each line of\u001b[m\r\n       a multi-line command in the same  history  entry,  adding\u001b[m\r\n       semicolons where necessary to preserve syntactic correct‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 5123 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.713032, "o", "\r\u001b[K       ness.  The \u001b[1mlithist\u001b[0m shell option causes the shell to  save\u001b[m\r\n       the command with embedded newlines instead of semicolons.\u001b[m\r\n       See the description of  the  \u001b[1mshopt\u001b[0m  builtin  below  under\u001b[m\r\n       \u001b[1mSHELL\u001b[0m \u001b[1mBUILTIN\u001b[0m \u001b[1mCOMMANDS\u001b[0m for information on setting and un‐\u001b[m\r\n       setting shell options.\u001b[m\r\n\u001b[m\r\n\u001b[1mHISTORY\u001b[0m \u001b[1mEXPANSION\u001b[0m\u001b[m\r\n       The shell supports a history expansion  feature  that  is\u001b[m\r\n       similar  to  the  history expansion in \u001b[1mcsh\u001b[0m.  This section\u001b[m\r\n       describes what syntax features are available.  This  fea‐\u001b[m\r\n       ture  is  enabled  by default for interactive shells, and\u001b[m\r\n       can be disabled using the \u001b[1m+H\u001b[0m option to  the  \u001b[1mset\u001b[0m  builtin\u001b[m\r\n       command (see \u001b[1mSHELL\u001b[0m \u001b[1mBUILTIN\u001b[0m \u001b[1mCOMMANDS\u001b[0m below).  Non-interac‐\u001b[m\r\n       tive shells do not perform history expansion by default.\u001b[m\r\n\u001b[m\r\n       History expansions introduce words from the history  list\u001b[m\r\n       into the i"]
[3624.713064, "o", "nput stream, making"]
[3624.71315, "o", " it easy to repeat commands,\u001b[m\r\n       insert the arguments to a previous command into the  cur‐\u001b[m\r\n       rent  input  line,  or  fix  errors  in previous commands\u001b[m\r\n       quickly.\u001b[m\r\n\u001b[m\r\n       History expansion is performed immediately after  a  com‐\u001b[m\r\n       plete  line  is  read,  before  the  shell breaks it into\u001b[m\r\n       words, and is performed on each line individually without\u001b[m\r\n       taking  quoting on previous lines into account.  It takes\u001b[m\r\n       place in two parts.  The first is to determine which line\u001b[m\r\n\u001b[7m Manual page bash(1) line 5149 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.743912, "o", "\r\u001b[K       from  the  history  list to use during substitution.  The\u001b[m\r\n       second is to select portions of that line  for  inclusion\u001b[m\r\n       into the current one.  The line selected from the history\u001b[m\r\n       is the \u001b[4mevent\u001b[24m, and the portions  of  that  line  that  are\u001b[m\r\n       acted upon are \u001b[4mwords\u001b[24m.  Various \u001b[4mmodifiers\u001b[24m are available to\u001b[m\r\n       manipulate the selected words.  The line is  broken  into\u001b[m\r\n       words  in the same fashion as when reading input, so that\u001b[m\r\n       several  \u001b[4mmetacharacter\u001b[24m-separated  words   surrounded   by\u001b[m\r\n       quotes  are  considered one word.  History expansions are\u001b[m\r\n       introduced by the appearance  of  the  history  expansion\u001b[m\r\n       character, which is \u001b[1m!\u001b[0m by default.  Only backslash (\u001b[1m\\\u001b[0m) and\u001b[m\r\n       single quotes can quote the history expansion  character,\u001b[m\r\n       but  the  history  expansion character is also treated as\u001b[m\r\n       quoted if it  immediately  precedes  the  closing  double\u001b[m\r\n  "]
[3624.744049, "o", "     quote in a double-quoted string.\u001b[m\r\n\u001b[m\r\n       Several characters inhibit history expansion if found im‐\u001b[m\r\n       mediately following the history expansion character, even\u001b[m\r\n       if  it is unquoted: space, tab, newline, carriage return,\u001b[m\r\n       and \u001b[1m=\u001b[0m.  If the \u001b[1mextglob\u001b[0m shell option is  enabled,  \u001b[1m(\u001b[0m  will\u001b[m\r\n       also inhibit expansion.\u001b[m\r\n\u001b[m\r\n       Several shell options settable with the \u001b[1mshopt\u001b[0m builtin may\u001b[m\r\n       be used to tailor the behavior of history expansion.   If\u001b[m\r\n       the  \u001b[1mhistverify\u001b[0m shell option is enabled (see the descrip‐\u001b[m\r\n       tion of the \u001b[1mshopt\u001b[0m builtin below), and \u001b[1mreadline\u001b[0m  is  being\u001b[m\r\n\u001b[7m Manual page bash(1) line 5175 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.774987, "o", "\r\u001b[K"]
[3624.775142, "o", "       used, history substitutions are not immediately passed to\u001b[m\r\n       the shell parser.  Instead, the expanded line is reloaded\u001b[m\r\n       into  the  \u001b[1mreadline\u001b[0m  editing buffer for further modifica‐\u001b[m\r\n       tion.  If \u001b[1mreadline\u001b[0m is  being  used,  and  the  \u001b[1mhistreedit\u001b[0m\u001b[m\r\n       shell  option  is  enabled, a failed history substitution\u001b[m\r\n       will be reloaded into the  \u001b[1mreadline\u001b[0m  editing  buffer  for\u001b[m\r\n       correction.  The \u001b[1m-p\u001b[0m option to the \u001b[1mhistory\u001b[0m builtin command\u001b[m\r\n       may be used to see what a history expansion will  do  be‐\u001b[m\r\n       fore  using it.  The \u001b[1m-s\u001b[0m option to the \u001b[1mhistory\u001b[0m builtin may\u001b[m\r\n       be used to add commands to the end of  the  history  list\u001b[m\r\n       without  actually executing them, so that they are avail‐\u001b[m\r\n       able for subsequent recall.\u001b[m\r\n\u001b[m\r\n       The shell allows control of the various  characters  used\u001b[m\r\n       by  the  history expansion mechanism (see the description\u001b[m\r\n       of \u001b[1"]
[3624.775149, "o", "mhistchars\u001b[0m above under  \u001b[1mShell\u001b[0m  \u001b[1mVariables\u001b[0m).   The  shell\u001b[m\r\n       uses  the history comment character to mark history time‐\u001b[m\r\n       stamps when writing the history file.\u001b[m\r\n\u001b[m\r\n   \u001b[1mEvent\u001b[0m \u001b[1mDesignators\u001b[0m\u001b[m\r\n       An event designator is a reference to a command line  en‐\u001b[m\r\n       try  in  the history list.  Unless the reference is abso‐\u001b[m\r\n       lute, events are relative to the current position in  the\u001b[m\r\n       history list.\u001b[m\r\n\u001b[m\r\n       \u001b[1m!\u001b[0m      Start a history substitution, except when followed\u001b[m\r\n\u001b[7m Manual page bash(1) line 5201 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.806446, "o", "\r\u001b[K              by a \u001b[1mblank\u001b[0m, newline, carriage return, = or ( (when\u001b[m\r\n              the  \u001b[1mextglob\u001b[0m  shell  option  is  enabled using the\u001b[m\r\n              \u001b[1mshopt\u001b[0m builtin).\u001b[m\r\n       \u001b[1m!\u001b[0m\u001b[4mn\u001b[24m     Refer to command line \u001b[4mn\u001b[24m.\u001b[m\r\n       \u001b[1m!-\u001b[0m\u001b[4mn\u001b[24m    Refer to the current command minus \u001b[4mn\u001b[24m.\u001b[m\r\n       \u001b[1m!!\u001b[0m     Refer to the previous command.  This is a  synonym\u001b[m\r\n              for `!-1'.\u001b[m\r\n       \u001b[1m!\u001b[0m\u001b[4mstring\u001b[24m\u001b[m\r\n              Refer  to  the  most  recent command preceding the\u001b[m\r\n              current position in the history list starting with\u001b[m\r\n              \u001b[4mstring\u001b[24m.\u001b[m\r\n       \u001b[1m!?\u001b[0m\u001b[4mstring\u001b[24m\u001b[1m[?]\u001b[0m\u001b[m\r\n              Refer  to  the  most  recent command preceding the\u001b[m\r\n              current position in the  history  list  containing\u001b[m\r\n              \u001b[4mstring\u001b[24m.   The  trailing \u001b[1m?\u001b[0m may be omitted if \u001b[4mstring\u001b[24m\u001b[m\r\n              is followed immediately by a newline.   If  \u001b[4mstring\u001b[24m\u001b[m\r"]
[3624.806603, "o", "\n              is missing, the string from the most recent search\u001b[m\r\n              is used; it is an error if there  is  no  previous\u001b[m\r\n              search string.\u001b[m\r\n       \u001b[1m^\u001b[0m\u001b[4mstring1\u001b[24m\u001b[1m^\u001b[0m\u001b[4mstring2\u001b[24m\u001b[1m^\u001b[0m\u001b[m\r\n              Quick  substitution.  Repeat the previous command,\u001b[m\r\n              replacing \u001b[4mstring1\u001b[24m  with  \u001b[4mstring2\u001b[24m.   Equivalent  to\u001b[m\r\n              ``!!:s^\u001b[4mstring1\u001b[24m^\u001b[4mstring2\u001b[24m^'' (see \u001b[1mModifiers\u001b[0m below).\u001b[m\r\n"]
[3624.80662, "o", "       \u001b[1m!#\u001b[0m     The entire command line typed so far.\u001b[m\r\n\u001b[m\r\n   \u001b[1mWord\u001b[0m \u001b[1mDesignators\u001b[0m\u001b[m\r\n\u001b[7m Manual page bash(1) line 5227 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.836969, "o", "\r\u001b[K       Word  designators  are  used to select desired words from\u001b[m\r\n       the event.  A \u001b[1m:\u001b[0m separates the  event  specification  from\u001b[m\r\n       the  word designator.  It may be omitted if the word des‐\u001b[m\r\n       ignator begins with a \u001b[1m^\u001b[0m, \u001b[1m$\u001b[0m, \u001b[1m*\u001b[0m, \u001b[1m-\u001b[0m, or \u001b[1m%\u001b[0m.  Words  are  num‐\u001b[m\r\n       bered from the beginning of the line, with the first word\u001b[m\r\n       being denoted by 0 (zero).  Words are inserted  into  the\u001b[m\r\n       current line separated by single spaces.\u001b[m\r\n\u001b[m\r\n"]
[3624.837109, "o", "       \u001b[1m0\u001b[0m \u001b[1m(zero)\u001b[0m\u001b[m\r\n              The  zeroth word.  For the shell, this is the com‐\u001b[m\r\n              mand word.\u001b[m\r\n       \u001b[4mn\u001b[24m      The \u001b[4mn\u001b[24mth word.\u001b[m\r\n       \u001b[1m^\u001b[0m      The first argument.  That is, word 1.\u001b[m\r\n       \u001b[1m$\u001b[0m      The last word.  This is usually the last argument,\u001b[m\r\n              but  will  expand  to  the zeroth word if there is\u001b[m\r\n              only one word in the line.\u001b[m\r\n       \u001b[1m%\u001b[0m      The  first  word  matched  by  the   most   recent\u001b[m\r\n              `?\u001b[4mstring\u001b[24m?'  search,  if  the  search string begins\u001b[m\r\n              with a character that is part of a word.\u001b[m\r\n       \u001b[4mx\u001b[24m\u001b[1m-\u001b[0m\u001b[4my\u001b[24m    A range of words; `-\u001b[4my\u001b[24m' abbreviates `0-\u001b[4my\u001b[24m'.\u001b[m\r\n       \u001b[1m*\u001b[0m      All of the words but the zeroth.  This is  a  syn‐\u001b[m\r\n              onym  for  `\u001b[4m1-$\u001b[24m'.   It is not an error to use \u001b[1m*\u001b[0m if\u001b[m\r\n              there is just one word in  the  event;  the  empty\u001b[m\r\n              string is returne"]
[3624.837141, "o", "d in that case.\u001b[m\r\n       \u001b[1mx*\u001b[0m     Abbreviates \u001b[4mx-$\u001b[24m.\u001b[m\r\n       \u001b[1mx-\u001b[0m     Abbreviates  \u001b[4mx-$\u001b[24m like \u001b[1mx*\u001b[0m, but omits the last word.\u001b[m\r\n\u001b[7m Manual page bash(1) line 5253 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.869018, "o", "\r\u001b[K              If \u001b[1mx\u001b[0m is missing, it defaults to 0.\u001b[m\r\n\u001b[m\r\n       If a word designator is supplied without an event  speci‐\u001b[m\r\n       fication, the previous command is used as the event.\u001b[m\r\n\u001b[m\r\n   \u001b[1mModifiers\u001b[0m\u001b[m\r\n       After  the  optional  word designator, there may appear a\u001b[m\r\n       sequence of one or more of the following modifiers,  each\u001b[m\r\n       preceded  by  a  `:'.  These modify, or edit, the word or\u001b[m\r\n       words selected from the history event.\u001b[m\r\n\u001b[m\r\n       \u001b[1mh\u001b[0m      Remove a trailing filename component, leaving only\u001b[m\r\n              the head.\u001b[m\r\n       \u001b[1mt\u001b[0m      Remove  all  leading  filename components, leaving\u001b[m\r\n              the tail.\u001b[m\r\n       \u001b[1mr\u001b[0m      Remove a trailing suffix of the form \u001b[4m.xxx\u001b[24m, leaving\u001b[m\r\n              the basename.\u001b[m\r\n       \u001b[1me\u001b[0m      Remove all but the trailing suffix.\u001b[m\r\n       \u001b[1mp\u001b[0m      Print the new command but do not execute it.\u001b[m\r\n       \u001b[1mq\u001b[0m      Quote the substituted words, escaping furthe"]
[3624.86905, "o", "r sub‐\u001b[m\r\n              stitutions.\u001b[m\r\n       \u001b[1mx\u001b[0m      Quote the substituted words as with \u001b[1mq\u001b[0m,  but  break\u001b[m\r\n              into  words  at  \u001b[1mblanks\u001b[0m and newlines.  The \u001b[1mq\u001b[0m and \u001b[1mx\u001b[0m\u001b[m\r\n              modifiers are mutually  exclusive;  the  last  one\u001b[m\r\n              supplied is used.\u001b[m\r\n       \u001b[1ms/\u001b[0m\u001b[4mold\u001b[24m\u001b[1m/\u001b[0m\u001b[4mnew\u001b[24m\u001b[1m/\u001b[0m\u001b[m\r\n\u001b[7m Manual page bash(1) line 5279 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.899618, "o", "\r\u001b[K"]
[3624.899715, "o", "              Substitute  \u001b[4mnew\u001b[24m for the first occurrence of \u001b[4mold\u001b[24m in\u001b[m\r\n              the event line.  Any character may be used as  the\u001b[m\r\n              delimiter  in  place of /.  The final delimiter is\u001b[m\r\n              optional if it is the last character of the  event\u001b[m\r\n              line.   The delimiter may be quoted in \u001b[4mold\u001b[24m and \u001b[4mnew\u001b[24m\u001b[m\r\n              with a single backslash.  If & appears in \u001b[4mnew\u001b[24m,  it\u001b[m\r\n              is replaced by \u001b[4mold\u001b[24m.  A single backslash will quote\u001b[m\r\n              the &.  If \u001b[4mold\u001b[24m is null, it is set to the last  \u001b[4mold\u001b[24m\u001b[m\r\n              substituted,  or, if no previous history substitu‐\u001b[m\r\n              tions took place, the last \u001b[4mstring\u001b[24m in a \u001b[1m!?\u001b[0m\u001b[4mstring\u001b[24m\u001b[1m[?]\u001b[0m\u001b[m\r\n              search.   If  \u001b[4mnew\u001b[24m  is  null,  each matching \u001b[4mold\u001b[24m is\u001b[m\r\n              deleted.\u001b[m\r\n       \u001b[1m&\u001b[0m      Repeat the previous substitution.\u001b[m\r\n       \u001b[1mg\u001b[0m      Cause changes to be applied ov"]
[3624.899747, "o", "er the entire  event\u001b[m\r\n              line.   This  is  used  in  conjunction  with `\u001b[1m:s\u001b[0m'\u001b[m\r\n              (e.g., `\u001b[1m:gs/\u001b[0m\u001b[4mold\u001b[24m\u001b[1m/\u001b[0m\u001b[4mnew\u001b[24m\u001b[1m/\u001b[0m')  or  `\u001b[1m:&\u001b[0m'.   If  used  with\u001b[m\r\n              `\u001b[1m:s\u001b[0m', any delimiter can be used in place of /, and\u001b[m\r\n              the final delimiter is optional if it is the  last\u001b[m\r\n              character  of the event line.  An \u001b[1ma\u001b[0m may be used as\u001b[m\r\n              a synonym for \u001b[1mg\u001b[0m.\u001b[m\r\n       \u001b[1mG\u001b[0m      Apply the following `\u001b[1ms\u001b[0m' or `\u001b[1m&\u001b[0m'  modifier  once  to\u001b[m\r\n              each word in the event line.\u001b[m\r\n\u001b[m\r\n\u001b[1mSHELL\u001b[0m \u001b[1mBUILTIN\u001b[0m \u001b[1mCOMMANDS\u001b[0m\u001b[m\r\n       Unless  otherwise  noted, each builtin command documented\u001b[m\r\n       in this section as accepting options preceded  by  \u001b[1m-\u001b[0m  ac‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 5305 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.932317, "o", "\r\u001b[K"]
[3624.932418, "o", "       cepts \u001b[1m--\u001b[0m to signify the end of the options.  The \u001b[1m:\u001b[0m, \u001b[1mtrue\u001b[0m,\u001b[m\r\n       \u001b[1mfalse\u001b[0m, and \u001b[1mtest\u001b[0m/\u001b[1m[\u001b[0m builtins do not accept options  and  do\u001b[m\r\n       not treat \u001b[1m--\u001b[0m specially.  The \u001b[1mexit\u001b[0m, \u001b[1mlogout\u001b[0m, \u001b[1mreturn\u001b[0m, \u001b[1mbreak\u001b[0m,\u001b[m\r\n       \u001b[1mcontinue\u001b[0m, \u001b[1mlet\u001b[0m, and \u001b[1mshift\u001b[0m builtins accept and process  ar‐\u001b[m\r\n       guments  beginning  with  \u001b[1m-\u001b[0m  without requiring \u001b[1m--\u001b[0m.  Other\u001b[m\r\n       builtins that accept arguments but are not  specified  as\u001b[m\r\n       accepting options interpret arguments beginning with \u001b[1m-\u001b[0m as\u001b[m\r\n       invalid options and require \u001b[1m--\u001b[0m to prevent this  interpre‐\u001b[m\r\n       tation.\u001b[m\r\n       \u001b[1m:\u001b[0m [\u001b[4marguments\u001b[24m]\u001b[m\r\n              No effect; the command does nothing beyond expand‐\u001b[m\r\n              ing \u001b[4marguments\u001b[24m and performing any  specified  redi‐\u001b[m\r\n              rections.  The return status is zero.\u001b[m\r\n\u001b[m\r\n        \u001b[1m.\u001b[0m  \u001b[4mfilename\u001b[24m [\u001b[4marguments"]
[3624.932438, "o", "\u001b[24m]\u001b[m\r\n   "]
[3624.932458, "o", "    \u001b[1msource\u001b[0m \u001b[4mfilename\u001b[24m [\u001b[4marguments\u001b[24m]\u001b[m\r\n              Read  and  execute  commands  from \u001b[4mfilename\u001b[24m in the\u001b[m\r\n              current shell environment and return the exit sta‐\u001b[m\r\n              tus  of  the  last command executed from \u001b[4mfilename\u001b[24m.\u001b[m\r\n              If \u001b[4mfilename\u001b[24m does not contain a slash, filenames in\u001b[m\r\n              \u001b[1mPATH\u001b[0m  are  used  to  find the directory containing\u001b[m\r\n              \u001b[4mfilename\u001b[24m, but \u001b[4mfilename\u001b[24m does not need  to  be  exe‐\u001b[m\r\n              cutable.   The  file searched for in \u001b[1mPATH\u001b[0m need not\u001b[m\r\n              be executable.  When \u001b[1mbash\u001b[0m is not in \u001b[4mposix\u001b[24m \u001b[4mmode\u001b[24m, it\u001b[m\r\n              searches the current directory if no file is found\u001b[m\r\n              in \u001b[1mPATH\u001b[0m.  If the \u001b[1msourcepath\u001b[0m option  to  the  \u001b[1mshopt\u001b[0m\u001b[m\r\n\u001b[7m Manual page bash(1) line 5331 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.964003, "o", "\r\u001b[K              builtin  command  is  turned  off, the \u001b[1mPATH\u001b[0m is not\u001b[m\r\n              searched.  If any \u001b[4marguments\u001b[24m are supplied, they be‐\u001b[m\r\n              come  the  positional  parameters when \u001b[4mfilename\u001b[24m is\u001b[m\r\n              executed.  Otherwise the positional parameters are\u001b[m\r\n              unchanged.   If the \u001b[1m-T\u001b[0m option is enabled, \u001b[1m.\u001b[0m inher‐\u001b[m\r\n              its any trap on \u001b[1mDEBUG\u001b[0m; if it  is  not,  any  \u001b[1mDEBUG\u001b[0m\u001b[m\r\n              trap  string is saved and restored around the call\u001b[m\r\n              to \u001b[1m.\u001b[0m, and \u001b[1m.\u001b[0m unsets the \u001b[1mDEBUG\u001b[0m trap  while  it  exe‐\u001b[m\r\n              cutes.   If  \u001b[1m-T\u001b[0m  is  not set, and the sourced file\u001b[m\r\n              changes the \u001b[1mDEBUG\u001b[0m trap, the new value is  retained\u001b[m\r\n              when \u001b[1m.\u001b[0m completes.  The return status is the status\u001b[m\r\n              of the last command exited within the script (0 if\u001b[m\r\n              no  commands  are executed), and false if \u001b[4mfilename\u001b[24m\u001b[m\r\n  "]
[3624.964139, "o", "            is not found or cannot be read.\u001b[m\r\n\u001b[m\r\n       \u001b[1malias\u001b[0m [\u001b[1m-p\u001b[0m] [\u001b[4mname\u001b[24m[=\u001b[4mvalue\u001b[24m] ...]\u001b[m\r\n              \u001b[1mAlias\u001b[0m with no arguments  or  with  the  \u001b[1m-p\u001b[0m  option\u001b[m\r\n              prints  the  list  of  aliases  in  the form \u001b[1malias\u001b[0m\u001b[m\r\n              \u001b[4mname\u001b[24m=\u001b[4mvalue\u001b[24m on standard output.  When arguments are\u001b[m\r\n              supplied,  an alias is defined for each \u001b[4mname\u001b[24m whose\u001b[m\r\n              \u001b[4mvalue\u001b[24m is given.  A trailing space in \u001b[4mvalue\u001b[24m  causes\u001b[m\r\n              the next word to be checked for alias substitution\u001b[m\r\n              when the alias is expanded.  For each \u001b[4mname\u001b[24m in  the\u001b[m\r\n              argument  list for which no \u001b[4mvalue\u001b[24m is supplied, the\u001b[m\r\n              name and value of the alias is printed.  \u001b[1mAlias\u001b[0m re‐\u001b[m\r\n              turns  true  unless  a  \u001b[4mname\u001b[24m is given for which no\u001b[m\r\n\u001b[7m Manual page bash(1) line 5357 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3624.995327, "o", "\r\u001b[K              alias has been defined.\u001b[m\r\n\u001b[m\r\n       \u001b[1mbg\u001b[0m [\u001b[4mjobspec\u001b[24m ...]\u001b[m\r\n              Resume each suspended job  \u001b[4mjobspec\u001b[24m  in  the  back‐\u001b[m\r\n              ground, as if it had been started with \u001b[1m&\u001b[0m.  If \u001b[4mjob‐\u001b[24m\u001b[m\r\n              \u001b[4mspec\u001b[24m is not present, the  shell's  notion  of  the\u001b[m\r\n              \u001b[4mcurrent\u001b[24m  \u001b[4mjob\u001b[24m is used.  \u001b[1mbg\u001b[0m \u001b[4mjobspec\u001b[24m returns 0 unless\u001b[m\r\n              run when job control is disabled or, when run with\u001b[m\r\n              job control enabled, any specified \u001b[4mjobspec\u001b[24m was not\u001b[m\r\n"]
[3624.995461, "o", "              found or was started without job control.\u001b[m\r\n\u001b[m\r\n       \u001b[1mbind\u001b[0m [\u001b[1m-m\u001b[0m \u001b[4mkeymap\u001b[24m] [\u001b[1m-lpsvPSVX\u001b[0m]\u001b[m\r\n       \u001b[1mbind\u001b[0m [\u001b[1m-m\u001b[0m \u001b[4mkeymap\u001b[24m] [\u001b[1m-q\u001b[0m \u001b[4mfunction\u001b[24m] [\u001b[1m-u\u001b[0m \u001b[4mfunction\u001b[24m] [\u001b[1m-r\u001b[0m \u001b[4mkeyseq\u001b[24m]\u001b[m\r\n       \u001b[1mbind\u001b[0m [\u001b[1m-m\u001b[0m \u001b[4mkeymap\u001b[24m] \u001b[1m-f\u001b[0m \u001b[4mfilename\u001b[24m\u001b[m\r\n       \u001b[1mbind\u001b[0m [\u001b[1m-m\u001b[0m \u001b[4mkeymap\u001b[24m] \u001b[1m-x\u001b[0m \u001b[4mkeyseq\u001b[24m:\u001b[4mshell-command\u001b[24m\u001b[m\r\n       \u001b[1mbind\u001b[0m [\u001b[1m-m\u001b[0m \u001b[4mkeymap\u001b[24m] \u001b[4mkeyseq\u001b[24m:\u001b[4mfunction-name\u001b[24m\u001b[m\r\n       \u001b[1mbind\u001b[0m [\u001b[1m-m\u001b[0m \u001b[4mkeymap\u001b[24m] \u001b[4mkeyseq\u001b[24m:\u001b[4mreadline-command\u001b[24m\u001b[m\r\n       \u001b[1mbind\u001b[0m \u001b[4mreadline-command-line\u001b[24m\u001b[m\r\n              Display current \u001b[1mreadline\u001b[0m key  and  function  bind‐\u001b[m\r\n              ings,  bind  a key sequence to a \u001b[1mreadline\u001b[0m function\u001b[m\r\n              or macro, or set a \u001b[1mreadline\u001b[0m variable.   Each  non-\u001b[m\r\n              option argument is a command as it would appear in\u001b[m\r\n             "]
[3624.995557, "o", " a \u001b[1mreadline\u001b[0m initialization file such  as  \u001b[4m.inputrc\u001b[24m,\u001b[m\r\n              but  each  binding  or command must be passed as a\u001b[m\r\n              separate     argument;     e.g.,      '\"\\C-x\\C-r\":\u001b[m\r\n              re-read-init-file'.   Options,  if  supplied, have\u001b[m\r\n\u001b[7m Manual page bash(1) line 5383 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.027126, "o", "\r\u001b[K"]
[3625.027236, "o", "              the following meanings:\u001b[m\r\n              \u001b[1m-m\u001b[0m \u001b[4mkeymap\u001b[24m\u001b[m\r\n                     Use \u001b[4mkeymap\u001b[24m as the keymap to be affected  by\u001b[m\r\n                     the subsequent bindings.  Acceptable \u001b[4mkeymap\u001b[24m\u001b[m\r\n                     names    are     \u001b[4memacs,\u001b[24m     \u001b[4memacs-standard,\u001b[24m\u001b[m\r\n                     \u001b[4memacs-meta,\u001b[24m    \u001b[4memacs-ctlx,\u001b[24m   \u001b[4mvi,\u001b[24m   \u001b[4mvi-move,\u001b[24m\u001b[m\r\n                     \u001b[4mvi-command\u001b[24m, and \u001b[4mvi-insert\u001b[24m.  \u001b[4mvi\u001b[24m  is  equiva‐\u001b[m\r\n                     lent  to \u001b[4mvi-command\u001b[24m (\u001b[4mvi-move\u001b[24m is also a syn‐\u001b[m\r\n                     onym); \u001b[4memacs\u001b[24m is equivalent  to  \u001b[4memacs-stan‐\u001b[24m\u001b[m\r\n                     \u001b[4mdard\u001b[24m.\u001b[m\r\n              \u001b[1m-l\u001b[0m     List the names of all \u001b[1mreadline\u001b[0m functions.\u001b[m\r\n              \u001b[1m-p\u001b[0m     Display  \u001b[1mreadline\u001b[0m  function names and bind‐\u001b[m\r\n                     ings in such a way that  they  can  be  re-\u001b[m\r\n                     read.\u001b[m\r\n   "]
[3625.02726, "o", "           \u001b[1m-P\u001b[0m     List  current  \u001b[1mreadline\u001b[0m  function names and\u001b[m\r\n                     bindings.\u001b[m\r\n              \u001b[1m-s\u001b[0m     Display \u001b[1mreadline\u001b[0m  key  sequences  bound  to\u001b[m\r\n                     macros  and the strings they output in such\u001b[m\r\n                     a way that they can be re-read.\u001b[m\r\n              \u001b[1m-S\u001b[0m     Display \u001b[1mreadline\u001b[0m  key  sequences  bound  to\u001b[m\r\n                     macros and the strings they output.\u001b[m\r\n              \u001b[1m-v\u001b[0m     Display  \u001b[1mreadline\u001b[0m variable names and values\u001b[m\r\n                     in such a way that they can be re-read.\u001b[m\r\n              \u001b[1m-V\u001b[0m     List current \u001b[1mreadline\u001b[0m  variable  names  and\u001b[m\r\n                     values.\u001b[m\r\n              \u001b[1m-f\u001b[0m \u001b[4mfilename\u001b[24m\u001b[m\r\n\u001b[7m Manual page bash(1) line 5409 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.057988, "o", "\r\u001b[K"]
[3625.058086, "o", "                     Read key bindings from \u001b[4mfilename\u001b[24m.\u001b[m\r\n              \u001b[1m-q\u001b[0m \u001b[4mfunction\u001b[24m\u001b[m\r\n                     Query  about  which  keys  invoke the named\u001b[m\r\n                     \u001b[4mfunction\u001b[24m.\u001b[m\r\n              \u001b[1m-u\u001b[0m \u001b[4mfunction\u001b[24m\u001b[m\r\n                     Unbind all keys bound to  the  named  \u001b[4mfunc‐\u001b[24m\u001b[m\r\n                     \u001b[4mtion\u001b[24m.\u001b[m\r\n              \u001b[1m-r\u001b[0m \u001b[4mkeyseq\u001b[24m\u001b[m\r\n                     Remove any current binding for \u001b[4mkeyseq\u001b[24m.\u001b[m\r\n              \u001b[1m-x\u001b[0m \u001b[4mkeyseq\u001b[24m\u001b[1m:\u001b[0m\u001b[4mshell-command\u001b[24m\u001b[m\r\n                     Cause \u001b[4mshell-command\u001b[24m to be executed whenever\u001b[m\r\n                     \u001b[4mkeyseq\u001b[24m is entered.  When  \u001b[4mshell-command\u001b[24m  is\u001b[m\r\n                     executed,  the shell sets the \u001b[1mREADLINE_LINE\u001b[0m\u001b[m\r\n                     variable to the contents  of  the  \u001b[1mreadline\u001b[0m\u001b[m\r\n                     line  buffer  and  the  \u001b[1mREADLINE_POINT\u001b[0m  and\u001b[m\r\n                     \u001b[1mREADLINE_MARK\u001b["]
[3625.0582, "o", "0m variables to the current  lo‐\u001b[m\r\n                     cation of the insertion point and the saved\u001b[m\r\n                     insertion point (the  mark),  respectively.\u001b[m\r\n                     The  shell assigns any numeric argument the\u001b[m\r\n                     user  supplied  to  the   \u001b[1mREADLINE_ARGUMENT\u001b[0m\u001b[m\r\n                     variable.   If  there was no argument, that\u001b[m\r\n                     variable is not set.  If the executed  com‐\u001b[m\r\n                     mand  changes  the  value  of  any of \u001b[1mREAD‐\u001b[0m\u001b[m\r\n                     \u001b[1mLINE_LINE\u001b[0m,   \u001b[1mREADLINE_POINT\u001b[0m,    or    \u001b[1mREAD‐\u001b[0m\u001b[m\r\n                     \u001b[1mLINE_MARK\u001b[0m,  those  new  values  will be re‐\u001b[m\r\n                     flected in the editing state.\u001b[m\r\n\u001b[7m Manual page bash(1) line 5435 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.088922, "o", "\r\u001b[K"]
[3625.089033, "o", "              \u001b[1m-X\u001b[0m     List all key sequences bound to shell  com‐\u001b[m\r\n                     mands and the associated commands in a for‐\u001b[m\r\n                     mat that can be reused as input.\u001b[m\r\n\u001b[m\r\n              The return value is 0 unless an  unrecognized  op‐\u001b[m\r\n              tion is given or an error occurred.\u001b[m\r\n\u001b[m\r\n       \u001b[1mbreak\u001b[0m [\u001b[4mn\u001b[24m]\u001b[m\r\n              Exit  from  within  a \u001b[1mfor\u001b[0m, \u001b[1mwhile\u001b[0m, \u001b[1muntil\u001b[0m, or \u001b[1mselect\u001b[0m\u001b[m\r\n              loop.  If \u001b[4mn\u001b[24m is specified, break \u001b[4mn\u001b[24m levels.  \u001b[4mn\u001b[24m  must\u001b[m\r\n              be  ≥  1.   If \u001b[4mn\u001b[24m is greater than the number of en‐\u001b[m\r\n              closing loops, all  enclosing  loops  are  exited.\u001b[m\r\n              The return value is 0 unless \u001b[4mn\u001b[24m is not greater than\u001b[m\r\n              or equal to 1.\u001b[m\r\n\u001b[m\r\n       \u001b[1mbuiltin\u001b[0m \u001b[4mshell-builtin\u001b[24m [\u001b[4marguments\u001b[24m]\u001b[m\r\n              Execute the specified shell  builtin,  passing  it\u001b[m\r\n              \u001b[4marguments\u001b[24m,  and "]
[3625.089055, "o", " return  its exit status.  This is\u001b[m\r\n              useful when defining a function whose name is  the\u001b[m\r\n              same as a shell builtin, retaining the functional‐\u001b[m\r\n              ity of the builtin within the  function.   The  \u001b[1mcd\u001b[0m\u001b[m\r\n              builtin  is  commonly redefined this way.  The re‐\u001b[m\r\n              turn status is false if  \u001b[4mshell-builtin\u001b[24m  is  not  a\u001b[m\r\n              shell builtin command.\u001b[m\r\n\u001b[m\r\n       \u001b[1mcaller\u001b[0m [\u001b[4mexpr\u001b[24m]\u001b[m\r\n\u001b[7m Manual page bash(1) line 5461 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.12027, "o", "\r\u001b[K"]
[3625.120392, "o", "              Returns  the context of any active subroutine call\u001b[m\r\n              (a shell function or a script executed with the  \u001b[1m.\u001b[0m\u001b[m\r\n              or  \u001b[1msource\u001b[0m  builtins).   Without \u001b[4mexpr\u001b[24m, \u001b[1mcaller\u001b[0m dis‐\u001b[m\r\n              plays the line number and source filename  of  the\u001b[m\r\n              current  subroutine call.  If a non-negative inte‐\u001b[m\r\n              ger is supplied as \u001b[4mexpr\u001b[24m, \u001b[1mcaller\u001b[0m displays the  line\u001b[m\r\n              number,  subroutine  name,  and source file corre‐\u001b[m\r\n              sponding to that position in the current execution\u001b[m\r\n              call  stack.   This extra information may be used,\u001b[m\r\n              for example, to print a stack trace.  The  current\u001b[m\r\n              frame  is  frame  0.  The return value is 0 unless\u001b[m\r\n              the shell is not executing a  subroutine  call  or\u001b[m\r\n              \u001b[4mexpr\u001b[24m  does  not  correspond to a valid position in\u001b[m\r\n              the call stack.\u001b[m\r\n\u001b[m\r\n       \u001b[1mcd\u001b[0m [\u001b[1m"]
[3625.120423, "o", "-L\u001b[0m|[\u001b[1m-P\u001b[0m [\u001b[1m-e\u001b[0m]] [-@]] [\u001b[4mdir\u001b[24m]\u001b[m\r\n              Change the current directory to \u001b[4mdir\u001b[24m.   if  \u001b[4mdir\u001b[24m  is\u001b[m\r\n              not supplied, the value of the \u001b[1mHOME\u001b[0m shell variable\u001b[m\r\n              is the default.  The variable \u001b[1mCDPATH\u001b[0m  defines  the\u001b[m\r\n              search path for the directory containing \u001b[4mdir\u001b[24m: each\u001b[m\r\n              directory name in \u001b[1mCDPATH\u001b[0m is searched for \u001b[4mdir\u001b[24m.  Al‐\u001b[m\r\n              ternative  directory names in \u001b[1mCDPATH\u001b[0m are separated\u001b[m\r\n              by a colon (:).  A null directory name  in  \u001b[1mCDPATH\u001b[0m\u001b[m\r\n              is the same as the current directory, i.e., ``\u001b[1m.\u001b[0m''.\u001b[m\r\n              If \u001b[4mdir\u001b[24m begins with a slash (/), then \u001b[1mCDPATH\u001b[0m is not\u001b[m\r\n              used.  The \u001b[1m-P\u001b[0m option causes \u001b[1mcd\u001b[0m to use the physical\u001b[m\r\n\u001b[7m Manual page bash(1) line 5487 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.151194, "o", "\r\u001b[K"]
[3625.151345, "o", "              directory structure by  resolving  symbolic  links\u001b[m\r\n              while  traversing  \u001b[4mdir\u001b[24m  and  before processing in‐\u001b[m\r\n              stances of \u001b[4m..\u001b[24m in \u001b[4mdir\u001b[24m (see also the  \u001b[1m-P\u001b[0m  option  to\u001b[m\r\n              the  \u001b[1mset\u001b[0m  builtin  command);  the \u001b[1m-L\u001b[0m option forces\u001b[m\r\n              symbolic links to be  followed  by  resolving  the\u001b[m\r\n              link  after processing instances of \u001b[4m..\u001b[24m in \u001b[4mdir\u001b[24m.  If\u001b[m\r\n              \u001b[4m..\u001b[24m appears in \u001b[4mdir\u001b[24m, it is processed by removing the\u001b[m\r\n              immediately  previous pathname component from \u001b[4mdir\u001b[24m,\u001b[m\r\n              back to a slash or the beginning of \u001b[4mdir\u001b[24m.   If  the\u001b[m\r\n              \u001b[1m-e\u001b[0m  option  is  supplied  with \u001b[1m-P\u001b[0m, and the current\u001b[m\r\n              working directory cannot  be  successfully  deter‐\u001b[m\r\n              mined after a successful directory change, \u001b[1mcd\u001b[0m will\u001b[m\r\n              return an unsuccessful status.   On  systems  tha"]
[3625.151442, "o", "t\u001b[m\r\n              support  it,  the  \u001b[1m-@\u001b[0m option presents the extended\u001b[m\r\n              attributes associated with a file as a  directory.\u001b[m\r\n              An  argument  of  \u001b[1m-\u001b[0m is converted to \u001b[1m$OLDPWD\u001b[0m before\u001b[m\r\n              the directory change is attempted.  If a non-empty\u001b[m\r\n              directory name from \u001b[1mCDPATH\u001b[0m is used, or if \u001b[1m-\u001b[0m is the\u001b[m\r\n              first argument, and the directory change  is  suc‐\u001b[m\r\n              cessful,  the absolute pathname of the new working\u001b[m\r\n              directory is written to the standard  output.   If\u001b[m\r\n              the  directory  change  is successful, \u001b[1mcd\u001b[0m sets the\u001b[m\r\n              value of the \u001b[1mPWD\u001b[0m environment variable to  the  new\u001b[m\r\n              directory  name,  and  sets the \u001b[1mOLDPWD\u001b[0m environment\u001b[m\r\n              variable to the value of the current  working  di‐\u001b[m\r\n              rectory  before  the  change.  The return value is\u001b[m\r\n\u001b[7m Manual page bash(1) line 5513 (press h for help "]
[3625.151474, "o", "or q to quit)\u001b[27m\u001b[K"]
[3625.1829, "o", "\r\u001b[K              true if the directory  was  successfully  changed;\u001b[m\r\n              false otherwise.\u001b[m\r\n\u001b[m\r\n       \u001b[1mcommand\u001b[0m [\u001b[1m-pVv\u001b[0m] \u001b[4mcommand\u001b[24m [\u001b[4marg\u001b[24m ...]\u001b[m\r\n              Run \u001b[4mcommand\u001b[24m with \u001b[4margs\u001b[24m suppressing the normal shell\u001b[m\r\n              function lookup.  Only builtin  commands  or  com‐\u001b[m\r\n              mands  found  in the \u001b[1mPATH\u001b[0m are executed.  If the \u001b[1m-p\u001b[0m\u001b[m\r\n              option is given, the search for  \u001b[4mcommand\u001b[24m  is  per‐\u001b[m\r\n              formed  using  a  default  value  for \u001b[1mPATH\u001b[0m that is\u001b[m\r\n              guaranteed to find all of the standard  utilities.\u001b[m\r\n              If  either  the \u001b[1m-V\u001b[0m or \u001b[1m-v\u001b[0m option is supplied, a de‐\u001b[m\r\n              scription of \u001b[4mcommand\u001b[24m is printed.   The  \u001b[1m-v\u001b[0m  option\u001b[m\r\n              causes  a  single  word  indicating the command or\u001b[m\r\n              filename used to invoke \u001b[4mcommand\u001b[24m to  be  displayed;\u001b[m\r\n              the \u001b[1m-V\u001b[0m option produces"]
[3625.182993, "o", " a more verbose description.\u001b[m\r\n              If the \u001b[1m-V\u001b[0m or \u001b[1m-v\u001b[0m option is supplied, the exit  sta‐\u001b[m\r\n              tus  is  0 if \u001b[4mcommand\u001b[24m was found, and 1 if not.  If\u001b[m\r\n              neither option is supplied and an  error  occurred\u001b[m\r\n              or  \u001b[4mcommand\u001b[24m  cannot  be  found, the exit status is\u001b[m\r\n              127.  Otherwise, the exit status  of  the  \u001b[1mcommand\u001b[0m\u001b[m\r\n              builtin is the exit status of \u001b[4mcommand\u001b[24m.\u001b[m\r\n\u001b[m\r\n       \u001b[1mcompgen\u001b[0m [\u001b[4moption\u001b[24m] [\u001b[4mword\u001b[24m]\u001b[m\r\n              Generate  possible completion matches for \u001b[4mword\u001b[24m ac‐\u001b[m\r\n              cording to the \u001b[4moption\u001b[24ms, which may  be  any  option\u001b[m\r\n              accepted  by  the \u001b[1mcomplete\u001b[0m builtin with the excep‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 5539 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.214418, "o", "\r\u001b[K"]
[3625.214532, "o", "              tion of \u001b[1m-p\u001b[0m and \u001b[1m-r\u001b[0m, and write the  matches  to  the\u001b[m\r\n              standard output.  When using the \u001b[1m-F\u001b[0m or \u001b[1m-C\u001b[0m options,\u001b[m\r\n              the various shell variables set  by  the  program‐\u001b[m\r\n              mable completion facilities, while available, will\u001b[m\r\n              not have useful values.\u001b[m\r\n\u001b[m\r\n              The matches will be generated in the same  way  as\u001b[m\r\n              if  the programmable completion code had generated\u001b[m\r\n              them directly from a completion specification with\u001b[m\r\n              the  same flags.  If \u001b[4mword\u001b[24m is specified, only those\u001b[m\r\n              completions matching \u001b[4mword\u001b[24m will be displayed.\u001b[m\r\n\u001b[m\r\n              The return value is true unless an invalid  option\u001b[m\r\n              is supplied, or no matches were generated.\u001b[m\r\n\u001b[m\r\n       \u001b[1mcomplete\u001b[0m  [\u001b[1m-abcdefgjksuv\u001b[0m] [\u001b[1m-o\u001b[0m \u001b[4mcomp-option\u001b[24m] [\u001b[1m-DEI\u001b[0m] [\u001b[1m-A\u001b[0m \u001b[4mac‐\u001b[24m\u001b[m\r\n       \u001b[4mtion\u001b[24m] [\u001b[1m-G\u001b[0m \u001b[4mglo"]
[3625.214659, "o", "bpat\u001b[24m] [\u001b[1m-W\u001b[0m \u001b[4mwordlist\u001b[24m]\u001b[m\r\n              [\u001b[1m-F\u001b[0m \u001b[4mfunction\u001b[24m] [\u001b[1m-C\u001b[0m \u001b[4mcommand\u001b[24m] [\u001b[1m-X\u001b[0m \u001b[4mfilterpat\u001b[24m] [\u001b[1m-P\u001b[0m \u001b[4mpre‐\u001b[24m\u001b[m\r\n              \u001b[4mfix\u001b[24m] [\u001b[1m-S\u001b[0m \u001b[4msuffix\u001b[24m] \u001b[4mname\u001b[24m [\u001b[4mname\u001b[24m \u001b[4m...\u001b[24m]\u001b[m\r\n       \u001b[1mcomplete\u001b[0m \u001b[1m-pr\u001b[0m [\u001b[1m-DEI\u001b[0m] [\u001b[4mname\u001b[24m ...]\u001b[m\r\n              Specify  how arguments to each \u001b[4mname\u001b[24m should be com‐\u001b[m\r\n              pleted.  If the \u001b[1m-p\u001b[0m option is supplied,  or  if  no\u001b[m\r\n              options are supplied, existing completion specifi‐\u001b[m\r\n              cations are printed in a way that allows  them  to\u001b[m\r\n              be  reused as input.  The \u001b[1m-r\u001b[0m option removes a com‐\u001b[m\r\n              pletion specification for each  \u001b[4mname\u001b[24m,  or,  if  no\u001b[m\r\n\u001b[7m Manual page bash(1) line 5565 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.245211, "o", "\r\u001b[K              \u001b[4mname\u001b[24ms are supplied, all completion specifications.\u001b[m\r\n              The \u001b[1m-D\u001b[0m option indicates that  other  supplied  op‐\u001b[m\r\n              tions  and actions should apply to the ``default''\u001b[m\r\n              command completion; that is, completion  attempted\u001b[m\r\n              on  a  command  for which no completion has previ‐\u001b[m\r\n              ously been defined.  The \u001b[1m-E\u001b[0m option indicates  that\u001b[m\r\n              other supplied options and actions should apply to\u001b[m\r\n              ``empty'' command completion; that is,  completion\u001b[m\r\n              attempted  on  a  blank line.  The \u001b[1m-I\u001b[0m option indi‐\u001b[m\r\n              cates that  other  supplied  options  and  actions\u001b[m\r\n              should  apply to completion on the initial non-as‐\u001b[m\r\n              signment word on the line, or after a command  de‐\u001b[m\r\n              limiter  such  as \u001b[1m;\u001b[0m or \u001b[1m|\u001b[0m, which is usually command\u001b[m\r\n              name completion.  If  multiple  options  are  sup"]
[3625.245342, "o", "‐\u001b[m\r\n              plied, the \u001b[1m-D\u001b[0m option takes precedence over \u001b[1m-E\u001b[0m, and\u001b[m\r\n              both take precedence over \u001b[1m-I\u001b[0m.  If any of  \u001b[1m-D\u001b[0m,  \u001b[1m-E\u001b[0m,\u001b[m\r\n              or  \u001b[1m-I\u001b[0m  are supplied, any other \u001b[4mname\u001b[24m arguments are\u001b[m\r\n              ignored; these completions only apply to the  case\u001b[m\r\n              specified by the option.\u001b[m\r\n\u001b[m\r\n              The  process of applying these completion specifi‐\u001b[m\r\n              cations when word completion is attempted  is  de‐\u001b[m\r\n              scribed above under \u001b[1mProgrammable\u001b[0m \u001b[1mCompletion\u001b[0m.\u001b[m\r\n\u001b[m\r\n              Other  options,  if  specified, have the following\u001b[m\r\n              meanings.  The arguments to the \u001b[1m-G\u001b[0m, \u001b[1m-W\u001b[0m, and \u001b[1m-X\u001b[0m op‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 5591 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.27684, "o", "\r\u001b[K              tions  (and,  if necessary, the \u001b[1m-P\u001b[0m and \u001b[1m-S\u001b[0m options)\u001b[m\r\n              should be quoted to protect  them  from  expansion\u001b[m\r\n              before the \u001b[1mcomplete\u001b[0m builtin is invoked.\u001b[m\r\n              \u001b[1m-o\u001b[0m \u001b[4mcomp-option\u001b[24m\u001b[m\r\n                      The  \u001b[4mcomp-option\u001b[24m  controls several aspects\u001b[m\r\n                      of the compspec's behavior beyond the sim‐\u001b[m\r\n                      ple  generation  of completions.  \u001b[4mcomp-op‐\u001b[24m\u001b[m\r\n                      \u001b[4mtion\u001b[24m may be one of:\u001b[m\r\n                      \u001b[1mbashdefault\u001b[0m\u001b[m\r\n                              Perform the rest  of  the  default\u001b[m\r\n                              \u001b[1mbash\u001b[0m  completions  if the compspec\u001b[m\r\n                              generates no matches.\u001b[m\r\n                      \u001b[1mdefault\u001b[0m Use  readline's  default  filename\u001b[m\r\n                              completion  if the compspec gener‐\u001b[m\r\n                              ates no matches.\u001b[m\r\n                   "]
[3625.276938, "o", "   \u001b[1mdirnames\u001b[0m\u001b[m\r\n                              Perform directory name  completion\u001b[m\r\n"]
[3625.277, "o", "                              if   the   compspec  generates  no\u001b[m\r\n                              matches.\u001b[m\r\n                      \u001b[1mfilenames\u001b[0m\u001b[m\r\n                              Tell readline  that  the  compspec\u001b[m\r\n                              generates  filenames,  so  it  can\u001b[m\r\n                              perform any filename-specific pro‐\u001b[m\r\n                              cessing  (like  adding  a slash to\u001b[m\r\n                              directory names,  quoting  special\u001b[m\r\n                              characters,  or suppressing trail‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 5617 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.308051, "o", "\r\u001b[K"]
[3625.308184, "o", "                              ing spaces).  Intended to be  used\u001b[m\r\n                              with shell functions.\u001b[m\r\n                      \u001b[1mnoquote\u001b[0m Tell  readline  not  to  quote the\u001b[m\r\n                              completed words if they are  file‐\u001b[m\r\n                              names  (quoting  filenames  is the\u001b[m\r\n                              default).\u001b[m\r\n                      \u001b[1mnosort\u001b[0m  Tell readline not to sort the list\u001b[m\r\n                              of possible completions alphabeti‐\u001b[m\r\n                              cally.\u001b[m\r\n                      \u001b[1mnospace\u001b[0m Tell  readline  not  to  append  a\u001b[m\r\n                              space  (the default) to words com‐\u001b[m\r\n                              pleted at the end of the line.\u001b[m\r\n                      \u001b[1mplusdirs\u001b[0m\u001b[m\r\n                              After any matches defined  by  the\u001b[m\r\n                              compspec  are generated, directory\u001b[m\r\n                              name completion is  attem"]
[3625.308227, "o", "pted  and\u001b[m\r\n                              any  matches  are added to the re‐\u001b[m\r\n                              sults of the other actions.\u001b[m\r\n              \u001b[1m-A\u001b[0m \u001b[4maction\u001b[24m\u001b[m\r\n                      The \u001b[4maction\u001b[24m may be one of the following  to\u001b[m\r\n                      generate a list of possible completions:\u001b[m\r\n                      \u001b[1malias\u001b[0m   Alias  names.   May also be speci‐\u001b[m\r\n                              fied as \u001b[1m-a\u001b[0m.\u001b[m\r\n                      \u001b[1marrayvar\u001b[0m\u001b[m\r\n                              Array variable names.\u001b[m\r\n                      \u001b[1mbinding\u001b[0m \u001b[1mReadline\u001b[0m key binding names.\u001b[m\r\n\u001b[7m Manual page bash(1) line 5643 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.339226, "o", "\r\u001b[K                      \u001b[1mbuiltin\u001b[0m Names of shell  builtin  commands.\u001b[m\r\n                              May also be specified as \u001b[1m-b\u001b[0m.\u001b[m\r\n                      \u001b[1mcommand\u001b[0m Command names.  May also be speci‐\u001b[m\r\n                              fied as \u001b[1m-c\u001b[0m.\u001b[m\r\n                      \u001b[1mdirectory\u001b[0m\u001b[m\r\n                              Directory  names.   May  also   be\u001b[m\r\n                              specified as \u001b[1m-d\u001b[0m.\u001b[m\r\n                      \u001b[1mdisabled\u001b[0m\u001b[m\r\n                              Names of disabled shell builtins.\u001b[m\r\n                      \u001b[1menabled\u001b[0m Names of enabled shell builtins.\u001b[m\r\n                      \u001b[1mexport\u001b[0m  Names of exported shell variables.\u001b[m\r\n                              May also be specified as \u001b[1m-e\u001b[0m.\u001b[m\r\n                      \u001b[1mfile\u001b[0m    File names.  May also be specified\u001b[m\r\n                              as \u001b[1m-f\u001b[0m.\u001b[m\r\n                      \u001b[1mfunction\u001b[0m\u001b[m\r\n                              Names of shell functions.\u001b[m\r\n    "]
[3625.339356, "o", "                  \u001b[1mgroup\u001b[0m   Group  names.   May also be speci‐\u001b[m\r\n                              fied as \u001b[1m-g\u001b[0m.\u001b[m\r\n                      \u001b[1mhelptopic\u001b[0m\u001b[m\r\n                              Help topics  as  accepted  by  the\u001b[m\r\n                              \u001b[1mhelp\u001b[0m builtin.\u001b[m\r\n                      \u001b[1mhostname\u001b[0m\u001b[m\r\n                              Hostnames,  as taken from the file\u001b[m\r\n                              specified by  the  \u001b[1mHOSTFILE\u001b[0m  shell\u001b[m\r\n                              variable.\u001b[m\r\n                      \u001b[1mjob\u001b[0m     Job  names,  if job control is ac‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 5669 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.371116, "o", "\r\u001b[K"]
[3625.371147, "o", "                              tive.  May also  be  specified  as\u001b[m\r\n                              \u001b[1m-j\u001b[0m.\u001b[m\r\n                      \u001b[1mkeyword\u001b[0m Shell reserved words.  May also be\u001b[m\r\n                              specified as \u001b[1m-k\u001b[0m.\u001b[m\r\n                      \u001b[1mrunning\u001b[0m Names of running jobs, if job con‐\u001b[m\r\n                              trol is active.\u001b[m\r\n                      \u001b[1mservice\u001b[0m Service names.  May also be speci‐\u001b[m\r\n                              fied as \u001b[1m-s\u001b[0m.\u001b[m\r\n                      \u001b[1msetopt\u001b[0m  Valid arguments for the \u001b[1m-o\u001b[0m  option\u001b[m\r\n                              to the \u001b[1mset\u001b[0m builtin.\u001b[m\r\n                      \u001b[1mshopt\u001b[0m   Shell  option names as accepted by\u001b[m\r\n                              the \u001b[1mshopt\u001b[0m builtin.\u001b[m\r\n                      \u001b[1msignal\u001b[0m  Signal names.\u001b[m\r\n                      \u001b[1mstopped\u001b[0m Names of stopped jobs, if job con‐\u001b[m\r\n                              trol is active.\u001b[m\r\n                      \u001b[1muser\u001b[0m    Use"]
[3625.371155, "o", "r names.  May "]
[3625.371174, "o", "also be specified\u001b[m\r\n                              as \u001b[1m-u\u001b[0m.\u001b[m\r\n                      \u001b[1mvariable\u001b[0m\u001b[m\r\n                              Names of all shell variables.  May\u001b[m\r\n                              also be specified as \u001b[1m-v\u001b[0m.\u001b[m\r\n              \u001b[1m-C\u001b[0m \u001b[4mcommand\u001b[24m\u001b[m\r\n                      \u001b[4mcommand\u001b[24m is executed in a subshell environ‐\u001b[m\r\n                      ment, and its output is used as the possi‐\u001b[m\r\n                      ble  completions.  Arguments are passed as\u001b[m\r\n                      with the \u001b[1m-F\u001b[0m option.\u001b[m\r\n              \u001b[1m-F\u001b[0m \u001b[4mfunction\u001b[24m\u001b[m\r\n\u001b[7m Manual page bash(1) line 5695 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.402724, "o", "\r\u001b[K"]
[3625.402927, "o", "                      The shell function \u001b[4mfunction\u001b[24m is executed in\u001b[m\r\n                      the  current  shell environment.  When the\u001b[m\r\n                      function is executed, the  first  argument\u001b[m\r\n                      (\u001b[1m$1\u001b[0m)  is the name of the command whose ar‐\u001b[m\r\n                      guments are being  completed,  the  second\u001b[m\r\n                      argument (\u001b[1m$2\u001b[0m) is the word being completed,\u001b[m\r\n                      and the third argument (\u001b[1m$3\u001b[0m)  is  the  word\u001b[m\r\n                      preceding  the word being completed on the\u001b[m\r\n                      current command line.  When  it  finishes,\u001b[m\r\n                      the  possible  completions  are  retrieved\u001b[m\r\n                      from the  value  of  the  \u001b[1mCOMPREPLY\u001b[0m  array\u001b[m\r\n                      variable.\u001b[m\r\n              \u001b[1m-G\u001b[0m \u001b[4mglobpat\u001b[24m\u001b[m\r\n                      The  pathname expansion pattern \u001b[4mglobpat\u001b[24m is\u001b[m\r\n                      expanded to generate the possible  compl"]
[3625.402943, "o", "e‐\u001b[m\r\n                      tions.\u001b[m\r\n              \u001b[1m-P\u001b[0m \u001b[4mprefix\u001b[24m\u001b[m\r\n                      \u001b[4mprefix\u001b[24m  is  added at the beginning of each\u001b[m\r\n                      possible completion after  all  other  op‐\u001b[m\r\n                      tions have been applied.\u001b[m\r\n              \u001b[1m-S\u001b[0m \u001b[4msuffix\u001b[24m\u001b[m\r\n                      \u001b[4msuffix\u001b[24m  is  appended to each possible com‐\u001b[m\r\n                      pletion after all other options have  been\u001b[m\r\n                      applied.\u001b[m\r\n              \u001b[1m-W\u001b[0m \u001b[4mwordlist\u001b[24m\u001b[m\r\n                      The \u001b[4mwordlist\u001b[24m is split using the characters\u001b[m\r\n\u001b[7m Manual page bash(1) line 5721 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.433876, "o", "\r\u001b[K"]
[3625.433992, "o", "                      in the \u001b[1mIFS\u001b[0m special variable as delimiters,\u001b[m\r\n                      and   each  resultant  word  is  expanded.\u001b[m\r\n                      Shell quoting is honored within  \u001b[4mwordlist\u001b[24m,\u001b[m\r\n                      in  order  to  provide a mechanism for the\u001b[m\r\n                      words to contain shell  metacharacters  or\u001b[m\r\n                      characters  in the value of \u001b[1mIFS\u001b[0m.  The pos‐\u001b[m\r\n                      sible completions are the members  of  the\u001b[m\r\n                      resultant  list which match the word being\u001b[m\r\n                      completed.\u001b[m\r\n              \u001b[1m-X\u001b[0m \u001b[4mfilterpat\u001b[24m\u001b[m\r\n                      \u001b[4mfilterpat\u001b[24m is a pattern as used  for  path‐\u001b[m\r\n                      name expansion.  It is applied to the list\u001b[m\r\n                      of possible completions generated  by  the\u001b[m\r\n                      preceding  options and arguments, and each\u001b[m\r\n                      completion matching \u001b[4mfilterpat\u001b[24m  is  removed"]
[3625.434014, "o", "\u001b[m\r\n                      from  the  list.  A leading \u001b[1m!\u001b[0m in \u001b[4mfilterpat\u001b[24m\u001b[m\r\n                      negates the pattern;  in  this  case,  any\u001b[m\r\n                      completion  not  matching \u001b[4mfilterpat\u001b[24m is re‐\u001b[m\r\n                      moved.\u001b[m\r\n\u001b[m\r\n              The return value is true unless an invalid  option\u001b[m\r\n              is supplied, an option other than \u001b[1m-p\u001b[0m or \u001b[1m-r\u001b[0m is sup‐\u001b[m\r\n              plied without a \u001b[4mname\u001b[24m argument, an attempt is  made\u001b[m\r\n              to  remove  a  completion specification for a \u001b[4mname\u001b[24m\u001b[m\r\n              for which no specification exists, or an error oc‐\u001b[m\r\n              curs adding a completion specification.\u001b[m\r\n\u001b[7m Manual page bash(1) line 5747 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.465548, "o", "\r\u001b[K"]
[3625.46559, "o", "\u001b[m\r\n       \u001b[1mcompopt\u001b[0m [\u001b[1m-o\u001b[0m \u001b[4moption\u001b[24m] [\u001b[1m-DEI\u001b[0m] [\u001b[1m+o\u001b[0m \u001b[4moption\u001b[24m] [\u001b[4mname\u001b[24m]\u001b[m\r\n              Modify  completion options for each \u001b[4mname\u001b[24m according\u001b[m\r\n              to the \u001b[4moption\u001b[24ms,  or  for  the  currently-executing\u001b[m\r\n              completion  if  no  \u001b[4mname\u001b[24ms are supplied.  If no \u001b[4mop‐\u001b[24m\u001b[m\r\n              \u001b[4mtion\u001b[24ms are given, display  the  completion  options\u001b[m\r\n              for each \u001b[4mname\u001b[24m or the current completion.  The pos‐\u001b[m\r\n              sible values of \u001b[4moption\u001b[24m are  those  valid  for  the\u001b[m\r\n              \u001b[1mcomplete\u001b[0m  builtin  described above.  The \u001b[1m-D\u001b[0m option\u001b[m\r\n              indicates that other supplied options should apply\u001b[m\r\n              to  the  ``default''  command completion; that is,\u001b[m\r\n              completion attempted on a  command  for  which  no\u001b[m\r\n              completion  has  previously  been defined.  The \u001b[1m-E\u001b[0m\u001b[m\r\n              option  indicates  that  other  supplie"]
[3625.465598, "o", "d   options\u001b"]
[3625.465689, "o", "[m\r\n              should apply to ``empty'' command completion; that\u001b[m\r\n              is, completion attempted on a blank line.  The  \u001b[1m-I\u001b[0m\u001b[m\r\n              option   indicates  that  other  supplied  options\u001b[m\r\n              should apply to completion on the initial  non-as‐\u001b[m\r\n              signment  word on the line, or after a command de‐\u001b[m\r\n              limiter such as \u001b[1m;\u001b[0m or \u001b[1m|\u001b[0m, which is  usually  command\u001b[m\r\n              name completion.\u001b[m\r\n\u001b[m\r\n              The  return value is true unless an invalid option\u001b[m\r\n              is supplied, an attempt is made to modify the  op‐\u001b[m\r\n              tions  for a \u001b[4mname\u001b[24m for which no completion specifi‐\u001b[m\r\n              cation exists, or an output error occurs.\u001b[m\r\n\u001b[7m Manual page bash(1) line 5773 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.496979, "o", "\r\u001b[K"]
[3625.497118, "o", "\u001b[m\r\n       \u001b[1mcontinue\u001b[0m [\u001b[4mn\u001b[24m]\u001b[m\r\n              Resume the next iteration of  the  enclosing  \u001b[1mfor\u001b[0m,\u001b[m\r\n              \u001b[1mwhile\u001b[0m,  \u001b[1muntil\u001b[0m, or \u001b[1mselect\u001b[0m loop.  If \u001b[4mn\u001b[24m is specified,\u001b[m\r\n              resume at the \u001b[4mn\u001b[24mth enclosing loop.  \u001b[4mn\u001b[24m must be ≥  1.\u001b[m\r\n              If  \u001b[4mn\u001b[24m  is  greater  than  the  number of enclosing\u001b[m\r\n              loops, the last enclosing loop (the  ``top-level''\u001b[m\r\n              loop)  is resumed.  The return value is 0 unless \u001b[4mn\u001b[24m\u001b[m\r\n              is not greater than or equal to 1.\u001b[m\r\n\u001b[m\r\n       \u001b[1mdeclare\u001b[0m [\u001b[1m-aAfFgiIlnrtux\u001b[0m] [\u001b[1m-p\u001b[0m] [\u001b[4mname\u001b[24m[=\u001b[4mvalue\u001b[24m] ...]\u001b[m\r\n       \u001b[1mtypeset\u001b[0m [\u001b[1m-aAfFgiIlnrtux\u001b[0m] [\u001b[1m-p\u001b[0m] [\u001b[4mname\u001b[24m[=\u001b[4mvalue\u001b[24m] ...]\u001b[m\r\n              Declare variables and/or give them attributes.  If\u001b[m\r\n              no  \u001b[4mname\u001b[24ms  are  given  then  display the values of\u001b[m\r\n              variables.  The \u001b[1m-p\u001b[0m option  will  display  the  at‐\u001b["]
[3625.497128, "o", "m\r\n              tributes and values of each \u001b[4mname\u001b[24m.  When \u001b[1m-p\u001b[0m is used\u001b[m\r\n              with \u001b[4mname\u001b[24m  arguments,  additional  options,  other\u001b[m\r\n              than  \u001b[1m-f\u001b[0m and \u001b[1m-F\u001b[0m, are ignored.  When \u001b[1m-p\u001b[0m is supplied\u001b[m\r\n              without \u001b[4mname\u001b[24m arguments, it will  display  the  at‐\u001b[m\r\n              tributes  and  values  of all variables having the\u001b[m\r\n              attributes specified by  the  additional  options.\u001b[m\r\n              If  no other options are supplied with \u001b[1m-p\u001b[0m, \u001b[1mdeclare\u001b[0m\u001b[m\r\n              will display the  attributes  and  values  of  all\u001b[m\r\n              shell  variables.  The \u001b[1m-f\u001b[0m option will restrict the\u001b[m\r\n              display to shell functions.   The  \u001b[1m-F\u001b[0m  option  in‐\u001b[m\r\n              hibits  the  display of function definitions; only\u001b[m\r\n\u001b[7m Manual page bash(1) line 5799 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.528595, "o", "\r\u001b[K"]
[3625.528781, "o", "              the function name and attributes are printed.   If\u001b[m\r\n              the  \u001b[1mextdebug\u001b[0m shell option is enabled using \u001b[1mshopt\u001b[0m,\u001b[m\r\n              the source file name and line  number  where  each\u001b[m\r\n              \u001b[4mname\u001b[24m is defined are displayed as well.  The \u001b[1m-F\u001b[0m op‐\u001b[m\r\n              tion implies \u001b[1m-f\u001b[0m.  The \u001b[1m-g\u001b[0m option  forces  variables\u001b[m\r\n              to  be  created  or  modified at the global scope,\u001b[m\r\n              even when \u001b[1mdeclare\u001b[0m is executed in a shell function.\u001b[m\r\n              It  is  ignored in all other cases.  The \u001b[1m-I\u001b[0m option\u001b[m\r\n              causes local variables to inherit  the  attributes\u001b[m\r\n              (except  the  \u001b[4mnameref\u001b[24m  attribute) and value of any\u001b[m\r\n              existing variable with the same  \u001b[4mname\u001b[24m  at  a  sur‐\u001b[m\r\n              rounding scope.  If there is no existing variable,\u001b[m\r\n              the local variable is initially unset.   The  fol‐\u001b[m\r\n              lowing  options  can be "]
[3625.528806, "o", "used to restrict output to\u001b[m\r\n              variables with the specified attribute or to  give\u001b[m\r\n              variables attributes:\u001b[m\r\n              \u001b[1m-a\u001b[0m     Each \u001b[4mname\u001b[24m is an indexed array variable (see\u001b[m\r\n                     \u001b[1mArrays\u001b[0m above).\u001b[m\r\n              \u001b[1m-A\u001b[0m     Each \u001b[4mname\u001b[24m is an associative array  variable\u001b[m\r\n                     (see \u001b[1mArrays\u001b[0m above).\u001b[m\r\n              \u001b[1m-f\u001b[0m     Use function names only.\u001b[m\r\n              \u001b[1m-i\u001b[0m     The  variable  is  treated  as  an integer;\u001b[m\r\n                     arithmetic evaluation (see \u001b[1mARITHMETIC\u001b[0m \u001b[1mEVAL‐\u001b[0m\u001b[m\r\n                     \u001b[1mUATION\u001b[0m  above)  is performed when the vari‐\u001b[m\r\n                     able is assigned a value.\u001b[m\r\n              \u001b[1m-l\u001b[0m     When the variable is assigned a value,  all\u001b[m\r\n\u001b[7m Manual page bash(1) line 5825 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.561692, "o", "\r\u001b[K                     upper-case   characters  are  converted  to\u001b[m\r\n                     lower-case.  The  upper-case  attribute  is\u001b[m\r\n                     disabled.\u001b[m\r\n              \u001b[1m-n\u001b[0m     Give  each \u001b[4mname\u001b[24m the \u001b[4mnameref\u001b[24m attribute, mak‐\u001b[m\r\n                     ing it a name reference  to  another  vari‐\u001b[m\r\n                     able.   That  other  variable is defined by\u001b[m\r\n                     the value of \u001b[4mname\u001b[24m.  All references, assign‐\u001b[m\r\n                     ments, and attribute modifications to \u001b[4mname\u001b[24m,\u001b[m\r\n                     except those using or changing the  \u001b[1m-n\u001b[0m  at‐\u001b[m\r\n                     tribute  itself, are performed on the vari‐\u001b[m\r\n                     able  referenced  by  \u001b[4mname\u001b[24m's  value.    The\u001b[m\r\n                     nameref  attribute cannot be applied to ar‐\u001b[m\r\n                     ray variables.\u001b[m\r\n              \u001b[1m-r\u001b[0m     Make \u001b[4mname\u001b[24ms readonly.   These  names  cannot\u001b[m\r\n                     then  "]
[3625.561782, "o", "be  assigned valu"]
[3625.561836, "o", "es by subsequent as‐\u001b[m\r\n                     signment statements or unset.\u001b[m\r\n              \u001b[1m-t\u001b[0m     Give each \u001b[4mname\u001b[24m the \u001b[4mtrace\u001b[24m attribute.  Traced\u001b[m\r\n                     functions  inherit  the  \u001b[1mDEBUG\u001b[0m  and  \u001b[1mRETURN\u001b[0m\u001b[m\r\n                     traps from the calling  shell.   The  trace\u001b[m\r\n                     attribute  has no special meaning for vari‐\u001b[m\r\n                     ables.\u001b[m\r\n              \u001b[1m-u\u001b[0m     When the variable is assigned a value,  all\u001b[m\r\n                     lower-case  characters are converted to up‐\u001b[m\r\n                     per-case.  The lower-case attribute is dis‐\u001b[m\r\n                     abled.\u001b[m\r\n              \u001b[1m-x\u001b[0m     Mark  \u001b[4mname\u001b[24ms  for  export to subsequent com‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 5851 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.591097, "o", "\r\u001b[K                     mands via the environment.\u001b[m\r\n\u001b[m\r\n              Using `+' instead of `-' turns off  the  attribute\u001b[m\r\n              instead,  with  the  exceptions that \u001b[1m+a\u001b[0m and \u001b[1m+A\u001b[0m may\u001b[m\r\n              not be used to destroy array variables and \u001b[1m+r\u001b[0m will\u001b[m\r\n              not remove the readonly attribute.  When used in a\u001b[m\r\n              function, \u001b[1mdeclare\u001b[0m and \u001b[1mtypeset\u001b[0m make each  \u001b[4mname\u001b[24m  lo‐\u001b[m\r\n              cal,  as with the \u001b[1mlocal\u001b[0m command, unless the \u001b[1m-g\u001b[0m op‐\u001b[m\r\n              tion is supplied.  If a variable name is  followed\u001b[m\r\n              by  =\u001b[4mvalue\u001b[24m,  the  value  of the variable is set to\u001b[m\r\n              \u001b[4mvalue\u001b[24m.  When using \u001b[1m-a\u001b[0m or \u001b[1m-A\u001b[0m and the  compound  as‐\u001b[m\r\n              signment  syntax  to create array variables, addi‐\u001b[m\r\n              tional attributes do not take effect until  subse‐\u001b[m\r\n"]
[3625.591211, "o", "              quent  assignments.   The return value is 0 unless\u001b[m\r\n              an invalid option is encountered,  an  attempt  is\u001b[m\r\n              made to define a function using ``-f foo=bar'', an\u001b[m\r\n              attempt is made to assign a value  to  a  readonly\u001b[m\r\n              variable,  an attempt is made to assign a value to\u001b[m\r\n              an array variable without using the  compound  as‐\u001b[m\r\n              signment  syntax  (see  \u001b[1mArrays\u001b[0m  above), one of the\u001b[m\r\n              \u001b[4mnames\u001b[24m is not a valid shell variable name,  an  at‐\u001b[m\r\n              tempt  is  made  to turn off readonly status for a\u001b[m\r\n              readonly variable, an attempt is made to turn  off\u001b[m\r\n              array  status for an array variable, or an attempt\u001b[m\r\n              is made to display a  non-existent  function  with\u001b[m\r\n              \u001b[1m-f\u001b[0m.\u001b[m\r\n\u001b[7m Manual page bash(1) line 5877 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.621599, "o", "\r\u001b[K"]
[3625.621713, "o", "\u001b[m\r\n       \u001b[1mdirs\u001b[0m \u001b[1m[-clpv]\u001b[0m \u001b[1m[+\u001b[0m\u001b[4mn\u001b[24m\u001b[1m]\u001b[0m \u001b[1m[-\u001b[0m\u001b[4mn\u001b[24m\u001b[1m]\u001b[0m\u001b[m\r\n              Without  options,  displays  the list of currently\u001b[m\r\n              remembered directories.  The default display is on\u001b[m\r\n              a  single  line  with directory names separated by\u001b[m\r\n              spaces.  Directories are added to  the  list  with\u001b[m\r\n              the  \u001b[1mpushd\u001b[0m  command;  the \u001b[1mpopd\u001b[0m command removes en‐\u001b[m\r\n              tries from the list.  The current directory is al‐\u001b[m\r\n              ways the first directory in the stack.\u001b[m\r\n              \u001b[1m-c\u001b[0m     Clears  the directory stack by deleting all\u001b[m\r\n                     of the entries.\u001b[m\r\n              \u001b[1m-l\u001b[0m     Produces a listing  using  full  pathnames;\u001b[m\r\n                     the  default listing format uses a tilde to\u001b[m\r\n                     denote the home directory.\u001b[m\r\n              \u001b[1m-p\u001b[0m     Print the directory stack  with  one  entry\u001b[m\r\n                     per line.\u001b[m\r\n"]
[3625.621747, "o", "              \u001b[1m-v\u001b[0m     Print  the  directory  stack with one entry\u001b[m\r\n                     per line, prefixing each entry with its in‐\u001b[m\r\n                     dex in the stack.\u001b[m\r\n              \u001b[1m+\u001b[0m\u001b[4mn\u001b[24m     Displays  the  \u001b[4mn\u001b[24mth  entry counting from the\u001b[m\r\n                     left of the list shown by \u001b[1mdirs\u001b[0m when invoked\u001b[m\r\n                     without options, starting with zero.\u001b[m\r\n              \u001b[1m-\u001b[0m\u001b[4mn\u001b[24m     Displays  the  \u001b[4mn\u001b[24mth  entry counting from the\u001b[m\r\n                     right of the list shown by  \u001b[1mdirs\u001b[0m  when  in‐\u001b[m\r\n                     voked without options, starting with zero.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page bash(1) line 5903 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.653653, "o", "\r\u001b[K"]
[3625.653708, "o", "              The  return value is 0 unless an invalid option is\u001b[m\r\n              supplied or \u001b[4mn\u001b[24m indexes beyond the end of the direc‐\u001b[m\r\n              tory stack.\u001b[m\r\n\u001b[m\r\n       \u001b[1mdisown\u001b[0m [\u001b[1m-ar\u001b[0m] [\u001b[1m-h\u001b[0m] [\u001b[4mjobspec\u001b[24m ... | \u001b[4mpid\u001b[24m ... ]\u001b[m\r\n              Without  options, remove each \u001b[4mjobspec\u001b[24m from the ta‐\u001b[m\r\n              ble of active jobs.  If \u001b[4mjobspec\u001b[24m  is  not  present,\u001b[m\r\n              and  neither the \u001b[1m-a\u001b[0m nor the \u001b[1m-r\u001b[0m option is supplied,\u001b[m\r\n              the \u001b[4mcurrent\u001b[24m \u001b[4mjob\u001b[24m is used.   If  the  \u001b[1m-h\u001b[0m  option  is\u001b[m\r\n              given, each \u001b[4mjobspec\u001b[24m is not removed from the table,\u001b[m\r\n              but is marked so that \u001b[1mSIGHUP\u001b[0m is not  sent  to  the\u001b[m\r\n              job if the shell receives a \u001b[1mSIGHUP\u001b[0m.  If no \u001b[4mjobspec\u001b[24m\u001b[m\r\n              is supplied, the \u001b[1m-a\u001b[0m option means to remove or mark\u001b[m\r\n              all jobs; the \u001b[1m-r\u001b[0m option without a \u001b[4mjobspec\u001b[24m argument\u001b[m\r\n  "]
[3625.653713, "o", "            restricts operation to running jobs.   The  return\u001b[m\r\n              value  is  0  unless  a \u001b[4mjobspec\u001b[24m does not specify a\u001b[m\r\n              valid job.\u001b[m\r\n\u001b[m\r\n       \u001b[1mecho\u001b[0m [\u001b[1m-neE\u001b[0m] [\u001b[4marg\u001b[24m ...]\u001b[m\r\n              Output the \u001b[4marg\u001b[24ms, separated by spaces, followed  by\u001b[m\r\n              a  newline.  The return status is 0 unless a write\u001b[m\r\n              error occurs.  If \u001b[1m-n\u001b[0m is  specified,  the  trailing\u001b[m\r\n              newline is suppressed.  If the \u001b[1m-e\u001b[0m option is given,\u001b[m\r\n              interpretation of the following  backslash-escaped\u001b[m\r\n              characters is enabled.  The \u001b[1m-E\u001b[0m option disables the\u001b[m\r\n              interpretation of these escape characters, even on\u001b[m\r\n\u001b[7m Manual page bash(1) line 5929 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.685109, "o", "\r\u001b[K"]
[3625.685192, "o", "              systems  where  they  are  interpreted by default.\u001b[m\r\n              The \u001b[1mxpg_echo\u001b[0m shell option may be used  to  dynami‐\u001b[m\r\n              cally  determine whether or not \u001b[1mecho\u001b[0m expands these\u001b[m\r\n              escape characters by default.  \u001b[1mecho\u001b[0m does  not  in‐\u001b[m\r\n              terpret  \u001b[1m--\u001b[0m  to mean the end of options.  \u001b[1mecho\u001b[0m in‐\u001b[m\r\n              terprets the following escape sequences:\u001b[m\r\n              \u001b[1m\\a\u001b[0m     alert (bell)\u001b[m\r\n              \u001b[1m\\b\u001b[0m     backspace\u001b[m\r\n              \u001b[1m\\c\u001b[0m     suppress further output\u001b[m\r\n              \u001b[1m\\e\u001b[0m\u001b[m\r\n              \u001b[1m\\E\u001b[0m     an escape character\u001b[m\r\n              \u001b[1m\\f\u001b[0m     form feed\u001b[m\r\n              \u001b[1m\\n\u001b[0m     new line\u001b[m\r\n              \u001b[1m\\r\u001b[0m     carriage return\u001b[m\r\n              \u001b[1m\\t\u001b[0m     horizontal tab\u001b[m\r\n              \u001b[1m\\v\u001b[0m     vertical tab\u001b[m\r\n              \u001b[1m\\\\\u001b[0m     backslash\u001b[m\r\n              \u001b[1m\\0\u001b[0m\u001b[4mnnn\u001b[24m  the eight-bit character whose value i"]
[3625.68521, "o", "s  the\u001b[m\r\n                     octal  value  \u001b[4mnnn\u001b[24m (zero to three octal dig‐\u001b[m\r\n                     its)\u001b[m\r\n              \u001b[1m\\x\u001b[0m\u001b[4mHH\u001b[24m   the eight-bit character whose value is  the\u001b[m\r\n                     hexadecimal  value  \u001b[4mHH\u001b[24m (one or two hex dig‐\u001b[m\r\n                     its)\u001b[m\r\n              \u001b[1m\\u\u001b[0m\u001b[4mHHHH\u001b[24m the Unicode (ISO/IEC 10646) character whose\u001b[m\r\n                     value is the hexadecimal value \u001b[4mHHHH\u001b[24m (one to\u001b[m\r\n                     four hex digits)\u001b[m\r\n\u001b[7m Manual page bash(1) line 5955 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.716515, "o", "\r\u001b[K"]
[3625.716541, "o", "              \u001b[1m\\U\u001b[0m\u001b[4mHHHHHHHH\u001b[24m\u001b[m\r\n                     the Unicode (ISO/IEC 10646) character whose\u001b[m\r\n                     value  is  the  hexadecimal  value \u001b[4mHHHHHHHH\u001b[24m\u001b[m\r\n                     (one to eight hex digits)\u001b[m\r\n\u001b[m\r\n       \u001b[1menable\u001b[0m [\u001b[1m-a\u001b[0m] [\u001b[1m-dnps\u001b[0m] [\u001b[1m-f\u001b[0m \u001b[4mfilename\u001b[24m] [\u001b[4mname\u001b[24m ...]\u001b[m\r\n              Enable and disable builtin shell  commands.   Dis‐\u001b[m\r\n              abling  a  builtin allows a disk command which has\u001b[m\r\n              the same name as a shell builtin  to  be  executed\u001b[m\r\n              without  specifying  a  full pathname, even though\u001b[m\r\n              the shell normally searches  for  builtins  before\u001b[m\r\n              disk  commands.   If \u001b[1m-n\u001b[0m is used, each \u001b[4mname\u001b[24m is dis‐\u001b[m\r\n              abled; otherwise, \u001b[4mnames\u001b[24m are enabled.  For example,\u001b[m\r\n              to  use the \u001b[1mtest\u001b[0m binary found via the \u001b[1mPATH\u001b[0m instead\u001b[m\r\n              of the shell  builtin  version,  run  ``enable  -n\u001b[m\r\n  "]
[3625.716545, "o", "            te"]
[3625.716566, "o", "st''.   The  \u001b[1m-f\u001b[0m  option  means  to  load the new\u001b[m\r\n              builtin command \u001b[4mname\u001b[24m from shared object  \u001b[4mfilename\u001b[24m,\u001b[m\r\n              on  systems  that  support  dynamic loading.  Bash\u001b[m\r\n              will use  the  value  of  the  \u001b[1mBASH_LOADABLES_PATH\u001b[0m\u001b[m\r\n              variable  as a colon-separated list of directories\u001b[m\r\n              in which to search for \u001b[4mfilename\u001b[24m.  The  default  is\u001b[m\r\n              system-dependent.   The  \u001b[1m-d\u001b[0m  option  will delete a\u001b[m\r\n              builtin previously loaded with \u001b[1m-f\u001b[0m.  If no \u001b[4mname\u001b[24m ar‐\u001b[m\r\n              guments  are  given,  or  if the \u001b[1m-p\u001b[0m option is sup‐\u001b[m\r\n              plied, a list of shell builtins is printed.   With\u001b[m\r\n              no  other  option  arguments, the list consists of\u001b[m\r\n\u001b[7m Manual page bash(1) line 5981 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.748005, "o", "\r\u001b[K"]
[3625.748119, "o", "              all enabled shell builtins.  If  \u001b[1m-n\u001b[0m  is  supplied,\u001b[m\r\n              only disabled builtins are printed.  If \u001b[1m-a\u001b[0m is sup‐\u001b[m\r\n              plied, the list  printed  includes  all  builtins,\u001b[m\r\n              with  an  indication of whether or not each is en‐\u001b[m\r\n              abled.  If \u001b[1m-s\u001b[0m  is  supplied,  the  output  is  re‐\u001b[m\r\n              stricted to the POSIX \u001b[4mspecial\u001b[24m builtins.  If no op‐\u001b[m\r\n              tions are supplied and  a  \u001b[4mname\u001b[24m  is  not  a  shell\u001b[m\r\n              builtin,  \u001b[1menable\u001b[0m  will attempt to load \u001b[4mname\u001b[24m from a\u001b[m\r\n              shared object named \u001b[4mname\u001b[24m, as if the  command  were\u001b[m\r\n              ``enable -f \u001b[4mname\u001b[24m \u001b[4mname\u001b[24m .  The return value is 0 un‐\u001b[m\r\n              less a \u001b[4mname\u001b[24m is not a shell builtin or there is  an\u001b[m\r\n              error loading a new builtin from a shared object.\u001b[m\r\n\u001b[m\r\n       \u001b[1meval\u001b[0m [\u001b[4marg\u001b[24m ...]\u001b[m\r\n              The \u001b[4marg\u001b[24ms are read and"]
[3625.748229, "o", " concatenated together into a\u001b[m\r\n              single command.  This command is then read and ex‐\u001b[m\r\n              ecuted  by  the  shell, and its exit status is re‐\u001b[m\r\n              turned as the value of  \u001b[1meval\u001b[0m.   If  there  are  no\u001b[m\r\n              \u001b[4margs\u001b[24m, or only null arguments, \u001b[1meval\u001b[0m returns 0.\u001b[m\r\n\u001b[m\r\n       \u001b[1mexec\u001b[0m [\u001b[1m-cl\u001b[0m] [\u001b[1m-a\u001b[0m \u001b[4mname\u001b[24m] [\u001b[4mcommand\u001b[24m [\u001b[4marguments\u001b[24m]]\u001b[m\r\n              If  \u001b[4mcommand\u001b[24m  is  specified, it replaces the shell.\u001b[m\r\n              No new process is created.  The  \u001b[4marguments\u001b[24m  become\u001b[m\r\n              the  arguments  to  \u001b[4mcommand\u001b[24m.   If the \u001b[1m-l\u001b[0m option is\u001b[m\r\n              supplied, the shell places a dash at the beginning\u001b[m\r\n              of the zeroth argument passed to \u001b[4mcommand\u001b[24m.  This is\u001b[m\r\n\u001b[7m Manual page bash(1) line 6007 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.779237, "o", "\r\u001b[K"]
[3625.779364, "o", "              what \u001b[4mlogin\u001b[24m(1) does.  The \u001b[1m-c\u001b[0m option causes  \u001b[4mcommand\u001b[24m\u001b[m\r\n              to  be  executed with an empty environment.  If \u001b[1m-a\u001b[0m\u001b[m\r\n              is supplied, the shell passes \u001b[4mname\u001b[24m as  the  zeroth\u001b[m\r\n              argument to the executed command.  If \u001b[4mcommand\u001b[24m can‐\u001b[m\r\n              not be executed for some reason, a non-interactive\u001b[m\r\n              shell  exits,  unless the \u001b[1mexecfail\u001b[0m shell option is\u001b[m\r\n              enabled.  In that case, it  returns  failure.   An\u001b[m\r\n              interactive shell returns failure if the file can‐\u001b[m\r\n              not be executed.  A subshell exits unconditionally\u001b[m\r\n              if  \u001b[1mexec\u001b[0m  fails.  If \u001b[4mcommand\u001b[24m is not specified, any\u001b[m\r\n              redirections take effect in the current shell, and\u001b[m\r\n              the return status is 0.  If there is a redirection\u001b[m\r\n              error, the return status is 1.\u001b[m\r\n\u001b[m\r\n       \u001b[1mexit\u001b[0m [\u001b[4mn\u001b[24m]\u001b[m\r\n              Cause the "]
[3625.779379, "o", "shell to exit with a status of \u001b[4mn\u001b[24m.  If  \u001b[4mn\u001b[24m\u001b[m\r\n              is  omitted,  the  exit status is that of the last\u001b[m\r\n              command executed.  A trap on \u001b[1mEXIT\u001b[0m is executed  be‐\u001b[m\r\n              fore the shell terminates.\u001b[m\r\n\u001b[m\r\n       \u001b[1mexport\u001b[0m [\u001b[1m-fn\u001b[0m] [\u001b[4mname\u001b[24m[=\u001b[4mword\u001b[24m]] ...\u001b[m\r\n       \u001b[1mexport\u001b[0m \u001b[1m-p\u001b[0m\u001b[m\r\n              The supplied \u001b[4mnames\u001b[24m are marked for automatic export\u001b[m\r\n              to the environment of subsequently  executed  com‐\u001b[m\r\n              mands.  If the \u001b[1m-f\u001b[0m option is given, the \u001b[4mnames\u001b[24m refer\u001b[m\r\n              to functions.  If no \u001b[4mnames\u001b[24m are given, or if the \u001b[1m-p\u001b[0m\u001b[m\r\n\u001b[7m Manual page bash(1) line 6033 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.809993, "o", "\r\u001b[K"]
[3625.810208, "o", "              option  is  supplied,  a  list of names of all ex‐\u001b[m\r\n              ported variables is printed.  The \u001b[1m-n\u001b[0m option causes\u001b[m\r\n              the  export property to be removed from each \u001b[4mname\u001b[24m.\u001b[m\r\n              If a variable name is followed by =\u001b[4mword\u001b[24m, the value\u001b[m\r\n              of the variable is set to \u001b[4mword\u001b[24m.  \u001b[1mexport\u001b[0m returns an\u001b[m\r\n              exit status of 0 unless an invalid option  is  en‐\u001b[m\r\n              countered,  one  of the \u001b[4mnames\u001b[24m is not a valid shell\u001b[m\r\n              variable name, or \u001b[1m-f\u001b[0m is supplied with a \u001b[4mname\u001b[24m  that\u001b[m\r\n              is not a function.\u001b[m\r\n\u001b[m\r\n       \u001b[1mfc\u001b[0m [\u001b[1m-e\u001b[0m \u001b[4mename\u001b[24m] [\u001b[1m-lnr\u001b[0m] [\u001b[4mfirst\u001b[24m] [\u001b[4mlast\u001b[24m]\u001b[m\r\n       \u001b[1mfc\u001b[0m \u001b[1m-s\u001b[0m [\u001b[4mpat\u001b[24m=\u001b[4mrep\u001b[24m] [\u001b[4mcmd\u001b[24m]\u001b[m\r\n              The  first  form  selects a range of commands from\u001b[m\r\n              \u001b[4mfirst\u001b[24m to \u001b[4mlast\u001b[24m from the history list  and  displays\u001b[m\r\n              or edits and "]
[3625.810223, "o", "re-executes them.  \u001b[4mFirst\u001b[24m and \u001b[4mlast\u001b[24m may\u001b[m\r\n              be specified as a string (to locate the last  com‐\u001b[m\r\n              mand  beginning  with  that string) or as a number\u001b[m\r\n              (an index into the history list, where a  negative\u001b[m\r\n              number  is used as an offset from the current com‐\u001b[m\r\n              mand number).  When listing, a \u001b[4mfirst\u001b[24m or \u001b[4mlast\u001b[24m of  0\u001b[m\r\n              is  equivalent  to  -1 and -0 is equivalent to the\u001b[m\r\n              current command (usually the \u001b[1mfc\u001b[0m  command);  other‐\u001b[m\r\n              wise  0 is equivalent to -1 and -0 is invalid.  If\u001b[m\r\n              \u001b[4mlast\u001b[24m is not specified, it is set  to  the  current\u001b[m\r\n              command  for listing (so that ``fc -l -10'' prints\u001b[m\r\n              the last 10 commands) and to \u001b[4mfirst\u001b[24m otherwise.   If\u001b[m\r\n\u001b[7m Manual page bash(1) line 6059 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.841413, "o", "\r\u001b[K"]
[3625.841496, "o", "              \u001b[4mfirst\u001b[24m  is not specified, it is set to the previous\u001b[m\r\n              command for editing and -16 for listing.\u001b[m\r\n\u001b[m\r\n              The \u001b[1m-n\u001b[0m option suppresses the command numbers  when\u001b[m\r\n              listing.   The \u001b[1m-r\u001b[0m option reverses the order of the\u001b[m\r\n              commands.  If the \u001b[1m-l\u001b[0m option is given, the commands\u001b[m\r\n              are listed on standard output.  Otherwise, the ed‐\u001b[m\r\n              itor given by \u001b[4mename\u001b[24m is invoked on a file  contain‐\u001b[m\r\n              ing  those  commands.   If \u001b[4mename\u001b[24m is not given, the\u001b[m\r\n              value of the \u001b[1mFCEDIT\u001b[0m  variable  is  used,  and  the\u001b[m\r\n              value  of \u001b[1mEDITOR\u001b[0m if \u001b[1mFCEDIT\u001b[0m is not set.  If neither\u001b[m\r\n              variable is set, \u001b[4mvi\u001b[24m is used.  When editing is com‐\u001b[m\r\n              plete,  the  edited  commands  are echoed and exe‐\u001b[m\r\n              cuted.\u001b[m\r\n\u001b[m"]
[3625.841535, "o", "\r\n              In the second form, \u001b[4mcommand\u001b[24m is  re-executed  after\u001b[m\r\n              each  instance of \u001b[4mpat\u001b[24m is replaced by \u001b[4mrep\u001b[24m.  \u001b[4mCommand\u001b[24m\u001b[m\r\n              is interpreted the same as \u001b[4mfirst\u001b[24m above.  A  useful\u001b[m\r\n              alias  to  use with this is ``r=\"fc -s\"'', so that\u001b[m\r\n              typing ``r cc'' runs the  last  command  beginning\u001b[m\r\n              with  ``cc'' and typing ``r'' re-executes the last\u001b[m\r\n              command.\u001b[m\r\n\u001b[m\r\n              If the first form is used, the return value  is  0\u001b[m\r\n              unless  an  invalid option is encountered or \u001b[4mfirst\u001b[24m\u001b[m\r\n              or \u001b[4mlast\u001b[24m specify history lines out  of  range.   If\u001b[m\r\n\u001b[7m Manual page bash(1) line 6085 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.873289, "o", "\r\u001b[K"]
[3625.873373, "o", "              the \u001b[1m-e\u001b[0m option is supplied, the return value is the\u001b[m\r\n              value of the last command executed or  failure  if\u001b[m\r\n              an  error  occurs  with the temporary file of com‐\u001b[m\r\n              mands.  If the second form  is  used,  the  return\u001b[m\r\n              status  is that of the command re-executed, unless\u001b[m\r\n              \u001b[4mcmd\u001b[24m does not specify  a  valid  history  line,  in\u001b[m\r\n              which case \u001b[1mfc\u001b[0m returns failure.\u001b[m\r\n\u001b[m\r\n       \u001b[1mfg\u001b[0m [\u001b[4mjobspec\u001b[24m]\u001b[m\r\n              Resume  \u001b[4mjobspec\u001b[24m in the foreground, and make it the\u001b[m\r\n              current job.   If  \u001b[4mjobspec\u001b[24m  is  not  present,  the\u001b[m\r\n              shell's  notion  of  the \u001b[4mcurrent\u001b[24m \u001b[4mjob\u001b[24m is used.  The\u001b[m\r\n              return value is that of the  command  placed  into\u001b[m\r\n              the foreground, or failure if run when job control\u001b[m\r\n              is disabled or, when run with job control enabled,\u001b[m\r\n              if \u001b[4mjobspec\u001b[24m does"]
[3625.873512, "o", " not specify a valid job or \u001b[4mjobspec\u001b[24m\u001b[m\r\n              specifies a job that was started without job  con‐\u001b[m\r\n              trol.\u001b[m\r\n\u001b[m\r\n       \u001b[1mgetopts\u001b[0m \u001b[4moptstring\u001b[24m \u001b[4mname\u001b[24m [\u001b[4marg\u001b[24m \u001b[4m...\u001b[24m]\u001b[m\r\n              \u001b[1mgetopts\u001b[0m is used by shell procedures to parse posi‐\u001b[m\r\n              tional parameters.  \u001b[4moptstring\u001b[24m contains the  option\u001b[m\r\n              characters  to  be  recognized;  if a character is\u001b[m\r\n              followed by a colon, the  option  is  expected  to\u001b[m\r\n              have  an  argument, which should be separated from\u001b[m\r\n              it by white space.  The colon  and  question  mark\u001b[m\r\n\u001b[7m Manual page bash(1) line 6111 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.904312, "o", "\r\u001b[K              characters  may  not be used as option characters.\u001b[m\r\n              Each time it is invoked, \u001b[1mgetopts\u001b[0m places  the  next\u001b[m\r\n              option  in  the  shell variable \u001b[4mname\u001b[24m, initializing\u001b[m\r\n              \u001b[4mname\u001b[24m if it does not exist, and the  index  of  the\u001b[m\r\n              next  argument  to  be processed into the variable\u001b[m\r\n              \u001b[1mOPTIND\u001b[0m.  \u001b[1mOPTIND\u001b[0m is initialized to 1 each time  the\u001b[m\r\n              shell  or  a shell script is invoked.  When an op‐\u001b[m\r\n              tion requires an argument, \u001b[1mgetopts\u001b[0m places that ar‐\u001b[m\r\n              gument  into  the variable \u001b[1mOPTARG\u001b[0m.  The shell does\u001b[m\r\n              not reset \u001b[1mOPTIND\u001b[0m automatically; it must  be  manu‐\u001b[m\r\n              ally  reset  between  multiple  calls  to  \u001b[1mgetopts\u001b[0m\u001b[m\r\n              within the same shell invocation if a new  set  of\u001b[m\r\n              parameters is to be used.\u001b[m\r\n\u001b[m\r\n"]
[3625.904489, "o", "              When  the  end  of options is encountered, \u001b[1mgetopts\u001b[0m\u001b[m\r\n              exits with  a  return  value  greater  than  zero.\u001b[m\r\n              \u001b[1mOPTIND\u001b[0m is set to the index of the first non-option\u001b[m\r\n              argument, and \u001b[4mname\u001b[24m is set to ?.\u001b[m\r\n\u001b[m\r\n              \u001b[1mgetopts\u001b[0m normally parses the positional parameters,\u001b[m\r\n              but  if more arguments are supplied as \u001b[4marg\u001b[24m values,\u001b[m\r\n              \u001b[1mgetopts\u001b[0m parses those instead.\u001b[m\r\n\u001b[m\r\n              \u001b[1mgetopts\u001b[0m can report errors in  two  ways.   If  the\u001b[m\r\n              first  character  of  \u001b[4moptstring\u001b[24m is a colon, \u001b[4msilent\u001b[24m\u001b[m\r\n              error reporting is used.  In normal operation, di‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 6137 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.935943, "o", "\r\u001b[K"]
[3625.935972, "o", "              agnostic messages are printed when invalid options\u001b[m\r\n              or missing option arguments are  encountered.   If\u001b[m\r\n              the variable \u001b[1mOPTERR\u001b[0m is set to 0, no error messages\u001b[m\r\n              will be displayed, even if the first character  of\u001b[m\r\n              \u001b[4moptstring\u001b[24m is not a colon.\u001b[m\r\n\u001b[m\r\n              If  an  invalid  option  is seen, \u001b[1mgetopts\u001b[0m places ?\u001b[m\r\n              into \u001b[4mname\u001b[24m and, if not silent, prints an error mes‐\u001b[m\r\n              sage and unsets \u001b[1mOPTARG\u001b[0m.  If \u001b[1mgetopts\u001b[0m is silent, the\u001b[m\r\n              option character found is placed in \u001b[1mOPTARG\u001b[0m and  no\u001b[m\r\n              diagnostic message is printed.\u001b[m\r\n\u001b[m\r\n              If  a  required argument is not found, and \u001b[1mgetopts\u001b[0m\u001b[m\r\n              is not silent, a question mark (\u001b[1m?\u001b[0m)  is  placed  in\u001b[m\r\n              \u001b[4mname\u001b[24m, \u001b[1mOPTARG\u001b[0m is unset, and a diagnostic message is\u001b[m\r\n              printed.  If \u001b[1mgetopts\u001b[0m is silent, then a  colon  "]
[3625.935981, "o", "(\u001b[1m:\u001b[0m)\u001b[m"]
[3625.936174, "o", "\r\n              is  placed in \u001b[4mname\u001b[24m and \u001b[1mOPTARG\u001b[0m is set to the option\u001b[m\r\n              character found.\u001b[m\r\n\u001b[m\r\n              \u001b[1mgetopts\u001b[0m returns true if an  option,  specified  or\u001b[m\r\n              unspecified,  is  found.   It returns false if the\u001b[m\r\n              end of options is encountered or an error occurs.\u001b[m\r\n\u001b[m\r\n       \u001b[1mhash\u001b[0m [\u001b[1m-lr\u001b[0m] [\u001b[1m-p\u001b[0m \u001b[4mfilename\u001b[24m] [\u001b[1m-dt\u001b[0m] [\u001b[4mname\u001b[24m]\u001b[m\r\n              Each time \u001b[1mhash\u001b[0m is invoked, the  full  pathname  of\u001b[m\r\n              the  command  \u001b[4mname\u001b[24m  is determined by searching the\u001b[m\r\n\u001b[7m Manual page bash(1) line 6163 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.966252, "o", "\r\u001b[K              directories in \u001b[1m$PATH\u001b[0m and remembered.   Any  previ‐\u001b[m\r\n              ously-remembered pathname is discarded.  If the \u001b[1m-p\u001b[0m\u001b[m\r\n              option is supplied, no path search  is  performed,\u001b[m\r\n              and  \u001b[4mfilename\u001b[24m  is used as the full filename of the\u001b[m\r\n              command.  The \u001b[1m-r\u001b[0m option causes the shell to forget\u001b[m\r\n              all  remembered  locations.   The \u001b[1m-d\u001b[0m option causes\u001b[m\r\n              the shell to forget  the  remembered  location  of\u001b[m\r\n              each \u001b[4mname\u001b[24m.  If the \u001b[1m-t\u001b[0m option is supplied, the full\u001b[m\r\n              pathname  to  which  each  \u001b[4mname\u001b[24m   corresponds   is\u001b[m\r\n              printed.   If multiple \u001b[4mname\u001b[24m arguments are supplied\u001b[m\r\n              with \u001b[1m-t\u001b[0m, the \u001b[4mname\u001b[24m is  printed  before  the  hashed\u001b[m\r\n              full  pathname.  The \u001b[1m-l\u001b[0m option causes output to be\u001b[m\r\n              displayed in a format that may be reused as input.\u001b[m\r\n              If  no"]
[3625.96628, "o", "  arguments are "]
[3625.966449, "o", "given, or if only \u001b[1m-l\u001b[0m is sup‐\u001b[m\r\n              plied, information about  remembered  commands  is\u001b[m\r\n              printed.   The return status is true unless a \u001b[4mname\u001b[24m\u001b[m\r\n              is not found or an invalid option is supplied.\u001b[m\r\n\u001b[m\r\n       \u001b[1mhelp\u001b[0m [\u001b[1m-dms\u001b[0m] [\u001b[4mpattern\u001b[24m]\u001b[m\r\n              Display helpful  information  about  builtin  com‐\u001b[m\r\n              mands.   If  \u001b[4mpattern\u001b[24m  is specified, \u001b[1mhelp\u001b[0m gives de‐\u001b[m\r\n              tailed help on all commands matching \u001b[4mpattern\u001b[24m; oth‐\u001b[m\r\n              erwise help for all the builtins and shell control\u001b[m\r\n              structures is printed.\u001b[m\r\n              \u001b[1m-d\u001b[0m     Display a short description of each \u001b[4mpattern\u001b[24m\u001b[m\r\n              \u001b[1m-m\u001b[0m     Display the description of each \u001b[4mpattern\u001b[24m  in\u001b[m\r\n\u001b[7m Manual page bash(1) line 6189 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3625.997234, "o", "\r\u001b[K                     a manpage-like format\u001b[m\r\n              \u001b[1m-s\u001b[0m     Display  only  a  short  usage synopsis for\u001b[m\r\n                     each \u001b[4mpattern\u001b[24m\u001b[m\r\n\u001b[m\r\n              The return status is 0 unless no  command  matches\u001b[m\r\n              \u001b[4mpattern\u001b[24m.\u001b[m\r\n\u001b[m\r\n       \u001b[1mhistory\u001b[0m \u001b[1m[\u001b[0m\u001b[4mn\u001b[24m\u001b[1m]\u001b[0m\u001b[m\r\n       \u001b[1mhistory\u001b[0m \u001b[1m-c\u001b[0m\u001b[m\r\n       \u001b[1mhistory\u001b[0m \u001b[1m-d\u001b[0m \u001b[4moffset\u001b[24m\u001b[m\r\n       \u001b[1mhistory\u001b[0m \u001b[1m-d\u001b[0m \u001b[4mstart\u001b[24m-\u001b[4mend\u001b[24m\u001b[m\r\n       \u001b[1mhistory\u001b[0m \u001b[1m-anrw\u001b[0m [\u001b[4mfilename\u001b[24m]\u001b[m\r\n       \u001b[1mhistory\u001b[0m \u001b[1m-p\u001b[0m \u001b[4marg\u001b[24m [\u001b[4marg\u001b[24m \u001b[4m...\u001b[24m]\u001b[m\r\n       \u001b[1mhistory\u001b[0m \u001b[1m-s\u001b[0m \u001b[4marg\u001b[24m [\u001b[4marg\u001b[24m \u001b[4m...\u001b[24m]\u001b[m\r\n              With  no options, display the command history list\u001b[m\r\n              with line numbers.  Lines listed  with  a  \u001b[1m*\u001b[0m  have\u001b[m\r\n              been  modified.   An  argument of \u001b[4mn\u001b[24m lists only the\u001b[m\r\n              last \u001b[4mn\u001b[24m lines.  If the shell variable  \u001b[1mHISTTIMEFOR"]
[3625.997258, "o", "‐\u001b[0m\u001b[m\r\n          "]
[3625.997348, "o", "    \u001b[1mMAT\u001b[0m  is  set  and not null, it is used as a format\u001b[m\r\n              string for \u001b[4mstrftime\u001b[24m(3) to display the  time  stamp\u001b[m\r\n              associated  with each displayed history entry.  No\u001b[m\r\n              intervening blank is printed between the formatted\u001b[m\r\n              time  stamp  and the history line.  If \u001b[4mfilename\u001b[24m is\u001b[m\r\n              supplied, it is used as the name  of  the  history\u001b[m\r\n              file;  if not, the value of \u001b[1mHISTFILE\u001b[0m is used.  Op‐\u001b[m\r\n              tions, if supplied, have the following meanings:\u001b[m\r\n\u001b[7m Manual page bash(1) line 6215 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.028346, "o", "\r\u001b[K"]
[3626.028565, "o", "              \u001b[1m-c\u001b[0m     Clear the history list by deleting all  the\u001b[m\r\n                     entries.\u001b[m\r\n              \u001b[1m-d\u001b[0m \u001b[4moffset\u001b[24m\u001b[m\r\n                     Delete  the  history entry at position \u001b[4moff‐\u001b[24m\u001b[m\r\n                     \u001b[4mset\u001b[24m.  If \u001b[4moffset\u001b[24m is negative, it  is  inter‐\u001b[m\r\n                     preted  as relative to one greater than the\u001b[m\r\n                     last history position, so negative  indices\u001b[m\r\n                     count back from the end of the history, and\u001b[m\r\n                     an index of -1 refers to the  current  \u001b[1mhis‐\u001b[0m\u001b[m\r\n                     \u001b[1mtory\u001b[0m \u001b[1m-d\u001b[0m command.\u001b[m\r\n              \u001b[1m-d\u001b[0m \u001b[4mstart\u001b[24m-\u001b[4mend\u001b[24m\u001b[m\r\n                     Delete the range of history entries between\u001b[m\r\n                     positions \u001b[4mstart\u001b[24m and \u001b[4mend\u001b[24m, inclusive.   Posi‐\u001b[m\r\n                     tive  and negative values for \u001b[4mstart\u001b[24m and \u001b[4mend\u001b[24m\u001b[m\r\n                     are interpreted as described abo"]
[3626.028583, "o", "ve.\u001b[m\r\n              \u001b[1m-a\u001b[0m     Append the ``new''  history  lines  to  the\u001b[m\r\n                     history  file.  These are history lines en‐\u001b[m\r\n                     tered since the beginning  of  the  current\u001b[m\r\n                     \u001b[1mbash\u001b[0m  session,  but not already appended to\u001b[m\r\n                     the history file.\u001b[m\r\n              \u001b[1m-n\u001b[0m     Read the history  lines  not  already  read\u001b[m\r\n                     from the history file into the current his‐\u001b[m\r\n                     tory list.  These are lines appended to the\u001b[m\r\n                     history  file  since  the  beginning of the\u001b[m\r\n                     current \u001b[1mbash\u001b[0m session.\u001b[m\r\n              \u001b[1m-r\u001b[0m     Read the contents of the history  file  and\u001b[m\r\n\u001b[7m Manual page bash(1) line 6241 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.059747, "o", "\r\u001b[K"]
[3626.059942, "o", "                     append them to the current history list.\u001b[m\r\n              \u001b[1m-w\u001b[0m     Write  the current history list to the his‐\u001b[m\r\n                     tory file, overwriting the  history  file's\u001b[m\r\n                     contents.\u001b[m\r\n              \u001b[1m-p\u001b[0m     Perform history substitution on the follow‐\u001b[m\r\n                     ing \u001b[4margs\u001b[24m and  display  the  result  on  the\u001b[m\r\n                     standard  output.   Does  not store the re‐\u001b[m\r\n                     sults in the history list.  Each  \u001b[4marg\u001b[24m  must\u001b[m\r\n                     be  quoted to disable normal history expan‐\u001b[m\r\n                     sion.\u001b[m\r\n              \u001b[1m-s\u001b[0m     Store the \u001b[4margs\u001b[24m in the  history  list  as  a\u001b[m\r\n                     single entry.  The last command in the his‐\u001b[m\r\n                     tory list is removed before  the  \u001b[4margs\u001b[24m  are\u001b[m\r\n                     added.\u001b[m\r\n\u001b[m\r\n              If  the  \u001b[1mHISTTIMEFORMAT\u001b[0m  variable is set, the time\u001b[m\r\n              stam"]
[3626.059956, "o", "p information associated with each history en‐\u001b[m\r\n              try  is  written  to the history file, marked with\u001b[m\r\n              the history comment character.  When  the  history\u001b[m\r\n              file  is  read,  lines  beginning with the history\u001b[m\r\n              comment character followed immediately by a  digit\u001b[m\r\n              are  interpreted  as  timestamps for the following\u001b[m\r\n              history entry.  The return value is  0  unless  an\u001b[m\r\n              invalid  option  is  encountered,  an error occurs\u001b[m\r\n              while reading or writing the history file, an  in‐\u001b[m\r\n              valid  \u001b[4moffset\u001b[24m  or range is supplied as an argument\u001b[m\r\n\u001b[7m Manual page bash(1) line 6267 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.091075, "o", "\r\u001b[K              to \u001b[1m-d\u001b[0m, or the history expansion supplied as an ar‐\u001b[m\r\n              gument to \u001b[1m-p\u001b[0m fails.\u001b[m\r\n\u001b[m\r\n       \u001b[1mjobs\u001b[0m [\u001b[1m-lnprs\u001b[0m] [ \u001b[4mjobspec\u001b[24m ... ]\u001b[m\r\n       \u001b[1mjobs\u001b[0m \u001b[1m-x\u001b[0m \u001b[4mcommand\u001b[24m [ \u001b[4margs\u001b[24m ... ]\u001b[m\r\n              The first form lists the active jobs.  The options\u001b[m\r\n              have the following meanings:\u001b[m\r\n              \u001b[1m-l\u001b[0m     List process IDs in addition to the  normal\u001b[m\r\n                     information.\u001b[m\r\n              \u001b[1m-n\u001b[0m     Display  information  only  about jobs that\u001b[m\r\n                     have changed status since the user was last\u001b[m\r\n                     notified of their status.\u001b[m\r\n              \u001b[1m-p\u001b[0m     List  only  the  process  ID  of  the job's\u001b[m\r\n                     process group leader.\u001b[m\r\n              \u001b[1m-r\u001b[0m     Display only running jobs.\u001b[m\r\n              \u001b[1m-s\u001b[0m     Display only stopped jobs.\u001b[m\r\n\u001b[m\r\n              If \u001b[4mjobspec\u001b[24m is given, output is restricted  to  in"]
[3626.0911, "o", "‐\u001b[m\r\n              formation  about that job.  The return status is 0\u001b[m\r\n              unless an invalid option is encountered or an  in‐\u001b[m\r\n              valid \u001b[4mjobspec\u001b[24m is supplied.\u001b[m\r\n\u001b[m\r\n              If  the  \u001b[1m-x\u001b[0m  option is supplied, \u001b[1mjobs\u001b[0m replaces any\u001b[m\r\n              \u001b[4mjobspec\u001b[24m found in \u001b[4mcommand\u001b[24m or \u001b[4margs\u001b[24m with  the  corre‐\u001b[m\r\n              sponding  process  group  ID, and executes \u001b[4mcommand\u001b[24m\u001b[m\r\n              passing it \u001b[4margs\u001b[24m, returning its exit status.\u001b[m\r\n\u001b[7m Manual page bash(1) line 6293 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.121513, "o", "\r\u001b[K"]
[3626.121599, "o", "\u001b[m\r\n       \u001b[1mkill\u001b[0m [\u001b[1m-s\u001b[0m \u001b[4msigspec\u001b[24m | \u001b[1m-n\u001b[0m \u001b[4msignum\u001b[24m | \u001b[1m-\u001b[0m\u001b[4msigspec\u001b[24m] [\u001b[4mpid\u001b[24m |  \u001b[4mjobspec\u001b[24m]\u001b[m\r\n       ...\u001b[m\r\n       \u001b[1mkill\u001b[0m \u001b[1m-l\u001b[0m|\u001b[1m-L\u001b[0m [\u001b[4msigspec\u001b[24m | \u001b[4mexit_status\u001b[24m]\u001b[m\r\n              Send  the signal named by \u001b[4msigspec\u001b[24m or \u001b[4msignum\u001b[24m to the\u001b[m\r\n              processes named by \u001b[4mpid\u001b[24m or \u001b[4mjobspec\u001b[24m.  \u001b[4msigspec\u001b[24m is ei‐\u001b[m\r\n              ther   a  case-insensitive  signal  name  such  as\u001b[m\r\n              \u001b[1mSIGKILL\u001b[0m (with or without the \u001b[1mSIG\u001b[0m prefix) or a sig‐\u001b[m\r\n              nal number; \u001b[4msignum\u001b[24m is a signal number.  If \u001b[4msigspec\u001b[24m\u001b[m\r\n              is not present, then \u001b[1mSIGTERM\u001b[0m is assumed.  An argu‐\u001b[m\r\n              ment  of  \u001b[1m-l\u001b[0m lists the signal names.  If any argu‐\u001b[m\r\n              ments are supplied when \u001b[1m-l\u001b[0m is given, the names  of\u001b[m\r\n              the  signals  corresponding  to  the arguments are\u001b[m\r\n              listed, and the return s"]
[3626.121621, "o", "tatus is 0.  The \u001b[4mexit_sta‐\u001b[24m\u001b[m\r\n              \u001b[4mtus\u001b[24m argument to \u001b[1m-l\u001b[0m is a number specifying either a\u001b[m\r\n              signal number or the exit status of a process ter‐\u001b[m\r\n              minated  by a signal.  The \u001b[1m-L\u001b[0m option is equivalent\u001b[m\r\n              to \u001b[1m-l\u001b[0m.  \u001b[1mkill\u001b[0m returns true if at least  one  signal\u001b[m\r\n              was successfully sent, or false if an error occurs\u001b[m\r\n              or an invalid option is encountered.\u001b[m\r\n\u001b[m\r\n       \u001b[1mlet\u001b[0m \u001b[4marg\u001b[24m [\u001b[4marg\u001b[24m ...]\u001b[m\r\n              Each \u001b[4marg\u001b[24m is an arithmetic expression to be  evalu‐\u001b[m\r\n              ated  (see  \u001b[1mARITHMETIC\u001b[0m  \u001b[1mEVALUATION\u001b[0m above).  If the\u001b[m\r\n              last \u001b[4marg\u001b[24m evaluates to 0, \u001b[1mlet\u001b[0m returns 1; 0  is  re‐\u001b[m\r\n              turned otherwise.\u001b[m\r\n\u001b[7m Manual page bash(1) line 6319 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.153616, "o", "\r\u001b[K"]
[3626.153707, "o", "\u001b[m\r\n       \u001b[1mlocal\u001b[0m [\u001b[4moption\u001b[24m] [\u001b[4mname\u001b[24m[=\u001b[4mvalue\u001b[24m] ... | - ]\u001b[m\r\n              For  each argument, a local variable named \u001b[4mname\u001b[24m is\u001b[m\r\n              created, and assigned \u001b[4mvalue\u001b[24m.  The  \u001b[4moption\u001b[24m  can  be\u001b[m\r\n              any  of the options accepted by \u001b[1mdeclare\u001b[0m.  When \u001b[1mlo‐\u001b[0m\u001b[m\r\n              \u001b[1mcal\u001b[0m is used within a function, it causes the vari‐\u001b[m\r\n              able  \u001b[4mname\u001b[24m  to  have a visible scope restricted to\u001b[m\r\n              that function and its children.  If \u001b[4mname\u001b[24m is -, the\u001b[m\r\n              set of shell options is made local to the function\u001b[m\r\n              in which \u001b[1mlocal\u001b[0m is invoked: shell  options  changed\u001b[m\r\n              using  the \u001b[1mset\u001b[0m builtin inside the function are re‐\u001b[m\r\n              stored to their original values when the  function\u001b[m\r\n              returns.   The  restore is effected as if a series\u001b[m\r\n              of \u001b[1mset\u001b[0m commands were executed to restore the  val‐\u001b[m\r\n     "]
[3626.153728, "o", "         ues "]
[3626.153757, "o", " that were in place before the function.  With\u001b[m\r\n              no operands, \u001b[1mlocal\u001b[0m writes a list  of  local  vari‐\u001b[m\r\n              ables  to  the standard output.  It is an error to\u001b[m\r\n              use \u001b[1mlocal\u001b[0m when not within a function.  The  return\u001b[m\r\n              status  is  0 unless \u001b[1mlocal\u001b[0m is used outside a func‐\u001b[m\r\n              tion, an invalid \u001b[4mname\u001b[24m is supplied, or  \u001b[4mname\u001b[24m  is  a\u001b[m\r\n              readonly variable.\u001b[m\r\n\u001b[m\r\n       \u001b[1mlogout\u001b[0m Exit a login shell.\u001b[m\r\n\u001b[m\r\n       \u001b[1mmapfile\u001b[0m [\u001b[1m-d\u001b[0m \u001b[4mdelim\u001b[24m] [\u001b[1m-n\u001b[0m \u001b[4mcount\u001b[24m] [\u001b[1m-O\u001b[0m \u001b[4morigin\u001b[24m] [\u001b[1m-s\u001b[0m \u001b[4mcount\u001b[24m] [\u001b[1m-t\u001b[0m]\u001b[m\r\n       [\u001b[1m-u\u001b[0m \u001b[4mfd\u001b[24m] [\u001b[1m-C\u001b[0m \u001b[4mcallback\u001b[24m] [\u001b[1m-c\u001b[0m \u001b[4mquantum\u001b[24m] [\u001b[4marray\u001b[24m]\u001b[m\r\n\u001b[7m Manual page bash(1) line 6345 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.185079, "o", "\r\u001b[K"]
[3626.18511, "o", "       \u001b[1mreadarray\u001b[0m [\u001b[1m-d\u001b[0m \u001b[4mdelim\u001b[24m] [\u001b[1m-n\u001b[0m \u001b[4mcount\u001b[24m] [\u001b[1m-O\u001b[0m  \u001b[4morigin\u001b[24m]  [\u001b[1m-s\u001b[0m  \u001b[4mcount\u001b[24m]\u001b[m\r\n       [\u001b[1m-t\u001b[0m] [\u001b[1m-u\u001b[0m \u001b[4mfd\u001b[24m] [\u001b[1m-C\u001b[0m \u001b[4mcallback\u001b[24m] [\u001b[1m-c\u001b[0m \u001b[4mquantum\u001b[24m] [\u001b[4marray\u001b[24m]\u001b[m\r\n              Read  lines  from  the standard input into the in‐\u001b[m\r\n              dexed array variable \u001b[4marray\u001b[24m, or from file  descrip‐\u001b[m\r\n              tor \u001b[4mfd\u001b[24m if the \u001b[1m-u\u001b[0m option is supplied.  The variable\u001b[m\r\n              \u001b[1mMAPFILE\u001b[0m is the default \u001b[4marray\u001b[24m.   Options,  if  sup‐\u001b[m\r\n              plied, have the following meanings:\u001b[m\r\n              \u001b[1m-d\u001b[0m     The  first  character  of  \u001b[4mdelim\u001b[24m is used to\u001b[m\r\n                     terminate each input line, rather than new‐\u001b[m\r\n                     line.   If  \u001b[4mdelim\u001b[24m is the empty string, \u001b[1mmap‐\u001b[0m\u001b[m\r\n                     \u001b[1mfile\u001b[0m will terminate a line when it reads  a\u001b[m\r\n                     NUL character.\u001b[m\r\n           "]
[3626.185118, "o", "   \u001b[1m-n\u001b["]
[3626.185301, "o", "0m     Copy  at  most \u001b[4mcount\u001b[24m lines.  If \u001b[4mcount\u001b[24m is 0,\u001b[m\r\n                     all lines are copied.\u001b[m\r\n              \u001b[1m-O\u001b[0m     Begin assigning to \u001b[4marray\u001b[24m at  index  \u001b[4morigin\u001b[24m.\u001b[m\r\n                     The default index is 0.\u001b[m\r\n              \u001b[1m-s\u001b[0m     Discard the first \u001b[4mcount\u001b[24m lines read.\u001b[m\r\n              \u001b[1m-t\u001b[0m     Remove  a  trailing \u001b[4mdelim\u001b[24m (default newline)\u001b[m\r\n                     from each line read.\u001b[m\r\n              \u001b[1m-u\u001b[0m     Read lines from file descriptor \u001b[4mfd\u001b[24m  instead\u001b[m\r\n                     of the standard input.\u001b[m\r\n              \u001b[1m-C\u001b[0m     Evaluate  \u001b[4mcallback\u001b[24m  each time \u001b[4mquantum\u001b[24m lines\u001b[m\r\n                     are read.  The \u001b[1m-c\u001b[0m option specifies \u001b[4mquantum\u001b[24m.\u001b[m\r\n              \u001b[1m-c\u001b[0m     Specify the number of  lines  read  between\u001b[m\r\n                     each call to \u001b[4mcallback\u001b[24m.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page bash(1) line 6371 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.216251, "o", "\r\u001b[K"]
[3626.216369, "o", "              If \u001b[1m-C\u001b[0m is specified without \u001b[1m-c\u001b[0m, the default quantum\u001b[m\r\n              is 5000.  When \u001b[4mcallback\u001b[24m is evaluated, it  is  sup‐\u001b[m\r\n              plied  the  index  of the next array element to be\u001b[m\r\n              assigned and the line to be assigned to that  ele‐\u001b[m\r\n              ment  as additional arguments.  \u001b[4mcallback\u001b[24m is evalu‐\u001b[m\r\n              ated after the line is read but before  the  array\u001b[m\r\n              element is assigned.\u001b[m\r\n\u001b[m\r\n              If  not  supplied with an explicit origin, \u001b[1mmapfile\u001b[0m\u001b[m\r\n              will clear \u001b[4marray\u001b[24m before assigning to it.\u001b[m\r\n\u001b[m\r\n              \u001b[1mmapfile\u001b[0m returns successfully unless an invalid op‐\u001b[m\r\n"]
[3626.21653, "o", "              tion  or option argument is supplied, \u001b[4marray\u001b[24m is in‐\u001b[m\r\n              valid or unassignable, or if \u001b[4marray\u001b[24m is not  an  in‐\u001b[m\r\n              dexed array.\u001b[m\r\n\u001b[m\r\n       \u001b[1mpopd\u001b[0m [-\u001b[1mn\u001b[0m] [+\u001b[4mn\u001b[24m] [-\u001b[4mn\u001b[24m]\u001b[m\r\n              Removes entries from the directory stack.  The el‐\u001b[m\r\n              ements are numbered from 0 starting at  the  first\u001b[m\r\n              directory listed by \u001b[1mdirs\u001b[0m.  With no arguments, \u001b[1mpopd\u001b[0m\u001b[m\r\n              removes the top  directory  from  the  stack,  and\u001b[m\r\n              changes  to  the new top directory.  Arguments, if\u001b[m\r\n              supplied, have the following meanings:\u001b[m\r\n              \u001b[1m-n\u001b[0m     Suppresses the normal change  of  directory\u001b[m\r\n                     when  removing  directories from the stack,\u001b[m\r\n                     so that only the stack is manipulated.\u001b[m\r\n\u001b[7m Manual page bash(1) line 6397 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.247757, "o", "\r\u001b[K              \u001b[1m+\u001b[0m\u001b[4mn\u001b[24m     Removes the \u001b[4mn\u001b[24mth  entry  counting  from  the\u001b[m\r\n                     left  of  the  list shown by \u001b[1mdirs\u001b[0m, starting\u001b[m\r\n                     with zero, from the  stack.   For  example:\u001b[m\r\n                     ``popd  +0''  removes  the first directory,\u001b[m\r\n                     ``popd +1'' the second.\u001b[m\r\n              \u001b[1m-\u001b[0m\u001b[4mn\u001b[24m     Removes the \u001b[4mn\u001b[24mth  entry  counting  from  the\u001b[m\r\n                     right  of  the list shown by \u001b[1mdirs\u001b[0m, starting\u001b[m\r\n                     with zero.  For example:  ``popd  -0''  re‐\u001b[m\r\n                     moves  the  last directory, ``popd -1'' the\u001b[m\r\n                     next to last.\u001b[m\r\n\u001b[m\r\n              If the top element of the directory stack is modi‐\u001b[m\r\n              fied,  and  the  \u001b[4m-n\u001b[24m  option was not supplied, \u001b[1mpopd\u001b[0m\u001b[m\r\n              uses the \u001b[1mcd\u001b[0m builtin to change to the directory  at\u001b[m\r\n              the  top  of the stack.  If the \u001b[1mcd\u001b[0m fails, \u001b[1mpop"]
[3626.247803, "o", "d\u001b[0m re‐\u001b[m\r\n              turns a non-zero value.\u001b[m\r\n\u001b[m\r\n              Otherwise, \u001b[1mpopd\u001b[0m returns false if an invalid option\u001b[m\r\n              is encountered, the directory stack is empty, or a\u001b[m\r\n              non-existent directory stack entry is specified.\u001b[m\r\n\u001b[m\r\n              If the \u001b[1mpopd\u001b[0m command is successful, bash runs  \u001b[1mdirs\u001b[0m\u001b[m\r\n              to show the final contents of the directory stack,\u001b[m\r\n              and the return status is 0.\u001b[m\r\n\u001b[m\r\n       \u001b[1mprintf\u001b[0m [\u001b[1m-v\u001b[0m \u001b[4mvar\u001b[24m] \u001b[4mformat\u001b[24m [\u001b[4marguments\u001b[24m]\u001b[m\r\n\u001b[7m Manual page bash(1) line 6423 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.27886, "o", "\r\u001b[K"]
[3626.278996, "o", "              Write the formatted \u001b[4marguments\u001b[24m to the standard out‐\u001b[m\r\n              put  under  the control of the \u001b[4mformat\u001b[24m.  The \u001b[1m-v\u001b[0m op‐\u001b[m\r\n              tion causes the output to be assigned to the vari‐\u001b[m\r\n              able \u001b[4mvar\u001b[24m rather than being printed to the standard\u001b[m\r\n              output.\u001b[m\r\n\u001b[m\r\n              The \u001b[4mformat\u001b[24m is a character  string  which  contains\u001b[m\r\n              three  types  of  objects: plain characters, which\u001b[m\r\n              are simply copied to  standard  output,  character\u001b[m\r\n              escape  sequences,  which are converted and copied\u001b[m\r\n              to the standard output, and format specifications,\u001b[m\r\n              each  of which causes printing of the next succes‐\u001b[m\r\n              sive  \u001b[4margument\u001b[24m.   In  addition  to  the   standard\u001b[m\r\n              \u001b[4mprintf\u001b[24m(1) format specifications, \u001b[1mprintf\u001b[0m interprets\u001b[m\r\n              the following extensions:\u001b[m\r\n              \u001b[1m%b\u001b[0m     causes \u001b[1mpri"]
[3626.279009, "o", "ntf\u001b[0m to  expand  backslash  escape\u001b[m\r\n                     sequences  in the corresponding \u001b[4margument\u001b[24m in\u001b[m\r\n                     the same way as \u001b[1mecho\u001b[0m \u001b[1m-e\u001b[0m.\u001b[m\r\n              \u001b[1m%q\u001b[0m     causes \u001b[1mprintf\u001b[0m to output  the  corresponding\u001b[m\r\n                     \u001b[4margument\u001b[24m  in a format that can be reused as\u001b[m\r\n                     shell input.\u001b[m\r\n              \u001b[1m%Q\u001b[0m     like \u001b[1m%q\u001b[0m, but applies any supplied precision\u001b[m\r\n                     to the \u001b[4margument\u001b[24m before quoting it.\u001b[m\r\n              \u001b[1m%(\u001b[0m\u001b[4mdatefmt\u001b[24m\u001b[1m)T\u001b[0m\u001b[m\r\n                     causes   \u001b[1mprintf\u001b[0m  to  output  the  date-time\u001b[m\r\n                     string resulting from using  \u001b[4mdatefmt\u001b[24m  as  a\u001b[m\r\n\u001b[7m Manual page bash(1) line 6449 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.309292, "o", "\r\u001b[K"]
[3626.309441, "o", "                     format  string for \u001b[4mstrftime\u001b[24m(3).  The corre‐\u001b[m\r\n                     sponding \u001b[4margument\u001b[24m is an integer  represent‐\u001b[m\r\n                     ing  the number of seconds since the epoch.\u001b[m\r\n                     Two special argument values may be used: -1\u001b[m\r\n                     represents  the current time, and -2 repre‐\u001b[m\r\n                     sents the time the shell was  invoked.   If\u001b[m\r\n                     no  argument  is  specified, conversion be‐\u001b[m\r\n                     haves as if -1 had been given.  This is  an\u001b[m\r\n                     exception to the usual \u001b[1mprintf\u001b[0m behavior.\u001b[m\r\n\u001b[m\r\n              The  %b,  %q,  and %T directives all use the field\u001b[m\r\n              width and  precision  arguments  from  the  format\u001b[m\r\n              specification  and  write that many bytes from (or\u001b[m\r\n              use that wide a field for) the expanded  argument,\u001b[m\r\n              which  usually  contains  more characters than the\u001b[m\r\n              original."]
[3626.309488, "o", "\u001b[m\r\n\u001b[m\r\n              Arguments  to  non-string  format  specifiers  are\u001b[m\r\n              treated as C constants, except that a leading plus\u001b[m\r\n              or minus sign is allowed, and if the leading char‐\u001b[m\r\n              acter  is  a  single or double quote, the value is\u001b[m\r\n              the ASCII value of the following character.\u001b[m\r\n\u001b[m\r\n              The \u001b[4mformat\u001b[24m is reused as necessary to  consume  all\u001b[m\r\n              of the \u001b[4marguments\u001b[24m.  If the \u001b[4mformat\u001b[24m requires more \u001b[4mar‐\u001b[24m\u001b[m\r\n              \u001b[4mguments\u001b[24m than are supplied, the extra format speci‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 6475 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.340991, "o", "\r\u001b[K              fications  behave  as  if  a  zero  value  or null\u001b[m\r\n              string, as appropriate, had  been  supplied.   The\u001b[m\r\n              return value is zero on success, non-zero on fail‐\u001b[m\r\n              ure.\u001b[m\r\n\u001b[m\r\n       \u001b[1mpushd\u001b[0m [\u001b[1m-n\u001b[0m] [+\u001b[4mn\u001b[24m] [-\u001b[4mn\u001b[24m]\u001b[m\r\n       \u001b[1mpushd\u001b[0m [\u001b[1m-n\u001b[0m] [\u001b[4mdir\u001b[24m]\u001b[m\r\n              Adds a directory  to  the  top  of  the  directory\u001b[m\r\n              stack, or rotates the stack, making the new top of\u001b[m\r\n              the stack the current working directory.  With  no\u001b[m\r\n              arguments, \u001b[1mpushd\u001b[0m exchanges the top two elements of\u001b[m\r\n              the directory stack.  Arguments, if supplied, have\u001b[m\r\n              the following meanings:\u001b[m\r\n              \u001b[1m-n\u001b[0m     Suppresses  the  normal change of directory\u001b[m\r\n                     when rotating or adding directories to  the\u001b[m\r\n                     stack,  so  that  only the stack is manipu‐\u001b[m\r\n                     lated.\u001b[m\r\n              \u001b[1m+\u001b"]
[3626.34111, "o", "[0m\u001b[4mn\u001b[24m     Rotates the stack so that the \u001b[4mn\u001b[24mth directory\u001b[m\r\n                     (counting  from  the left of the list shown\u001b[m\r\n                     by \u001b[1mdirs\u001b[0m, starting with zero) is at the top.\u001b[m\r\n              \u001b[1m-\u001b[0m\u001b[4mn\u001b[24m     Rotates the stack so that the \u001b[4mn\u001b[24mth directory\u001b[m\r\n                     (counting  from the right of the list shown\u001b[m\r\n                     by \u001b[1mdirs\u001b[0m, starting with zero) is at the top.\u001b[m\r\n              \u001b[4mdir\u001b[24m    Adds \u001b[4mdir\u001b[24m to the directory stack at the top\u001b[m\r\n\u001b[m\r\n              After the stack has been modified, if the  \u001b[1m-n\u001b[0m  op‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 6501 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.372396, "o", "\r\u001b[K"]
[3626.372421, "o", "              tion  was  not supplied, \u001b[1mpushd\u001b[0m uses the \u001b[1mcd\u001b[0m builtin\u001b[m\r\n              to change to the  directory  at  the  top  of  the\u001b[m\r\n              stack.   If the \u001b[1mcd\u001b[0m fails, \u001b[1mpushd\u001b[0m returns a non-zero\u001b[m\r\n              value.\u001b[m\r\n\u001b[m\r\n              Otherwise, if no arguments are supplied, \u001b[1mpushd\u001b[0m re‐\u001b[m\r\n              turns 0 unless the directory stack is empty.  When\u001b[m\r\n              rotating the directory stack, \u001b[1mpushd\u001b[0m returns 0  un‐\u001b[m\r\n              less  the  directory stack is empty or a non-exis‐\u001b[m\r\n              tent directory stack element is specified.\u001b[m\r\n\u001b[m\r\n              If the \u001b[1mpushd\u001b[0m command is successful, bash runs \u001b[1mdirs\u001b[0m\u001b[m\r\n              to show the final contents of the directory stack.\u001b[m\r\n\u001b[m\r\n       \u001b[1mpwd\u001b[0m [\u001b[1m-LP\u001b[0m]\u001b[m\r\n              Print the absolute pathname of the current working\u001b[m\r\n"]
[3626.372426, "o", "              directory.  The pathname printed contains no  sym‐\u001b[m\r\n              bolic links if the \u001b[1m-P\u001b[0m option is supplied or the \u001b"]
[3626.372608, "o", "[1m-o\u001b[0m\u001b[m\r\n              \u001b[1mphysical\u001b[0m option to the \u001b[1mset\u001b[0m builtin command is  en‐\u001b[m\r\n              abled.   If  the  \u001b[1m-L\u001b[0m  option is used, the pathname\u001b[m\r\n              printed may contain symbolic  links.   The  return\u001b[m\r\n              status  is  0 unless an error occurs while reading\u001b[m\r\n              the name of the current directory  or  an  invalid\u001b[m\r\n              option is supplied.\u001b[m\r\n\u001b[m\r\n       \u001b[1mread\u001b[0m  [\u001b[1m-ers\u001b[0m]  [\u001b[1m-a\u001b[0m \u001b[4maname\u001b[24m] [\u001b[1m-d\u001b[0m \u001b[4mdelim\u001b[24m] [\u001b[1m-i\u001b[0m \u001b[4mtext\u001b[24m] [\u001b[1m-n\u001b[0m \u001b[4mnchars\u001b[24m]\u001b[m\r\n\u001b[7m Manual page bash(1) line 6527 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.403993, "o", "\r\u001b[K       [\u001b[1m-N\u001b[0m \u001b[4mnchars\u001b[24m] [\u001b[1m-p\u001b[0m \u001b[4mprompt\u001b[24m] [\u001b[1m-t\u001b[0m \u001b[4mtimeout\u001b[24m] [\u001b[1m-u\u001b[0m \u001b[4mfd\u001b[24m] [\u001b[4mname\u001b[24m ...]\u001b[m\r\n              One line is read from the standard input, or  from\u001b[m\r\n              the  file descriptor \u001b[4mfd\u001b[24m supplied as an argument to\u001b[m\r\n              the \u001b[1m-u\u001b[0m option, split into words as described above\u001b[m\r\n              under  \u001b[1mWord\u001b[0m  \u001b[1mSplitting\u001b[0m,  and the first word is as‐\u001b[m\r\n              signed to the first \u001b[4mname\u001b[24m, the second word  to  the\u001b[m\r\n              second  \u001b[4mname\u001b[24m,  and so on.  If there are more words\u001b[m\r\n              than names, the remaining words and  their  inter‐\u001b[m\r\n              vening  delimiters  are assigned to the last \u001b[4mname\u001b[24m.\u001b[m\r\n              If there are  fewer  words  read  from  the  input\u001b[m\r\n              stream  than  names,  the  remaining names are as‐\u001b[m\r\n              signed empty values.  The characters  in  \u001b[1mIFS\u001b[0m  are\u001b[m\r\n              used  to  split the line into"]
[3626.40402, "o", " words using th"]
[3626.404042, "o", "e same\u001b[m\r\n              rules the  shell  uses  for  expansion  (described\u001b[m\r\n              above  under \u001b[1mWord\u001b[0m \u001b[1mSplitting\u001b[0m).  The backslash char‐\u001b[m\r\n              acter (\u001b[1m\\\u001b[0m) may be used to remove any special  mean‐\u001b[m\r\n              ing  for the next character read and for line con‐\u001b[m\r\n              tinuation.  Options, if supplied, have the follow‐\u001b[m\r\n              ing meanings:\u001b[m\r\n              \u001b[1m-a\u001b[0m \u001b[4maname\u001b[24m\u001b[m\r\n                     The  words  are  assigned to sequential in‐\u001b[m\r\n                     dices of the array variable \u001b[4maname\u001b[24m, starting\u001b[m\r\n                     at 0.  \u001b[4maname\u001b[24m is unset before any new values\u001b[m\r\n                     are assigned.  Other \u001b[4mname\u001b[24m arguments are ig‐\u001b[m\r\n                     nored.\u001b[m\r\n              \u001b[1m-d\u001b[0m \u001b[4mdelim\u001b[24m\u001b[m\r\n\u001b[7m Manual page bash(1) line 6553 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.434606, "o", "\r\u001b[K                     The  first  character  of  \u001b[4mdelim\u001b[24m is used to\u001b[m\r\n                     terminate the input line, rather than  new‐\u001b[m\r\n                     line.   If  \u001b[4mdelim\u001b[24m is the empty string, \u001b[1mread\u001b[0m\u001b[m\r\n                     will terminate a line when it reads  a  NUL\u001b[m\r\n                     character.\u001b[m\r\n              \u001b[1m-e\u001b[0m     If the standard input is coming from a ter‐\u001b[m\r\n                     minal, \u001b[1mreadline\u001b[0m  (see  \u001b[1mREADLINE\u001b[0m  above)  is\u001b[m\r\n                     used to obtain the line.  Readline uses the\u001b[m\r\n                     current (or default, if  line  editing  was\u001b[m\r\n                     not  previously  active)  editing settings,\u001b[m\r\n                     but uses readline's default  filename  com‐\u001b[m\r\n                     pletion.\u001b[m\r\n              \u001b[1m-i\u001b[0m \u001b[4mtext\u001b[24m\u001b[m\r\n                     If \u001b[1mreadline\u001b[0m is being used to read the line,\u001b[m\r\n                     \u001b[4mtext\u001b[24m is placed into the editing buffer  be‐\u001b[m\r\n    "]
[3626.43463, "o", "                 f"]
[3626.434646, "o", "ore editing begins.\u001b[m\r\n              \u001b[1m-n\u001b[0m \u001b[4mnchars\u001b[24m\u001b[m\r\n                     \u001b[1mread\u001b[0m  returns  after reading \u001b[4mnchars\u001b[24m charac‐\u001b[m\r\n                     ters rather than  waiting  for  a  complete\u001b[m\r\n                     line  of  input,  but honors a delimiter if\u001b[m\r\n                     fewer than \u001b[4mnchars\u001b[24m characters are  read  be‐\u001b[m\r\n                     fore the delimiter.\u001b[m\r\n              \u001b[1m-N\u001b[0m \u001b[4mnchars\u001b[24m\u001b[m\r\n                     \u001b[1mread\u001b[0m  returns  after reading exactly \u001b[4mnchars\u001b[24m\u001b[m\r\n                     characters rather than waiting for  a  com‐\u001b[m\r\n                     plete  line of input, unless EOF is encoun‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 6579 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.466392, "o", "\r\u001b[K                     tered or \u001b[1mread\u001b[0m times out.  Delimiter charac‐\u001b[m\r\n                     ters  encountered  in  the  input  are  not\u001b[m\r\n                     treated specially and do not cause \u001b[1mread\u001b[0m  to\u001b[m\r\n                     return  until  \u001b[4mnchars\u001b[24m  characters are read.\u001b[m\r\n                     The result is not split on  the  characters\u001b[m\r\n                     in  \u001b[1mIFS\u001b[0m; the intent is that the variable is\u001b[m\r\n                     assigned exactly the characters read  (with\u001b[m\r\n                     the  exception of backslash; see the \u001b[1m-r\u001b[0m op‐\u001b[m\r\n                     tion below).\u001b[m\r\n              \u001b[1m-p\u001b[0m \u001b[4mprompt\u001b[24m\u001b[m\r\n                     Display \u001b[4mprompt\u001b[24m on standard error, without a\u001b[m\r\n                     trailing newline, before attempting to read\u001b[m\r\n                     any input.  The prompt is displayed only if\u001b[m\r\n                     input is coming from a terminal.\u001b[m\r\n              \u001b[1m-r\u001b[0m     Backslash does not act as an escape c"]
[3626.466433, "o", "harac‐\u001b[m\r\n                     ter.  The backslash  is  considered  to  be\u001b[m\r\n                     part  of  the line.  In particular, a back‐\u001b[m\r\n                     slash-newline pair may not then be used  as\u001b[m\r\n                     a line continuation.\u001b[m\r\n              \u001b[1m-s\u001b[0m     Silent  mode.   If  input  is coming from a\u001b[m\r\n                     terminal, characters are not echoed.\u001b[m\r\n              \u001b[1m-t\u001b[0m \u001b[4mtimeout\u001b[24m\u001b[m\r\n                     Cause \u001b[1mread\u001b[0m to time out and  return  failure\u001b[m\r\n                     if a complete line of input (or a specified\u001b[m\r\n                     number of characters) is  not  read  within\u001b[m\r\n                     \u001b[4mtimeout\u001b[24m  seconds.  \u001b[4mtimeout\u001b[24m may be a decimal\u001b[m\r\n\u001b[7m Manual page bash(1) line 6605 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.498068, "o", "\r\u001b[K"]
[3626.498207, "o", "                     number with a fractional portion  following\u001b[m\r\n                     the decimal point.  This option is only ef‐\u001b[m\r\n                     fective if \u001b[1mread\u001b[0m is  reading  input  from  a\u001b[m\r\n                     terminal,  pipe,  or other special file; it\u001b[m\r\n                     has no effect  when  reading  from  regular\u001b[m\r\n                     files.   If  \u001b[1mread\u001b[0m times out, \u001b[1mread\u001b[0m saves any\u001b[m\r\n                     partial input read into the specified vari‐\u001b[m\r\n                     able  \u001b[4mname\u001b[24m.   If \u001b[4mtimeout\u001b[24m is 0, \u001b[1mread\u001b[0m returns\u001b[m\r\n                     immediately, without  trying  to  read  any\u001b[m\r\n                     data.   The  exit  status  is 0 if input is\u001b[m\r\n                     available on the specified file descriptor,\u001b[m\r\n                     or  the read will return EOF, non-zero oth‐\u001b[m\r\n                     erwise.  The exit status  is  greater  than\u001b[m\r\n                     128 if the timeout is exceeded.\u001b[m\r\n              "]
[3626.498226, "o", "\u001b[1m-u\u001b[0m \u001b[4mfd\u001b[24m  Read input from file descriptor \u001b[4mfd\u001b[24m.\u001b[m\r\n\u001b[m\r\n              If  no  \u001b[4mnames\u001b[24m are supplied, the line read, without\u001b[m\r\n              the ending delimiter but otherwise unmodified,  is\u001b[m\r\n              assigned  to  the variable \u001b[1mREPLY\u001b[0m.  The exit status\u001b[m\r\n              is zero, unless end-of-file is  encountered,  \u001b[1mread\u001b[0m\u001b[m\r\n              times  out  (in  which  case the status is greater\u001b[m\r\n              than 128), a variable assignment  error  (such  as\u001b[m\r\n              assigning  to  a  readonly variable) occurs, or an\u001b[m\r\n              invalid file descriptor is supplied as  the  argu‐\u001b[m\r\n              ment to \u001b[1m-u\u001b[0m.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page bash(1) line 6631 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.529842, "o", "\r\u001b[K"]
[3626.529935, "o", "       \u001b[1mreadonly\u001b[0m [\u001b[1m-aAf\u001b[0m] [\u001b[1m-p\u001b[0m] [\u001b[4mname\u001b[24m[=\u001b[4mword\u001b[24m] ...]\u001b[m\r\n              The given \u001b[4mnames\u001b[24m are marked readonly; the values of\u001b[m\r\n              these \u001b[4mnames\u001b[24m may not be changed by  subsequent  as‐\u001b[m\r\n              signment.  If the \u001b[1m-f\u001b[0m option is supplied, the func‐\u001b[m\r\n              tions corresponding to the \u001b[4mnames\u001b[24m  are  so  marked.\u001b[m\r\n              The  \u001b[1m-a\u001b[0m  option restricts the variables to indexed\u001b[m\r\n              arrays; the \u001b[1m-A\u001b[0m option restricts the  variables  to\u001b[m\r\n              associative arrays.  If both options are supplied,\u001b[m\r\n              \u001b[1m-A\u001b[0m takes precedence.  If  no  \u001b[4mname\u001b[24m  arguments  are\u001b[m\r\n              given,  or if the \u001b[1m-p\u001b[0m option is supplied, a list of\u001b[m\r\n              all readonly names is printed.  The other  options\u001b[m\r\n              may  be used to restrict the output to a subset of\u001b[m\r\n              the set of readonly names.  The \u001b[1m-p\u001b[0m  option  causes\u001b[m\r\n              ou"]
[3626.529968, "o", "tput  to  be  displayed  in a format that may be\u001b[m\r\n              reused as input.  If a variable name  is  followed\u001b[m\r\n              by  =\u001b[4mword\u001b[24m,  the  value  of  the variable is set to\u001b[m\r\n              \u001b[4mword\u001b[24m.  The return status is 0  unless  an  invalid\u001b[m\r\n"]
[3626.530028, "o", "              option  is  encountered, one of the \u001b[4mnames\u001b[24m is not a\u001b[m\r\n              valid shell variable name, or \u001b[1m-f\u001b[0m is supplied  with\u001b[m\r\n              a \u001b[4mname\u001b[24m that is not a function.\u001b[m\r\n\u001b[m\r\n       \u001b[1mreturn\u001b[0m [\u001b[4mn\u001b[24m]\u001b[m\r\n              Causes a function to stop executing and return the\u001b[m\r\n              value specified by \u001b[4mn\u001b[24m to its caller.  If \u001b[4mn\u001b[24m is omit‐\u001b[m\r\n              ted, the return status is that of the last command\u001b[m\r\n              executed in the function body.  If \u001b[1mreturn\u001b[0m is  exe‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 6657 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3626.561537, "o", "\r\u001b[K              cuted  by a trap handler, the last command used to\u001b[m\r\n              determine the status is the last command  executed\u001b[m\r\n              before  the  trap  handler.  If \u001b[1mreturn\u001b[0m is executed\u001b[m\r\n              during a \u001b[1mDEBUG\u001b[0m trap, the last command used to  de‐\u001b[m\r\n              termine the status is the last command executed by\u001b[m\r\n              the trap handler before \u001b[1mreturn\u001b[0m  was  invoked.   If\u001b[m\r\n              \u001b[1mreturn\u001b[0m is used outside a function, but during exe‐\u001b[m\r\n              cution of a script by the \u001b[1m.\u001b[0m  (\u001b[1msource\u001b[0m) command,  it\u001b[m\r\n              causes the shell to stop executing that script and\u001b[m\r\n              return either \u001b[4mn\u001b[24m or the exit  status  of  the  last\u001b[m\r\n              command  executed  within  the  script as the exit\u001b[m\r\n              status of the script.  If \u001b[4mn\u001b[24m is supplied,  the  re‐\u001b[m\r\n              turn  value  is its least significant 8 bits.  The\u001b[m\r\n              return status is non-zero if \u001b[1mretu"]
[3626.561613, "o", "rn\u001b[0m is suppli"]
[3626.561633, "o", "ed  a\u001b[m\r\n              non-numeric  argument,  or is used outside a func‐\u001b[m\r\n              tion and not during execution of a script by \u001b[1m.\u001b[0m  or\u001b[m\r\n              \u001b[1msource\u001b[0m.   Any  command  associated with the \u001b[1mRETURN\u001b[0m\u001b[m\r\n              trap is executed before  execution  resumes  after\u001b[m\r\n              the function or script.\u001b[m\r\n\u001b[m\r\n       \u001b[1mset\u001b[0m [\u001b[1m-abefhkmnptuvxBCEHPT\u001b[0m] [\u001b[1m-o\u001b[0m \u001b[4moption-name\u001b[24m] [\u001b[1m--\u001b[0m] [\u001b[1m-\u001b[0m] [\u001b[4marg\u001b[24m\u001b[m\r\n       ...]\u001b[m\r\n       \u001b[1mset\u001b[0m [\u001b[1m+abefhkmnptuvxBCEHPT\u001b[0m] [\u001b[1m+o\u001b[0m \u001b[4moption-name\u001b[24m] [\u001b[1m--\u001b[0m] [\u001b[1m-\u001b[0m] [\u001b[4marg\u001b[24m\u001b[m\r\n       ...]\u001b[m\r\n              Without  options,  display  the  name and value of\u001b[m\r\n              each shell variable in a format that can be reused\u001b[m\r\n\u001b[7m Manual page bash(1) line 6683 (press h for help or q to quit)\u001b[27m\u001b[K"]
