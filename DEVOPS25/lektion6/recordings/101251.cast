[3626.718026, "o", "                              above).\u001b[m\r\n                      \u001b[1mkeyword\u001b[0m Same as \u001b[1m-k\u001b[0m.\u001b[m\r\n                      \u001b[1mmonitor\u001b[0m Same as \u001b[1m-m\u001b[0m.\u001b[m\r\n                      \u001b[1mnoclobber\u001b[0m\u001b[m\r\n                              Same as \u001b[1m-C\u001b[0m.\u001b[m\r\n                      \u001b[1mnoexec\u001b[0m  Same as \u001b[1m-n\u001b[0m.\u001b[m\r\n                      \u001b[1mnoglob\u001b[0m  Same as \u001b[1m-f\u001b[0m.\u001b[m\r\n                      \u001b[1mnolog\u001b[0m   Currently ignored.\u001b[m\r\n                      \u001b[1mnotify\u001b[0m  Same as \u001b[1m-b\u001b[0m.\u001b[m\r\n                      \u001b[1mnounset\u001b[0m Same as \u001b[1m-u\u001b[0m.\u001b[m\r\n                      \u001b[1monecmd\u001b[0m  Same as \u001b[1m-t\u001b[0m.\u001b[m\r\n                      \u001b[1mphysical\u001b[0m\u001b[m\r\n                              Same as \u001b[1m-P\u001b[0m.\u001b[m\r\n                      \u001b[1mpipefail\u001b[0m\u001b[m\r\n                              If  set,  the  return  value  of a\u001b[m\r\n                              pipeline is the value of the  last\u001b[m\r\n                              (rightmost) command to exit with a\u001b[m\r\n                              non-zero sta"]
