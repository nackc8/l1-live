[2447.193902, "o", "ON\u001b[24m...] \u001b[1m-e \u001b[4m\u001b[22mPATTERNS\u001b[24m ... [\u001b[4mFILE\u001b[24m...]\u001b[m\r\n\u001b[9;1H\u001b[K       \u001b[1mgrep \u001b[22m[\u001b[4mOPTION\u001b[24m...] \u001b[1m-f \u001b[4m\u001b[22mPATTERN_FILE\u001b[24m ... [\u001b[4mFILE\u001b[24m...]\u001b[m\r\n\u001b[10;1H\u001b[K\u001b[m\r\n\u001b[11;1H\u001b[K\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[12;1H"]
[2447.194604, "o", "...skipping...\r\n       \u001b[1m\u001b[7m-o\u001b[27m\u001b[1m\u001b[22m, \u001b[1m-\u001b[7m-o\u001b[27m\u001b[1m\u001b[22m\u001b[1mnly-matching\u001b[0m\u001b[m\r\n              Print  only the matched (non-empty) parts of a matching line,\u001b[m\r\n              with each such part on a separate output line.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-q\u001b[22m, \u001b[1m--quiet\u001b[22m, \u001b[1m--silent\u001b[0m\u001b[m\r\n              Quiet; do  not  write  anything  to  standard  output.   Exit\u001b[m\r\n              immediately  with  zero status if any match is found, even if\u001b[m\r\n              an error was detected.  Also  see  the  \u001b[1m-s  \u001b[22mor  \u001b[1m--no-messages\u001b[0m\u001b[m\r\n              option.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-s\u001b[22m, \u001b[1m--no-messages\u001b[0m\u001b[m\r\n\u001b[7m Manual page grep(1) line 133 (press h for help or q to quit)\u001b[27m\u001b[K"]
