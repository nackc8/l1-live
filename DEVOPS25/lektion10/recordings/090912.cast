[1855.422673, "o", "\u001b[12;1H\u001b[13;1H\u001b[7m-----Info: (grep)Command-line Options, 25 lines --92%-----------------------\u001b[0m\u001b[1;1H* Menu:\u001b[2;1H\u001b[K\u001b[3;1H\u001b[4m* Generic Program Information\u001b[24m::\u001b[K\u001b[4;1H\u001b[4m* Matching Control\u001b[24m::\u001b[K\u001b[5;1H\u001b[4m* General Output Control\u001b[24m::\u001b[K\u001b[6;1H\u001b[4m* Output Line Prefix Control\u001b[24m::\u001b[K\u001b[7;1H\u001b[4m* Context Line Control\u001b[24m::\u001b[K\u001b[8;1H\u001b[4m* File and Directory Selection\u001b[24m::\u001b[K\u001b[9;1H\u001b[4m* Other Options\u001b[24m::\u001b[K\u001b[10;1H\u001b[K\u001b[11;1H   Several additional options control which variant of the ‘grep’\u001b[12;1Hmatching engine is used.  \u001b[1m*Note grep Programs\u001b[0m::.\u001b[K\u001b[12;1H"]
