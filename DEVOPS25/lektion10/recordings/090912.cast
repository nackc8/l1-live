[1804.655199, "o", "\u001b[4mGREP\u001b[24m(1)                        User Commands                        \u001b[4mGREP\u001b[24m(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       grep, egrep, fgrep, rgrep - print lines that match patterns\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mgrep \u001b[22m[\u001b[4mOPTION\u001b[24m...] \u001b[4mPATTERNS\u001b[24m [\u001b[4mFILE\u001b[24m...]\u001b[m\r\n       \u001b[1mgrep \u001b[22m[\u001b[4mOPTION\u001b[24m...] \u001b[1m-e \u001b[4m\u001b[22mPATTERNS\u001b[24m ... [\u001b[4mFILE\u001b[24m...]\u001b[m\r\n       \u001b[1mgrep \u001b[22m[\u001b[4mOPTION\u001b[24m...] \u001b[1m-f \u001b[4m\u001b[22mPATTERN_FILE\u001b[24m ... [\u001b[4mFILE\u001b[24m...]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       \u001b[1mgrep  \u001b[22msearches  for  \u001b[4mPATTERNS\u001b[24m in each \u001b[4mFILE\u001b[24m.  \u001b[4mPATTERNS\u001b[24m is one or more\u001b[m\r\n       patterns separated by newline characters, and \u001b[1mgrep \u001b[22mprints each  line\u001b[m\r\n\u001b[7m Manual page grep(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1805.52876, "o", "\r\u001b[K"]
[1805.528853, "o", "       that  matches  a  pattern.  Typically \u001b[4mPATTERNS\u001b[24m should be quoted when\u001b[m\r\n       \u001b[1mgrep \u001b[22mis used in a shell command.\u001b[m\r\n\u001b[m\r\n       A \u001b[4mFILE\u001b[24m of “\u001b[1m-\u001b[22m” stands for standard  input.   If  no  \u001b[4mFILE\u001b[24m  is  given,\u001b[m\r\n       recursive  searches  examine the working directory, and nonrecursive\u001b[m\r\n       searches read standard input.\u001b[m\r\n\u001b[m\r\n       Debian also includes the variant programs \u001b[1megrep\u001b[22m,  \u001b[1mfgrep  \u001b[22mand  \u001b[1mrgrep\u001b[22m.\u001b[m\r\n       These  programs  are  the  same  as  \u001b[1mgrep -E\u001b[22m,  \u001b[1mgrep -F\u001b[22m, and \u001b[1mgrep -r\u001b[22m,\u001b[m\r\n       respectively.  These variants are deprecated  upstream,  but  Debian\u001b[m\r\n       provides  for backward compatibility. For portability reasons, it is\u001b[m\r\n       recommended to avoid the variant programs, and  use  \u001b[1mgrep  \u001b[22mwith  the\u001b[m\r\n       related option instead.\u001b[m\r\n\u001b[7m Manual page grep(1) line 14 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1805.970729, "o", "\r\u001b[K"]
[1805.970825, "o", "\u001b[m\r\n\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n   \u001b[1mGeneric Program Information\u001b[0m\u001b[m\r\n       \u001b[1m--help \u001b[22mOutput a usage message and exit.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-V\u001b[22m, \u001b[1m--version\u001b[0m\u001b[m\r\n              Output the version number of \u001b[1mgrep \u001b[22mand exit.\u001b[m\r\n\u001b[m\r\n   \u001b[1mPattern Syntax\u001b[0m\u001b[m\r\n       \u001b[1m-E\u001b[22m, \u001b[1m--extended-regexp\u001b[0m\u001b[m\r\n              Interpret \u001b[4mPATTERNS\u001b[24m as extended regular expressions (EREs, see\u001b[m\r\n              below).\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page grep(1) line 27 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1809.451167, "o", "\r\u001b[K       \u001b[1m-F\u001b[22m, \u001b[1m--fixed-strings\u001b[0m\u001b[m\r\n              Interpret \u001b[4mPATTERNS\u001b[24m as fixed strings, not regular expressions.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-G\u001b[22m, \u001b[1m--basic-regexp\u001b[0m\u001b[m\r\n              Interpret  \u001b[4mPATTERNS\u001b[24m  as  basic regular expressions (BREs, see\u001b[m\r\n              below).  This is the default.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-P\u001b[22m, \u001b[1m--perl-regexp\u001b[0m\u001b[m\r\n              Interpret \u001b[4mPATTERNS\u001b[24m  as  Perl-compatible  regular  expressions\u001b[m\r\n              (PCREs).   This option is experimental when combined with the\u001b[m\r\n              \u001b[1m-z  \u001b[22m(\u001b[1m--null-data\u001b[22m)  option,  and   \u001b[1mgrep   -P   \u001b[22mmay   warn   of\u001b[m\r\n              unimplemented features.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page grep(1) line 40 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1810.613387, "o", "\r\u001b[K/"]
[1810.935135, "o", "\u001b[KE\bE"]
[1811.137662, "o", "\u001b[KR\bR"]
[1811.303347, "o", "\u001b[KE\bE"]
[1811.617753, "o", "\r\u001b[K"]
[1811.618954, "o", "\u001b[1;1H\u001b[K       \u001b[1m-F\u001b[22m, \u001b[1m--fixed-strings\u001b[0m\u001b[m\r\n\u001b[2;1H\u001b[K              Interpret \u001b[4mPATTERNS\u001b[24m as fixed strings, not regular expressions.\u001b[m\r\n\u001b[3;1H\u001b[K\u001b[m\r\n\u001b[4;1H\u001b[K       \u001b[1m-G\u001b[22m, \u001b[1m--basic-regexp\u001b[0m\u001b[m\r\n\u001b[5;1H\u001b[K              Interpret  \u001b[4mPATTERNS\u001b[24m  as  basic regular expressions (BREs, see\u001b[m\r\n\u001b[6;1H\u001b[K              below).  This is the default.\u001b[m\r\n\u001b[7;1H\u001b[K\u001b[m\r\n\u001b[8;1H\u001b[K       \u001b[1m-P\u001b[22m, \u001b[1m--perl-regexp\u001b[0m\u001b[m\r\n\u001b[9;1H\u001b[K              Interpret \u001b[4mPATTERNS\u001b[24m  as  Perl-compatible  regular  expressions\u001b[m\r\n\u001b[10;1H\u001b[K              (PCREs).   This option is experimental when combined with the\u001b[m\r\n\u001b[11;1H\u001b[K              \u001b[1m-z  \u001b[22m(\u001b[1m--null-data\u001b[22m)  option,  and   \u001b[1mgrep   -P   \u001b[22mmay   warn   of\u001b[m\r\n\u001b[12;1H\u001b[K              unimplemented features.\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[m\r\n\u001b[14;1H\u001b[1;1H\u001b[K       \u001b[1m-F\u001b[22m, \u001b[1m--fixed-strings\u001b[0m\u001b[m\r\n\u001b[2;1H\u001b[K              Interpret \u001b[4mPATTERNS\u001b[24m as fixed strings, not regular expressions.\u001b[m\r\n\u001b[3;1H\u001b[K\u001b[m\r\n\u001b[4;1H\u001b[K       \u001b[1m-G\u001b[22m, \u001b[1m--basic-r"]
[1811.619539, "o", "egexp\u001b[0m\u001b[m\r\n\u001b[5;1H\u001b[K              Interpret  \u001b[4mPATTERNS\u001b[24m  as  basic regular expressions (BREs, see\u001b[m\r\n\u001b[6;1H\u001b[K              below).  This is the default.\u001b[m\r\n\u001b[7;1H\u001b[K\u001b[m\r\n\u001b[8;1H\u001b[K       \u001b[1m-P\u001b[22m, \u001b[1m--perl-regexp\u001b[0m\u001b[m\r\n\u001b[9;1H\u001b[K              Interpret \u001b[4mPATTERNS\u001b[24m  as  Perl-compatible  regular  expressions\u001b[m\r\n\u001b[10;1H\u001b[K              (PCREs).   This option is experimental when combined with the\u001b[m\r\n\u001b[11;1H\u001b[K              \u001b[1m-z  \u001b[22m(\u001b[1m--null-data\u001b[22m)  option,  and   \u001b[1mgrep   -P   \u001b[22mmay   warn   of\u001b[m\r\n\u001b[12;1H\u001b[K              unimplemented features.\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[m\r\n\u001b[14;1H"]
[1811.621562, "o", "...skipping...\r\n       syntax: “basic” (BRE), “extended” (\u001b[7mERE\u001b[27m) and “perl” (PCRE).   In  GNU\u001b[m\r\n       \u001b[1mgrep\u001b[22m,  basic  and  extended regular expressions are merely different\u001b[m\r\n       notations for the same  pattern-matching  functionality.   In  other\u001b[m\r\n       implementations,  basic  regular  expressions  are  ordinarily  less\u001b[m\r\n       powerful than extended, though occasionally  it  is  the  other  way\u001b[m\r\n       around.   The  following  description  applies  to  extended regular\u001b[m\r\n       expressions;  differences  for   basic   regular   expressions   are\u001b[m\r\n       summarized  afterwards.   Perl-compatible  regular  expressions have\u001b[m\r\n       different functionality, and are documented  in  \u001b[1mpcre2syntax\u001b[22m(3)  and\u001b[m\r\n       \u001b[1mpcre2pattern\u001b[22m(3), but work only if PCRE support is enabled.\u001b[m\r\n\u001b[m\r\n       The  fundamental  building  blocks  are the regular expressions that\u001b[m\r\n       match a single character.  Most characters,  including  all  letters\u001b[m\r\n\u001b[7m Manual page grep(1) line 353 (press h for help or q to quit)\u001b[27m\u001b[K"]
[1813.163797, "o", "\r\u001b[K/\r\u001b[K"]
[1813.165217, "o", "\r\u001b[K\u001b[7mPattern not found  (press RETURN)\u001b[27m"]
[1813.785706, "o", "\u001b[14;1H\u001b[K\r\u001b[K/\r\u001b[K"]
[1813.787358, "o", "\r\u001b[K\u001b[7mPattern not found  (press RETURN)\u001b[27m"]
[1814.378641, "o", "\u001b[14;1H\u001b[K"]
[1814.378869, "o", "\r\u001b[K\u001b[7m Manual page grep(1) line 353/667 54% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1814.933008, "o", "\r\u001b[K"]
[1814.933126, "o", "       and  digits,  are  regular  expressions  that match themselves.  Any\u001b[m\r\n       meta-character with special meaning may be quoted  by  preceding  it\u001b[m\r\n       with a backslash.\u001b[m\r\n\u001b[m\r\n       The  period  \u001b[1m.  \u001b[22mmatches  any  single  character.   It is unspecified\u001b[m\r\n       whether it matches an encoding error.\u001b[m\r\n\u001b[m\r\n   \u001b[1mCharacter Classes and Bracket Expressions\u001b[0m\u001b[m\r\n       A \u001b[4mbracket\u001b[24m \u001b[4mexpression\u001b[24m is a list of characters enclosed by  \u001b[1m[  \u001b[22mand  \u001b[1m]\u001b[22m.\u001b[m\r\n       It  matches  any  single  character  in  that  list.   If  the first\u001b[m\r\n       character of the list is the caret \u001b[1m^ \u001b[22mthen it matches  any  character\u001b[m\r\n       \u001b[4mnot\u001b[24m  in  the  list; it is unspecified whether it matches an encoding\u001b[m\r\n       error.  For example, the regular expression \u001b[1m[0123456789] \u001b[22mmatches any\u001b[m\r\n\u001b[7m Manual page grep(1) line 366/667 56% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.435627, "o", "\r\u001b[K"]
[1815.4357, "o", "       single digit.\u001b[m\r\n\u001b[m\r\n       Within a bracket expression, a  \u001b[4mrange\u001b[24m  \u001b[4mexpression\u001b[24m  consists  of  two\u001b[m\r\n       characters  separated  by a hyphen.  It matches any single character\u001b[m\r\n       that sorts between the two characters, inclusive, using the locale's\u001b[m\r\n       collating sequence and character set.  For example, in the default C\u001b[m\r\n       locale, \u001b[1m[a-d] \u001b[22mis equivalent to \u001b[1m[abcd]\u001b[22m.  Many locales sort characters\u001b[m\r\n       in dictionary order, and in these locales  \u001b[1m[a-d]  \u001b[22mis  typically  not\u001b[m\r\n       equivalent  to  \u001b[1m[abcd]\u001b[22m;  it  might  be  equivalent to \u001b[1m[aBbCcDd]\u001b[22m, for\u001b[m\r\n       example.   To  obtain  the  traditional  interpretation  of  bracket\u001b[m\r\n       expressions,  you  can  use  the  C  locale  by  setting  the \u001b[1mLC_ALL\u001b[0m\u001b[m\r\n       environment variable to the value \u001b[1mC\u001b[22m.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page grep(1) line 379/667 58% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.467133, "o", "\r\u001b[K"]
[1815.467228, "o", "       Finally, certain named classes of characters are  predefined  within\u001b[m\r\n       bracket  expressions, as follows.  Their names are self explanatory,\u001b[m\r\n       and they are \u001b[1m[:alnum:]\u001b[22m, \u001b[1m[:alpha:]\u001b[22m, \u001b[1m[:blank:]\u001b[22m, \u001b[1m[:cntrl:]\u001b[22m,  \u001b[1m[:digit:]\u001b[22m,\u001b[m\r\n       \u001b[1m[:graph:]\u001b[22m,  \u001b[1m[:lower:]\u001b[22m,  \u001b[1m[:print:]\u001b[22m,  \u001b[1m[:punct:]\u001b[22m, \u001b[1m[:space:]\u001b[22m, \u001b[1m[:upper:]\u001b[22m,\u001b[m\r\n       and \u001b[1m[:xdigit:]\u001b[22m.  For example, \u001b[1m[[:alnum:]] \u001b[22mmeans the character  class\u001b[m\r\n       of  numbers  and letters in the current locale.  In the C locale and\u001b[m\r\n       ASCII character set encoding,  this  is  the  same  as  \u001b[1m[0-9A-Za-z]\u001b[22m.\u001b[m\r\n       (Note  that  the  brackets  in  these  class  names  are part of the\u001b[m\r\n       symbolic names, and must be included in  addition  to  the  brackets\u001b[m\r\n       delimiting the bracket expression.)  Most meta-characters lose their\u001b[m\r\n       special  meaning inside bracket expressions.  To include a literal \u001b[1m]\u001b[0m\u001b[m\r\n       place it firs"]
[1815.467303, "o", "t in the list.  Similarly, to include a literal \u001b[1m^ \u001b[22mplace\u001b[m\r\n       it anywhere but first.  Finally, to include a  literal  \u001b[1m-  \u001b[22mplace  it\u001b[m\r\n\u001b[7m Manual page grep(1) line 392/667 61% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.498837, "o", "\r\u001b[K"]
[1815.49932, "o", "       last.\u001b[m\r\n\u001b[m\r\n   \u001b[1mAnchoring\u001b[0m\u001b[m\r\n       The  caret  \u001b[1m^  \u001b[22mand  the  dollar  sign  \u001b[1m$  \u001b[22mare  meta-characters  that\u001b[m\r\n       respectively match the empty string at the beginning and  end  of  a\u001b[m\r\n       line.\u001b[m\r\n\u001b[m\r\n   \u001b[1mThe Backslash Character and Special Expressions\u001b[0m\u001b[m\r\n       The  symbols  \u001b[1m\\<  \u001b[22mand  \u001b[1m\\> \u001b[22mrespectively match the empty string at the\u001b[m\r\n       beginning and end of a word.  The symbol \u001b[1m\\b \u001b[22mmatches the empty string\u001b[m\r\n       at the edge of a word, and \u001b[1m\\B \u001b[22mmatches the empty string provided it's\u001b[m\r\n       \u001b[4mnot\u001b[24m at the edge  of  a  word.   The  symbol  \u001b[1m\\w  \u001b[22mis  a  synonym  for\u001b[m\r\n       \u001b[1m[_[:alnum:]] \u001b[22mand \u001b[1m\\W \u001b[22mis a synonym for \u001b[1m[^_[:alnum:]]\u001b[22m.\u001b[m\r\n\u001b[7m Manual page grep(1) line 405/667 63% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.532849, "o", "\r\u001b[K"]
[1815.533125, "o", "\u001b[m\r\n   \u001b[1mRepetition\u001b[0m\u001b[m\r\n       A  regular  expression  may be followed by one of several repetition\u001b[m\r\n       operators:\u001b[m\r\n       \u001b[1m?      \u001b[22mThe preceding item is optional and matched at most once.\u001b[m\r\n       \u001b[1m*      \u001b[22mThe preceding item will be matched zero or more times.\u001b[m\r\n       \u001b[1m+      \u001b[22mThe preceding item will be matched one or more times.\u001b[m\r\n       \u001b[1m{\u001b[4m\u001b[22mn\u001b[24m\u001b[1m}    \u001b[22mThe preceding item is matched exactly \u001b[4mn\u001b[24m times.\u001b[m\r\n       \u001b[1m{\u001b[4m\u001b[22mn\u001b[24m\u001b[1m,}   \u001b[22mThe preceding item is matched \u001b[4mn\u001b[24m or more times.\u001b[m\r\n       \u001b[1m{,\u001b[4m\u001b[22mm\u001b[24m\u001b[1m}   \u001b[22mThe preceding item is matched at most \u001b[4mm\u001b[24m times.  This is a GNU\u001b[m\r\n              extension.\u001b[m\r\n       \u001b[1m{\u001b[4m\u001b[22mn\u001b[24m\u001b[1m,\u001b[4m\u001b[22mm\u001b[24m\u001b[1m}  \u001b[22mThe preceding item is matched at least \u001b[4mn\u001b[24m times, but not  more\u001b[m\r\n              than \u001b[4mm\u001b[24m times.\u001b[m\r\n\u001b[7m Manual page grep(1) line 418/667 65% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.565038, "o", "\r\u001b[K"]
[1815.565164, "o", "\u001b[m\r\n   \u001b[1mConcatenation\u001b[0m\u001b[m\r\n       Two  regular  expressions may be concatenated; the resulting regular\u001b[m\r\n       expression matches any string formed by concatenating two substrings\u001b[m\r\n       that respectively match the concatenated expressions.\u001b[m\r\n\u001b[m\r\n   \u001b[1mAlternation\u001b[0m\u001b[m\r\n       Two regular expressions may be joined by the infix operator  \u001b[1m|\u001b[22m;  the\u001b[m\r\n       resulting  regular  expression  matches  any  string matching either\u001b[m\r\n       alternate expression.\u001b[m\r\n\u001b[m\r\n   \u001b[1mPrecedence\u001b[0m\u001b[m\r\n       Repetition takes precedence over concatenation, which in turn  takes\u001b[m\r\n\u001b[7m Manual page grep(1) line 431/667 66% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.59599, "o", "\r\u001b[K"]
[1815.596096, "o", "       precedence  over alternation.  A whole expression may be enclosed in\u001b[m\r\n       parentheses  to  override  these  precedence  rules   and   form   a\u001b[m\r\n       subexpression.\u001b[m\r\n\u001b[m\r\n   \u001b[1mBack-references and Subexpressions\u001b[0m\u001b[m\r\n       The  back-reference  \u001b[1m\\\u001b[4m\u001b[22mn\u001b[24m,  where  \u001b[4mn\u001b[24m  is  a  single digit, matches the\u001b[m\r\n       substring previously matched by the \u001b[4mn\u001b[24mth parenthesized  subexpression\u001b[m\r\n       of the regular expression.\u001b[m\r\n\u001b[m\r\n   \u001b[1mBasic vs Extended Regular Expressions\u001b[0m\u001b[m\r\n       In  basic regular expressions the meta-characters \u001b[1m?\u001b[22m, \u001b[1m+\u001b[22m, \u001b[1m{\u001b[22m, \u001b[1m|\u001b[22m, \u001b[1m(\u001b[22m, and\u001b[m\r\n       \u001b[1m) \u001b[22mlose their special meaning; instead use the  backslashed  versions\u001b[m\r\n       \u001b[1m\\?\u001b[22m, \u001b[1m\\+\u001b[22m, \u001b[1m\\{\u001b[22m, \u001b[1m\\|\u001b[22m, \u001b[1m\\(\u001b[22m, and \u001b[1m\\)\u001b[22m.\u001b[m\r\n\u001b[7m Manual page grep(1) line 444/667 68% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.627265, "o", "\r\u001b[K"]
[1815.627434, "o", "\u001b[m\r\n\u001b[1mEXIT STATUS\u001b[0m\u001b[m\r\n       Normally  the  exit status is 0 if a line is selected, 1 if no lines\u001b[m\r\n       were selected, and 2 if an error occurred.  However, if  the  \u001b[1m-q  \u001b[22mor\u001b[m\r\n       \u001b[1m--quiet  \u001b[22mor \u001b[1m--silent \u001b[22mis used and a line is selected, the exit status\u001b[m\r\n       is 0 even if an error occurred.\u001b[m\r\n\u001b[m\r\n\u001b[1mENVIRONMENT\u001b[0m\u001b[m\r\n       The behavior of  \u001b[1mgrep  \u001b[22mis  affected  by  the  following  environment\u001b[m\r\n       variables.\u001b[m\r\n\u001b[m\r\n       The  locale  for category \u001b[1mLC_\u001b[4m\u001b[22mfoo\u001b[24m is specified by examining the three\u001b[m\r\n       environment variables \u001b[1mLC_ALL\u001b[22m, \u001b[1mLC_\u001b[4m\u001b[22mfoo\u001b[24m,  \u001b[1mLANG\u001b[22m,  in  that  order.   The\u001b[m\r\n\u001b[7m Manual page grep(1) line 457/667 70% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.658747, "o", "\r\u001b[K"]
[1815.659253, "o", "       first  of  these  variables  that  is set specifies the locale.  For\u001b[m\r\n       example, if \u001b[1mLC_ALL \u001b[22mis not set, but \u001b[1mLC_MESSAGES \u001b[22mis set to \u001b[1mpt_BR\u001b[22m, then\u001b[m\r\n       the  Brazilian  Portuguese  locale  is  used  for  the   \u001b[1mLC_MESSAGES\u001b[0m\u001b[m\r\n       category.   The  C  locale  is  used  if  none  of these environment\u001b[m\r\n       variables are set, if the locale catalog is  not  installed,  or  if\u001b[m\r\n       \u001b[1mgrep  \u001b[22mwas  not  compiled  with national language support (NLS).  The\u001b[m\r\n       shell command \u001b[1mlocale -a \u001b[22mlists locales that are currently available.\u001b[m\r\n\u001b[m\r\n       \u001b[1mGREP_COLORS\u001b[0m\u001b[m\r\n              Controls how the \u001b[1m--color \u001b[22moption highlights output.  Its value\u001b[m\r\n              is a colon-separated list of capabilities  that  defaults  to\u001b[m\r\n              \u001b[1mms=01;31:mc=01;31:sl=:cx=:fn=35:ln=32:bn=32:se=36 \u001b[22mwith the \u001b[1mrv\u001b[0m\u001b[m\r\n              and \u001b[1mne \u001b[22mboolean capabilities omitted (i.e., false).  Supported\u001b[m\r\n\u001b[7m Manual page grep(1) line 470/667 72% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.689954, "o", "\r\u001b[K"]
[1815.690538, "o", "              capabilities are as follows.\u001b[m\r\n\u001b[m\r\n              \u001b[1msl=    \u001b[22mSGR substring for whole selected lines (i.e., matching\u001b[m\r\n                     lines  when  the \u001b[1m-v \u001b[22mcommand-line option is omitted, or\u001b[m\r\n                     non-matching lines when \u001b[1m-v \u001b[22mis specified).  If  however\u001b[m\r\n                     the  boolean  \u001b[1mrv  \u001b[22mcapability  and  the \u001b[1m-v \u001b[22mcommand-line\u001b[m\r\n                     option are  both  specified,  it  applies  to  context\u001b[m\r\n                     matching  lines  instead.  The default is empty (i.e.,\u001b[m\r\n                     the terminal's default color pair).\u001b[m\r\n\u001b[m\r\n              \u001b[1mcx=    \u001b[22mSGR substring for  whole  context  lines  (i.e.,  non-\u001b[m\r\n                     matching  lines  when  the  \u001b[1m-v  \u001b[22mcommand-line option is\u001b[m\r\n                     omitted, or matching lines when \u001b[1m-v \u001b[22mis specified).   If\u001b[m\r\n\u001b[7m Manual page grep(1) line 483/667 74% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.72303, "o", "\r\u001b[K"]
[1815.72341, "o", "                     however  the boolean \u001b[1mrv \u001b[22mcapability and the \u001b[1m-v \u001b[22mcommand-\u001b[m\r\n                     line option are both specified, it applies to selected\u001b[m\r\n                     non-matching lines  instead.   The  default  is  empty\u001b[m\r\n                     (i.e., the terminal's default color pair).\u001b[m\r\n\u001b[m\r\n              \u001b[1mrv     \u001b[22mBoolean  value  that  reverses (swaps) the meanings of\u001b[m\r\n                     the \u001b[1msl= \u001b[22mand \u001b[1mcx= \u001b[22mcapabilities when the \u001b[1m-v  \u001b[22mcommand-line\u001b[m\r\n                     option  is specified.  The default is false (i.e., the\u001b[m\r\n                     capability is omitted).\u001b[m\r\n\u001b[m\r\n              \u001b[1mmt=01;31\u001b[0m\u001b[m\r\n                     SGR substring  for  matching  non-empty  text  in  any\u001b[m\r\n                     matching  line  (i.e.,  a  selected  line  when the \u001b[1m-v\u001b[0m\u001b[m\r\n\u001b[7m Manual page grep(1) line 496/667 77% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.753266, "o", "\r\u001b[K"]
[1815.753478, "o", "                     command-line option is omitted, or a context line when\u001b[m\r\n                     \u001b[1m-v \u001b[22mis  specified).   Setting  this  is  equivalent  to\u001b[m\r\n                     setting  both  \u001b[1mms=  \u001b[22mand \u001b[1mmc= \u001b[22mat once to the same value.\u001b[m\r\n                     The default is a bold red  text  foreground  over  the\u001b[m\r\n                     current line background.\u001b[m\r\n\u001b[m\r\n              \u001b[1mms=01;31\u001b[0m\u001b[m\r\n                     SGR   substring  for  matching  non-empty  text  in  a\u001b[m\r\n                     selected  line.   (This  is  only  used  when  the  \u001b[1m-v\u001b[0m\u001b[m\r\n                     command-line  option  is  omitted.)  The effect of the\u001b[m\r\n                     \u001b[1msl= \u001b[22m(or \u001b[1mcx= \u001b[22mif \u001b[1mrv\u001b[22m) capability remains active when this\u001b[m\r\n                     kicks in.  The default is a bold red  text  foreground\u001b[m\r\n                     over the current line background.\u001b[m\r\n\u001b[7m Manual page grep(1) line 509/667 79% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.785299, "o", "\r\u001b[K"]
[1815.785785, "o", "\u001b[m\r\n              \u001b[1mmc=01;31\u001b[0m\u001b[m\r\n                     SGR substring for matching non-empty text in a context\u001b[m\r\n                     line.   (This  is  only  used when the \u001b[1m-v \u001b[22mcommand-line\u001b[m\r\n                     option is specified.)  The effect of the \u001b[1mcx=  \u001b[22m(or  \u001b[1msl=\u001b[0m\u001b[m\r\n                     if  \u001b[1mrv\u001b[22m)  capability remains active when this kicks in.\u001b[m\r\n                     The default is a bold red  text  foreground  over  the\u001b[m\r\n                     current line background.\u001b[m\r\n\u001b[m\r\n              \u001b[1mfn=35  \u001b[22mSGR  substring  for  file  names prefixing any content\u001b[m\r\n                     line.  The default is a magenta text  foreground  over\u001b[m\r\n                     the terminal's default background.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page grep(1) line 522/667 81% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.817862, "o", "\r\u001b[K"]
[1815.818137, "o", "              \u001b[1mln=32  \u001b[22mSGR  substring  for line numbers prefixing any content\u001b[m\r\n                     line.  The default is a green text foreground over the\u001b[m\r\n                     terminal's default background.\u001b[m\r\n\u001b[m\r\n              \u001b[1mbn=32  \u001b[22mSGR substring for byte offsets prefixing  any  content\u001b[m\r\n                     line.  The default is a green text foreground over the\u001b[m\r\n                     terminal's default background.\u001b[m\r\n\u001b[m\r\n              \u001b[1mse=36  \u001b[22mSGR substring for separators that are inserted between\u001b[m\r\n                     selected line fields (\u001b[1m:\u001b[22m), between context line fields,\u001b[m\r\n                     (\u001b[1m-\u001b[22m), and between groups of adjacent lines when nonzero\u001b[m\r\n                     context is specified (\u001b[1m--\u001b[22m).  The default is a cyan text\u001b[m\r\n                     foreground over the terminal's default background.\u001b[m\r\n\u001b[7m Manual page grep(1) line 535/667 83% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.848769, "o", "\r\u001b[K"]
[1815.848872, "o", "\u001b[m\r\n              \u001b[1mne     \u001b[22mBoolean  value  that  prevents  clearing to the end of\u001b[m\r\n                     line using Erase in Line (EL) to  Right  (\u001b[1m\\33[K\u001b[22m)  each\u001b[m\r\n                     time  a  colorized  item  ends.   This  is  needed  on\u001b[m\r\n                     terminals  on  which  EL  is  not  supported.   It  is\u001b[m\r\n                     otherwise   useful   on   terminals   for   which  the\u001b[m\r\n                     \u001b[1mback_color_erase  \u001b[22m(\u001b[1mbce\u001b[22m)  boolean  terminfo  capability\u001b[m\r\n                     does  not  apply,  when the chosen highlight colors do\u001b[m\r\n                     not affect the background, or when EL is too  slow  or\u001b[m\r\n                     causes  too much flicker.  The default is false (i.e.,\u001b[m\r\n                     the capability is omitted).\u001b[m\r\n\u001b[m\r\n              Note that boolean capabilities have no \u001b[1m=\u001b[22m... part.   They  are\u001b[m\r\n\u001b[7m Manual page grep(1) line 548/667 85% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.880012, "o", "\r\u001b[K"]
[1815.880321, "o", "              omitted  (i.e.,  false)  by  default  and  become  true  when\u001b[m\r\n              specified.\u001b[m\r\n\u001b[m\r\n              See  the  Select  Graphic  Rendition  (SGR)  section  in  the\u001b[m\r\n              documentation of the text terminal that is used for permitted\u001b[m\r\n              values  and  their  meaning  as  character attributes.  These\u001b[m\r\n              substring values are integers in decimal  representation  and\u001b[m\r\n              can  be  concatenated  with  semicolons.   \u001b[1mgrep \u001b[22mtakes care of\u001b[m\r\n              assembling  the  result  into   a   complete   SGR   sequence\u001b[m\r\n              (\u001b[1m\\33[\u001b[22m...\u001b[1mm\u001b[22m).  Common values to concatenate include \u001b[1m1 \u001b[22mfor bold,\u001b[m\r\n              \u001b[1m4  \u001b[22mfor  underline, \u001b[1m5 \u001b[22mfor blink, \u001b[1m7 \u001b[22mfor inverse, \u001b[1m39 \u001b[22mfor default\u001b[m\r\n              foreground color, \u001b[1m30 \u001b[22mto \u001b[1m37 \u001b[22mfor foreground colors,  \u001b[1m90  \u001b[22mto  \u001b[1m97\u001b[0m\u001b[m\r\n              for  16-color  mode foreground colors, \u001b[1m38;5;0 \u001b[22mto \u001b[1m38;5;255 \u001b[22mfor\u001b[m\r\n\u001b[7m Manual page grep(1) line 561/667 87% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.912495, "o", "\r\u001b[K              88-color  and  256-color  modes  foreground  colors,  \u001b[1m49  \u001b[22mfor\u001b[m\r\n              default background color, \u001b[1m40 \u001b[22mto \u001b[1m47 \u001b[22mfor background colors, \u001b[1m100\u001b[0m\u001b[m\r\n              to  \u001b[1m107  \u001b[22mfor  16-color  mode background colors, and \u001b[1m48;5;0 \u001b[22mto\u001b[m\r\n              \u001b[1m48;5;255 \u001b[22mfor 88-color and 256-color modes background colors.\u001b[m\r\n\u001b[m\r\n       \u001b[1mLC_ALL\u001b[22m, \u001b[1mLC_COLLATE\u001b[22m, \u001b[1mLANG\u001b[0m\u001b[m\r\n              These  variables  specify  the  locale  for  the   \u001b[1mLC_COLLATE\u001b[0m\u001b[m\r\n              category,  which  determines  the  collating sequence used to\u001b[m\r\n              interpret range expressions like \u001b[1m[a-z]\u001b[22m.\u001b[m\r\n\u001b[m\r\n       \u001b[1mLC_ALL\u001b[22m, \u001b[1mLC_CTYPE\u001b[22m, \u001b[1mLANG\u001b[0m\u001b[m\r\n              These variables specify the locale for the \u001b[1mLC_CTYPE \u001b[22mcategory,\u001b[m\r\n              which  determines  the  type  of  characters,   e.g.,   which\u001b[m\r\n\u001b[7m Manual page grep(1) line 574/667 89% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.941967, "o", "\r\u001b[K"]
[1815.942078, "o", "              characters are whitespace.  This category also determines the\u001b[m\r\n              character  encoding,  that  is,  whether  text  is encoded in\u001b[m\r\n              UTF-8, ASCII, or some other encoding.   In  the  C  or  POSIX\u001b[m\r\n              locale, all characters are encoded as a single byte and every\u001b[m\r\n              byte is a valid character.\u001b[m\r\n\u001b[m\r\n       \u001b[1mLC_ALL\u001b[22m, \u001b[1mLC_MESSAGES\u001b[22m, \u001b[1mLANG\u001b[0m\u001b[m\r\n              These  variables  specify  the  locale  for  the  \u001b[1mLC_MESSAGES\u001b[0m\u001b[m\r\n              category, which determines the language that  \u001b[1mgrep  \u001b[22muses  for\u001b[m\r\n              messages.    The  default  C  locale  uses  American  English\u001b[m\r\n              messages.\u001b[m\r\n\u001b[m\r\n       \u001b[1mPOSIXLY_CORRECT\u001b[0m\u001b[m\r\n\u001b[7m Manual page grep(1) line 587/667 91% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1815.973806, "o", "\r\u001b[K"]
[1815.973867, "o", "              If set, \u001b[1mgrep  \u001b[22mbehaves  as  POSIX  requires;  otherwise,  \u001b[1mgrep\u001b[0m\u001b[m\r\n              behaves  more  like  other GNU programs.  POSIX requires that\u001b[m\r\n              options that follow file names must be treated as file names;\u001b[m\r\n              by default, such options are permuted to  the  front  of  the\u001b[m\r\n              operand  list  and  are  treated  as  options.   Also,  POSIX\u001b[m\r\n              requires that unrecognized options be diagnosed as “illegal”,\u001b[m\r\n              but since they are not really against the law the default  is\u001b[m\r\n              to diagnose them as “invalid”.\u001b[m\r\n\u001b[m\r\n\u001b[1mNOTES\u001b[0m\u001b[m\r\n       This man page is maintained only fitfully; the full documentation is\u001b[m\r\n       often more up-to-date.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page grep(1) line 600/667 93% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1816.006644, "o", "\r\u001b[K"]
[1816.006791, "o", "\u001b[1mCOPYRIGHT\u001b[0m\u001b[m\r\n       Copyright 1998-2000, 2002, 2005-2023 Free Software Foundation, Inc.\u001b[m\r\n\u001b[m\r\n       This is free software; see the source for copying conditions.  There\u001b[m\r\n       is  NO  warranty;  not  even  for  MERCHANTABILITY  or FITNESS FOR A\u001b[m\r\n       PARTICULAR PURPOSE.\u001b[m\r\n\u001b[m\r\n\u001b[1mBUGS\u001b[0m\u001b[m\r\n   \u001b[1mReporting Bugs\u001b[0m\u001b[m\r\n       Email bug reports to the bug-reporting  address  ⟨bug-grep@gnu.org⟩.\u001b[m\r\n       An  email  archive ⟨https://lists.gnu.org/mailman/listinfo/bug-grep⟩\u001b[m\r\n       and                  a                  bug                  tracker\u001b[m\r\n       ⟨https://debbugs.gnu.org/cgi/pkgreport.cgi?package=grep⟩  are avail‐\u001b[m\r\n\u001b[7m Manual page grep(1) line 613/667 95% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1816.037813, "o", "\r\u001b[K"]
[1816.037927, "o", "       able.\u001b[m\r\n\u001b[m\r\n   \u001b[1mKnown Bugs\u001b[0m\u001b[m\r\n       Large repetition counts in the \u001b[1m{\u001b[4m\u001b[22mn\u001b[24m\u001b[1m,\u001b[4m\u001b[22mm\u001b[24m\u001b[1m} \u001b[22mconstruct may cause \u001b[1mgrep \u001b[22mto use\u001b[m\r\n       lots of memory.  In addition, certain other obscure regular  expres‐\u001b[m\r\n       sions  require exponential time and space, and may cause \u001b[1mgrep \u001b[22mto run\u001b[m\r\n       out of memory.\u001b[m\r\n\u001b[m\r\n       Back-references are very slow, and may require exponential time.\u001b[m\r\n\u001b[m\r\n\u001b[1mEXAMPLE\u001b[0m\u001b[m\r\n       The following example outputs the location and contents of any  line\u001b[m\r\n       containing  “f”  and ending in “.c”, within all files in the current\u001b[m\r\n\u001b[7m Manual page grep(1) line 626/667 96% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1816.069626, "o", "\r\u001b[K       directory whose names contain “g” and end in “.h”.   The  \u001b[1m-n  \u001b[22moption\u001b[m\r\n       outputs  line  numbers, the \u001b[1m-- \u001b[22margument treats expansions of “*g*.h”\u001b[m\r\n       starting with “-” as file names not  options,  and  the  empty  file\u001b[m\r\n       /dev/null  causes file names to be output even if only one file name\u001b[m\r\n       happens to be of the form “*g*.h”.\u001b[m\r\n\u001b[m\r\n         $ \u001b[1mgrep \u001b[22m-n -- 'f.*\\.c$' *g*.h /dev/null\u001b[m\r\n         argmatch.h:1:/* definitions and prototypes for argmatch.c\u001b[m\r\n\u001b[m\r\n       The only line that matches is line 1 of argmatch.h.  Note  that  the\u001b[m\r\n       regular expression syntax used in the pattern differs from the glob‐\u001b[m\r\n       bing syntax that the shell uses to match file names.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page grep(1) line 639/667 98% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1816.100696, "o", "\r\u001b[K"]
[1816.100788, "o", "\u001b[1mSEE ALSO\u001b[0m\u001b[m\r\n   \u001b[1mRegular Manual Pages\u001b[0m\u001b[m\r\n       \u001b[1mawk\u001b[22m(1),   \u001b[1mcmp\u001b[22m(1),   \u001b[1mdiff\u001b[22m(1),   \u001b[1mfind\u001b[22m(1),  \u001b[1mperl\u001b[22m(1),  \u001b[1msed\u001b[22m(1),  \u001b[1msort\u001b[22m(1),\u001b[m\r\n       \u001b[1mxargs\u001b[22m(1), \u001b[1mread\u001b[22m(2), \u001b[1mpcre2\u001b[22m(3), \u001b[1mpcre2syntax\u001b[22m(3),  \u001b[1mpcre2pattern\u001b[22m(3),  \u001b[1mter‐\u001b[0m\u001b[m\r\n       \u001b[1mminfo\u001b[22m(5), \u001b[1mglob\u001b[22m(7), \u001b[1mregex\u001b[22m(7)\u001b[m\r\n\u001b[m\r\n   \u001b[1mFull Documentation\u001b[0m\u001b[m\r\n       A  complete  manual  ⟨https://www.gnu.org/software/grep/manual/⟩  is\u001b[m\r\n       available.  If the \u001b[1minfo \u001b[22mand \u001b[1mgrep \u001b[22mprograms are properly installed  at\u001b[m\r\n       your site, the command\u001b[m\r\n\u001b[m\r\n              \u001b[1minfo grep\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page grep(1) line 652/667 100% (press h for help or q to quit)\u001b[27m\u001b[K"]
[1816.131458, "o", "\r\u001b[K"]
[1816.131516, "o", "       should give you access to the complete manual.\u001b[m\r\n\u001b[m\r\nGNU grep 3.11                    2019-12-29                         \u001b[4mGREP\u001b[24m(1)\u001b[m\r\n\u001b[7m Manual page grep(1) line 655/667 (END) (press h for help or q to quit)\u001b[27m\u001b[K"]
