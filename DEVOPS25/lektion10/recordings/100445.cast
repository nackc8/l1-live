[35.959828, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page sed(1) line 149 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.002592, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       h H    Copy/append pattern space to hold space.\u001b[m\r\n\u001b[7m Manual page sed(1) line 150 (press h for help or q to quit)\u001b[27m\u001b[K"]
[36.557426, "o", "\r\u001b[K"]
[36.557679, "o", "\u001b[m\r\n       g G    Copy/append hold space to pattern space.\u001b[m\r\n\u001b[m\r\n       l      List out the current line in a ``visually unambiguous'' form.\u001b[m\r\n\u001b[m\r\n       l \u001b[4mwidth\u001b[0m\u001b[m\r\n              List out the current line in a ``visually unambiguous'' form,\u001b[m\r\n              breaking it at \u001b[4mwidth\u001b[24m characters.  This is a GNU extension.\u001b[m\r\n\u001b[m\r\n       n N    Read/append the next line of input into the pattern space.\u001b[m\r\n\u001b[m\r\n       p      Print the current pattern space.\u001b[m\r\n\u001b[m\r\n       P      Print up to the first embedded newline of the current pattern\u001b[m\r\n              space.\u001b[m\r\n\u001b[m\r\n       s/\u001b[4mregexp\u001b[24m/\u001b[4mreplacement\u001b[24m/\u001b[m\r\n\u001b[7m Manual page sed(1) line 167 (press h for help or q to quit)\u001b[27m\u001b[K"]
[37.713161, "o", "\r\u001b[K"]
[37.713259, "o", "              Attempt  to  match \u001b[4mregexp\u001b[24m against the pattern space.  If suc‐\u001b[m\r\n              cessful, replace that portion matched with \u001b[4mreplacement\u001b[24m.   The\u001b[m\r\n              \u001b[4mreplacement\u001b[24m  may  contain the special character \u001b[1m& \u001b[22mto refer to\u001b[m\r\n              that portion of the pattern space which matched, and the spe‐\u001b[m\r\n              cial escapes \\1 through \\9  to  refer  to  the  corresponding\u001b[m\r\n              matching sub-expressions in the \u001b[4mregexp\u001b[24m.\u001b[m\r\n\u001b[m\r\n       t \u001b[4mlabel\u001b[0m\u001b[m\r\n              If  a  s/// has done a successful substitution since the last\u001b[m\r\n              input line was read and since the last t or T  command,  then\u001b[m\r\n              branch  to  \u001b[4mlabel\u001b[24m;  if  \u001b[4mlabel\u001b[24m  is  omitted,  branch to end of\u001b[m\r\n              script.\u001b[m\r\n\u001b[m\r\n       T \u001b[4mlabel\u001b[0m\u001b[m\r\n              If no s/// has done a successful substitution since the  last\u001b[m\r\n              input  line  was read and since the last t or T command, then\u001b[m\r\n              branch to \u001b[4mlabel\u001b[24m; if  \u001b[4mlabel\u001b[24m  is  omitted,  branch  to  end  of\u001b[m\r\n\u001b[7m Manual page sed(1) line 184 (press h for help or q to quit)\u001b[27m\u001b[K"]
[38.937431, "o", "\r\u001b[K"]
[38.937525, "o", "              script.  This is a GNU extension.\u001b[m\r\n\u001b[m\r\n       w \u001b[4mfilename\u001b[0m\u001b[m\r\n              Write the current pattern space to \u001b[4mfilename\u001b[24m.\u001b[m\r\n\u001b[m\r\n       W \u001b[4mfilename\u001b[0m\u001b[m\r\n              Write  the  first  line of the current pattern space to \u001b[4mfile‐\u001b[0m\u001b[m\r\n              \u001b[4mname\u001b[24m.  This is a GNU extension.\u001b[m\r\n\u001b[m\r\n       x      Exchange the contents of the hold and pattern spaces.\u001b[m\r\n\u001b[m\r\n       y/\u001b[4msource\u001b[24m/\u001b[4mdest\u001b[24m/\u001b[m\r\n"]
[38.937842, "o", "              Transliterate the characters in the pattern space  which  ap‐\u001b[m\r\n              pear in \u001b[4msource\u001b[24m to the corresponding character in \u001b[4mdest\u001b[24m.\u001b[m\r\n\u001b[m\r\n\u001b[1mAddresses\u001b[0m\u001b[m\r\n       \u001b[4mSed\u001b[24m  commands can be given with no addresses, in which case the com‐\u001b[m\r\n\u001b[7m Manual page sed(1) line 201 (press h for help or q to quit)\u001b[27m\u001b[K"]
