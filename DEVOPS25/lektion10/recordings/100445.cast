[34.61259, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       d      Delete pattern space.  Start next cycle.\u001b[m\r\n\u001b[7m Manual page sed(1) line 142 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.013409, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page sed(1) line 143 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.057868, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       D      If pattern space contains no newline, start a normal new  cy‐\u001b[m\r\n\u001b[7m Manual page sed(1) line 144 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.091355, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              cle  as  if the d command was issued.  Otherwise, delete text\u001b[m\r\n\u001b[7m Manual page sed(1) line 145 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.169524, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              in the pattern space up to the first newline, and restart cy‐\u001b[m\r\n\u001b[7m Manual page sed(1) line 146 (press h for help or q to quit)\u001b[27m\u001b[K"]
[35.545966, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              cle with the resultant pattern space, without reading  a  new\u001b[m\r\n\u001b[7m Manual page sed(1) line 147 (press h for help or q to quit)\u001b[27m\u001b[K"]
