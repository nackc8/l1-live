[2712.572285, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K      printf \"\\\\n%s: ERROR: failed to open ID file '%s': %s\\\\n\" \"$0\" \"$f\" \"$ \b:\u001b[K"]
[2712.611415, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K(printf '%s\\n%s\\n' \"$ErrMSG\" \"$L_PRIVMSG\" | sed -e 's/.*: *//')\" >&2\r\n:\u001b[K"]
