[3905.715288, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       shell provides a number of builtin array variables.\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1813 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.754173, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       see  the descriptions of individual builtins below for details.  The\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1812 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.772894, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       Other builtins accept array name arguments as well (e.g.,  \u001b[1mmapfile\u001b[22m);\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1811 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.811073, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       array  values in a way that allows them to be reused as assignments.\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1810 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.850676, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       standard input to an array.  The \u001b[1mset \u001b[22mand  \u001b[1mdeclare  \u001b[22mbuiltins  display\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1809 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.869289, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       builtin  accepts a \u001b[1m-a \u001b[22moption to assign a list of words read from the\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1808 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.907588, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       array.  If both options are supplied, \u001b[1m-A \u001b[22mtakes precedence.  The \u001b[1mread\u001b[0m\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1807 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.947218, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       specify an indexed array and a \u001b[1m-A \u001b[22moption to specify  an  associative\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1806 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.96625, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       The \u001b[1mdeclare\u001b[22m, \u001b[1mlocal\u001b[22m, and \u001b[1mreadonly \u001b[22mbuiltins each accept a \u001b[1m-a \u001b[22moption to\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1805 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.004535, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1804 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.043262, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       desired (e.g., unset 'a[4]').\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1803 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.06148, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       pathname expansion.  Quote the argument if pathname expansion is not\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1802 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.101901, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       described  above,  (e.g.,  unset  a[4]),  the argument is subject to\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1801 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.120678, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       mand, such as with \u001b[1munset\u001b[22m, without using the  word  expansion  syntax\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1800 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.158213, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       When using a variable name with a subscript as an argument to a com‐\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1799 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.197625, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1798 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.217386, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       the array itself.\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1797 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.257874, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       dexed  array,  unset removes all of the elements but does not remove\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1796 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.295889, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       this unsets the element with subscript \u001b[1m* \u001b[22mor \u001b[1m@\u001b[22m.  If \u001b[4mname\u001b[24m  is  an  in‐\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1795 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.315192, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       array  when  \u001b[4msubscript\u001b[24m  is \u001b[1m* \u001b[22mor \u001b[1m@\u001b[22m.  If \u001b[4mname\u001b[24m is an associative array,\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1794 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.47505, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page bash(1) line 1795 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3906.96526, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[1mEXPANSION\u001b[0m\u001b[m\r\n\u001b[7m Manual page bash(1) line 1796 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.004855, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[7mExpansion\u001b[27m is performed on the command line after it has  been  split\u001b[m\r\n\u001b[7m Manual page bash(1) line 1797 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.023919, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       into  words.   The shell performs these expansions: \u001b[4mbrace\u001b[24m \u001b[4mexpansion\u001b[24m,\u001b[m\r\n\u001b[7m Manual page bash(1) line 1798 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.062991, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[4mtilde\u001b[24m \u001b[4mexpansion\u001b[24m, \u001b[4mparameter\u001b[24m \u001b[4mand\u001b[24m \u001b[4mvariable\u001b[24m \u001b[4mexpansion\u001b[24m, \u001b[4mcommand\u001b[24m \u001b[4msubstitu‐\u001b[0m\u001b[m\r\n\u001b[7m Manual page bash(1) line 1799 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.100562, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[4mtion\u001b[24m, \u001b[4marithmetic\u001b[24m \u001b[4mexpansion\u001b[24m, \u001b[4mword\u001b[24m \u001b[4msplitting\u001b[24m, \u001b[4mpathname\u001b[24m \u001b[4mexpansion\u001b[24m,  and\u001b[m\r\n\u001b[7m Manual page bash(1) line 1800 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.120721, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[4mquote\u001b[24m \u001b[4mremoval\u001b[24m.\u001b[m\r\n\u001b[7m Manual page bash(1) line 1801 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.160439, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[3907.16059, "o", "\u001b[m\r\n\u001b[7m Manual page bash(1) line 1802 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.179566, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       The  order of expansions is: brace expansion; tilde expansion, para‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 1803 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.220035, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       meter and variable expansion, arithmetic expansion, and command sub‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 1804 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.261031, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       stitution (done in a left-to-right fashion); word  splitting;  path‐\u001b[m\r\n\u001b[7m Manual page bash(1) line 1805 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.279992, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       name expansion; and quote removal.\u001b[m\r\n\u001b[7m Manual page bash(1) line 1806 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.32112, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page bash(1) line 1807 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.359697, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       On  systems  that  can  support it, there is an additional expansion\u001b[m\r\n\u001b[7m Manual page bash(1) line 1808 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.37862, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       available: \u001b[4mprocess\u001b[24m \u001b[4msubstitution\u001b[24m.  This is performed at the same time\u001b[m\r\n\u001b[7m Manual page bash(1) line 1809 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.418332, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       as tilde, parameter, variable, and arithmetic expansion and  command\u001b[m\r\n\u001b[7m Manual page bash(1) line 1810 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.437976, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       substitution.\u001b[m\r\n\u001b[7m Manual page bash(1) line 1811 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.47748, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page bash(1) line 1812 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.517324, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[4mQuote\u001b[24m \u001b[4mremoval\u001b[24m is always performed last.  It removes quote characters\u001b[m\r\n\u001b[7m Manual page bash(1) line 1813 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.536334, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       present  in  the  original  word, not ones resulting from one of the\u001b[m\r\n\u001b[7m Manual page bash(1) line 1814 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3907.577152, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       other expansions, unless they have been quoted themselves.\u001b[m\r\n\u001b[7m Manual page bash(1) line 1815 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3935.513125, "o", "\r\u001b[K\u001b[m\r\n       Only brace expansion, word splitting, and pathname expansion can in‐\u001b[m\r\n       crease the number of words of the expansion; other expansions expand\u001b[m\r\n       a single word to a single word.  The only exceptions to this are the\u001b[m\r\n       expansions of \u001b[1m\"$@\" \u001b[22mand \u001b[1m\"${\u001b[4m\u001b[22mname\u001b[24m\u001b[1m[@]}\"\u001b[22m, and,  in  most  cases,  \u001b[1m$*  \u001b[22mand\u001b[m\r\n       \u001b[1m${\u001b[4m\u001b[22mname\u001b[24m\u001b[1m[*]} \u001b[22mas explained above (see \u001b[1mPARAMETERS\u001b[22m).\u001b[m\r\n\u001b[m\r\n   \u001b[1mBrace \u001b[7mExpansion\u001b[27m\u001b[1m\u001b[0m\u001b[m\r\n       \u001b[4mBrace\u001b[24m \u001b[4mexpansion\u001b[24m is a mechanism to generate arbitrary strings sharing\u001b[m\r\n       a  common  prefix  and  suffix,  either of which can be empty.  This\u001b[m\r\n       mechanism is similar to \u001b[4mpathname\u001b[24m \u001b[4mexpansion\u001b[24m, but the filenames gener‐\u001b[m\r\n       ated need not exist.  Patterns to be brace expanded are formed  from\u001b[m\r\n       an optional \u001b[4mpreamble\u001b[24m, followed by either a series of comma-separated\u001b[m\r\n       strings  or a sequence expression between a pair of braces, followed\u001b[m\r\n       by an optional \u001b[4mpostscript\u001b[24m.  The preamble is prefixed to each  string\u001b[m\r\n       contained  within the braces, and the postscript is then appended to\u001b[m\r\n       each resulting string, expanding left to right.\u001b[m\r\n\u001b[m\r\n       Brace expansions may be nested.  The results of each expanded string\u001b[m\r\n       are not sorted; brace expansion preserves left to right order.   For\u001b[m\r\n\u001b[7m Manual page bash(1) line 1835 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3939.066908, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       other expansions, unless they have been quoted themselves.\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1834 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3939.318947, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       present  in  the  original  word, not ones resulting from one of the\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1833 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3939.526338, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[4mQuote\u001b[24m \u001b[4mremoval\u001b[24m is always performed last.  It removes quote characters\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1832 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3939.655104, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1831 (press h for help or q to quit)\u001b[27m\u001b[K"]
