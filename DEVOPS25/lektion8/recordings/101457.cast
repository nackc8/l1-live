[3905.519831, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[4mtion\u001b[24m, \u001b[4marithmetic\u001b[24m \u001b[4mexpansion\u001b[24m, \u001b[4mword\u001b[24m \u001b[4msplitting\u001b[24m, \u001b[4mpathname\u001b[24m \u001b[4mexpansion\u001b[24m,  and\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1819 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.559577, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[4mtilde\u001b[24m \u001b[4mexpansion\u001b[24m, \u001b[4mparameter\u001b[24m \u001b[4mand\u001b[24m \u001b[4mvariable\u001b[24m \u001b[4mexpansion\u001b[24m, \u001b[4mcommand\u001b[24m \u001b[4msubstitu‐\u001b[0m\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1818 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.59844, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       into  words.   The shell performs these expansions: \u001b[4mbrace\u001b[24m \u001b[4mexpansion\u001b[24m,\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1817 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.616891, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[7mExpansion\u001b[27m is performed on the command line after it has  been  split\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1816 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.656256, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[1mEXPANSION\u001b[0m\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1815 (press h for help or q to quit)\u001b[27m\u001b[K"]
