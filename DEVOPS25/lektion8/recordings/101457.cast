[3905.207443, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       as tilde, parameter, variable, and arithmetic expansion and  command\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1829 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3905.246656, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       available: \u001b[4mprocess\u001b[24m \u001b[4msubstitution\u001b[24m.  This is performed at the same time\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1828 (press h for help or q to quit)\u001b[27m\u001b[K"]
