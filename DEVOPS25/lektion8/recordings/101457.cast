[3900.835431, "o", "\r\u001b[K\u001b[1;1H\u001b[K\u001b[4mBASH\u001b[24m(1)                   General Commands Manual                   \u001b[4mBASH\u001b[24m(1)\u001b[m\r\n\u001b[2;1H\u001b[K\u001b[m\r\n\u001b[3;1H\u001b[K\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H\u001b[K       bash - GNU Bourne-Again SHell\u001b[m\r\n\u001b[5;1H\u001b[K\u001b[m\r\n\u001b[6;1H\u001b[K\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[K       \u001b[1mbash \u001b[22m[options] [command_string | file]\u001b[m\r\n\u001b[8;1H\u001b[K\u001b[m\r\n\u001b[9;1H\u001b[K\u001b[1mCOPYRIGHT\u001b[0m\u001b[m\r\n\u001b[10;1H\u001b[K       Bash  is  Copyright  (C)  1989-2025 by the Free Software Foundation,\u001b[m\r\n\u001b[11;1H\u001b[K       Inc.\u001b[m\r\n\u001b[12;1H\u001b[K\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[14;1H\u001b[K       \u001b[1mBash \u001b[22mis a command language interpreter that executes  commands  read\u001b[m\r\n\u001b[15;1H\u001b[K       from the standard input, from a string, or from a file.  It is a re‐\u001b[m\r\n\u001b[16;1H\u001b[K       implementation  and  extension  of  the Bourne shell, the historical\u001b[m\r\n\u001b[17;1H\u001b[K       Unix command language interpreter.  \u001b[1mBash  \u001b[22malso  incorporates  useful\u001b[m\r\n\u001b[18;1H\u001b[K       features from the \u001b[4mKorn\u001b[24m and \u001b[4mC\u001b[24m shells (\u001b[1mksh \u001b[22mand \u001b[1mcsh\u001b[22m).\u001b[m\r\n\u001b[19;1H\u001b[K\u001b[m\r\n\u001b[20;1H\u001b[K       POS"]
[3900.83571, "o", "IX is the name for a family of computing standards based on Unix.\u001b[m\r\n\u001b[21;1H\u001b[1;1H\u001b[K\u001b[4mBASH\u001b[24m(1)                   General Commands Manual                   \u001b[4mBASH\u001b[24m(1)\u001b[m\r\n\u001b[2;1H\u001b[K\u001b[m\r\n\u001b[3;1H\u001b[K\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H\u001b[K       bash - GNU Bourne-Again SHell\u001b[m\r\n\u001b[5;1H\u001b[K\u001b[m\r\n\u001b[6;1H\u001b[K\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[K       \u001b[1mbash \u001b[22m[options] [command_string | file]\u001b[m\r\n\u001b[8;1H\u001b[K\u001b[m\r\n\u001b[9;1H\u001b[K\u001b[1mCOPYRIGHT\u001b[0m\u001b[m\r\n\u001b[10;1H\u001b[K       Bash  is  Copyright  (C)  1989-2025 by the Free Software Foundation,\u001b[m\r\n\u001b[11;1H\u001b[K       Inc.\u001b[m\r\n\u001b[12;1H\u001b[K\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[14;1H\u001b[K       \u001b[1mBash \u001b[22mis a command language interpreter that executes  commands  read\u001b[m\r\n\u001b[15;1H\u001b[K       from the standard input, from a string, or from a file.  It is a re‐\u001b[m\r\n\u001b[16;1H\u001b[K       implementation  and  extension  of  the Bourne shell, the historical\u001b[m\r\n\u001b[17;1H\u001b[K       Unix command language interpreter.  \u001b[1mBash  \u001b[22malso  incorporates  useful\u001b[m\r\n\u001b[18;1H\u001b[K       features from the \u001b[4mKorn\u001b[24m and \u001b[4mC\u001b[24m s"]
[3900.836605, "o", "hells (\u001b[1mksh \u001b[22mand \u001b[1mcsh\u001b[22m).\u001b[m\r\n\u001b[19;1H\u001b[K\u001b[m\r\n\u001b[20;1H\u001b[K       POSIX is the name for a family of computing standards based on Unix.\u001b[m\r\n\u001b[21;1H"]
[3900.837809, "o", "...skipping...\r\n       \u001b[1mTilde \u001b[7mExpansion\u001b[27m\u001b[1m \u001b[22min the \u001b[1mEXPANSION \u001b[22msection.\u001b[m\r\n\u001b[m\r\n       When  \u001b[1mbash \u001b[22mis invoked as an interactive login shell, or as a non-in‐\u001b[m\r\n       teractive shell with the \u001b[1m--login \u001b[22moption, it first reads and executes\u001b[m\r\n       commands from the file \u001b[4m/etc/profile\u001b[24m, if  that  file  exists.   After\u001b[m\r\n       reading  that file, it looks for \u001b[4m~/.bash_profile\u001b[24m, \u001b[4m~/.bash_login\u001b[24m, and\u001b[m\r\n       \u001b[4m~/.profile\u001b[24m, in that order, and reads and executes commands from  the\u001b[m\r\n       first  one  that exists and is readable.  The \u001b[1m--noprofile \u001b[22moption may\u001b[m\r\n       be used when the shell is started to inhibit this behavior.\u001b[m\r\n\u001b[m\r\n       When an interactive login shell exits, or  a  non-interactive  login\u001b[m\r\n       shell  executes  the  \u001b[1mexit  \u001b[22mbuiltin command, \u001b[1mbash \u001b[22mreads and executes\u001b[m\r\n       commands from the file \u001b[4m~/.bash_logout\u001b[24m, if it exists.\u001b[m\r\n\u001b[m\r\n       When an interactive shell that is not a login shell is started, \u001b[1mbash\u001b[0m\u001b[m\r\n       reads and executes commands from \u001b[4metc/bash.bashrc\u001b[24m and  \u001b[4m~/.bashrc\u001b[24m,  if\u001b[m\r\n       that  file  exists.   The \u001b[1m--norc \u001b[22moption inhibits this behavior.  The\u001b[m\r\n       \u001b[1m--rcfile  \u001b[4m\u001b[22mfile\u001b[24m  option  causes  \u001b[1mbash  \u001b[22mto   use   \u001b[4mfile\u001b[24m   instead   of\u001b[m\r\n       \u001b[4metc/bash.bashrc\u001b[24m and \u001b[4m~/.bashrc\u001b[24m.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page bash(1) line 170 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3902.0551, "o", "\r\u001b[K/\r\u001b[K"]
[3902.059165, "o", "...skipping...\r\n       \u001b[1m$((\u001b[22m...\u001b[1m))  \u001b[22mexpansion  is  not  used (see \u001b[1mArithmetic \u001b[7mExpansion\u001b[27m\u001b[1m\u001b[22m\u001b[1m \u001b[22mbelow).\u001b[m\r\n       Word splitting and pathname expansion are not performed.  Assignment\u001b[m\r\n       statements may also appear as arguments to the \u001b[1malias\u001b[22m, \u001b[1mdeclare\u001b[22m, \u001b[1mtype‐\u001b[0m\u001b[m\r\n       \u001b[1mset\u001b[22m, \u001b[1mexport\u001b[22m, \u001b[1mreadonly\u001b[22m, and \u001b[1mlocal \u001b[22mbuiltin commands (\u001b[4mdeclaration\u001b[24m  com‐\u001b[m\r\n       mands).   When in posix mode, these builtins may appear in a command\u001b[m\r\n       after one or more instances of the \u001b[1mcommand \u001b[22mbuiltin and retain  these\u001b[m\r\n       assignment statement properties.\u001b[m\r\n\u001b[m\r\n       In the context where an assignment statement is assigning a value to\u001b[m\r\n       a  shell  variable  or  array index, the “+=” operator appends to or\u001b[m\r\n       adds to the variable's previous value.  This includes  arguments  to\u001b[m\r\n       \u001b[4mdeclaration\u001b[24m  commands  such as \u001b[1mdeclare \u001b[22mthat accept assignment state‐\u001b[m\r\n       ments.  When “+=” is applied to a variable for which the \u001b[1minteger \u001b[22mat‐\u001b[m\r\n       tribute has been set, the variable's current  value  and  \u001b[4mvalue\u001b[24m  are\u001b[m\r\n       each evaluated as arithmetic expressions, and the sum of the results\u001b[m\r\n       is  assigned  as the variable's value.  The current value is usually\u001b[m\r\n       an integer constant, but may be an expression.  When “+=” is applied\u001b[m\r\n       to an array variable using compound assignment (see  \u001b[1mArrays  \u001b[22mbelow),\u001b[m\r\n       the variable's value is not unset (as it is when using “=”), and new\u001b[m\r\n       values  are  appended to the array beginning at one greater than the\u001b[m\r\n\u001b[7m Manual page bash(1) line 788 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3902.546073, "o", "\r\u001b[K/\r\u001b[K"]
[3902.550239, "o", "...skipping...\r\n       \u001b[7mExpansion\u001b[27m is performed on the command line after it has  been  split\u001b[m\r\n       into  words.   The shell performs these expansions: \u001b[4mbrace\u001b[24m \u001b[4mexpansion\u001b[24m,\u001b[m\r\n       \u001b[4mtilde\u001b[24m \u001b[4mexpansion\u001b[24m, \u001b[4mparameter\u001b[24m \u001b[4mand\u001b[24m \u001b[4mvariable\u001b[24m \u001b[4mexpansion\u001b[24m, \u001b[4mcommand\u001b[24m \u001b[4msubstitu‐\u001b[0m\u001b[m\r\n       \u001b[4mtion\u001b[24m, \u001b[4marithmetic\u001b[24m \u001b[4mexpansion\u001b[24m, \u001b[4mword\u001b[24m \u001b[4msplitting\u001b[24m, \u001b[4mpathname\u001b[24m \u001b[4mexpansion\u001b[24m,  and\u001b[m\r\n       \u001b[4mquote\u001b[24m \u001b[4mremoval\u001b[24m.\u001b[m\r\n\u001b[m\r\n       The  order of expansions is: brace expansion; tilde expansion, para‐\u001b[m\r\n       meter and variable expansion, arithmetic expansion, and command sub‐\u001b[m\r\n       stitution (done in a left-to-right fashion); word  splitting;  path‐\u001b[m\r\n       name expansion; and quote removal.\u001b[m\r\n\u001b[m\r\n       On  systems  that  can  support it, there is an additional expansion\u001b[m\r\n       available: \u001b[4mprocess\u001b[24m \u001b[4msubstitution\u001b[24m.  This is performed at the same time\u001b[m\r\n       as tilde, parameter, variable, and arithmetic expansion and  command\u001b[m\r\n       substitution.\u001b[m\r\n\u001b[m\r\n       \u001b[4mQuote\u001b[24m \u001b[4mremoval\u001b[24m is always performed last.  It removes quote characters\u001b[m\r\n       present  in  the  original  word, not ones resulting from one of the\u001b[m\r\n       other expansions, unless they have been quoted themselves.\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page bash(1) line 1816 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3902.994219, "o", "\r\u001b[K/\r\u001b[K...skipping...\r\n   \u001b[1mBrace \u001b[7mExpansion\u001b[27m\u001b[1m\u001b[0m\u001b[m\r\n       \u001b[4mBrace\u001b[24m \u001b[4mexpansion\u001b[24m is a mechanism to generate arbitrary strings sharing\u001b[m\r\n       a  common  prefix  and  suffix,  either of which can be empty.  This\u001b[m\r\n       mechanism is similar to \u001b[4mpathname\u001b[24m \u001b[4mexpansion\u001b[24m, but the filenames gener‐\u001b[m\r\n       ated need not exist.  Patterns to be brace expanded are formed  from\u001b[m\r\n       an optional \u001b[4mpreamble\u001b[24m, followed by either a series of comma-separated\u001b[m\r\n       strings  or a sequence expression between a pair of braces, followed\u001b[m\r\n       by an optional \u001b[4mpostscript\u001b[24m.  The preamble is prefixed to each  string\u001b[m\r\n       contained  within the braces, and the postscript is then appended to\u001b[m\r\n       each resulting string, expanding left to right.\u001b[m\r\n\u001b[m\r\n       Brace expansions may be nested.  The results of each expanded string\u001b[m\r\n       are not sorted; brace expansion preserves left to right order.   For\u001b[m\r\n       example, a\u001b[1m{\u001b[22md,c,b\u001b[1m}\u001b[22me expands into “ade ace abe”.\u001b[m\r\n\u001b[m\r\n       A sequence expression takes the form \u001b[4mx\u001b[24m\u001b[1m..\u001b[4m\u001b[22my\u001b[24m\u001b[1m[..\u001b[4m\u001b[22mincr\u001b[24m\u001b[1m]\u001b[22m, where \u001b[4mx\u001b[24m and \u001b[4my\u001b[24m are\u001b[m\r\n       either  integers or single letters, and \u001b[4mincr\u001b[24m, an optional increment,\u001b[m\r\n       is an integer.  When integers are supplied, the  expression  expands\u001b[m\r\n       to  each number between \u001b[4mx\u001b[24m and \u001b[4my\u001b[24m, inclusive.  If either \u001b[4mx\u001b[24m or \u001b[4my\u001b[24m begins\u001b[m\r\n       with a zero, each generated term will contain  the  same  number  of\u001b[m\r\n\u001b[7m Manual page bash(1) line 1842 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3904.364887, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1841 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3904.854225, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m${\u001b[4m\u001b[22mname\u001b[24m\u001b[1m[*]} \u001b[22mas explained above (see \u001b[1mPARAMETERS\u001b[22m).\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1840 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3904.893905, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       expansions of \u001b[1m\"$@\" \u001b[22mand \u001b[1m\"${\u001b[4m\u001b[22mname\u001b[24m\u001b[1m[@]}\"\u001b[22m, and,  in  most  cases,  \u001b[1m$*  \u001b[22mand\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1839 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3904.913188, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       a single word to a single word.  The only exceptions to this are the\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1838 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3904.952756, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       crease the number of words of the expansion; other expansions expand\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1837 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3904.993153, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       Only brace expansion, word splitting, and pathname expansion can in‐\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1836 (press h for help or q to quit)\u001b[27m\u001b[K"]
