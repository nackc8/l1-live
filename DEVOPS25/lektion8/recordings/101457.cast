[2985.235416, "o", "\u001b[4mLS\u001b[24m(1)                     General Commands Manual                     \u001b[4mLS\u001b[24m(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       ls - List directory contents.  Ignore files and directories starting\u001b[m\r\n       with a '.' by default\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mls  \u001b[22m[\u001b[1m--help\u001b[22m] [\u001b[1m--format\u001b[22m] [\u001b[1m-C \u001b[22m] [\u001b[1m-l\u001b[22m|\u001b[1m--long\u001b[22m] [\u001b[1m-x \u001b[22m] [\u001b[1m-T\u001b[22m|\u001b[1m--tabsize\u001b[22m] [\u001b[1m-m \u001b[22m]\u001b[m\r\n       [\u001b[1m--zero\u001b[22m] [\u001b[1m-D\u001b[22m|\u001b[1m--dired\u001b[22m] [\u001b[1m--hyperlink\u001b[22m] [\u001b[1m-1 \u001b[22m]  [\u001b[1m-o  \u001b[22m]  [\u001b[1m-g  \u001b[22m]  [\u001b[1m-n\u001b[22m|\u001b[1m--nu‐\u001b[0m\u001b[m\r\n       \u001b[1mmeric-uid-gid\u001b[22m]    [\u001b[1m--quoting-style\u001b[22m]   [\u001b[1m-N\u001b[22m|\u001b[1m--literal\u001b[22m]   [\u001b[1m-b\u001b[22m|\u001b[1m--escape\u001b[22m]\u001b[m\r\n       [\u001b[1m-Q\u001b[22m|\u001b[1m--quote-name\u001b[22m]  [\u001b[1m-q\u001b[22m|\u001b[1m--hide-control-chars\u001b[22m]  [\u001b[1m--show-control-chars\u001b[22m]\u001b[m\r\n       [\u001b[1m--time\u001b[22m]  [\u001b[1m-c  \u001b[22m]  [\u001b[1m-u \u001b[22m] [\u001b[1m--hide\u001b[22m] [\u001b[1m-I\u001b[22m|\u001b[1m--ignore\u001b[22m] [\u001b[1m-B\u001b[22m|\u001b[1m--ignore-backups\u001b[22m]\u001b[m\r\n       [\u001b[1m--sort\u001b[22m] [\u001b[1m-S \u001b[22m] [\u001b[1m-t \u001b[22m] [\u001b[1m-v \u001b[22m] [\u001b[1m-X \u001b[22m] [\u001b[1m-U \u001b[22m] [\u001b[1m-L\u001b[22m|\u001b[1m--dereference\u001b[22m]  [\u001b[1m--deref‐\u001b[0m\u001b[m\r\n       \u001b[1merence-command-line-symlink-to-dir\u001b[22m]  [\u001b[1m-H\u001b[22m|\u001b[1m--dereference-command-line\u001b[22m]\u001b[m\r\n       [\u001b[1m-G\u001b[22m|\u001b[1m--no-group\u001b[22m]  [\u001b[1m--author\u001b[22m]  [\u001b[1m-a\u001b[22m|\u001b[1m--all\u001b[22m]  [\u001b[1m-A\u001b[22m|\u001b[1m--almost-all\u001b[22m]   [\u001b[1m-f   \u001b[22m]\u001b[m\r\n       [\u001b[1m-d\u001b[22m|\u001b[1m--directory\u001b[22m]   [\u001b[1m-h\u001b[22m|\u001b[1m--human-readable\u001b[22m]   [\u001b[1m-k\u001b[22m|\u001b[1m--kibibytes\u001b[22m]   [\u001b[1m--si\u001b[22m]\u001b[m\r\n\u001b[7m Manual page ls(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
