[3939.993321, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       as tilde, parameter, variable, and arithmetic expansion and  command\u001b[m\r\n\u001b[21;1H\r\u001b[K\u001b[7m Manual page bash(1) line 1829 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3940.481221, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       by an optional \u001b[4mpostscript\u001b[24m.  The preamble is prefixed to each  string\u001b[m\r\n\u001b[7m Manual page bash(1) line 1830 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3940.649341, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       contained  within the braces, and the postscript is then appended to\u001b[m\r\n\u001b[7m Manual page bash(1) line 1831 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3941.154115, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       each resulting string, expanding left to right.\u001b[m\r\n\u001b[7m Manual page bash(1) line 1832 (press h for help or q to quit)\u001b[27m\u001b[K"]
[3941.17385, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page bash(1) line 1833 (press h for help or q to quit)\u001b[27m\u001b[K"]
