[4698.39948, "o", "\u001b[1;1H\u001b[K       To print a process tree:\u001b[m\r\n\u001b[2;1H\u001b[K          \u001b[1mps -ejH\u001b[0m\u001b[m\r\n\u001b[3;1H\u001b[K          \u001b[1mps axjf\u001b[0m\u001b[m\r\n\u001b[4;1H\u001b[K\u001b[m\r\n\u001b[5;1H\u001b[K       To get info about threads:\u001b[m\r\n\u001b[6;1H\u001b[K          \u001b[1mps -eLf\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[K          \u001b[1mps axms\u001b[0m\u001b[m\r\n\u001b[8;1H\u001b[K\u001b[m\r\n\u001b[9;1H\u001b[K       To get security info:\u001b[m\r\n\u001b[10;1H\u001b[K          \u001b[1mps -eo euser,ruser,suser,fuser,f,comm,label\u001b[0m\u001b[m\r\n\u001b[11;1H\u001b[K          \u001b[1mps axZ\u001b[0m\u001b[m\r\n\u001b[12;1H\u001b[K          \u001b[1mps -eM\u001b[0m\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[m\r\n\u001b[14;1H\u001b[K       To see every process running as root (real & effective ID) in user\u001b[m\r\n\u001b[15;1H\u001b[K       format:\u001b[m\r\n\u001b[16;1H\u001b[K          \u001b[1mps -U root -u root u\u001b[0m\u001b[m\r\n\u001b[17;1H\u001b[K\u001b[m\r\n\u001b[18;1H\u001b[1;1H\u001b[K       To print a process tree:\u001b[m\r\n\u001b[2;1H\u001b[K          \u001b[1mps \u001b[7m-e\u001b[27m\u001b[1mjH\u001b[0m\u001b[m\r\n\u001b[3;1H\u001b[K          \u001b[1mps axjf\u001b[0m\u001b[m\r\n\u001b[4;1H\u001b[K\u001b[m\r\n\u001b[5;1H\u001b[K       To get info about threads:\u001b[m\r\n\u001b[6;1H\u001b[K          \u001b[1mps \u001b[7m-e\u001b[27m\u001b[1mLf\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[K          \u001b[1mps axms\u001b[0m\u001b[m\r\n\u001b[8;1H\u001b[K\u001b[m\r\n\u001b[9;1H\u001b[K       To get security info:\u001b[m\r\n\u001b[10;1H\u001b[K          \u001b[1mps"]
[4698.400158, "o", " \u001b[7m-e\u001b[27m\u001b[1mo euser,ruser,suser,fuser,f,comm,label\u001b[0m\u001b[m\r\n\u001b[11;1H\u001b[K          \u001b[1mps axZ\u001b[0m\u001b[m\r\n\u001b[12;1H\u001b[K          \u001b[1mps \u001b[7m-e\u001b[27m\u001b[1mM\u001b[0m\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[m\r\n\u001b[14;1H\u001b[K       To see every process running as root (real & effective ID) in user\u001b[m\r\n\u001b[15;1H\u001b[K       format:\u001b[m\r\n\u001b[16;1H\u001b[K          \u001b[1mps -U root -u root u\u001b[0m\u001b[m\r\n\u001b[17;1H\u001b[K\u001b[m\r\n\u001b[18;1H       To see every process with a user-defined format:\u001b[m\r\n\u001b[7m Manual page ps(1) line 62 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4699.508132, "o", "\r\u001b[K/\r\u001b[K"]
[4699.508216, "o", "          \u001b[1mps \u001b[7m-e\u001b[27m\u001b[1mo pid,tid,class,rtprio,ni,pri,psr,pcpu,stat,wchan:14,comm\u001b[0m\u001b[m\r\n          \u001b[1mps axo stat,euid,ruid,tty,tpgid,sess,pgrp,ppid,pid,pcpu,comm\u001b[0m\u001b[m\r\n          \u001b[1mps -Ao pid,tt,user,fname,tmout,f,wchan\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ps(1) line 66 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4699.695851, "o", "\r\u001b[K/\r\u001b[K       Print only the process IDs of syslogd:\u001b[m\r\n          \u001b[1mps -C syslogd -o pid=\u001b[0m\u001b[m\r\n\u001b[m\r\n       Print only the name of PID 42:\u001b[m\r\n\u001b[7m Manual page ps(1) line 70 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4699.845003, "o", "\r\u001b[K/\r\u001b[K          \u001b[1mps -q 42 -o comm=\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ps(1) line 72 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4700.14022, "o", "\r\u001b[K/\r\u001b[K"]
[4700.140316, "o", "\u001b[1mSIMPLE PROCESS SELECTION\u001b[0m\u001b[m\r\n       \u001b[1ma      \u001b[22mLift the BSD-style  \"only  yourself\"  restriction,  which  is\u001b[m\r\n              imposed  upon  the  set  of all processes when some BSD-style\u001b[m\r\n              (without \"-\") options are used or  when  the  \u001b[1mps  \u001b[22mpersonality\u001b[m\r\n              setting  is  BSD-like.  The set of processes selected in this\u001b[m\r\n              manner is in addition to the set  of  processes  selected  by\u001b[m\r\n              other  means.   An  alternate description is that this option\u001b[m\r\n\u001b[7m Manual page ps(1) line 79 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4700.476079, "o", "\r\u001b[K/\r\u001b[K"]
[4700.476467, "o", "...skipping...\r\n       \u001b[1m-A     \u001b[22mSelect all processes.  Identical to \u001b[1m\u001b[7m-e\u001b[27m\u001b[1m\u001b[22m\u001b[1m\u001b[22m.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-a     \u001b[22mSelect   all  processes  except  both  session  leaders  (see\u001b[m\r\n              \u001b[4mgetsid\u001b[24m(2)) and processes not associated with a terminal.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-d     \u001b[22mSelect all processes except session leaders.\u001b[m\r\n\u001b[m\r\n       \u001b[1m--deselect\u001b[0m\u001b[m\r\n              Select all processes except those that fulfill the  specified\u001b[m\r\n              conditions (negates the selection).  Identical to \u001b[1m-N\u001b[22m.\u001b[m\r\n\u001b[m\r\n       \u001b[1m\u001b[7m-e\u001b[27m\u001b[1m     \u001b[22mSelect all processes.  Identical to \u001b[1m-A\u001b[22m.\u001b[m\r\n\u001b[m\r\n       \u001b[1mg      \u001b[22mReally  all, even session leaders.  This flag is obsolete and\u001b[m\r\n              may be discontinued in a  future  release.   It  is  normally\u001b[m\r\n              implied  by  the \u001b[1ma \u001b[22mflag, and is only useful when operating in\u001b[m\r\n              the sunos4 personality.\u001b[m\r\n\u001b[7m Manual page ps(1) line 99 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4702.276832, "o", "\r\u001b[K/\r\u001b[K"]
[4702.277331, "o", "\u001b[m\r\n       \u001b[1m-N     \u001b[22mSelect all processes except those that fulfill the  specified\u001b[m\r\n              conditions (negates the selection).  Identical to \u001b[1m--deselect\u001b[22m.\u001b[m\r\n\u001b[m\r\n       \u001b[1mT      \u001b[22mSelect   all   processes   associated   with  this  terminal.\u001b[m\r\n              Identical to the \u001b[1mt \u001b[22moption without any argument.\u001b[m\r\n\u001b[m\r\n       \u001b[1mr      \u001b[22mRestrict the selection to only running processes.\u001b[m\r\n\u001b[m\r\n       \u001b[1mx      \u001b[22mLift the BSD-style \"must have a tty\"  restriction,  which  is\u001b[m\r\n              imposed  upon  the  set  of all processes when some BSD-style\u001b[m\r\n\u001b[7m Manual page ps(1) line 110 (press h for help or q to quit)\u001b[27m\u001b[K"]
