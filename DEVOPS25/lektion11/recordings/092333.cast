[4945.425507, "o", "\u001b[Ke\be"]
[4945.591681, "o", "\r\u001b[K"]
[4945.592884, "o", "\u001b[1;1H\u001b[K\u001b[4mPS\u001b[24m(1)                       User Commands                       \u001b[4mPS\u001b[24m(1)\u001b[m\r\n\u001b[2;1H\u001b[K\u001b[m\r\n\u001b[3;1H\u001b[K\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H\u001b[K       ps - report a snapshot of the current processes.\u001b[m\r\n\u001b[5;1H\u001b[K\u001b[m\r\n\u001b[6;1H\u001b[K\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[K       \u001b[1mps \u001b[22m[\u001b[4moptions\u001b[24m]\u001b[m\r\n\u001b[8;1H\u001b[K\u001b[m\r\n\u001b[9;1H\u001b[K\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[10;1H\u001b[K       \u001b[1mps \u001b[22mdisplays information about a selection of the active\u001b[m\r\n\u001b[11;1H\u001b[K       processes.  If you want a repetitive update of the selection\u001b[m\r\n\u001b[12;1H\u001b[K       and the displayed information, use \u001b[1mtop \u001b[22minstead.\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[m\r\n\u001b[14;1H\u001b[K       This version of \u001b[1mps \u001b[22maccepts several kinds of options:\u001b[m\r\n\u001b[15;1H\u001b[K\u001b[m\r\n\u001b[16;1H\u001b[1;1H\u001b[K\u001b[4mPS\u001b[24m(1)                       User Commands                       \u001b[4mPS\u001b[24m(1)\u001b[m\r\n\u001b[2;1H\u001b[K\u001b[m\r\n\u001b[3;1H\u001b[K\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H\u001b[K       ps - report a snapshot of the current processes.\u001b[m\r\n\u001b[5;1H\u001b[K\u001b[m\r\n\u001b[6;1H\u001b[K\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[K       \u001b[1mps \u001b[22m[\u001b[4moptions\u001b[24m]\u001b[m\r\n\u001b[8;1H\u001b[K\u001b[m\r\n\u001b[9;1H\u001b[K"]
[4945.593561, "o", "\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[10;1H\u001b[K       \u001b[1mps \u001b[22mdisplays information about a selection of the active\u001b[m\r\n\u001b[11;1H\u001b[K       processes.  If you want a repetitive update of the selection\u001b[m\r\n\u001b[12;1H\u001b[K       and the displayed information, use \u001b[1mtop \u001b[22minstead.\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[m\r\n\u001b[14;1H\u001b[K       This version of \u001b[1mps \u001b[22maccepts several kinds of options:\u001b[m\r\n\u001b[15;1H\u001b[K\u001b[m\r\n\u001b[16;1H"]
[4945.593774, "o", "...skipping...\r\n       The   use   of   BSD-style  options  will  add  process  \u001b[7mstate\u001b[27m\u001b[m\r\n       (stat=STAT) to the default display and show the  command  args\u001b[m\r\n       (args=COMMAND)  instead  of  the  executable  name.   You  can\u001b[m\r\n       override this with the \u001b[1mPS_FORMAT  \u001b[22menvironment  variable.   The\u001b[m\r\n       use   of  BSD-style  options  will  also  change  the  process\u001b[m\r\n       selection to include processes on other terminals (TTYs)  that\u001b[m\r\n       are  owned  by  you;  alternately,  this  may  be described as\u001b[m\r\n       setting the selection to be the set of all processes  filtered\u001b[m\r\n       to  exclude  processes  owned  by  other  users  or  not  on a\u001b[m\r\n       terminal.  These effects are not considered when  options  are\u001b[m\r\n       described as being \"identical\" below, so \u001b[1m-M \u001b[22mwill be considered\u001b[m\r\n       identical to \u001b[1mZ \u001b[22mand so on.\u001b[m\r\n\u001b[m\r\n       Except  as  described  below,  process  selection  options are\u001b[m\r\n       additive.  The default selection is discarded,  and  then  the\u001b[m\r\n\u001b[7m Manual page ps(1) line 35 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4946.624601, "o", "\r\u001b[K/\r\u001b[K"]
[4946.627033, "o", "...skipping...\r\n              Identical to \u001b[1m-o pid,\u001b[4m\u001b[22mformat\u001b[24m\u001b[1m,\u001b[7mstate\u001b[27m\u001b[22m\u001b[24m\u001b[1m,tname,time,command  \u001b[22mor\u001b[m\r\n              \u001b[1m-o pid,\u001b[4m\u001b[22mformat\u001b[24m\u001b[1m,tname,time,cmd\u001b[22m, see \u001b[1m-o \u001b[22mbelow.\u001b[m\r\n\u001b[m\r\n       \u001b[1mo \u001b[4m\u001b[22mformat\u001b[0m\u001b[m\r\n              Specify  user-defined  format.   Identical  to  \u001b[1m-o  \u001b[22mand\u001b[m\r\n              \u001b[1m--format\u001b[22m.\u001b[m\r\n\u001b[m\r\n       \u001b[1m-o \u001b[4m\u001b[22mformat\u001b[0m\u001b[m\r\n              User-defined format.  \u001b[4mformat\u001b[24m is a  single  argument  in\u001b[m\r\n              the  form of a blank-separated or comma-separated list,\u001b[m\r\n              which  offers  a  way  to  specify  individual   output\u001b[m\r\n              columns.   The recognized keywords are described in the\u001b[m\r\n              \u001b[1mSTANDARD FORMAT SPECIFIERS \u001b[22msection below.  Headers  may\u001b[m\r\n              be  renamed  (\u001b[1mps -o pid,ruser=RealUser -o comm=Command\u001b[22m)\u001b[m\r\n              as desired.  If all column headers  are  empty  (\u001b[1mps  -o\u001b[0m\u001b[m\r\n\u001b[7m Manual page ps(1) line 326 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4952.76602, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[4952.766885, "o", "\u001b[H\u001bM              Like  \u001b[1m-o\u001b[22m,  but  preloaded  with  some  default columns.\u001b[m\r\n\u001b[16;1H\r\u001b[K\u001b[7m Manual page ps(1) line 325 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4953.444347, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m-O \u001b[4m\u001b[22mformat\u001b[0m\u001b[m\r\n\u001b[16;1H\r\u001b[K\u001b[7m Manual page ps(1) line 324 (press h for help or q to quit)\u001b[27m\u001b[K"]
