[4674.251132, "o", "\u001b[4mPS\u001b[24m(1)                          User Commands                          \u001b[4mPS\u001b[24m(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       ps - report a snapshot of the current processes.\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mps \u001b[22m[\u001b[4moptions\u001b[24m]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       \u001b[1mps \u001b[22mdisplays information about a selection of the active processes.\u001b[m\r\n       If you want a repetitive update of the selection and the displayed\u001b[m\r\n       information, use \u001b[1mtop \u001b[22minstead.\u001b[m\r\n\u001b[m\r\n       This version of \u001b[1mps \u001b[22maccepts several kinds of options:\u001b[m\r\n\u001b[m\r\n       1   UNIX  options,  which  may  be grouped and must be preceded by a\u001b[m\r\n           dash.\u001b[m\r\n\u001b[7m Manual page ps(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[4674.683063, "o", "\r\u001b[K/"]
[4674.817779, "o", "\u001b[Kt\bt"]
