[4693.704954, "o", "\u001b[1;1H\u001b[K\u001b[4mPS\u001b[24m(1)                          User Commands                          \u001b[4mPS\u001b[24m(1)\u001b[m\r\n\u001b[2;1H\u001b[K\u001b[m\r\n\u001b[3;1H\u001b[K\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H\u001b[K       ps - report a snapshot of the current processes.\u001b[m\r\n\u001b[5;1H\u001b[K\u001b[m\r\n\u001b[6;1H\u001b[K\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[K       \u001b[1mps \u001b[22m[\u001b[4moptions\u001b[24m]\u001b[m\r\n\u001b[8;1H\u001b[K\u001b[m\r\n\u001b[9;1H\u001b[K\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[10;1H\u001b[K       \u001b[1mps \u001b[22mdisplays information about a selection of the active processes.\u001b[m\r\n\u001b[11;1H\u001b[K       If you want a repetitive update of the selection and the displayed\u001b[m\r\n\u001b[12;1H\u001b[K       information, use \u001b[1mtop \u001b[22minstead.\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[m\r\n\u001b[14;1H\u001b[K       This version of \u001b[1mps \u001b[22maccepts several kinds of options:\u001b[m\r\n\u001b[15;1H\u001b[K\u001b[m\r\n\u001b[16;1H\u001b[K       1   UNIX  options,  which  may  be grouped and must be preceded by a\u001b[m\r\n\u001b[17;1H\u001b[K           dash.\u001b[m\r\n\u001b[18;1H\u001b[1;1H\u001b[K\u001b[4mPS\u001b[24m(1)                          User Commands                          \u001b[4mPS\u001b[24m(1)\u001b[m\r\n\u001b[2;1H\u001b[K\u001b[m\r\n\u001b[3;1H\u001b[K\u001b[1mNAME\u001b[0m\u001b[m\r\n\u001b[4;1H\u001b[K       ps - report a snapshot of the curren"]
[4693.705834, "o", "t processes.\u001b[m\r\n\u001b[5;1H\u001b[K\u001b[m\r\n\u001b[6;1H\u001b[K\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n\u001b[7;1H\u001b[K       \u001b[1mps \u001b[22m[\u001b[4moptions\u001b[24m]\u001b[m\r\n\u001b[8;1H\u001b[K\u001b[m\r\n\u001b[9;1H\u001b[K\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[10;1H\u001b[K       \u001b[1mps \u001b[22mdisplays information about a selection of the active processes.\u001b[m\r\n\u001b[11;1H\u001b[K       If you want a repetitive update of the selection and the displayed\u001b[m\r\n\u001b[12;1H\u001b[K       information, use \u001b[1mtop \u001b[22minstead.\u001b[m\r\n\u001b[13;1H\u001b[K\u001b[m\r\n\u001b[14;1H\u001b[K       This version of \u001b[1mps \u001b[22maccepts several kinds of options:\u001b[m\r\n\u001b[15;1H\u001b[K\u001b[m\r\n\u001b[16;1H\u001b[K       1   UNIX  options,  which  may  be grouped and must be preceded by a\u001b[m\r\n\u001b[17;1H\u001b[K           dash.\u001b[m\r\n\u001b[18;1H"]
[4693.706083, "o", "...skipping...\r\n       To print a process \u001b[7mtree\u001b[27m:\u001b[m\r\n          \u001b[1mps -ejH\u001b[0m\u001b[m\r\n          \u001b[1mps axjf\u001b[0m\u001b[m\r\n\u001b[m\r\n       To get info about threads:\u001b[m\r\n          \u001b[1mps -eLf\u001b[0m\u001b[m\r\n          \u001b[1mps axms\u001b[0m\u001b[m\r\n\u001b[m\r\n       To get security info:\u001b[m\r\n          \u001b[1mps -eo euser,ruser,suser,fuser,f,comm,label\u001b[0m\u001b[m\r\n          \u001b[1mps axZ\u001b[0m\u001b[m\r\n          \u001b[1mps -eM\u001b[0m\u001b[m\r\n\u001b[m\r\n       To see every process running as root (real & effective ID) in user\u001b[m\r\n       format:\u001b[m\r\n          \u001b[1mps -U root -u root u\u001b[0m\u001b[m\r\n\u001b[m\r\n\u001b[7m Manual page ps(1) line 61 (press h for help or q to quit)\u001b[27m\u001b[K"]
