[4366.874814, "o", "#!/bin/bash\r\n\r\n\rMINNE=apple\r\n\r\n\r\u001b[7m# Parentes = Ny barnprocess via \"fork\", kopia av variabler och allt annat\u001b[27m\r\n\r\u001b[7mfoo() (\u001b[27m\r\n\r\u001b[7m    echo Inner eat 1 \"$MINNE\"\u001b[27m\r\n\r\u001b[7m    MINNE=banan\u001b[27m\r\n\r\u001b[7m    echo Inner eat 2 \"$MINNE\"\u001b[27m\r\n\r\u001b[7m)\u001b[27m\r\n\r\n\r\u001b[7mfoo\u001b[27m\r\u001b[7mecho Outer eat \"$MINNE\"\u001b[27m\r"]
[4367.723832, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A# Parentes = Ny barnprocess via \"fork\", kopia av variabler och allt annat\r\n\rfoo() (\r\n\r    echo Inner eat 1 \"$MINNE\"\r\n\r    MINNE=banan\r\n\r    echo Inner eat 2 \"$MINNE\"\r\n\r)\r\n\r\n\rfoo\recho Outer eat \"$MINNE\"\r\r\n\u001b[?2004l\r"]
