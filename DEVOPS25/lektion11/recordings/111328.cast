[474.058496, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K              Send signal to every <pid> listed.\u001b[m\r\n\u001b[7m Manual page kill(1) line 9 (press h for help or q to quit)\u001b[27m\u001b[K"]
