[243.329911, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       Mandatory  arguments to long options are mandatory for short\u001b[m\r\n\u001b[7m Manual page nice(1) line 3 (press h for help or q to quit)\u001b[27m\u001b[K"]
[243.363467, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       options too.\u001b[m\r\n\u001b[7m Manual page nice(1) line 4 (press h for help or q to quit)\u001b[27m\u001b[K"]
