[475.200725, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mkill \u001b[22m[options] <pid> [...]\u001b[m\r\n\u001b[14;1H\r\u001b[K\u001b[7m Manual page kill(1) line 7 (press h for help or q to quit)\u001b[27m\u001b[K"]
