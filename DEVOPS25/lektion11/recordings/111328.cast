[474.154467, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-s <signal>\u001b[0m\u001b[m\r\n\u001b[7m Manual page kill(1) line 12 (press h for help or q to quit)\u001b[27m\u001b[K"]
[474.588349, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       available signals.  Particularly useful signals include HUP,\u001b[m\r\n\u001b[14;1H\r\u001b[K\u001b[7m Manual page kill(1) line 11 (press h for help or q to quit)\u001b[27m\u001b[K"]
[474.758917, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       The  default  signal for kill is TERM.  Use \u001b[1m-l \u001b[22mor \u001b[1m-L \u001b[22mto list\u001b[m\r\n\u001b[14;1H\r\u001b[K\u001b[7m Manual page kill(1) line 10 (press h for help or q to quit)\u001b[27m\u001b[K"]
[474.916402, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[14;1H\r\u001b[K\u001b[7m Manual page kill(1) line 9 (press h for help or q to quit)\u001b[27m\u001b[K"]
